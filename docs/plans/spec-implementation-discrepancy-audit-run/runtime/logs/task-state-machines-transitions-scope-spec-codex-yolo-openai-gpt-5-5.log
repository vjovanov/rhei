  1556	fn validate_artifact_definitions(
  1557	    state_name: &str,
  1558	    field_name: &str,
  1559	    artifacts: &[StateArtifactDef],
  1560	) -> Result<(), StateMachineLoadError> {
  1561	    let mut seen_names = HashSet::new();
  1562	
  1563	    for artifact in artifacts {
  1564	        let name = artifact.name.trim();
  1565	        if name.is_empty() {
  1566	            return Err(StateMachineLoadError::Invalid(format!(
  1567	                "state '{state_name}' contains an artifact in '{field_name}' with an empty 'name'"
  1568	            )));
  1569	        }
  1570	        if !seen_names.insert(name) {
  1571	            return Err(StateMachineLoadError::Invalid(format!(
  1572	                "state '{state_name}' contains duplicate artifact name '{name}' in '{field_name}'"
  1573	            )));
  1574	        }
  1575	
  1576	        let path = artifact.path.trim();
  1577	        if path.is_empty() {
  1578	            return Err(StateMachineLoadError::Invalid(format!(
  1579	                "state '{state_name}' artifact '{name}' in '{field_name}' has an empty 'path'"
  1580	            )));
  1581	        }
  1582	        if artifact.optional && field_name == "outputs" {
  1583	            return Err(StateMachineLoadError::Invalid(format!(
  1584	                "state '{state_name}' artifact '{name}' in 'outputs' may not be marked 'optional'; only inputs may be optional"
  1585	            )));
  1586	        }
  1587	        if Path::new(path).is_absolute() {
  1588	            return Err(StateMachineLoadError::Invalid(format!(
  1589	                "state '{state_name}' artifact '{name}' in '{field_name}' must use a relative path, got '{path}'"
  1590	            )));
  1591	        }
  1592	        if path_escapes_workspace_root(path) {
  1593	            return Err(StateMachineLoadError::Invalid(format!(
  1594	                "state '{state_name}' artifact '{name}' in '{field_name}' escapes the workspace root via path '{path}'"
  1595	            )));
  1596	        }
  1597	    }
  1598	
  1599	    Ok(())
  1600	}
  1601	
  1602	fn path_escapes_workspace_root(path: &str) -> bool {
  1603	    let expanded = path.replace("{task_id}", "task").replace("{state}", "state");
  1604	    let mut depth = 0usize;
  1605	
  1606	    for component in Path::new(&expanded).components() {
  1607	        match component {
  1608	            Component::Prefix(_) | Component::RootDir => return true,
  1609	            Component::ParentDir => {
  1610	                if depth == 0 {
  1611	                    return true;
  1612	                }
  1613	                depth -= 1;
  1614	            }
  1615	            Component::Normal(_) => depth += 1,
  1616	            Component::CurDir => {}
  1617	        }
  1618	    }
  1619	
  1620	    false
  1621	}
