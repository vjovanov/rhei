  6029	    /// The registry-resolved transport profile for `agent`.
  6030	    profile: CustomAgentProfile,
  6031	    /// Resolved mode name, or `None` if the agent has no modes or none was
  6032	    /// selected.
  6033	    mode: Option<String>,
  6034	    /// Inline execution target selector, when the state resolves via `target`
  6035	    /// or `all_targets`.
  6036	    target: Option<ExecutionTarget>,
  6037	    model: Option<String>,
  6038	    timeout_secs: Option<u64>,
