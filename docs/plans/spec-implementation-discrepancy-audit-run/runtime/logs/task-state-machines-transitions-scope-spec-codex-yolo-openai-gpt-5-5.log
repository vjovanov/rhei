  1373	**WorkflowHandlers.java:**
  1374	```java
  1375	package com.example.workflow;
  1376	
  1377	import io.rhei.TransitionContext;
  1378	import io.rhei.TransitionResult;
  1379	
  1380	public class WorkflowHandlers {
  1381	
  1382	    public static TransitionResult prepareValidation(TransitionContext ctx) {
  1383	        Task task = ctx.getTask();
  1384	
  1385	        // Validate required fields
  1386	        if (task.getMetadata().get("requestor") == null) {
  1387	            return TransitionResult.failure("Missing required field: requestor");
  1388	        }
  1389	
  1390	        return TransitionResult.success();
  1391	    }
  1392	
  1393	    public static TransitionResult runValidation(TransitionContext ctx) {
  1394	        Task task = ctx.getTask();
  1395	
  1396	        // Run business rules
  1397	        ValidationResult validation = BusinessRules.validate(task);
  1398	
  1399	        if (!validation.isValid()) {
  1400	            // Trigger transition to rejected instead
  1401	            return TransitionResult.builder()
  1402	                .success(true)
  1403	                .nextState("rejected")
  1404	                .data("validation_errors", validation.getErrors())
  1405	                .build();
  1406	        }
  1407	
  1408	        return TransitionResult.success()
  1409	            .withData("validation_id", validation.getId());
  1410	    }
  1411	
  1412	    public static TransitionResult checkApprovalRules(TransitionContext ctx) {
  1413	        Task task = ctx.getTask();
  1414	        BigDecimal amount = task.getMetadata().getDecimal("amount");
  1415	
  1416	        // Amounts over threshold need additional approval
  1417	        if (amount.compareTo(APPROVAL_THRESHOLD) > 0) {
  1418	            List<String> approvers = ApprovalService.getRequiredApprovers(amount);
  1419	
  1420	            return TransitionResult.success()
  1421	                .withData("required_approvers", approvers)
  1422	                .withData("approval_level", "elevated");
  1423	        }
  1424	
  1425	        return TransitionResult.success();
  1426	    }
  1427	
  1428	    public static TransitionResult startExecution(TransitionContext ctx) {
  1429	        Task task = ctx.getTask();
  1430	
  1431	        try {
  1432	            ExecutionJob job = ExecutionService.start(task);
  1433	
  1434	            return TransitionResult.success()
  1435	                .withData("execution_id", job.getId())
  1436	                .withData("started_at", Instant.now());
  1437	
  1438	        } catch (ExecutionException e) {
  1439	            return TransitionResult.failure(
  1440	                "Failed to start execution: " + e.getMessage()
  1441	            );
  1442	        }
  1443	    }
  1444	}
  1445	```
