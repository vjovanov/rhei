  3944	/// Explain why a specific declared transition is not applicable right now,
  3945	/// in user-facing prose. Returns a short phrase (e.g. "condition `visitCount
  3946	/// >= visits` evaluated to false" or "visit budget for state 'review' is
  3947	/// exhausted"). Does NOT re-check applicability — callers are expected to
  3948	/// invoke this only when `transition_rule_is_applicable` returned false.
  3949	fn describe_blocked_transition(
  3950	    rule: &rhei_core::ast::TransitionRule,
  3951	    machine: &rhei_validator::StateMachine,
  3952	    metadata: Option<&Metadata>,
  3953	    task_id: &TaskId,
  3954	    current_state: &str,
  3955	    current_state_raw: &str,
  3956	) -> String {
  3957	    if !loop_reentry_allowed(
  3958	        machine,
  3959	        metadata,
  3960	        task_id,
  3961	        current_state,
  3962	        current_state_raw,
  3963	        &rule.to.0,
  3964	    ) {
  3965	        return format!("visit budget for state '{}' is exhausted", current_state);
  3966	    }
  3967	    if let Some(condition) = rule.condition.as_deref() {
  3968	        return format!("condition `{}` evaluated to false", condition);
  3969	    }
  3970	    "transition is not currently applicable".to_string()
  3971	}
