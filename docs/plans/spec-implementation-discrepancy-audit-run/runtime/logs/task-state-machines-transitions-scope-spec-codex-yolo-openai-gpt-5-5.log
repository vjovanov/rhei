  1332	    description: Workflow request received and awaiting validation
  1333	  validating:
  1334	    description: Business rule validation
  1335	  approved:
  1336	    description: Awaiting execution
  1337	  executing:
  1338	    description: Workflow execution in progress
  1339	  completed:
  1340	    description: Workflow finished successfully
  1341	    final: true
  1342	  rejected:
  1343	    description: Workflow request rejected by validation
  1344	    final: true
  1345	
  1346	transitions:
  1347	  - from: submitted
  1348	    to: validating
  1349	    on_leave: java:com.example.workflow.WorkflowHandlers::prepareValidation
  1350	    on_enter: java:com.example.workflow.WorkflowHandlers::runValidation
  1351	
  1352	  - from: validating
  1353	    to: approved
  1354	    on_leave: java:com.example.workflow.WorkflowHandlers::checkApprovalRules
  1355	    on_enter: java:com.example.workflow.WorkflowHandlers::notifyApprovers
  1356	
  1357	  - from: validating
