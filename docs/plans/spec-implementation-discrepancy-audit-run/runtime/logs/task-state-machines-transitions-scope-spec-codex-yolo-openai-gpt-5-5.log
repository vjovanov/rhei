  1425	fn validate_program_value(
  1426	    state_name: &str,
  1427	    value: &serde_yaml::Value,
  1428	) -> Result<(), StateMachineLoadError> {
  1429	    match value {
  1430	        serde_yaml::Value::String(command) => {
  1431	            if command.trim().is_empty() {
  1432	                return Err(StateMachineLoadError::Invalid(format!(
  1433	                    "state '{state_name}' declares an empty 'program' value"
  1434	                )));
  1435	            }
  1436	        }
  1437	        serde_yaml::Value::Mapping(mapping) => {
  1438	            let Some(command) = mapping.get(serde_yaml::Value::String("command".to_string()))
  1439	            else {
  1440	                return Err(StateMachineLoadError::Invalid(format!(
  1441	                    "state '{state_name}' program object must include a 'command' field"
  1442	                )));
  1443	            };
  1444	            validate_program_command(state_name, command)?;
  1445	
  1446	            if let Some(env) = mapping.get(serde_yaml::Value::String("env".to_string())) {
  1447	                match env {
  1448	                    serde_yaml::Value::Mapping(env_map) => {
  1449	                        for (key, value) in env_map {
  1450	                            let Some(key) = key.as_str() else {
  1451	                                return Err(StateMachineLoadError::Invalid(format!(
  1452	                                    "state '{state_name}' program.env keys must be strings"
  1453	                                )));
  1454	                            };
  1455	                            if key.trim().is_empty() {
  1456	                                return Err(StateMachineLoadError::Invalid(format!(
  1457	                                    "state '{state_name}' program.env contains an empty key"
  1458	                                )));
  1459	                            }
  1460	                            if !matches!(
  1461	                                value,
  1462	                                serde_yaml::Value::Null
  1463	                                    | serde_yaml::Value::Bool(_)
  1464	                                    | serde_yaml::Value::Number(_)
  1465	                                    | serde_yaml::Value::String(_)
  1466	                            ) {
  1467	                                return Err(StateMachineLoadError::Invalid(format!(
  1468	                                    "state '{state_name}' program.env['{key}'] must be a scalar value"
  1469	                                )));
  1470	                            }
  1471	                        }
