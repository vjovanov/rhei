   716	    fn validate_model_configuration(&self) -> Result<(), StateMachineLoadError> {
   717	        let mut seen = HashSet::new();
   718	        for model in &self.models {
   719	            let trimmed = model.trim();
   720	            if trimmed.is_empty() {
   721	                return Err(StateMachineLoadError::Invalid(
   722	                    "top-level 'models' entries must be non-empty strings".to_string(),
   723	                ));
   724	            }
   725	            if !seen.insert(trimmed) {
   726	                return Err(StateMachineLoadError::Invalid(format!(
   727	                    "top-level 'models' contains duplicate entry '{trimmed}'"
   728	                )));
   729	            }
   730	        }
   731	
   732	        for (state_name, state) in &self.states {
   733	            if state.target.is_some() && !state.all_targets.is_empty() {
   734	                return Err(StateMachineLoadError::Invalid(format!(
   735	                    "state '{state_name}' cannot set both 'target' and 'all_targets'"
   736	                )));
   737	            }
   738	            if (state.target.is_some() || !state.all_targets.is_empty())
   739	                && (state.model.is_some()
   740	                    || !state.all_models.is_empty()
   741	                    || state.agent.is_some()
   742	                    || state.agent_mode.is_some())
   743	            {
   744	                return Err(StateMachineLoadError::Invalid(format!(
   745	                    "state '{state_name}' cannot combine 'target' or 'all_targets' with \
   746	                     'model', 'all_models', 'agent', or 'agent_mode'"
   747	                )));
   748	            }
   749	            if let Some(selector) = state.target.as_deref() {
   750	                parse_execution_target(selector).map_err(|message| {
   751	                    StateMachineLoadError::Invalid(format!(
   752	                        "state '{state_name}' has invalid 'target': {message}"
   753	                    ))
   754	                })?;
   755	            }
   756	            if !state.all_targets.is_empty() {
   757	                let mut seen_targets = HashSet::new();
   758	                for selector in &state.all_targets {
   759	                    let parsed = parse_execution_target(selector).map_err(|message| {
   760	                        StateMachineLoadError::Invalid(format!(
   761	                            "state '{state_name}' has invalid 'all_targets' entry: {message}"
   762	                        ))
   763	                    })?;
   764	                    let normalized = parsed.selector();
   765	                    if !seen_targets.insert(normalized.clone()) {
   766	                        return Err(StateMachineLoadError::Invalid(format!(
   767	                            "state '{state_name}' contains duplicate 'all_targets' entry '{normalized}'"
   768	                        )));
   769	                    }
   770	                }
   771	            }
   772	            if !state.all_models.is_empty() && state.model.is_some() {
   773	                return Err(StateMachineLoadError::Invalid(format!(
   774	                    "state '{state_name}' cannot set both 'all_models' and 'model'"
   775	                )));
   776	            }
   777	
   778	            if state.visits == Some(0) {
   779	                return Err(StateMachineLoadError::Invalid(format!(
   780	                    "state '{state_name}' declares 'visits: 0' but visits must be at least 1"
   781	                )));
   782	            }
   783	
   784	            validate_artifact_definitions(state_name, "inputs", &state.inputs)?;
   785	            validate_artifact_definitions(state_name, "outputs", &state.outputs)?;
   786	
   787	            // Agent validation.
