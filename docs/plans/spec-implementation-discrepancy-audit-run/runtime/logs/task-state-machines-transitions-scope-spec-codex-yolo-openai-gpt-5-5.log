  8278	                        if state_after != state_name {
  8279	                            run_info!(
  8280	                                "  Task {} advanced: '{}' -> '{}'",
  8281	                                task_id_str,
  8282	                                state_name,
  8283	                                state_after
  8284	                            );
  8285	                            advanced_any = true;
  8286	                        } else if status.success() {
  8287	                            let pending_more = reloaded
  8288	                                .rhei
  8289	                                .tasks
  8290	                                .iter()
  8291	                                .find(|t| t.id == target_id)
  8292	                                .and_then(|task| {
  8293	                                    machine.states.get(state_name.as_str()).map(|state_def| {
  8294	                                        task_has_pending_agent_invocations(
  8295	                                            &workspace_root,
  8296	                                            task,
  8297	                                            &state_name,
  8298	                                            task.state.as_str(),
  8299	                                            machine,
  8300	                                            reloaded.rhei.metadata.as_ref(),
  8301	                                            state_def,
  8302	                                            settings,
  8303	                                        )
  8304	                                    })
  8305	                                })
  8306	                                .transpose()?
  8307	                                .unwrap_or(false);
  8308	                            if pending_more {
  8309	                                continue;
  8310	                            }
  8311	                            match try_auto_advance_task(
  8312	                                input,
  8313	                                machine,
  8314	                                callback_paths,
  8315	                                &task_id_str,
  8316	                                &state_name,
  8317	                                opts.no_callbacks(),
  8318	                            ) {
  8319	                                Ok(Some(to_state)) => {
  8320	                                    run_info!(
  8321	                                        "  Task {} auto-advanced: '{}' -> '{}'",
  8322	                                        task_id_str,
  8323	                                        state_name,
  8324	                                        to_state
  8325	                                    );
  8326	                                    advanced_any = true;
  8327	                                }
  8328	                                Ok(None) => {
  8329	                                    run_warn!(
  8330	                                        "  warning: agent exited 0 but task {} did not advance from '{}'",
  8331	                                        task_id_str, state_name
  8332	                                    );
  8333	                                }
  8334	                                Err(err) => {
  8335	                                    run_warn!(
  8336	                                        "  warning: agent exited 0 but task {} could not auto-advance from '{}': {}",
  8337	                                        task_id_str, state_name, err
  8338	                                    );
  8339	                                }
  8340	                            }
  8341	                        } else {
  8342	                            let code = status.code().unwrap_or(-1);
  8343	                            run_error!(
  8344	                                "  error: agent exited with code {} for task {}",
  8345	                                code,
  8346	                                task_id_str
  8347	                            );
  8348	                            if !opts.continue_on_error() {
  8349	                                return Err(miette!(
  8350	                                    "agent exited with code {code} for Task {task_id_str}. \
  8351	                                     Use --continue-on-error to skip failures."
  8352	                                ));
  8353	                            }
  8354	                        }
  8355	                    }
  8356	                    Err(err) => {
  8357	                        run_error!("  error for task {}: {}", task_id_str, err);
  8358	                        if !opts.continue_on_error() {
  8359	                            return Err(err);
  8360	                        }
  8361	                    }
  8362	                }
  8363	            }
  8364	        }
  8365	
  8366	        sink.emit(RunEvent::PassEnded { pass, progressed: advanced_any });
  8367	
  8368	        if !advanced_any {
  8369	            break;
  8370	        }
  8371	    }
  8372	
  8373	    // Print summary.
  8374	    let (terminal_count, total_tasks) = if opts.dry_run() {
  8375	        run_info!("\nDry run complete — no programs or agents were spawned.");
  8376	        (0usize, 0usize)
  8377	    } else if agents_spawned == 0 && programs_spawned == 0 {
  8378	        if callback_transitions_made == 0 {
  8379	            run_info!("No tasks could be advanced.");
  8380	            (0usize, 0usize)
  8381	        } else {
  8382	            let loaded = load_plan(input)?;
  8383	            let terminal_count = loaded
  8384	                .rhei
  8385	                .tasks
  8386	                .iter()
  8387	                .filter(|t| is_terminal_state(t.state.as_str(), machine))
  8388	                .count();
  8389	            run_info!(
  8390	                "\nRun complete: {} callback transition(s), {}/{} tasks in terminal state.",
  8391	                callback_transitions_made,
  8392	                terminal_count,
  8393	                loaded.rhei.tasks.len()
  8394	            );
  8395	            run_info!("Final states: {}", format_state_counts(&loaded.rhei));
  8396	            for task in &loaded.rhei.tasks {
  8397	                run_info!("  - {} [{}]", format_task_label(task), task.state);
  8398	            }
  8399	            (terminal_count, loaded.rhei.tasks.len())
  8400	        }
  8401	    } else {
  8402	        let loaded = load_plan(input)?;
  8403	        let terminal_count = loaded
  8404	            .rhei
  8405	            .tasks
  8406	            .iter()
  8407	            .filter(|t| is_terminal_state(t.state.as_str(), machine))
  8408	            .count();
  8409	        run_info!(
  8410	            "\nRun complete: {} agent(s), {} program(s) spawned, {}/{} tasks in terminal state.",
  8411	            agents_spawned,
  8412	            programs_spawned,
  8413	            terminal_count,
  8414	            loaded.rhei.tasks.len()
  8415	        );
  8416	        run_info!("Final states: {}", format_state_counts(&loaded.rhei));
  8417	        for task in &loaded.rhei.tasks {
  8418	            run_info!("  - {} [{}]", format_task_label(task), task.state);
  8419	        }
  8420	        (terminal_count, loaded.rhei.tasks.len())
  8421	    };
  8422	
  8423	    sink.emit(RunEvent::RunFinished {
  8424	        summary: RunSummary {
  8425	            agents_spawned,
  8426	            programs_spawned,
  8427	            terminal_tasks: terminal_count,
  8428	            total_tasks,
  8429	        },
  8430	    });
  8431	    drop(sink);
  8432	    drop(frontend);
