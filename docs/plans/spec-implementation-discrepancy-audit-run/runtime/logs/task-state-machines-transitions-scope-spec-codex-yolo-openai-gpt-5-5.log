  5933	/// Union `defaults.mcp_servers` with a state's `mcp_servers`, deduped by id.
  5934	///
  5935	/// `None` on the state = inherit defaults. `Some(empty)` = clear defaults.
  5936	/// `Some(non-empty)` = append/override defaults by id (state wins).
  5937	fn effective_mcp_entries(
  5938	    defaults: &[StateMcpEntry],
  5939	    state: Option<&[StateMcpEntry]>,
  5940	) -> Vec<StateMcpEntry> {
  5941	    match state {
  5942	        None => defaults.to_vec(),
  5943	        Some([]) => Vec::new(),
  5944	        Some(list) => {
  5945	            let mut out: Vec<StateMcpEntry> = defaults.to_vec();
  5946	            for entry in list {
  5947	                if let Some(pos) = out.iter().position(|e| e.id() == entry.id()) {
  5948	                    out[pos] = entry.clone();
  5949	                } else {
  5950	                    out.push(entry.clone());
  5951	                }
  5952	            }
  5953	            out
  5954	        }
  5955	    }
  5956	}
  5957	
  5958	fn effective_skill_entries(
  5959	    defaults: &[StateSkillEntry],
  5960	    state: Option<&[StateSkillEntry]>,
  5961	) -> Vec<StateSkillEntry> {
  5962	    match state {
  5963	        None => defaults.to_vec(),
  5964	        Some([]) => Vec::new(),
  5965	        Some(list) => {
  5966	            let mut out: Vec<StateSkillEntry> = defaults.to_vec();
  5967	            for entry in list {
  5968	                if let Some(pos) = out.iter().position(|e| e.id() == entry.id()) {
  5969	                    out[pos] = entry.clone();
  5970	                } else {
  5971	                    out.push(entry.clone());
  5972	                }
  5973	            }
  5974	            out
  5975	        }
  5976	    }
  5977	}
  5978	
  5979	/// Resolve one entry against the registry. Inline definitions on the entry
  5980	/// take precedence over registry lookups.
  5981	fn resolve_mcp_entry(
  5982	    entry: &StateMcpEntry,
  5983	    registry: &BTreeMap<String, McpServerProfile>,
  5984	) -> ResolvedMcpEntry {
  5985	    let id = entry.id().to_string();
  5986	    let optional = entry.is_optional();
  5987	    let inline = match entry {
  5988	        StateMcpEntry::Object(obj) if obj.command.is_some() || obj.url.is_some() => {
  5989	            Some(inline_mcp_profile(obj))
  5990	        }
  5991	        _ => None,
  5992	    };
  5993	    let definition = inline.or_else(|| registry.get(&id).cloned());
  5994	    ResolvedMcpEntry { id, optional, definition }
  5995	}
  5996	
  5997	fn resolve_skill_entry(
  5998	    entry: &StateSkillEntry,
  5999	    registry: &BTreeMap<String, SkillProfile>,
  6000	) -> ResolvedSkillEntry {
  6001	    let id = entry.id().to_string();
  6002	    let optional = entry.is_optional();
  6003	    let inline = match entry {
  6004	        StateSkillEntry::Object(obj) if obj.path.is_some() => Some(SkillProfile {
  6005	            path: obj.path.clone().unwrap_or_default(),
  6006	            description: obj.description.clone(),
  6007	        }),
  6008	        _ => None,
  6009	    };
  6010	    let definition = inline.or_else(|| registry.get(&id).cloned());
  6011	    ResolvedSkillEntry { id, optional, definition }
  6012	}
  6013	
  6014	fn inline_mcp_profile(obj: &StateMcpEntryObject) -> McpServerProfile {
  6015	    McpServerProfile {
  6016	        command: obj.command.clone(),
  6017	        url: obj.url.clone(),
  6018	        transport: obj.transport.clone(),
  6019	        env: obj.env.clone(),
  6020	        working_directory: obj.working_directory.clone(),
  6021	        startup_timeout: obj.startup_timeout.clone(),
  6022	    }
  6023	}
