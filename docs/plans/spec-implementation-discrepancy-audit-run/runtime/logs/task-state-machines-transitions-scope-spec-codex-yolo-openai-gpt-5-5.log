  1364	    on_leave: java:com.example.workflow.WorkflowHandlers::acquireLocks
  1365	    on_enter: java:com.example.workflow.WorkflowHandlers::startExecution
  1366	
  1367	  - from: executing
  1368	    to: completed
  1369	    on_leave: java:com.example.workflow.WorkflowHandlers::releaseLocks
  1370	    on_enter: java:com.example.workflow.WorkflowHandlers::recordCompletion
