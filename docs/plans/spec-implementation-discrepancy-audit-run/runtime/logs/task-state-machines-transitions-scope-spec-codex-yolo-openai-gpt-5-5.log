  7338	            .rhei
  7339	            .tasks
  7340	            .iter()
  7341	            .filter(|task| is_terminal_state(task.state.as_str(), &machine))
  7342	            .count();
  7343	        println!(
  7344	            "Running {} '{}' with {} task(s) ({} terminal at start).",
  7345	            if is_workspace { "workspace" } else { "plan" },
  7346	            loaded.rhei.title,
  7347	            loaded.rhei.tasks.len(),
  7348	            initial_terminal_count
  7349	        );
  7350	        println!("Initial states: {}", format_state_counts(&loaded.rhei));
  7351	        run_callback_mode(input, &machine, &callback_paths, &opts)
  7352	    }
  7353	}
