  1053	### Example 3: JavaScript Integration via NAPI
  1054	
  1055	JavaScript callbacks are registered as native functions and called synchronously during transitions:
  1056	
  1057	**states-js.yaml:**
  1058	```yaml
  1059	name: nodejs-workflow
  1060	version: 1.0
  1061	
  1062	states:
  1063	  idle:
  1064	  processing:
  1065	    description: Async operation in progress
  1066	  awaiting-confirmation:
  1067	    description: User confirmation required
  1068	  done:
  1069	    final: true
  1070	
  1071	transitions:
  1072	  - from: idle
  1073	    to: processing
  1074	    on_leave: js:prepareProcessing
  1075	    on_enter: js:startAsyncWork
  1076	
  1077	  - from: processing
  1078	    to: awaiting-confirmation
  1079	    on_leave: js:packageResults
  1080	    on_enter: js:promptUser
  1081	
  1082	  - from: processing
  1083	    to: done
  1084	    on_leave: js:skipConfirmation
  1085	    on_enter: js:finalizeWorkflow
  1086	
  1087	  - from: awaiting-confirmation
  1088	    to: done
  1089	    on_leave: js:validateConfirmation
  1090	    on_enter: js:finalizeWorkflow
  1091	```
  1092	
  1093	**workflow.ts:**
  1094	```typescript
  1095	import { Rhei, TransitionContext, TransitionResult } from 'rhei-napi';
  1096	
  1097	// Initialize Rhei with state machine
  1098	const rhei = new Rhei({
  1099	  stateMachine: './states-js.yaml',
  1100	  rheiPath: './my-workflow.rhei.md'
  1101	});
  1102	
  1103	function findTask(nodes, id) {
  1104	  for (const node of nodes) {
  1105	    if (node.id === id) return node;
  1106	    const nested = findTask(node.children, id);
  1107	    if (nested) return nested;
  1108	  }
  1109	  return undefined;
  1110	}
  1111	
  1112	// Register transition handlers
  1113	rhei.onLeave('idle', 'processing', async (ctx: TransitionContext): Promise<TransitionResult> => {
  1114	  console.log(`Preparing task ${ctx.task.id} for processing...`);
  1115	
  1116	  // Validate preconditions
  1117	  const allDepsComplete = ctx.task.metadata.dependsOn.every(depId => {
  1118	    const dep = findTask(ctx.rhei.tasks, depId);
  1119	    return dep?.metadata.state === 'done';
  1120	  });

