  4763	/// Pre-pass over `text` that resolves `{if condition}…{else}…{endif}` blocks
  4764	/// before variable substitution runs.
  4765	///
  4766	/// Supported conditions (v1): `input.<name>.exists`
  4767	/// Nesting is not supported in v1.
  4768	fn process_conditional_blocks(text: &str, context: &RuntimeTemplateContext<'_>) -> String {
  4769	    let mut result = String::with_capacity(text.len());
  4770	    let mut remaining = text;
  4771	
  4772	    while let Some(if_start) = remaining.find("{if ") {
  4773	        let after_open = if_start + "{if ".len();
  4774	        let Some(close_brace) = remaining[after_open..].find('}') else {
  4775	            // Malformed opening tag — pass through the '{' and move on
  4776	            result.push_str(&remaining[..if_start + 1]);
  4777	            remaining = &remaining[if_start + 1..];
  4778	            continue;
  4779	        };
  4780	        let condition = &remaining[after_open..after_open + close_brace];
  4781	        let tag_end = after_open + close_brace + 1; // position after '}'
  4782	
  4783	        // Consume the newline that follows the opening tag line
  4784	        let body_start = if remaining[tag_end..].starts_with('\n') { tag_end + 1 } else { tag_end };
  4785	
  4786	        // Emit everything before the opening tag unchanged
  4787	        result.push_str(&remaining[..if_start]);
  4788	
  4789	        let (true_branch, false_branch, after_endif) = parse_if_block(&remaining[body_start..]);
  4790	
  4791	        if evaluate_if_condition(condition, context) {
  4792	            result.push_str(true_branch);
  4793	        } else if let Some(fb) = false_branch {
  4794	            result.push_str(fb);
  4795	        }
  4796	        // else: block removed entirely
  4797	
  4798	        remaining = after_endif;
  4799	    }
  4800	
  4801	    result.push_str(remaining);
  4802	    collapse_extra_blank_lines(&result)
  4803	}
