   964	    /// Validate the per-state `mcp_servers` and `skills` lists and the
   965	    /// matching `mcp_unavailable` / `skill_unavailable` transition triggers.
   966	    ///
   967	    /// This pass is purely structural — it rejects malformed entries,
   968	    /// duplicate ids, and the gating/program/final exclusions. Cross-file
   969	    /// reference resolution against settings registries happens elsewhere
   970	    /// (the CLI merges settings and checks id resolution at load time).
   971	    fn validate_tooling_configuration(&self) -> Result<(), StateMachineLoadError> {
   972	        for (state_name, state) in &self.states {
   973	            validate_state_mcp_entries(state_name, state)?;
   974	            validate_state_skill_entries(state_name, state)?;
   975	        }
   976	
   977	        for transition in &self.transitions {
   978	            validate_transition_tooling_trigger(
   979	                transition,
   980	                transition.mcp_unavailable.as_ref(),
   981	                "mcp_unavailable",
   982	            )?;
   983	            validate_transition_tooling_trigger(
   984	                transition,
   985	                transition.skill_unavailable.as_ref(),
   986	                "skill_unavailable",
   987	            )?;
   988	
   989	            if transition.mcp_unavailable.is_some() || transition.skill_unavailable.is_some() {
   990	                if let Some(from_state) = self.states.get(&transition.from.0) {
   991	                    if from_state.program.is_some() {
   992	                        return Err(StateMachineLoadError::Invalid(format!(
   993	                            "transition from '{}' to '{}' declares a tooling-unavailable trigger \
   994	                             but source state '{}' is a program state (tooling triggers are agent-only)",
   995	                            transition.from.0, transition.to.0, transition.from.0
   996	                        )));
   997	                    }
   998	                }
   999	            }
  1000	        }
  1001	
  1002	        Ok(())
  1003	    }
