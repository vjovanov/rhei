  1661	/// Parsed task-state value from markdown, optionally carrying an explicit visit suffix.
  1662	#[derive(Debug, Clone, PartialEq, Eq)]
  1663	pub struct ParsedTaskState {
  1664	    /// Canonical state name defined in the state machine.
  1665	    pub state: String,
  1666	    /// Explicit visit count encoded in markdown as `<state>-<n>`.
  1667	    pub visit: Option<u32>,
  1668	}
  1669	
  1670	/// Parse a markdown task-state value against a state machine.
  1671	///
  1672	/// Exact state names take precedence. If the raw value is not an exact state
  1673	/// match, Rhei interprets a trailing `-<n>` suffix as a counted-loop visit when
  1674	/// the prefix is a valid state name.
  1675	pub fn parse_task_state(raw: &str, machine: &StateMachine) -> ParsedTaskState {
  1676	    if machine.is_valid_state(raw) {
  1677	        return ParsedTaskState { state: raw.to_string(), visit: None };
  1678	    }
  1679	
  1680	    if let Some((base, visit_text)) = raw.rsplit_once('-') {
  1681	        if let Ok(visit) = visit_text.parse::<u32>() {
  1682	            if machine.is_valid_state(base) {
  1683	                return ParsedTaskState { state: base.to_string(), visit: Some(visit) };
  1684	            }
  1685	        }
  1686	    }
  1687	
  1688	    ParsedTaskState { state: raw.to_string(), visit: None }
  1689	}
