  7286	/// Execute the `run` subcommand: advance tasks through the state machine
  7287	/// in dependency order.
  7288	///
  7289	/// In agent mode (the default when an agent is configured), spawns coding
  7290	/// agents for each task. In callback-only mode (`--no-agent`), advances
  7291	/// tasks through transition callbacks only.
  7292	fn run_command(
  7293	    input: &Path,
  7294	    state_machine_path: Option<&Path>,
  7295	    opts: RunOptions,
  7296	) -> MietteResult<()> {
  7297	    let loaded = load_plan(input)?;
  7298	    let resolved = resolve_state_machine_for_loaded_plan(input, &loaded, state_machine_path)?;
  7299	    let machine = resolved.machine;
  7300	    let callback_paths = resolve_callback_paths(resolved.path.as_deref(), input)?;
  7301	    let workspace_root = execution_workspace_root(&callback_paths.plan_path);
  7302	    let settings = load_merged_settings(&workspace_root);
  7303	
  7304	    // Warn if --parallel > 1 on single-file plans.
  7305	    let is_workspace = workspace::is_workspace(input);
  7306	    let effective_parallel = if opts.parallel() > 1 && !is_workspace {
  7307	        eprintln!(
  7308	            "warning: --parallel > 1 is not supported for single-file plans (risk of \
  7309	             conflicting edits). Falling back to sequential execution."
  7310	        );
  7311	        1
  7312	    } else {
  7313	        opts.parallel()
  7314	    };
  7315	
  7316	    // Initial validation pass.
  7317	    let mut report = rhei_validator::validate_with_machine(&loaded.rhei, &machine);
  7318	    report.errors.extend(validate_machine_settings_references(&machine, &settings));
  7319	    if report.has_errors() {
  7320	        return Err(validation_report(input, resolved.path.as_deref(), &report.errors));
  7321	    }
  7322	
  7323	    let mut use_standalone_mode = false;
  7324	    for def in machine.states.values() {
  7325	        if def.terminal || def.gating {
  7326	            continue;
  7327	        }
  7328	        if state_declares_autonomous_execution(def) {
  7329	            use_standalone_mode = true;
  7330	            break;
  7331	        }
  7332	    }
