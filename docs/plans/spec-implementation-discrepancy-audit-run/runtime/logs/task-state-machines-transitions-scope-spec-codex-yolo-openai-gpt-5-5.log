  1182	  preprocessing:
  1183	    description: Data preparation phase
  1184	  training:
  1185	    description: Model training in progress
  1186	  evaluating:
  1187	    description: Model evaluation phase
  1188	  deployed:
  1189	    description: Model deployed to production
  1190	    final: true
  1191	  failed:
  1192	    description: Pipeline execution failed
  1193	    final: true
  1194	
  1195	transitions:
  1196	  - from: queued
  1197	    to: preprocessing
  1198	    on_leave: py:validate_dataset
  1199	    on_enter: py:start_preprocessing
  1200	
  1201	  - from: preprocessing
  1202	    to: training
  1203	    on_leave: py:finalize_features
  1204	    on_enter: py:initialize_training
  1205	
  1206	  - from: training
  1207	    to: evaluating
  1208	    on_leave: py:save_checkpoint
  1209	    on_enter: py:run_evaluation
  1210	
  1211	  - from: evaluating
