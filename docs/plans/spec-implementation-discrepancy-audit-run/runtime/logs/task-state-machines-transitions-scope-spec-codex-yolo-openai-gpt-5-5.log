   646	    pub fn builtin_default() -> Self {
   647	        Self::from_yaml_str(DEFAULT_STATES_YAML).expect("built-in states YAML is always valid")
   648	    }
   649	
   650	    /// Load a StateMachine from YAML string contents.
   651	    pub fn from_yaml_str(yaml: &str) -> Result<Self, StateMachineLoadError> {
   652	        let sm: Self = serde_yaml::from_str(yaml)?;
   653	        sm.validate_model_configuration()?;
   654	        sm.validate_program_configuration()?;
   655	        sm.validate_tooling_configuration()?;
   656	        sm.validate_template_conditions()?;
   657	        sm.validate_profiles_and_node_policy()?;
   658	        sm.validate_poll_configuration()?;
   659	        Ok(sm)
   660	    }
   661	
   662	    /// Resolve the profile that applies to a node with the given kind and id.
   663	    ///
   664	    /// Resolution order matches the States Specification — Node Policy:
   665	    /// `overrides` (first matching `pattern`) → `by_type[<kind>]` →
   666	    /// `default`. Returns `None` when the machine does not declare
   667	    /// `profiles` / `node_policy`.
   668	    ///
   669	    /// The `pattern` in `overrides` is currently matched as an exact
   670	    /// task-id string. Glob semantics will follow when task ids carry
   671	    /// hierarchical segments in the AST.
   672	    pub fn profile_for(&self, kind: Option<&str>, task_id: Option<&str>) -> Option<&Profile> {
   673	        let (profiles, policy) = self.profiles.as_ref().zip(self.node_policy.as_ref())?;
   674	        let resolved_name = if let Some(id) = task_id {
   675	            policy
   676	                .overrides
   677	                .iter()
   678	                .find(|ov| ov.pattern == id)
   679	                .map(|ov| ov.profile.as_str())
   680	                .or_else(|| kind.and_then(|k| policy.by_type.get(k).map(|s| s.as_str())))
   681	                .unwrap_or(policy.default.as_str())
   682	        } else {
   683	            kind.and_then(|k| policy.by_type.get(k).map(|s| s.as_str()))
   684	                .unwrap_or(policy.default.as_str())
   685	        };
   686	        profiles.get(resolved_name)
   687	    }
   688	
   689	    /// Resolve the profile bound to the plan-root node.
   690	    pub fn root_profile(&self) -> Option<&Profile> {
   691	        let (profiles, policy) = self.profiles.as_ref().zip(self.node_policy.as_ref())?;
   692	        profiles.get(policy.root.as_str())
   693	    }
   694	
   695	    /// Load a StateMachine from a file path.
   696	    pub fn from_yaml_file<P: AsRef<Path>>(path: P) -> Result<Self, StateMachineLoadError> {
   697	        let text = std::fs::read_to_string(path)?;
   698	        Self::from_yaml_str(&text)
   699	    }
