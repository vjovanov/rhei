  1981	/// Enforce that a terminal node has no non-terminal descendants anywhere in
  1982	/// its subtree.
  1983	fn validate_terminal_tree_coherence(
  1984	    rhei: &Rhei,
  1985	    machine: &StateMachine,
  1986	    report: &mut ValidationReport,
  1987	) {
  1988	    fn is_terminal(state_raw: &str, machine: &StateMachine) -> bool {
  1989	        let parsed = parse_task_state(state_raw, machine);
  1990	        machine.states.get(&parsed.state).map(|d| d.terminal).unwrap_or(false)
  1991	    }
  1992	
  1993	    fn check_descendants(
  1994	        ancestor: &Task,
  1995	        node: &Task,
  1996	        machine: &StateMachine,
  1997	        report: &mut ValidationReport,
  1998	    ) {
  1999	        for child in &node.children {
  2000	            if !is_terminal(&child.state, machine) {
  2001	                report.errors.push(format!(
  2002	                    "Task {} is in terminal state '{}' but descendant Task {} ('{}') is in non-terminal state '{}'",
  2003	                    ancestor.id, ancestor.state, child.id, child.title, child.state
  2004	                ));
  2005	            }
  2006	            check_descendants(ancestor, child, machine, report);
  2007	        }
  2008	    }
  2009	
  2010	    for_each_node(rhei, |task| {
  2011	        if is_terminal(&task.state, machine) {
  2012	            check_descendants(task, task, machine, report);
  2013	        }
  2014	    });
  2015	}
