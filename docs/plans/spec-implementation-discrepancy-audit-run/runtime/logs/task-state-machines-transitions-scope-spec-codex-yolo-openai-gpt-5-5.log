  6041	#[derive(Clone)]
  6042	enum ProgramCommand {
  6043	    Shell(String),
  6044	    Exec(Vec<String>),
  6045	}
  6046	
  6047	#[derive(Clone)]
  6048	struct ProgramSpec {
  6049	    command: ProgramCommand,
