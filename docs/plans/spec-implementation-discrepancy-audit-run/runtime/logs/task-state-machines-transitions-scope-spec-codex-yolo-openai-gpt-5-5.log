   883	    fn validate_program_configuration(&self) -> Result<(), StateMachineLoadError> {
   884	        for (state_name, state) in &self.states {
   885	            if let Some(program) = &state.program {
   886	                validate_program_value(state_name, program)?;
   887	                if state.terminal {
   888	                    return Err(StateMachineLoadError::Invalid(format!(
   889	                        "state '{state_name}' is final and cannot declare a 'program' (terminal states have no work to execute)"
   890	                    )));
   891	                }
   892	                if state.gating {
   893	                    return Err(StateMachineLoadError::Invalid(format!(
   894	                        "state '{state_name}' is gating and cannot declare a 'program' (gating states require human action)"
   895	                    )));
   896	                }
   897	            }
   898	        }
   899	
   900	        for transition in &self.transitions {

 succeeded in 863ms:
   900	        for transition in &self.transitions {
   901	            if transition.exit_code.is_none() {
   902	                continue;
   903	            }
   904	
   905	            let Some(from_state) = self.states.get(&transition.from.0) else {
   906	                continue;
   907	            };
   908	            if from_state.program.is_none() {
   909	                return Err(StateMachineLoadError::Invalid(format!(
   910	                    "transition from '{}' to '{}' declares 'exit_code' but source state '{}' does not declare a program",
   911	                    transition.from.0, transition.to.0, transition.from.0
   912	                )));
   913	            }
   914	        }
   915	
   916	        Ok(())
