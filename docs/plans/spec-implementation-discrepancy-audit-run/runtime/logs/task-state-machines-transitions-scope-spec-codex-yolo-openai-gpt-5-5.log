  4292	fn task_id_to_json(id: &TaskId) -> serde_json::Value {
  4293	    serde_json::Value::String(id.to_string())
  4294	}
  4295	
  4296	fn task_summary_json(task: &rhei_core::ast::Task) -> serde_json::Value {
  4297	    serde_json::json!({
  4298	        "id": task_id_to_json(&task.id),
  4299	        "kind": task.kind,
  4300	        "title": task.title,
  4301	        "state": task.state,
  4302	    })
