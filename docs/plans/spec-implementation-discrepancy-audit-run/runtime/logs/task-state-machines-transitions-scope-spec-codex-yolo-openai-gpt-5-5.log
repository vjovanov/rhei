  1623	/// Parse a human-readable duration string into seconds.
  1624	///
  1625	/// Supported formats: `30s`, `5m`, `1h`, `2h30m`, `1h15m30s`.
  1626	/// Returns `None` if the string is not a valid duration.
  1627	pub fn parse_duration_secs(s: &str) -> Option<u64> {
  1628	    let s = s.trim();
  1629	    if s.is_empty() {
  1630	        return None;
  1631	    }
  1632	
  1633	    let mut total: u64 = 0;
  1634	    let mut current_num = String::new();
  1635	    let mut found_any = false;
  1636	
  1637	    for ch in s.chars() {
  1638	        if ch.is_ascii_digit() {
  1639	            current_num.push(ch);
  1640	        } else {
  1641	            let n: u64 = current_num.parse().ok()?;
  1642	            current_num.clear();
  1643	            match ch {
  1644	                'h' => total = total.checked_add(n.checked_mul(3600)?)?,
  1645	                'm' => total = total.checked_add(n.checked_mul(60)?)?,
  1646	                's' => total = total.checked_add(n)?,
  1647	                _ => return None,
  1648	            }
  1649	            found_any = true;
  1650	        }
  1651	    }
  1652	
  1653	    // Reject trailing digits without a unit suffix or empty input.
  1654	    if !current_num.is_empty() || !found_any {
  1655	        return None;
  1656	    }
  1657	
  1658	    Some(total)
  1659	}
