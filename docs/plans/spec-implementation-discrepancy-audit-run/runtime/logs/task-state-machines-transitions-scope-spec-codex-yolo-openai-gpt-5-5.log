  5838	/// The tooling a state contributes to the agent subprocess.
  5839	///
  5840	/// Half A: availability is computed from registry resolution only — an entry
  5841	/// whose id resolves (or carries an inline definition) is reported available.
  5842	/// Half B will hook actual MCP handshake checks and skill-path probes into
  5843	/// the same struct, leaving call sites unchanged.
  5844	#[derive(Debug, Clone, Default)]
  5845	struct ResolvedTooling {
