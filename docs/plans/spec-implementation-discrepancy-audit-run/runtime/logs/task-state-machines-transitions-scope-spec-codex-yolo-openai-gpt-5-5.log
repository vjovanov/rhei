  5850	impl ResolvedTooling {
  5851	    /// Ids whose definition resolved — used for `{mcp.<name>.available}` and
  5852	    /// the `RHEI_MCP_<NAME>_AVAILABLE` env vars.
  5853	    fn mcp_available(&self, id: &str) -> bool {
  5854	        self.mcp_servers.iter().any(|e| e.id == id && e.definition.is_some())
  5855	    }
  5856	
  5857	    fn skill_available(&self, id: &str) -> bool {
  5858	        self.skills.iter().any(|e| e.id == id && e.definition.is_some())
  5859	    }
  5860	
  5861	    /// Comma-separated ids of resolved MCP servers (available only).
  5862	    fn mcp_servers_csv(&self) -> String {
