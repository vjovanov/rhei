  4655	/// Evaluate a condition expression for `{if <condition>}` blocks.
  4656	///
  4657	/// Supported forms: `input.<name>.exists`, `mcp.<name>.available`,
  4658	/// `skill.<id>.available`.
  4659	fn evaluate_if_condition(condition: &str, context: &RuntimeTemplateContext<'_>) -> bool {
  4660	    if let Some(name) = condition.strip_prefix("input.").and_then(|s| s.strip_suffix(".exists")) {
  4661	        let visit_count = Some(render_visit_count(
  4662	            context.metadata,
  4663	            &context.task.id,
  4664	            context.state_name,
  4665	            context.current_state_raw,
  4666	            context.machine,
  4667	        ));
  4668	        if let Some(state_def) = context.machine.states.get(context.state_name) {
  4669	            if let Some(artifact) = state_def.inputs.iter().find(|a| a.name == name) {
  4670	                let (_, path) = resolve_artifact_path(
  4671	                    context.workspace_root,
  4672	                    artifact,
  4673	                    &context.task.id.to_string(),
  4674	                    context.state_name,
  4675	                    visit_count,
  4676	                    context.target,
  4677	                    context.model,
  4678	                    context.agent,
  4679	                    context.agent_mode,
  4680	                );
  4681	                return path.exists();
  4682	            }
  4683	        }
  4684	        return false;
  4685	    }
  4686	
  4687	    if let Some(name) = condition.strip_prefix("mcp.").and_then(|s| s.strip_suffix(".available")) {
  4688	        return context.tooling.map_or(false, |t| t.mcp_available(name));
  4689	    }
  4690	
  4691	    if let Some(id) = condition.strip_prefix("skill.").and_then(|s| s.strip_suffix(".available")) {
  4692	        return context.tooling.map_or(false, |t| t.skill_available(id));
  4693	    }
  4694	
  4695	    false
  4696	}
  4697	
  4698	/// Parse the body of an `{if}` block (text after the opening `{if ...}\n`).
  4699	///
  4700	/// Returns `(true_branch, optional_false_branch, text_after_endif)`.
  4701	/// Tag lines (`{else}`, `{endif}`) are consumed and excluded from all slices.
  4702	fn parse_if_block(body: &str) -> (&str, Option<&str>, &str) {
  4703	    if let Some(else_pos) = body.find("{else}") {
  4704	        let true_branch = &body[..else_pos];
  4705	        let after_else_tag = else_pos + "{else}".len();
  4706	        let false_start = if body[after_else_tag..].starts_with('\n') {
  4707	            after_else_tag + 1
  4708	        } else {
  4709	            after_else_tag
  4710	        };
  4711	        if let Some(endif_rel) = body[false_start..].find("{endif}") {
  4712	            let false_branch = &body[false_start..false_start + endif_rel];
  4713	            let after_endif_tag = false_start + endif_rel + "{endif}".len();
  4714	            let after_endif = if body[after_endif_tag..].starts_with('\n') {
  4715	                &body[after_endif_tag + 1..]
  4716	            } else {
  4717	                &body[after_endif_tag..]
  4718	            };
  4719	            return (true_branch, Some(false_branch), after_endif);
  4720	        }
  4721	        // Malformed: {else} but no {endif} — treat whole body as true branch
  4722	        return (body, None, "");
  4723	    }
  4724	
