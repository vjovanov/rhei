  6059	
  6060	fn resolve_target_agent(
  6061	    selector: &str,
  6062	    state_def: Option<&rhei_validator::StateDef>,
  6063	    settings: &RheiSettings,
  6064	) -> MietteResult<ResolvedAgent> {
  6065	    let target = parse_execution_target(selector)
  6066	        .map_err(|err| miette!("invalid target selector '{}': {}", selector, err))?;
  6067	    let agent = AgentConfig::from(target.agent.clone());
  6068	    let profile = settings.agents.get(agent.id()).cloned().ok_or_else(|| {
  6069	        miette!(
  6070	            "agent '{}' is not defined. Add an entry to agents.<id> in \
  6071	             .rhei/settings.json or ~/.config/rhei/settings.json, or \
  6072	             reference one of the built-in ids ({}).",
  6073	            agent.id(),
  6074	            built_in_agents().keys().map(|s| s.as_str()).collect::<Vec<_>>().join(", ")
  6075	        )
  6076	    })?;
  6077	
  6078	    if let Some(mode) = target.mode.as_deref() {
  6079	        if !profile.modes.contains_key(mode) && !profile.modes.is_empty() {
  6080	            return Err(miette!(
  6081	                "agent '{}' has no mode '{}'. Available modes: {}.",
  6082	                agent.id(),
  6083	                mode,
  6084	                profile.modes.keys().map(|s| s.as_str()).collect::<Vec<_>>().join(", ")
  6085	            ));
  6086	        }
  6087	    }
  6088	
  6089	    let timeout_secs = state_def
  6090	        .and_then(|d| d.agent_timeout.as_deref())
  6091	        .and_then(rhei_validator::parse_duration_secs)
  6092	        .or_else(|| profile.timeout.as_deref().and_then(rhei_validator::parse_duration_secs))
  6093	        .or_else(|| settings.agent_timeout.as_deref().and_then(rhei_validator::parse_duration_secs))
  6094	        .or_else(|| {
  6095	            settings.defaults.agent_timeout.as_deref().and_then(rhei_validator::parse_duration_secs)
  6096	        });
  6097	
  6098	    Ok(ResolvedAgent {
  6099	        agent,
  6100	        profile,
  6101	        mode: target.mode.clone(),
  6102	        target: Some(target.clone()),
  6103	        model: Some(target.model.clone()),
  6104	        timeout_secs,
  6105	    })
  6106	}
  6107	
  6108	fn resolve_legacy_agent_with_model(
  6109	    state_def: Option<&rhei_validator::StateDef>,
  6110	    settings: &RheiSettings,
  6111	    opts: &RunOptions,
  6112	    model_override: Option<String>,
  6113	) -> MietteResult<Option<ResolvedAgent>> {
  6114	    // Agent id resolution: CLI > state > settings.
  6115	    let agent = if let Some(ovr) = opts.agent_override() {
  6116	        Some(AgentConfig::from(ovr))
  6117	    } else if let Some(a) = state_def.and_then(|d| d.agent.clone()) {
  6118	        Some(a)
  6119	    } else {
  6120	        settings.agent.clone()
  6121	    };
  6122	
  6123	    let Some(agent) = agent else {
  6124	        return Ok(None);
  6125	    };
  6126	
  6127	    let profile = settings.agents.get(agent.id()).cloned().ok_or_else(|| {
  6128	        miette!(
  6129	            "agent '{}' is not defined. Add an entry to agents.<id> in \
  6130	             .rhei/settings.json or ~/.config/rhei/settings.json, or \
  6131	             reference one of the built-in ids ({}).",
  6132	            agent.id(),
  6133	            built_in_agents().keys().map(|s| s.as_str()).collect::<Vec<_>>().join(", ")
  6134	        )
  6135	    })?;
  6136	
  6137	    let model = if let Some(ovr) = model_override {
  6138	        Some(ovr)
  6139	    } else if let Some(ovr) = opts.model_override() {
  6140	        Some(ovr.to_string())
  6141	    } else if let Some(m) = state_def.and_then(|d| d.model.clone()) {
  6142	        Some(m)
  6143	    } else {
  6144	        settings.model.clone()
  6145	    };
  6146	
  6147	    let mode = if let Some(ovr) = opts.agent_mode_override() {
  6148	        Some(ovr.to_string())
  6149	    } else if let Some(m) = state_def.and_then(|d| d.agent_mode.clone()) {
  6150	        Some(m)
  6151	    } else if let Some(m) = settings.defaults.agent_mode.clone() {
  6152	        Some(m)
  6153	    } else if let Some(m) = settings.agent_mode.clone() {
  6154	        Some(m)
  6155	    } else {
  6156	        profile.modes.keys().next().cloned()
  6157	    };
  6158	
  6159	    if let Some(name) = &mode {
  6160	        if !profile.modes.contains_key(name) && !profile.modes.is_empty() {
  6161	            return Err(miette!(
  6162	                "agent '{}' has no mode '{}'. Available modes: {}.",
  6163	                agent.id(),
  6164	                name,
  6165	                profile.modes.keys().map(|s| s.as_str()).collect::<Vec<_>>().join(", ")
  6166	            ));
  6167	        }
  6168	    }
  6169	
  6170	    let timeout_secs = state_def
  6171	        .and_then(|d| d.agent_timeout.as_deref())
  6172	        .and_then(rhei_validator::parse_duration_secs)
  6173	        .or_else(|| profile.timeout.as_deref().and_then(rhei_validator::parse_duration_secs))
  6174	        .or_else(|| settings.agent_timeout.as_deref().and_then(rhei_validator::parse_duration_secs))
  6175	        .or_else(|| {
  6176	            settings.defaults.agent_timeout.as_deref().and_then(rhei_validator::parse_duration_secs)
  6177	        });
  6178	
  6179	    Ok(Some(ResolvedAgent { agent, profile, mode, target: None, model, timeout_secs }))
  6180	}
  6181	
  6182	/// Resolve the agent/model/mode/timeout for a task's current state.
  6183	fn resolve_agent_invocations(
  6184	    machine: &rhei_validator::StateMachine,
  6185	    state_name: &str,
  6186	    settings: &RheiSettings,
  6187	    opts: &RunOptions,
  6188	) -> MietteResult<Vec<ResolvedAgent>> {
  6189	    if opts.no_agent() {
  6190	        return Ok(Vec::new());
  6191	    }
  6192	
  6193	    let state_def = machine.states.get(state_name);
  6194	    if let Some(state_def) = state_def {
  6195	        if !state_def.all_targets.is_empty() {
  6196	            let mut resolved = Vec::with_capacity(state_def.all_targets.len());
  6197	            for selector in &state_def.all_targets {
  6198	                resolved.push(resolve_target_agent(selector, Some(state_def), settings)?);
  6199	            }
  6200	            return Ok(resolved);
  6201	        }
  6202	        if let Some(selector) = state_def.target.as_deref() {
  6203	            return Ok(vec![resolve_target_agent(selector, Some(state_def), settings)?]);
  6204	        }
  6205	        if !state_def.all_models.is_empty() {
  6206	            let mut resolved = Vec::with_capacity(state_def.all_models.len());
  6207	            for model in &state_def.all_models {
  6208	                if let Some(agent) = resolve_legacy_agent_with_model(
  6209	                    Some(state_def),
  6210	                    settings,
  6211	                    opts,
  6212	                    Some(model.clone()),
  6213	                )? {
  6214	                    resolved.push(agent);
  6215	                }
  6216	            }
  6217	            return Ok(resolved);
  6218	        }
  6219	    }
  6220	
  6221	    Ok(resolve_legacy_agent_with_model(state_def, settings, opts, None)?.into_iter().collect())
  6222	}
  6223	
  6224	fn resolve_agent(
  6225	    machine: &rhei_validator::StateMachine,
  6226	    state_name: &str,
  6227	    settings: &RheiSettings,
  6228	    opts: &RunOptions,
  6229	) -> MietteResult<Option<ResolvedAgent>> {
  6230	    Ok(resolve_agent_invocations(machine, state_name, settings, opts)?.into_iter().next())
  6231	}
  6232	
  6233	type TransitionInvocationContext<'a> =
  6234	    (Option<&'a ExecutionTarget>, Option<&'a str>, Option<&'a str>, Option<&'a str>);
  6235	
  6236	fn transition_contexts_for_state<'a>(
  6237	    state_def: &'a rhei_validator::StateDef,
  6238	    resolved_invocations: &'a [ResolvedAgent],
  6239	) -> Vec<TransitionInvocationContext<'a>> {
  6240	    if !resolved_invocations.is_empty() {
  6241	        return resolved_invocations
  6242	            .iter()
  6243	            .map(|resolved| {
  6244	                (
  6245	                    resolved.target.as_ref(),
  6246	                    resolved.model.as_deref(),
  6247	                    Some(resolved.agent.id()),
  6248	                    resolved.mode.as_deref(),
  6249	                )
  6250	            })
  6251	            .collect();
  6252	    }
  6253	
  6254	    if !state_def.all_models.is_empty() {
  6255	        return state_def
  6256	            .all_models
  6257	            .iter()
  6258	            .map(|model| (None, Some(model.as_str()), None, None))
  6259	            .collect();
  6260	    }
