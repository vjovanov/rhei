  5864	            .iter()
  5865	            .filter(|e| e.definition.is_some())
  5866	            .map(|e| e.id.as_str())
  5867	            .collect::<Vec<_>>()
  5868	            .join(",")
  5869	    }
  5870	
  5871	    fn skills_csv(&self) -> String {
  5872	        self.skills
  5873	            .iter()
  5874	            .filter(|e| e.definition.is_some())
  5875	            .map(|e| e.id.as_str())
  5876	            .collect::<Vec<_>>()
  5877	            .join(",")
  5878	    }
