  1005	    /// Validate the `profiles` and `node_policy` blocks introduced by the
  1006	    /// current schema revision.
  1007	    ///
  1008	    /// When both are absent, the machine is treated as legacy and no
  1009	    /// additional checks run. When either is present, both must be present
  1010	    /// and consistent:
  1011	    ///
  1012	    /// - `profiles` is non-empty.
  1013	    /// - Every profile's `initial` names a defined state and is a member of
  1014	    ///   its own `allowed` list; every `allowed` entry names a defined state;
  1015	    ///   `allowed` has no duplicates.
  1016	    /// - `node_policy.root` and `node_policy.default` name defined profiles.
  1017	    /// - Every `by_type` value names a defined profile. Keys must be
  1018	    ///   non-empty and unique; `rhei` is reserved and rejected here.
  1019	    /// - Every `overrides` entry has a non-empty `match` and names a defined
  1020	    ///   profile.
  1021	    fn validate_profiles_and_node_policy(&self) -> Result<(), StateMachineLoadError> {
  1022	        match (self.profiles.as_ref(), self.node_policy.as_ref()) {
  1023	            (None, None) => return Ok(()),
  1024	            (Some(_), None) => {
  1025	                return Err(StateMachineLoadError::Invalid(
  1026	                    "state machine declares 'profiles' but no 'node_policy' block".to_string(),
  1027	                ));
  1028	            }
  1029	            (None, Some(_)) => {
  1030	                return Err(StateMachineLoadError::Invalid(
  1031	                    "state machine declares 'node_policy' but no 'profiles' block".to_string(),
  1032	                ));
  1033	            }
  1034	            (Some(_), Some(_)) => {}
  1035	        }
  1036	
  1037	        let profiles = self.profiles.as_ref().expect("profiles present");
  1038	        let policy = self.node_policy.as_ref().expect("node_policy present");
  1039	
  1040	        if profiles.is_empty() {
  1041	            return Err(StateMachineLoadError::Invalid(
  1042	                "'profiles' must declare at least one profile".to_string(),
  1043	            ));
  1044	        }
  1045	
  1046	        for (profile_name, profile) in profiles {
  1047	            if profile_name.trim().is_empty() {
  1048	                return Err(StateMachineLoadError::Invalid(
  1049	                    "'profiles' contains an entry with an empty name".to_string(),
  1050	                ));
  1051	            }
  1052	
  1053	            if profile.initial.trim().is_empty() {
  1054	                return Err(StateMachineLoadError::Invalid(format!(
  1055	                    "profile '{profile_name}' declares an empty 'initial'"
  1056	                )));
  1057	            }
  1058	
  1059	            if !self.states.contains_key(&profile.initial) {
  1060	                return Err(StateMachineLoadError::Invalid(format!(
  1061	                    "profile '{profile_name}' has 'initial: {}' but no such state is defined",
  1062	                    profile.initial
  1063	                )));
  1064	            }
  1065	
  1066	            if profile.allowed.is_empty() {
  1067	                return Err(StateMachineLoadError::Invalid(format!(
  1068	                    "profile '{profile_name}' declares an empty 'allowed' list"
  1069	                )));
  1070	            }
  1071	
  1072	            let mut seen = HashSet::new();
  1073	            for allowed in &profile.allowed {
  1074	                let trimmed = allowed.trim();
  1075	                if trimmed.is_empty() {
  1076	                    return Err(StateMachineLoadError::Invalid(format!(
  1077	                        "profile '{profile_name}' contains an empty entry in 'allowed'"
  1078	                    )));
  1079	                }
  1080	                if !seen.insert(trimmed) {
  1081	                    return Err(StateMachineLoadError::Invalid(format!(
  1082	                        "profile '{profile_name}' contains duplicate 'allowed' entry '{trimmed}'"
  1083	                    )));
  1084	                }
  1085	                if !self.states.contains_key(trimmed) {
  1086	                    return Err(StateMachineLoadError::Invalid(format!(
  1087	                        "profile '{profile_name}' lists unknown state '{trimmed}' in 'allowed'"
  1088	                    )));
  1089	                }
  1090	            }
  1091	
  1092	            if !profile.allowed.iter().any(|s| s == &profile.initial) {
  1093	                return Err(StateMachineLoadError::Invalid(format!(
  1094	                    "profile '{profile_name}' 'initial: {}' is not in its own 'allowed' list",
  1095	                    profile.initial
  1096	                )));
  1097	            }
  1098	        }
  1099	
  1100	        if !profiles.contains_key(&policy.root) {
  1101	            return Err(StateMachineLoadError::Invalid(format!(
  1102	                "'node_policy.root' references undefined profile '{}'",
  1103	                policy.root
  1104	            )));
  1105	        }
  1106	        if !profiles.contains_key(&policy.default) {
  1107	            return Err(StateMachineLoadError::Invalid(format!(
  1108	                "'node_policy.default' references undefined profile '{}'",
  1109	                policy.default
  1110	            )));
  1111	        }
  1112	
  1113	        let mut seen_kinds = HashSet::new();
  1114	        for (kind, profile_name) in &policy.by_type {
  1115	            let trimmed_kind = kind.trim();
  1116	            if trimmed_kind.is_empty() {
  1117	                return Err(StateMachineLoadError::Invalid(
  1118	                    "'node_policy.by_type' contains an empty node-kind key".to_string(),
  1119	                ));
  1120	            }
  1121	            if trimmed_kind.eq_ignore_ascii_case("rhei") {
  1122	                return Err(StateMachineLoadError::Invalid(
  1123	                    "'node_policy.by_type' must not declare the reserved kind 'rhei' \
  1124	                     (the root node is bound via 'node_policy.root')"
  1125	                        .to_string(),
  1126	                ));
  1127	            }
  1128	            if !seen_kinds.insert(trimmed_kind.to_ascii_lowercase()) {
  1129	                return Err(StateMachineLoadError::Invalid(format!(
  1130	                    "'node_policy.by_type' contains duplicate kind '{trimmed_kind}' \
  1131	                     (kind matching is case-insensitive)"
  1132	                )));
  1133	            }
  1134	            if !profiles.contains_key(profile_name) {
  1135	                return Err(StateMachineLoadError::Invalid(format!(
  1136	                    "'node_policy.by_type.{trimmed_kind}' references undefined profile \
  1137	                     '{profile_name}'"
  1138	                )));
  1139	            }
  1140	        }
  1141	
  1142	        for (idx, ov) in policy.overrides.iter().enumerate() {
  1143	            if ov.pattern.trim().is_empty() {
  1144	                return Err(StateMachineLoadError::Invalid(format!(
  1145	                    "'node_policy.overrides[{idx}]' has an empty 'match'"
  1146	                )));
  1147	            }
  1148	            if !profiles.contains_key(&ov.profile) {
  1149	                return Err(StateMachineLoadError::Invalid(format!(
  1150	                    "'node_policy.overrides[{idx}]' references undefined profile '{}'",
  1151	                    ov.profile
  1152	                )));
  1153	            }
  1154	        }
  1155	
  1156	        for (state_name, state) in &self.states {
  1157	            if state.initial {
  1158	                return Err(StateMachineLoadError::Invalid(format!(
  1159	                    "state '{state_name}' declares 'initial: true', but the machine uses \
  1160	                     'profiles' — the initial state is a property of each profile"
  1161	                )));
  1162	            }
  1163	        }
  1164	
  1165	        Ok(())
  1166	    }
  1167	
  1168	    /// Validate that every `{if <condition>}` tag in `instructions` and
  1169	    /// `personality` fields references a condition the engine can evaluate.
  1170	    ///
  1171	    /// Supported forms:
  1172	    /// - `input.<name>.exists` — `<name>` must be a declared input artifact
  1173	    ///   on the same state.
  1174	    /// - `mcp.<name>.available` — `<name>` must appear in the state's
  1175	    ///   `mcp_servers` list (including `defaults.mcp_servers` ids when
  1176	    ///   inherited is not cleared; this layer only checks the state-level
  1177	    ///   declaration since defaults live in settings, not the machine).
  1178	    /// - `skill.<id>.available` — same rule for the `skills` list.
  1179	    fn validate_template_conditions(&self) -> Result<(), StateMachineLoadError> {
  1180	        for (state_name, state) in &self.states {
  1181	            for (field_name, text) in [
  1182	                ("instructions", state.instructions.as_deref()),
  1183	                ("personality", state.personality.as_deref()),
  1184	            ] {
  1185	                let Some(text) = text else { continue };
  1186	                for condition in extract_if_conditions(text) {
  1187	                    if let Some(input_name) =
  1188	                        condition.strip_prefix("input.").and_then(|s| s.strip_suffix(".exists"))
  1189	                    {
  1190	                        if !state.inputs.iter().any(|a| a.name == input_name) {
  1191	                            return Err(StateMachineLoadError::Invalid(format!(
  1192	                                "state '{state_name}' {field_name} contains \
  1193	                                 '{{if {condition}}}' but '{input_name}' is not a declared input \
  1194	                                 on this state"
  1195	                            )));
  1196	                        }
  1197	                    } else if let Some(mcp_id) =
  1198	                        condition.strip_prefix("mcp.").and_then(|s| s.strip_suffix(".available"))
  1199	                    {
  1200	                        let declared = state
  1201	                            .mcp_servers
  1202	                            .as_deref()
  1203	                            .map(|entries| entries.iter().any(|e| e.id() == mcp_id))
  1204	                            .unwrap_or(false);
  1205	                        if !declared {
  1206	                            return Err(StateMachineLoadError::Invalid(format!(
  1207	                                "state '{state_name}' {field_name} contains \
  1208	                                 '{{if {condition}}}' but '{mcp_id}' is not declared in this state's \
  1209	                                 'mcp_servers' list"
  1210	                            )));
  1211	                        }
  1212	                    } else if let Some(skill_id) =
  1213	                        condition.strip_prefix("skill.").and_then(|s| s.strip_suffix(".available"))
  1214	                    {
  1215	                        let declared = state
  1216	                            .skills
  1217	                            .as_deref()
  1218	                            .map(|entries| entries.iter().any(|e| e.id() == skill_id))
  1219	                            .unwrap_or(false);
  1220	                        if !declared {
  1221	                            return Err(StateMachineLoadError::Invalid(format!(
  1222	                                "state '{state_name}' {field_name} contains \
  1223	                                 '{{if {condition}}}' but '{skill_id}' is not declared in this state's \
  1224	                                 'skills' list"
  1225	                            )));
  1226	                        }
  1227	                    } else {
  1228	                        return Err(StateMachineLoadError::Invalid(format!(
  1229	                            "state '{state_name}' {field_name} contains \
  1230	                             '{{if {condition}}}' which is not a recognised condition; \
  1231	                             supported forms: 'input.<name>.exists', 'mcp.<name>.available', 'skill.<id>.available'"
  1232	                        )));
  1233	                    }
  1234	                }
  1235	            }
  1236	        }
  1237	
  1238	        Ok(())
