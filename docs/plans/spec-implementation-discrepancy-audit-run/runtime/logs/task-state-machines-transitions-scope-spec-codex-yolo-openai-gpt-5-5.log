    30	/// Ids use dotted paths such as `1.2` or `api.cache.fix`. Each segment is
    31	/// either numeric (`NUMBER`) or named (`IDENTIFIER`) per the grammar.
    32	#[derive(Debug, Clone, PartialEq, Eq, Hash)]
    33	pub enum TaskIdSegment {
