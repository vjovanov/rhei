    47	/// Hierarchical task identifier.
    48	///
    49	/// Root tasks have a single segment (`1`, `api`). Child tasks append one
    50	/// segment per level of nesting (`1.2`, `api.cache.fix`).
    51	#[derive(Debug, Clone, PartialEq, Eq, Hash)]
    52	pub struct TaskId {
    53	    pub segments: Vec<TaskIdSegment>,
    54	}
    55	
    56	impl TaskId {
    57	    /// Build an id from an explicit list of segments. At least one segment
    58	    /// must be present; callers are responsible for that invariant.
    59	    pub fn from_segments(segments: Vec<TaskIdSegment>) -> Self {
    60	        Self { segments }
    61	    }
    62	
    63	    /// Build a single-segment numeric id (`1`, `42`).
    64	    pub fn number(n: u32) -> Self {
    65	        Self { segments: vec![TaskIdSegment::Number(n)] }
    66	    }
    67	
    68	    /// Build a single-segment named id (`api`, `fix-cache`).
    69	    pub fn named<S: Into<String>>(s: S) -> Self {
    70	        Self { segments: vec![TaskIdSegment::Named(s.into())] }
    71	    }
    72	
    73	    /// Depth of the id path (number of segments). Always `>= 1` for
    74	    /// well-formed ids.
    75	    pub fn depth(&self) -> usize {
    76	        self.segments.len()
    77	    }
    78	
    79	    /// Whether this id is a proper extension of `other` by exactly one
    80	    /// segment.
    81	    pub fn extends(&self, other: &TaskId) -> bool {
    82	        self.segments.len() == other.segments.len() + 1
    83	            && self.segments[..other.segments.len()] == other.segments[..]
    84	    }
    85	
    86	    /// The parent id, if any (strips the trailing segment).
    87	    pub fn parent(&self) -> Option<TaskId> {
    88	        if self.segments.len() <= 1 {
