  2079	/// Detect cycles using Kahn's algorithm; report a generic cycle set on failure.
  2080	fn validate_circular_dependencies(
  2081	    _rhei: &Rhei,
  2082	    index: &HashMap<TaskId, &Task>,
  2083	    report: &mut ValidationReport,
  2084	) {
  2085	    // Build adjacency as dep -> dependent
  2086	    let mut nodes: HashSet<TaskId> = index.keys().cloned().collect();
  2087	    let mut adj: HashMap<TaskId, Vec<TaskId>> = HashMap::new();
  2088	    let mut indegree: HashMap<TaskId, usize> = HashMap::new();
  2089	
  2090	    for n in nodes.clone() {
  2091	        adj.entry(n.clone()).or_default();
  2092	        indegree.entry(n).or_insert(0);
  2093	    }
  2094	
  2095	    for task in index.values() {
  2096	        // task depends on deps; edges: dep -> task.id
  2097	        for dep in &task.prior {
  2098	            // Include unseen dependency as a node to make cycle detection robust even if integrity check was skipped.
  2099	            nodes.insert(dep.clone());
  2100	            adj.entry(dep.clone()).or_default().push(task.id.clone());
  2101	            *indegree.entry(task.id.clone()).or_insert(0) += 1;
  2102	            indegree.entry(dep.clone()).or_insert(0);
  2103	        }
  2104	    }
  2105	
  2106	    // Kahn's algorithm
  2107	    let mut q: VecDeque<TaskId> =
  2108	        indegree.iter().filter_map(|(n, &d)| if d == 0 { Some(n.clone()) } else { None }).collect();
  2109	    let mut processed = 0usize;
  2110	
  2111	    while let Some(n) = q.pop_front() {
  2112	        processed += 1;
  2113	        if let Some(neigh) = adj.get(&n) {
  2114	            for m in neigh {
  2115	                if let Some(d) = indegree.get_mut(m) {
  2116	                    *d -= 1;
  2117	                    if *d == 0 {
  2118	                        q.push_back(m.clone());
  2119	                    }
  2120	                }
  2121	            }
  2122	        }
  2123	    }
  2124	
  2125	    if processed != indegree.len() {
  2126	        // Collect nodes still with indegree > 0
  2127	        let cyc_nodes: Vec<String> = indegree
  2128	            .iter()
  2129	            .filter_map(|(n, &d)| if d > 0 { Some(n.to_string()) } else { None })
  2130	            .collect();
  2131	        if !cyc_nodes.is_empty() {
  2132	            report
  2133	                .errors
  2134	                .push(format!("Circular dependency detected among tasks: {:?}", cyc_nodes));
  2135	        } else {
  2136	            report
  2137	                .errors
  2138	                .push("Circular dependency detected (unable to isolate nodes)".to_string());
  2139	        }
  2140	    }
  2141	}
