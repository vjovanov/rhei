    38	impl fmt::Display for TaskIdSegment {
    39	    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
    40	        match self {
    41	            TaskIdSegment::Number(n) => write!(f, "{n}"),
    42	            TaskIdSegment::Named(s) => write!(f, "{s}"),
    43	        }
    44	    }
