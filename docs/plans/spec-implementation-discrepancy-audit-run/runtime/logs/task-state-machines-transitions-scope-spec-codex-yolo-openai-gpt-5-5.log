  1242	/// Extract every condition string from `{if <condition>}` tags in `text`.
  1243	fn extract_if_conditions(text: &str) -> Vec<&str> {
  1244	    let mut conditions = Vec::new();
  1245	    let mut remaining = text;
  1246	    while let Some(start) = remaining.find("{if ") {
  1247	        let after_open = start + "{if ".len();
  1248	        if let Some(close) = remaining[after_open..].find('}') {
  1249	            conditions.push(&remaining[after_open..after_open + close]);
  1250	            remaining = &remaining[after_open + close + 1..];
  1251	        } else {
  1252	            break;
  1253	        }
  1254	    }
  1255	    conditions
  1256	}
  1257	
  1258	fn validate_state_mcp_entries(
  1259	    state_name: &str,
  1260	    state: &StateDef,
  1261	) -> Result<(), StateMachineLoadError> {
  1262	    let Some(entries) = state.mcp_servers.as_deref() else {
  1263	        return Ok(());
  1264	    };
  1265	
  1266	    if !entries.is_empty() {
  1267	        if state.gating {
  1268	            return Err(StateMachineLoadError::Invalid(format!(
  1269	                "state '{state_name}' is gating and cannot declare 'mcp_servers' (gating states are human-only)"
  1270	            )));
  1271	        }
  1272	        if state.program.is_some() {
  1273	            return Err(StateMachineLoadError::Invalid(format!(
  1274	                "state '{state_name}' declares 'program' and cannot declare 'mcp_servers' (programs execute deterministically)"
  1275	            )));
  1276	        }
  1277	        if state.terminal {
  1278	            return Err(StateMachineLoadError::Invalid(format!(
  1279	                "state '{state_name}' is final and cannot declare 'mcp_servers' (terminal states have no work)"
  1280	            )));
  1281	        }
  1282	    }
  1283	
  1284	    let mut seen = HashSet::new();
  1285	    for entry in entries {
  1286	        let id = entry.id();
  1287	        if id.trim().is_empty() {
  1288	            return Err(StateMachineLoadError::Invalid(format!(
  1289	                "state '{state_name}' has an mcp_servers entry with an empty id"
  1290	            )));
  1291	        }
  1292	        if !seen.insert(id.to_string()) {
  1293	            return Err(StateMachineLoadError::Invalid(format!(
  1294	                "state '{state_name}' has a duplicate mcp_servers id '{id}'"
  1295	            )));
  1296	        }
  1297	        if let StateMcpEntry::Object(obj) = entry {
  1298	            if obj.command.is_some() && obj.url.is_some() {
  1299	                return Err(StateMachineLoadError::Invalid(format!(
  1300	                    "state '{state_name}' mcp_servers entry '{id}' declares both 'command' and 'url' (mutually exclusive)"
  1301	                )));
  1302	            }
  1303	            if let Some(command) = &obj.command {
  1304	                if command.is_empty() {
  1305	                    return Err(StateMachineLoadError::Invalid(format!(
  1306	                        "state '{state_name}' mcp_servers entry '{id}' has an empty 'command'"
  1307	                    )));
  1308	                }
  1309	            }
  1310	            if let Some(url) = &obj.url {
  1311	                if url.trim().is_empty() {
  1312	                    return Err(StateMachineLoadError::Invalid(format!(
  1313	                        "state '{state_name}' mcp_servers entry '{id}' has an empty 'url'"
  1314	                    )));
  1315	                }
  1316	            }
  1317	        }
  1318	    }
  1319	    Ok(())
  1320	}

