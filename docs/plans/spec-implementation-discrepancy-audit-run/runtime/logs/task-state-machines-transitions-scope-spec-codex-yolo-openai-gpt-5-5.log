   837	                )));
   838	            }
   839	
   840	            let mut state_seen = HashSet::new();
   841	            for model in &state.all_models {
   842	                let trimmed = model.trim();
   843	                if trimmed.is_empty() {
   844	                    return Err(StateMachineLoadError::Invalid(format!(
   845	                        "state '{state_name}' contains an empty 'all_models' entry"
   846	                    )));
   847	                }
   848	                if !state_seen.insert(trimmed) {
   849	                    return Err(StateMachineLoadError::Invalid(format!(
   850	                        "state '{state_name}' contains duplicate 'all_models' entry '{trimmed}'"
   851	                    )));
   852	                }
   853	                if !seen.contains(trimmed) {
   854	                    return Err(StateMachineLoadError::Invalid(format!(
   855	                        "state '{state_name}' references unknown model '{trimmed}' in 'all_models'"
   856	                    )));
   857	                }
   858	            }
   859	
   860	            if let Some(model) = state.model.as_deref() {
   861	                let trimmed = model.trim();
   862	                if trimmed.is_empty() {
   863	                    return Err(StateMachineLoadError::Invalid(format!(
   864	                        "state '{state_name}' declares an empty 'model' value"
   865	                    )));
   866	                }
   867	                if self.models.is_empty() {
   868	                    return Err(StateMachineLoadError::Invalid(format!(
   869	                        "state '{state_name}' sets 'model: {trimmed}' but the machine does not declare any top-level 'models'"
   870	                    )));
   871	                }
   872	                if !seen.contains(trimmed) {
   873	                    return Err(StateMachineLoadError::Invalid(format!(
   874	                        "state '{state_name}' references unknown model '{trimmed}'"
   875	                    )));
   876	                }
   877	            }
   878	        }
   879	
   880	        Ok(())
   881	    }
