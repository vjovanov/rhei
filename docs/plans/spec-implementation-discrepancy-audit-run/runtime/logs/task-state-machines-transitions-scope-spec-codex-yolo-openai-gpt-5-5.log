  9313	    let task = loaded
  9314	        .rhei
  9315	        .tasks
  9316	        .iter()
  9317	        .find(|t| t.id == target_id)
  9318	        .ok_or_else(|| miette!("task '{}' not found in the plan", task_id_str))?;
