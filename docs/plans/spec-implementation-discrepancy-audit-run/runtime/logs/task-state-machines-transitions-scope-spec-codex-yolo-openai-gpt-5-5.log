  1931	/// Warn when an authored `**Assignee:**` value is empty after trim.
  1932	///
  1933	/// The spec treats the field itself as optional; its *value* is only
  1934	/// required to be a non-empty title when present.
  1935	fn validate_assignee_nonempty(rhei: &Rhei, report: &mut ValidationReport) {
  1936	    for_each_node(rhei, |task| {
  1937	        if let Some(assignee) = &task.assignee {
  1938	            if assignee.trim().is_empty() {
  1939	                report.warnings.push(format!("Task {} has an empty **Assignee:** value", task.id));
  1940	            }
  1941	        }
  1942	    });
  1943	}
  1944	
  1945	fn validate_task_id_uniqueness(rhei: &Rhei, report: &mut ValidationReport) {
  1946	    let mut seen: HashSet<TaskId> = HashSet::new();
  1947	    for_each_node(rhei, |task| {
  1948	        if !seen.insert(task.id.clone()) {
  1949	            report.errors.push(format!("Duplicate task id: Task {}", task.id));
  1950	        }
  1951	    });
  1952	}
  1953	
  1954	/// Verify that sibling ids are unique under the same parent and that every
  1955	/// child id extends its parent id by exactly one segment.
  1956	fn validate_sibling_uniqueness(rhei: &Rhei, report: &mut ValidationReport) {
  1957	    fn recurse(parent: Option<&Task>, siblings: &[Task], report: &mut ValidationReport) {
  1958	        let mut seen: HashSet<TaskId> = HashSet::new();
  1959	        for task in siblings {
  1960	            if let Some(p) = parent {
  1961	                if !task.id.extends(&p.id) {
  1962	                    report.errors.push(format!(
  1963	                        "Task {} must extend parent Task {} by exactly one segment",
  1964	                        task.id, p.id
  1965	                    ));
  1966	                }
  1967	            }
  1968	            if !seen.insert(task.id.clone()) {
  1969	                report.errors.push(format!(
  1970	                    "Duplicate sibling task id: Task {}{}",
  1971	                    task.id,
  1972	                    parent.map(|p| format!(" under Task {}", p.id)).unwrap_or_default()
  1973	                ));
  1974	            }
  1975	            recurse(Some(task), &task.children, report);
  1976	        }
  1977	    }
  1978	    recurse(None, &rhei.tasks, report);
  1979	}
