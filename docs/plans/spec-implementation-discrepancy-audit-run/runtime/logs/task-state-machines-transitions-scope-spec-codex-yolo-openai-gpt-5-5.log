  8579	/// Try to fire a timeout transition for a task after an agent was killed.
  8580	fn fire_timeout_transition(
  8581	    input: &Path,
  8582	    machine: &rhei_validator::StateMachine,
  8583	    callback_paths: &CallbackPaths,
  8584	    task_id_str: &str,
  8585	    from_state: &str,
  8586	    no_callbacks: bool,
  8587	) {
  8588	    // Look for a transition with a timeout field from the current state.
  8589	    let timeout_rule = machine
  8590	        .transitions
  8591	        .iter()
  8592	        .find(|rule| (rule.from.0 == from_state || rule.from.0 == "*") && rule.timeout.is_some());
  8593	    if let Some(rule) = timeout_rule {
  8594	        let to_state = &rule.to.0;
  8595	        let loaded = match load_plan(input) {
  8596	            Ok(l) => l,
  8597	            Err(_) => return,
  8598	        };
  8599	        let task_file = loaded.task_file(task_id_str, input);
  8600	        let metadata_file = if workspace::is_workspace(input) {
  8601	            input.join("index.rhei.md")
  8602	        } else {
  8603	            task_file.clone()
  8604	        };
  8605	        match execute_transition(
  8606	            TransitionFiles { task_file: &task_file, metadata_file: &metadata_file },
  8607	            callback_paths,
  8608	            machine,
  8609	            task_id_str,
  8610	            from_state,
  8611	            to_state,
  8612	            no_callbacks,
  8613	        ) {
  8614	            Ok(()) => {
  8615	                println!(
  8616	                    "  Timeout transition: Task {} '{}' -> '{}'",
  8617	                    task_id_str, from_state, to_state
  8618	                );
  8619	            }
  8620	            Err(err) => {
  8621	                eprintln!(
  8622	                    "  warning: failed to fire timeout transition for Task {}: {}",
  8623	                    task_id_str, err
  8624	                );
  8625	            }
  8626	        }
  8627	    }
  8628	}
