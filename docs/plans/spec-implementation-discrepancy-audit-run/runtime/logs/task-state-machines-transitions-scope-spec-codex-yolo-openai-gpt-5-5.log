  9401	        1 + task.children.iter().map(count_nodes).sum::<usize>()
  9402	    }
  9403	    let task_count = loaded.rhei.tasks.len();
  9404	    let total_nodes: usize = loaded.rhei.tasks.iter().map(count_nodes).sum();
  9405	    let descendant_count = total_nodes.saturating_sub(task_count);
  9406	
  9407	    for file in reset_target_files(&loaded, input) {
  9408	        reset_plan_file_states(&file, &initial_state)?;
  9409	    }
  9410	    if workspace::is_workspace(input) {
  9411	        clear_runtime_metadata_in_file(&input.join("index.rhei.md"), true)?;
  9412	    }
  9413	
  9414	    let mut removed_runtime = false;
  9415	    let runtime_dir = if workspace::is_workspace(input) {
  9416	        Some(input.join("runtime"))
  9417	    } else {
  9418	        input.parent().map(|p| p.join("runtime"))
  9419	    };
  9420	    if let Some(runtime_dir) = runtime_dir {
  9421	        if runtime_dir.exists() {
  9422	            fs::remove_dir_all(&runtime_dir).map_err(|err| {
  9423	                file_io_report(&runtime_dir, "failed to remove runtime directory", err)
  9424	            })?;
  9425	            removed_runtime = true;
  9426	        }
  9427	    }
  9428	
  9429	    if descendant_count == 0 {
  9430	        println!("Reset {} task(s) to initial state '{}'.", task_count, initial_state);
  9431	    } else {
  9432	        println!(
  9433	            "Reset {} task(s) (and {} descendant task(s)) to initial state '{}'.",
  9434	            task_count, descendant_count, initial_state
  9435	        );
  9436	    }
  9437	    if removed_runtime {
  9438	        println!("Removed runtime output.");
  9439	    } else {
  9440	        println!("No runtime output was present.");
  9441	    }
