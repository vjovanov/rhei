  8512	                        task_id_str, current_state_raw, to_state
  8513	                    );
  8514	                    println!("  {}", format_task_label(task));
  8515	                    if is_terminal_state(&to_state, machine) {
  8516	                        println!("  Result: reached terminal state '{}'.", to_state);
  8517	                    } else {
  8518	                        println!("  Result: now in '{}'.", to_state);
  8519	                    }
  8520	                    let reloaded = load_plan(input)?;
  8521	                    let discovered = newly_discovered_tasks(&task_ids_before, &reloaded.rhei.tasks);
  8522	                    if !discovered.is_empty() {
  8523	                        println!(
