  1230	)
  1231	
  1232	@rhei.on_leave("queued", "preprocessing")
  1233	def validate_dataset(ctx: TransitionContext) -> TransitionResult:
  1234	    """Validate dataset exists and is properly formatted."""
  1235	    task = ctx.task
  1236	
  1237	    dataset_path = task.metadata.get("dataset_path")
  1238	    if not dataset_path or not Path(dataset_path).exists():
  1239	        return TransitionResult(
  1240	            success=False,
  1241	            error=f"Dataset not found: {dataset_path}"
  1242	        )
  1243	
  1244	    # Validate schema
  1245	    if not validate_schema(dataset_path):
  1246	        return TransitionResult(
  1247	            success=False,
  1248	            error="Dataset schema validation failed"
  1249	        )
  1250	
  1251	    return TransitionResult(success=True)
  1252	
  1253	
  1254	@rhei.on_enter("training")
  1255	def initialize_training(ctx: TransitionContext) -> TransitionResult:
  1256	    """Set up training environment and begin model training."""
  1257	    task = ctx.task
  1258	
  1259	    # Initialize training configuration
  1260	    config = {
  1261	        "epochs": task.metadata.get("epochs", 100),
  1262	        "batch_size": task.metadata.get("batch_size", 32),
  1263	        "learning_rate": task.metadata.get("lr", 0.001),
  1264	    }
  1265	
  1266	    # Start training job
  1267	    job_id = training_service.start(config)
  1268	
  1269	    return TransitionResult(
  1270	        success=True,
  1271	        data={"job_id": job_id, "config": config}
  1272	    )
  1273	
  1274	
  1275	@rhei.on_leave("training", "evaluating")
  1276	def save_checkpoint(ctx: TransitionContext) -> TransitionResult:
  1277	    """Save model checkpoint and determine if evaluation should proceed."""
  1278	    task = ctx.task
  1279	    job_id = ctx.transition_data.get("job_id")
  1280	
  1281	    # Get training metrics
  1282	    metrics = training_service.get_metrics(job_id)
  1283	
  1284	    if metrics["loss"] > 10.0:  # Training diverged
  1285	        return TransitionResult(
  1286	            success=True,
  1287	            next_state="failed",  # Override: go to failed instead of evaluating
  1288	            error="Training diverged - loss too high"
  1289	        )
  1290	
  1291	    # Save checkpoint
  1292	    checkpoint_path = save_model_checkpoint(job_id)
  1293	
  1294	    return TransitionResult(
  1295	        success=True,
  1296	        data={"checkpoint": checkpoint_path, "metrics": metrics}
  1297	    )
  1298	
  1299	
  1300	@rhei.on_leave("evaluating", "deployed")
  1301	def validate_metrics(ctx: TransitionContext) -> TransitionResult:
  1302	    """Validate model meets deployment criteria."""
  1303	    metrics = ctx.transition_data.get("metrics", {})
  1304	
  1305	    min_accuracy = 0.85
  1306	    if metrics.get("accuracy", 0) < min_accuracy:
  1307	        return TransitionResult(
  1308	            success=False,
  1309	            error=f"Accuracy {metrics.get('accuracy')} below threshold {min_accuracy}"
  1310	        )
  1311	
  1312	    return TransitionResult(success=True)
  1313	
  1314	
  1315	if __name__ == "__main__":
