  8745	    use std::collections::HashMap;
  8746	
  8747	    fn collect<'a>(task: &'a rhei_core::ast::Task, out: &mut Vec<&'a rhei_core::ast::Task>) {
  8748	        out.push(task);
  8749	        for c in &task.children {
  8750	            collect(c, out);
  8751	        }
  8752	    }
  8753	    let mut all = Vec::new();
  8754	    for t in &rhei.tasks {
  8755	        collect(t, &mut all);
  8756	    }
  8757	
  8758	    if all.is_empty() {
  8759	        return "no tasks are ready to claim (plan has no tasks)".to_string();
  8760	    }
  8761	
  8762	    let state_map: HashMap<&TaskId, String> =
  8763	        all.iter().map(|t| (&t.id, normalized_state_name(t.state.as_str(), machine))).collect();
  8764	
  8765	    let non_terminal: Vec<&rhei_core::ast::Task> =
  8766	        all.iter().copied().filter(|t| !is_terminal_state(t.state.as_str(), machine)).collect();
  8767	
  8768	    if non_terminal.is_empty() {
  8769	        return "no tasks are ready to claim: every task is already in a terminal state."
  8770	            .to_string();
  8771	    }
  8772	
  8773	    let priors_satisfied = |task: &rhei_core::ast::Task| -> bool {
  8774	        task.prior.iter().all(|dep_id| {
  8775	            state_map.get(dep_id).map(|s| dependency_is_satisfied(s, machine)).unwrap_or(false)
  8776	        })
  8777	    };
  8778	
  8779	    let ready_non_initial: Vec<&rhei_core::ast::Task> = non_terminal
  8780	        .iter()
  8781	        .copied()
  8782	        .filter(|t| {
  8783	            let s = normalized_state_name(t.state.as_str(), machine);
  8784	            let is_initial = machine.states.get(&s).map(|def| def.initial).unwrap_or(false);
  8785	            !is_initial && priors_satisfied(t)
  8786	        })
  8787	        .collect();
  8788	
  8789	    if let Some(task) = ready_non_initial.first() {
  8790	        let state_name = normalized_state_name(task.state.as_str(), machine);
  8791	        let outgoing: Vec<String> = machine
  8792	            .transitions()
  8793	            .iter()
  8794	            .filter(|rule| rule.from.0 == state_name || rule.from.0 == "*")
  8795	            .map(|rule| rule.to.0.clone())
  8796	            .collect();
  8797	        let outgoing =
  8798	            if outgoing.is_empty() { "(none declared)".to_string() } else { outgoing.join(", ") };
  8799	        return format!(
  8800	            "no tasks can be auto-claimed: Task {} is mid-workflow in state '{}'. \
  8801	             Pick one of its outgoing transitions [{}] with \
  8802	             `rhei transition <plan> --task {} --from {} --to <state>`.",
  8803	            task.id, state_name, outgoing, task.id, state_name
  8804	        );
  8805	    }
  8806	
  8807	    let blocked: Vec<&rhei_core::ast::Task> =
  8808	        non_terminal.iter().copied().filter(|t| !priors_satisfied(t)).collect();
  8809	    if !blocked.is_empty() {
  8810	        let ids: Vec<String> = blocked.iter().take(3).map(|t| format!("Task {}", t.id)).collect();
  8811	        let suffix = if blocked.len() > 3 {
  8812	            format!(" (+{} more)", blocked.len() - 3)
  8813	        } else {
  8814	            String::new()
  8815	        };
  8816	        return format!(
  8817	            "no tasks are ready to claim: {} blocked by incomplete prerequisites{}.",
  8818	            ids.join(", "),
  8819	            suffix
  8820	        );
  8821	    }
  8822	
  8823	    // Fallback: we found non-terminal tasks with priors satisfied but no
  8824	    // other category matched. Keep the legacy phrasing for this edge case.
  8825	    "no tasks are ready to claim".to_string()
  8826	}
  8827	
  8828	/// Check whether a state is terminal (final) in the state machine.
  8829	fn is_terminal_state(state: &str, machine: &rhei_validator::StateMachine) -> bool {
  8830	    let normalized = normalized_state_name(state, machine);
  8831	    machine.states.get(&normalized).map(|def| def.terminal).unwrap_or(false)
  8832	}
  8833	
  8834	fn state_declares_autonomous_execution(def: &rhei_validator::StateDef) -> bool {
  8835	    def.program.is_some()
  8836	        || def.agent.is_some()
  8837	        || def.model.is_some()
  8838	        || def.target.is_some()
  8839	        || !def.all_models.is_empty()
  8840	        || !def.all_targets.is_empty()
  8841	}
  8842	
  8843	/// Find the next forward transition from a given state.
  8844	///
  8845	/// Prefers exact `from` matches over wildcard (`*`) rules, and skips
  8846	/// transitions to terminal states via wildcards (those are escape hatches
  8847	/// like cancellation, not forward progress).
  8848	fn find_next_transition(
  8849	    task: &rhei_core::ast::Task,
  8850	    rhei: &rhei_core::ast::Rhei,
  8851	    machine: &rhei_validator::StateMachine,
  8852	) -> MietteResult<Option<String>> {
  8853	    let current_state = normalized_state_name(task.state.as_str(), machine);
  8854	
  8855	    // First, look for an exact from-state match.
  8856	    for rule in machine.transitions() {
  8857	        if rule.from.0 == current_state
  8858	            && transition_rule_is_applicable(
  8859	                rule,
  8860	                machine,
  8861	                rhei.metadata.as_ref(),
  8862	                &task.id,
  8863	                &current_state,
  8864	                task.state.as_str(),
  8865	            )?
  8866	        {
  8867	            return Ok(Some(rule.to.0.clone()));
  8868	        }
  8869	    }
  8870	
  8871	    // Fall back to wildcard, but only to non-terminal states (forward progress).
  8872	    for rule in machine.transitions() {
  8873	        if rule.from.0 == "*" {
  8874	            let is_terminal =
  8875	                machine.states.get(&rule.to.0).map(|def| def.terminal).unwrap_or(false);
  8876	            if !is_terminal
  8877	                && transition_rule_is_applicable(
  8878	                    rule,
  8879	                    machine,
  8880	                    rhei.metadata.as_ref(),
  8881	                    &task.id,
  8882	                    &current_state,
  8883	                    task.state.as_str(),
  8884	                )?
  8885	            {
  8886	                return Ok(Some(rule.to.0.clone()));
  8887	            }
  8888	        }
  8889	    }
  8890	
  8891	    Ok(None)
  8892	}
  8893	
  8894	fn try_auto_advance_task(
  8895	    input: &Path,
  8896	    machine: &rhei_validator::StateMachine,
  8897	    callback_paths: &CallbackPaths,
  8898	    task_id_str: &str,
  8899	    current_state: &str,
  8900	    no_callbacks: bool,
  8901	) -> MietteResult<Option<String>> {
  8902	    let loaded = load_plan(input)?;
  8903	    let target_id = parse_task_id(task_id_str);
  8904	    let Some(task) = loaded.rhei.tasks.iter().find(|t| t.id == target_id) else {
  8905	        return Ok(None);
  8906	    };
  8907	    let Some(to_state) = find_next_transition(task, &loaded.rhei, machine)? else {
  8908	        return Ok(None);
  8909	    };
  8910	
  8911	    let task_file = loaded.task_file(task_id_str, input);
  8912	    let metadata_file = if workspace::is_workspace(input) {
  8913	        input.join("index.rhei.md")
  8914	    } else {
  8915	        task_file.clone()
  8916	    };
  8917	
  8918	    execute_transition(
  8919	        TransitionFiles { task_file: &task_file, metadata_file: &metadata_file },
  8920	        callback_paths,
  8921	        machine,
  8922	        task_id_str,
  8923	        current_state,
  8924	        &to_state,
  8925	        no_callbacks,
  8926	    )?;
  8927	
  8928	    Ok(Some(to_state))
  8929	}
  8930	
  8931	/// Parse a task ID string into a [`TaskId`].
  8932	///
  8933	/// Accepts both single-segment ids (`1`, `api`) and dotted paths (`1.2`,
  8934	/// `api.cache`). Malformed input is treated as a single named segment so
  8935	/// downstream lookups fail cleanly with a "not found" message.
  8936	fn parse_task_id(s: &str) -> TaskId {
  8937	    if s.is_empty() {
  8938	        return TaskId::named(s);
  8939	    }
  8940	    let mut segments = Vec::new();
  8941	    for part in s.split('.') {
  8942	        if part.is_empty() {
  8943	            return TaskId::named(s);
  8944	        }
  8945	        if let Ok(n) = part.parse::<u32>() {
  8946	            segments.push(rhei_core::ast::TaskIdSegment::Number(n));
  8947	        } else {
  8948	            segments.push(rhei_core::ast::TaskIdSegment::Named(part.to_string()));
  8949	        }
  8950	    }
  8951	    TaskId::from_segments(segments)
  8952	}
  8953	
  8954	/// Insert a `**Assignee:** <value>` metadata line for a specific task.
  8955	///
  8956	/// Locates the `### Task <id>:` header, walks through its metadata block
  8957	/// (`**State:**`, optional `**Prior:**`), and inserts the Assignee line at
  8958	/// the end of that block, matching the grammar order specified in
  8959	/// docs/rhei.spec.md §268. A duplicate insertion is a no-op if the task
  8960	/// already has an assignee line; the caller is responsible for ensuring the
  8961	/// field is absent first (use claim-time eligibility checks).
  8962	fn insert_task_assignee(raw: &str, task_id: &str, assignee: &str) -> MietteResult<String> {
  8963	    let lines: Vec<&str> = raw.lines().collect();
  8964	    let mut result: Vec<String> = Vec::with_capacity(lines.len() + 1);
  8965	
  8966	    let task_prefix = format!("### Task {}:", task_id);
  8967	    let mut in_target_task = false;
  8968	    let mut last_metadata_idx: Option<usize> = None;
  8969	    let mut already_present = false;
  8970	    let mut inserted = false;
  8971	
  8972	    for line in lines.iter() {
  8973	        if line.starts_with("### Task ") {
  8974	            if let Some(meta_idx) = last_metadata_idx.take() {
  8975	                // Leaving previous target without finding a home for the
  8976	                // assignee line — insert immediately after its last metadata
  8977	                // line before appending the subsequent task header.
  8978	                insert_after(&mut result, meta_idx, &format_assignee(assignee));
  8979	                inserted = true;
  8980	            }
  8981	            in_target_task = line.starts_with(&task_prefix);
  8982	        }
  8983	
  8984	        if in_target_task && line.starts_with("**Assignee:**") {
  8985	            already_present = true;
  8986	        }
  8987	        if in_target_task && (line.starts_with("**State:**") || line.starts_with("**Prior:**")) {
  8988	            last_metadata_idx = Some(result.len());
  8989	        }
  8990	
  8991	        result.push((*line).to_string());
  8992	    }
  8993	
  8994	    if already_present {
  8995	        // Nothing to do — preserve input verbatim to keep trailing newline.
  8996	        return Ok(raw.to_string());
  8997	    }
  8998	    if inserted {
  8999	        let mut output = result.join("\n");
  9000	        if raw.ends_with('\n') {
  9001	            output.push('\n');
  9002	        }
  9003	        return Ok(output);
  9004	    }
  9005	
  9006	    let Some(meta_idx) = last_metadata_idx else {
  9007	        return Err(miette!(
  9008	            "could not find **State:**/**Prior:** metadata line for Task {} in the markdown",
  9009	            task_id
  9010	        ));
  9011	    };
  9012	    insert_after(&mut result, meta_idx, &format_assignee(assignee));
  9013	
  9014	    let mut output = result.join("\n");
  9015	    if raw.ends_with('\n') {
  9016	        output.push('\n');
  9017	    }
  9018	    Ok(output)
  9019	}
  9020	
  9021	fn format_assignee(value: &str) -> String {
  9022	    format!("**Assignee:** {}", value)
  9023	}
  9024	
  9025	fn insert_after(lines: &mut Vec<String>, idx: usize, value: &str) {
  9026	    let insert_at = idx + 1;
  9027	    if insert_at >= lines.len() {
  9028	        lines.push(value.to_string());
  9029	    } else {
  9030	        lines.insert(insert_at, value.to_string());
  9031	    }
  9032	}
  9033	
  9034	/// Rewrite the `**State:**` line for a specific task in the raw markdown.
  9035	///
  9036	/// Locates the `### Task <id>:` header and replaces the immediately following
  9037	/// `**State:**` line with the new state value.
  9038	fn rewrite_task_state(raw: &str, task_id: &str, new_state: &str) -> MietteResult<String> {
  9039	    let lines: Vec<&str> = raw.lines().collect();
  9040	    let mut result = Vec::with_capacity(lines.len());
  9041	
  9042	    // Build the task header prefix to match.
  9043	    let task_prefix = format!("### Task {}:", task_id);
  9044	
  9045	    let mut in_target_task = false;
  9046	    let mut state_replaced = false;
  9047	
  9048	    for line in &lines {
  9049	        if !state_replaced && line.starts_with("### Task ") {
  9050	            in_target_task = line.starts_with(&task_prefix);
  9051	        }
  9052	
  9053	        if in_target_task && !state_replaced && line.starts_with("**State:**") {
  9054	            let formatted = format!("**State:** {}", format_state_metadata_value(new_state));
  9055	            result.push(formatted);
  9056	            state_replaced = true;
  9057	            continue;
  9058	        }
  9059	
  9060	        result.push(line.to_string());
  9061	    }
  9062	
  9063	    if !state_replaced {
  9064	        return Err(miette!("could not find **State:** line for Task {} in the markdown", task_id));
  9065	    }
  9066	
  9067	    // Preserve trailing newline if original had one.
  9068	    let mut output = result.join("\n");
  9069	    if raw.ends_with('\n') {
  9070	        output.push('\n');
  9071	    }
  9072	    Ok(output)
  9073	}
  9074	
  9075	/// Execute the `next` subcommand: transition the next ready task to the next state,
  9076	/// and print the task details with instructions.
  9077	fn next_command(
  9078	    input: &Path,
  9079	    state_machine_path: Option<&Path>,
  9080	    task_id_filter: Option<&str>,
  9081	    as_json: bool,
  9082	    no_callbacks: bool,
  9083	    peek: bool,
  9084	) -> MietteResult<()> {
  9085	    let loaded = load_plan(input)?;
  9086	    let resolved = resolve_state_machine_for_loaded_plan(input, &loaded, state_machine_path)?;
  9087	    let machine = resolved.machine;
  9088	    let callback_paths = resolve_callback_paths(resolved.path.as_deref(), input)?;
  9089	    let workspace_root = execution_workspace_root(&callback_paths.plan_path);
  9090	
  9091	    // Validate the plan first.
  9092	    let report = rhei_validator::validate_with_machine(&loaded.rhei, &machine);
  9093	    if report.has_errors() {
  9094	        return Err(validation_report(input, resolved.path.as_deref(), &report.errors));
  9095	    }
  9096	
  9097	    // Find the target task to claim.
  9098	    let (task_id_str, current_state_raw, current_state) = if let Some(tid) = task_id_filter {
  9099	        let target_id = parse_task_id(tid);
  9100	        let task = loaded
  9101	            .rhei
  9102	            .tasks
  9103	            .iter()
  9104	            .find(|t| t.id == target_id)
  9105	            .ok_or_else(|| miette!("task '{}' not found in the plan", tid))?;
  9106	        let state_name = normalized_state_name(task.state.as_str(), &machine);
  9107	        let is_initial = machine.states.get(&state_name).map(|def| def.initial).unwrap_or(false);
  9108	        if is_initial {
  9109	            let state_map: HashMap<&TaskId, String> = loaded
  9110	                .rhei
  9111	                .tasks
  9112	                .iter()
  9113	                .map(|t| (&t.id, normalized_state_name(t.state.as_str(), &machine)))
  9114	                .collect();
  9115	            let all_priors_done = task.prior.iter().all(|dep_id| {
  9116	                state_map.get(dep_id).map(|s| dependency_is_satisfied(s, &machine)).unwrap_or(false)
  9117	            });
  9118	            if !all_priors_done {
  9119	                return Err(miette!("Task {} is blocked by incomplete prerequisites", tid));
  9120	            }
  9121	        }
  9122	        let state_def = machine
  9123	            .states
  9124	            .get(&state_name)
  9125	            .ok_or_else(|| miette!("state '{}' missing from loaded machine", state_name))?;
  9126	        let settings = load_merged_settings(&workspace_root);
  9127	        ensure_state_inputs_exist_for_transition(
  9128	            &workspace_root,
  9129	            tid,
  9130	            &state_name,
  9131	            state_def,
  9132	            Some(render_visit_count(
  9133	                loaded.rhei.metadata.as_ref(),
  9134	                &task.id,
  9135	                &state_name,
  9136	                task.state.as_str(),
  9137	                &machine,
  9138	            )),
  9139	            &machine,
  9140	            &settings,
  9141	            &format!("Task {} cannot be claimed in state {}.", tid, state_name),
  9142	        )?;
  9143	        (tid.to_string(), task.state.as_str().to_string(), state_name)
  9144	    } else {
  9145	        let ready = find_claimable_tasks(&loaded.rhei, &machine);
  9146	        if ready.is_empty() {
  9147	            return Err(miette!("{}", diagnose_no_claimable(&loaded.rhei, &machine)));
  9148	        }
  9149	        let task = ready.into_iter().next().unwrap();
  9150	        let state_name = normalized_state_name(task.state.as_str(), &machine);
  9151	        let state_def = machine
  9152	            .states
  9153	            .get(&state_name)
  9154	            .ok_or_else(|| miette!("state '{}' missing from loaded machine", state_name))?;
  9155	        let settings = load_merged_settings(&workspace_root);
  9156	        ensure_state_inputs_exist_for_transition(
  9157	            &workspace_root,
  9158	            &task.id.to_string(),
  9159	            &state_name,
  9160	            state_def,
  9161	            Some(render_visit_count(
  9162	                loaded.rhei.metadata.as_ref(),
  9163	                &task.id,
  9164	                &state_name,
  9165	                task.state.as_str(),
  9166	                &machine,
  9167	            )),
  9168	            &machine,
  9169	            &settings,
  9170	            &format!("Task {} cannot be claimed in state {}.", task.id, state_name),
  9171	        )?;
  9172	        (task.id.to_string(), task.state.to_string(), state_name)
  9173	    };
  9174	
  9175	    // Determine whether we need a state transition.
  9176	    // Tasks in an initial state (e.g. draft) are transitioned forward.
  9177	    let is_initial = machine.states.get(&current_state).map(|d| d.initial).unwrap_or(false);
  9178	    let current_state_def = machine
  9179	        .states
  9180	        .get(&current_state)
  9181	        .ok_or_else(|| miette!("state '{}' missing from loaded machine", current_state))?;
  9182	    let auto_transition_initial =
  9183	        is_initial && !state_declares_autonomous_execution(current_state_def);
  9184	
  9185	    let task_file = loaded.task_file(&task_id_str, input);
  9186	    let metadata_file = if workspace::is_workspace(input) {
  9187	        input.join("index.rhei.md")
  9188	    } else {
  9189	        task_file.clone()
  9190	    };
  9191	
  9192	    let final_state = if auto_transition_initial && !peek {
  9193	        // Advance from the initial state (e.g. draft → pending).
  9194	        let target_id = parse_task_id(&task_id_str);
  9195	        let task = loaded
  9196	            .rhei
  9197	            .tasks
  9198	            .iter()
  9199	            .find(|task| task.id == target_id)
  9200	            .ok_or_else(|| miette!("task '{}' not found in the plan", task_id_str))?;
  9201	        let to_state = find_next_transition(task, &loaded.rhei, &machine)?.ok_or_else(|| {
  9202	            miette!("no forward transition available from state '{}'", current_state_raw)
  9203	        })?;
  9204	        execute_transition(
  9205	            TransitionFiles { task_file: &task_file, metadata_file: &metadata_file },
  9206	            &callback_paths,
  9207	            &machine,
  9208	            &task_id_str,
  9209	            &current_state,
  9210	            &to_state,
  9211	            no_callbacks,
  9212	        )?;
  9213	        to_state
  9214	    } else {
  9215	        current_state.clone()
  9216	    };
  9217	
  9218	    // Re-load to get the updated task for output.
  9219	    let loaded = load_plan(input)?;
  9220	    let target_id = parse_task_id(&task_id_str);
  9221	    let task = loaded
  9222	        .rhei
  9223	        .tasks
  9224	        .iter()
  9225	        .find(|t| t.id == target_id)
  9226	        .ok_or_else(|| miette!("task '{}' not found after transition", task_id_str))?;
  9227	
  9228	    // Resolve agent/model for display.
  9229	    let settings = load_merged_settings(&workspace_root);
  9230	    let no_agent_opts = default_run_options();
  9231	    let resolved = resolve_agent(&machine, &final_state, &settings, &no_agent_opts)?;
  9232	    let agent_id_str = resolved.as_ref().map(|r| r.agent.id().to_string());
  9233	    let model_id_str = resolved.as_ref().and_then(|r| r.model.clone());
  9234	
  9235	    // Claim mode only: write `**Assignee:**` to the task file so a second
  9236	    // `rhei next` cannot re-claim the same task. Skipped in peek mode and
  9237	    // when the task already has an assignee set.
  9238	    if !peek && task.assignee.is_none() {
  9239	        if let Some(agent) = agent_id_str.as_deref() {
  9240	            write_task_assignee(&task_file, &task_id_str, agent)?;
  9241	        }
  9242	    }
  9243	    let tooling = resolve_tooling(&machine, &final_state, &settings);
  9244	    let render_context = RuntimeTemplateContext {
  9245	        workspace_root: &workspace_root,
  9246	        plan_path: &callback_paths.plan_path,
  9247	        state_machine_path: callback_paths.state_machine_path.as_deref(),
  9248	        plan_title: &loaded.rhei.title,
  9249	        task,
  9250	        state_name: &final_state,
