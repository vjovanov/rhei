   919	    /// Validate the per-state `poll:` block: well-formed `interval` and
   920	    /// `max_attempts`, mutually exclusive with `visits`, forbidden on
   921	    /// final/gating states, and at least one self-loop transition is
   922	    /// declared so the retry branch is reachable.
   923	    fn validate_poll_configuration(&self) -> Result<(), StateMachineLoadError> {
   924	        for (state_name, state) in &self.states {
   925	            let Some(poll) = state.poll.as_ref() else { continue };
   926	            if parse_duration_secs(&poll.interval).is_none() {
   927	                return Err(StateMachineLoadError::Invalid(format!(
   928	                    "state '{state_name}' has poll.interval '{}' that is not a valid duration (expected e.g. '30s', '5m', '1h')",
   929	                    poll.interval
   930	                )));
   931	            }
   932	            if poll.max_attempts < 1 {
   933	                return Err(StateMachineLoadError::Invalid(format!(
   934	                    "state '{state_name}' has poll.max_attempts {} (must be >= 1)",
   935	                    poll.max_attempts
   936	                )));
   937	            }
   938	            if state.terminal {
   939	                return Err(StateMachineLoadError::Invalid(format!(
   940	                    "state '{state_name}' is final and cannot declare 'poll' (terminal states have no work to execute)"
   941	                )));
   942	            }
   943	            if state.gating {
   944	                return Err(StateMachineLoadError::Invalid(format!(
   945	                    "state '{state_name}' is gating and cannot declare 'poll' (gating states require human action; polling executes autonomously)"
   946	                )));
   947	            }
   948	            if state.visits.is_some() {
   949	                return Err(StateMachineLoadError::Invalid(format!(
   950	                    "state '{state_name}' declares both 'poll' and 'visits'; poll.max_attempts replaces the visits cap"
   951	                )));
   952	            }
   953	            let has_self_loop =
   954	                self.transitions.iter().any(|t| t.from.0 == *state_name && t.to.0 == *state_name);
   955	            if !has_self_loop {
   956	                return Err(StateMachineLoadError::Invalid(format!(
   957	                    "state '{state_name}' declares 'poll' but has no self-loop transition; add a transition with from: {state_name} and to: {state_name} so the retry branch is reachable"
   958	                )));
   959	            }
   960	        }
   961	        Ok(())
   962	    }
