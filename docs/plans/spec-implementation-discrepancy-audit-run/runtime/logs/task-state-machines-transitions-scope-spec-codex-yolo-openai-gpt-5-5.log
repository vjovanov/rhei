   945	
   946	### Example 2: CLI Integration with Bash Functions
   947	
   948	When using the CLI, callbacks map to bash functions that receive task context as JSON on stdin:
   949	
   950	**states-cli.yaml:**
   951	```yaml
   952	name: cli-workflow
   953	version: 1.0
   954	
   955	states:
   956	  pending:
   957	    description: Task is waiting to be executed
   958	  running:
   959	    description: Script execution in progress
   960	  completed:
   961	    description: Task finished successfully
   962	    final: true
   963	  failed:
   964	    description: Task execution failed
   965	    final: true
   966	
   967	transitions:
   968	  - from: pending
   969	    to: running
   970	    on_leave: cli:validate_preconditions
   971	    on_enter: cli:start_execution
   972	
   973	  - from: running
   974	    to: completed
   975	    on_leave: cli:capture_outputs
   976	    on_enter: cli:report_success
   977	
   978	  - from: running
   979	    to: failed
   980	    on_leave: cli:capture_error_context
   981	    on_enter: cli:report_failure
   982	```
   983	
   984	**workflow-handlers.sh:**
   985	```bash
   986	#!/usr/bin/env bash
   987	# Handlers sourced by rhei-cli when executing transitions
   988	#
   989	# CLI Callback Contract:
   990	# - Receive TransitionContext as JSON on stdin
   991	# - Return TransitionResult as JSON on stdout (same format as other platforms)
   992	# - Exit code 0 = callback executed successfully (check 'success' field for result)
   993	# - Exit code non-zero = callback crashed (treated as rejection)
   994	
   995	# Called when leaving 'pending' state
   996	validate_preconditions() {
   997	    local context
   998	    context=$(cat)  # Read JSON from stdin
   999	
  1000	    task_id=$(echo "$context" | jq -r '.task.id')
  1001	    dependencies=$(echo "$context" | jq -r '.task.metadata.dependsOn[]')
  1002	
  1003	    # Check all dependencies are completed
  1004	    for dep in $dependencies; do
  1005	        dep_state=$(echo "$context" | jq -r ".rhei.tasks[] | select(.id == \"$dep\") | .metadata.state")
  1006	        if [[ "$dep_state" != "completed" ]]; then
  1007	            # Return proper TransitionResult with success=false
  1008	            echo '{"success": false, "error": "Dependency not met: '$dep'"}'
  1009	            return 0  # Exit 0 because callback ran successfully; success=false rejects
  1010	        fi
  1011	    done
  1012	
  1013	    echo '{"success": true, "data": {"message": "All preconditions met"}}'
  1014	    return 0
  1015	}
  1016	
  1017	# Called when entering 'running' state
  1018	start_execution() {
  1019	    local context
  1020	    context=$(cat)
  1021	
  1022	    task_id=$(echo "$context" | jq -r '.task.id')
  1023	    echo '{"success": true, "data": {"task_id": "'$task_id'", "timestamp": "'$(date -Iseconds)'"}}'
  1024	}
  1025	
  1026	# Called when leaving 'running' to determine next state
  1027	capture_outputs() {
  1028	    local context
  1029	    context=$(cat)
  1030	
  1031	    # Return next state based on exit code of the task
  1032	    exit_code=$(echo "$context" | jq -r '.execution.exit_code // 0')
  1033	
  1034	    if [[ "$exit_code" -eq 0 ]]; then
  1035	        echo '{"success": true, "data": {"outputs": {}}}'
  1036	    else
  1037	        # Redirect to 'failed' state
  1038	        echo '{"success": true, "nextState": "failed", "data": {"errorCode": '$exit_code'}}'
  1039	    fi
  1040	}
  1041	```
  1042	
  1043	**CLI invocation:**
  1044	```bash
  1045	# Execute a rhei with custom handlers
  1046	rhei-cli run examples/release-automation.rhei.md \
  1047	    --state-machine states-cli.yaml \
  1048	    --handlers ./workflow-handlers.sh
  1049	```
