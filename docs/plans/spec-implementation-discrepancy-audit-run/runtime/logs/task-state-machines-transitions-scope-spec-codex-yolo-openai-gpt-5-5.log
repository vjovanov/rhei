  3925	fn loop_reentry_allowed(
  3926	    machine: &rhei_validator::StateMachine,
  3927	    metadata: Option<&Metadata>,
  3928	    task_id: &TaskId,
  3929	    current_state: &str,
  3930	    current_state_raw: &str,
  3931	    to_state: &str,
  3932	) -> bool {
