  3838	fn resolve_condition_operand(
  3839	    token: &str,
  3840	    metadata: Option<&Metadata>,
  3841	    task_id: &TaskId,
  3842	    current_state: &str,
  3843	    current_state_raw: &str,
  3844	    machine: &rhei_validator::StateMachine,
  3845	) -> MietteResult<i64> {
  3846	    if let Ok(value) = token.parse::<i64>() {
  3847	        return Ok(value);
  3848	    }
  3849	
  3850	    match token {
  3851	        "visitCount" | "visit_count" => Ok(current_state_visit_count(
  3852	            metadata,
  3853	            task_id,
  3854	            current_state,
  3855	            current_state_raw,
  3856	            machine,
  3857	        ) as i64),
  3858	        "visits" => {
  3859	            let limit = state_visit_limit(machine, current_state).ok_or_else(|| {
  3860	                miette!("state '{}' does not declare a visit limit", current_state)
  3861	            })?;
  3862	            Ok(limit as i64)
  3863	        }
  3864	        other => {
  3865	            let value = task_metadata_number(metadata, task_id, other).ok_or_else(|| {
  3866	                miette!("condition operand '{}' is not available in task metadata", other)
  3867	            })?;
  3868	            Ok(value as i64)
  3869	        }
  3870	    }
  3871	}
