  1517	fn validate_program_command(
  1518	    state_name: &str,
  1519	    command: &serde_yaml::Value,
  1520	) -> Result<(), StateMachineLoadError> {
  1521	    match command {
  1522	        serde_yaml::Value::String(value) => {
  1523	            if value.trim().is_empty() {
  1524	                return Err(StateMachineLoadError::Invalid(format!(
  1525	                    "state '{state_name}' program.command must be a non-empty string"
  1526	                )));
  1527	            }
  1528	        }
  1529	        serde_yaml::Value::Sequence(values) => {
  1530	            if values.is_empty() {
  1531	                return Err(StateMachineLoadError::Invalid(format!(
  1532	                    "state '{state_name}' program.command array must not be empty"
  1533	                )));
  1534	            }
  1535	            for value in values {
  1536	                match value {
  1537	                    serde_yaml::Value::String(item) if !item.trim().is_empty() => {}
  1538	                    _ => {
  1539	                        return Err(StateMachineLoadError::Invalid(format!(
  1540	                            "state '{state_name}' program.command entries must be non-empty strings"
  1541	                        )))
  1542	                    }
  1543	                }
  1544	            }
  1545	        }
  1546	        _ => {
  1547	            return Err(StateMachineLoadError::Invalid(format!(
  1548	                "state '{state_name}' program.command must be a string or string array"
  1549	            )))
  1550	        }
  1551	    }
  1552	
  1553	    Ok(())
  1554	}
