   106	/// Trait for executing transition callbacks.
   107	///
   108	/// Implementations resolve a [`CallbackRef`] identifier and invoke the
   109	/// corresponding callback, passing the [`CallbackContext`] as input.
   110	pub trait CallbackExecutor {
   111	    /// Execute a callback and return its result.
   112	    fn execute(
   113	        &self,
   114	        callback: &CallbackRef,
   115	        context: &CallbackContext<'_>,
   116	    ) -> Result<CallbackResult, CallbackError>;
   117	}
   118	
   119	/// Executes `cli:`-prefixed callbacks as shell commands.
   120	///
   121	/// The command portion after `cli:` is run via `sh -c` from
   122	/// [`CallbackContext::callback_cwd`]. The runtime delivers two channels:
   123	///
   124	/// - **Environment variables** (always present):
   125	///   - `RHEI_TASK_ID` — the task identifier
   126	///   - `RHEI_FROM_STATE` — the state being left
   127	///   - `RHEI_TO_STATE` — the state being entered
   128	///   - `RHEI_PLAN_PATH` — path to the plan file
   129	///   - `RHEI_MODEL` — model identifier when the state declares one
   130	///   - `RHEI_AGENT` — agent identifier when the state declares one
   131	///
   132	/// - **Stdin JSON**: when `context.context_json` is `Some`, the full
   133	///   `TransitionContext` is serialized and written to the child's stdin.
   134	///
   135	/// The callback is expected to emit a `TransitionResult` JSON object on
   136	/// stdout (`{ success, error?, nextState?, data? }`). Exit-code semantics:
   137	///
   138	/// - **Zero** + parseable JSON → the parsed result is returned as-is,
   139	///   except that `success: false` combined with `nextState` is downgraded
   140	///   to rejection per the spec.
   141	/// - **Zero** + empty stdout → implicit success (compatible with callbacks
   142	///   that don't yet speak the TransitionResult protocol).
   143	/// - **Zero** + non-empty stdout that does not parse as JSON → implicit
   144	///   success; the raw stdout is preserved for logging but not interpreted.
   145	/// - **Non-zero** → rejection with an error synthesized from stderr. This
   146	///   matches the spec: "exit code non-zero = callback crashed".
   147	pub struct ShellCallbackExecutor;
   148	
   149	impl CallbackExecutor for ShellCallbackExecutor {
   150	    fn execute(
   151	        &self,
   152	        callback: &CallbackRef,
   153	        context: &CallbackContext<'_>,
   154	    ) -> Result<CallbackResult, CallbackError> {
   155	        let id = &callback.0;
   156	
   157	        let command =
   158	            id.strip_prefix("cli:").ok_or_else(|| CallbackError::UnknownPlatform(id.clone()))?;
   159	
   160	        let mut cmd = Command::new("sh");
   161	        cmd.arg("-c")
   162	            .arg(command)
   163	            .current_dir(context.callback_cwd)
   164	            .env("RHEI_TASK_ID", context.task_id)
   165	            .env("RHEI_FROM_STATE", context.from_state)
   166	            .env("RHEI_TO_STATE", context.to_state)
   167	            .env("RHEI_PLAN_PATH", context.plan_path.as_os_str())
   168	            .stdin(Stdio::piped())
   169	            .stdout(Stdio::piped())
   170	            .stderr(Stdio::piped());
   171	        if let Some(model) = context.model {
   172	            cmd.env("RHEI_MODEL", model);
   173	        }
   174	        if let Some(agent) = context.agent {
   175	            cmd.env("RHEI_AGENT", agent);
   176	        }
   177	
   178	        let mut child =
   179	            cmd.spawn().map_err(|e| CallbackError::SpawnFailed(command.to_string(), e))?;
   180	
   181	        if let Some(ctx_json) = context.context_json {
   182	            let payload = serde_json::to_vec(ctx_json).unwrap_or_else(|_| b"{}".to_vec());
   183	            if let Some(mut stdin) = child.stdin.take() {
   184	                match stdin.write_all(&payload) {
   185	                    Ok(()) => {}
   186	                    // `BrokenPipe` means the callback closed its stdin
   187	                    // before we finished writing (e.g. `exit 1` / scripts
   188	                    // that don't consume stdin). That's not an executor
   189	                    // failure — the child still ran and its exit status /
   190	                    // stdout / stderr are the truth of the matter.
   191	                    Err(e) if e.kind() == std::io::ErrorKind::BrokenPipe => {}
   192	                    Err(e) => {
   193	                        return Err(CallbackError::StdinWriteFailed(command.to_string(), e));
   194	                    }
   195	                }
   196	                // Dropping stdin here closes the pipe so the callback sees EOF.
   197	            }
   198	        } else {
   199	            // No context payload — still close the callback's stdin so reads
   200	            // (e.g. `cat`) return immediately instead of blocking.
   201	            drop(child.stdin.take());
   202	        }
   203	
   204	        let output = child
   205	            .wait_with_output()
   206	            .map_err(|e| CallbackError::SpawnFailed(command.to_string(), e))?;
   207	
   208	        let stdout = String::from_utf8_lossy(&output.stdout).into_owned();
   209	        let stderr = String::from_utf8_lossy(&output.stderr).into_owned();
   210	
   211	        if !output.status.success() {
   212	            let code = output.status.code();
   213	            let tail = stderr.trim();
   214	            let error = match (code, tail.is_empty()) {
   215	                (Some(c), true) => format!("callback crashed (exit {c})"),
   216	                (Some(c), false) => format!("callback crashed (exit {c}): {tail}"),
   217	                (None, true) => "callback terminated by signal".to_string(),
   218	                (None, false) => format!("callback terminated by signal: {tail}"),
   219	            };
   220	            return Ok(CallbackResult {
   221	                success: false,
   222	                error: Some(error),
   223	                next_state: None,
   224	                data: None,
   225	                stdout,
   226	                stderr,
   227	            });
   228	        }
   229	
   230	        Ok(parse_callback_stdout(&stdout, stderr.clone())
   231	            .unwrap_or_else(|| CallbackResult::implicit_success(stdout.clone(), stderr)))
   232	    }
   233	}
   234	
   235	/// Parse the stdout of a CLI callback as a `TransitionResult`.
   236	///
   237	/// Returns `None` when the payload is empty or not a recognizable
   238	/// `TransitionResult` JSON object, signalling to the caller that it
   239	/// should fall back to the implicit-success behavior.
   240	fn parse_callback_stdout(stdout: &str, stderr: String) -> Option<CallbackResult> {
   241	    let trimmed = stdout.trim();
   242	    if trimmed.is_empty() {
   243	        return None;
   244	    }
   245	    let value: JsonValue = serde_json::from_str(trimmed).ok()?;
   246	    let object = value.as_object()?;
   247	    let success = object.get("success")?.as_bool()?;
   248	
   249	    let error = object.get("error").and_then(|v| v.as_str()).map(str::to_string);
   250	    let next_state = object.get("nextState").and_then(|v| v.as_str()).map(str::to_string);
   251	    let data = object.get("data").cloned();
   252	
   253	    // Spec invariant: `success: false` with `nextState` is invalid and is
   254	    // downgraded to rejection. Never forward a redirect from a rejection.
   255	    let next_state = if success { next_state } else { None };
   256	    let error = if success {
   257	        error
   258	    } else {
   259	        error.or_else(|| Some("transition rejected by callback".to_string()))
   260	    };
   261	
   262	    Some(CallbackResult { success, error, next_state, data, stdout: stdout.to_string(), stderr })
   263	}
   264	
   265	/// A no-op executor that skips all callbacks (used with `--no-callbacks`).
   266	pub struct NoopCallbackExecutor;
   267	
   268	impl CallbackExecutor for NoopCallbackExecutor {
   269	    fn execute(
   270	        &self,
   271	        _callback: &CallbackRef,
   272	        _context: &CallbackContext<'_>,
   273	    ) -> Result<CallbackResult, CallbackError> {
   274	        Ok(CallbackResult {
   275	            success: true,
   276	            error: None,
   277	            next_state: None,
   278	            data: None,
   279	            stdout: String::new(),
   280	            stderr: String::new(),
   281	        })
   282	    }
   283	}
