    28	/// Result of validating a parsed plan.
    29	///
    30	/// Errors indicate invalid input. Warnings indicate accepted input with
    31	/// noteworthy conditions, such as subtasks under named task identifiers.
    32	#[derive(Debug, Default, Clone, PartialEq, Eq)]
    33	pub struct ValidationReport {
    34	    /// Validation failures that should cause command execution to fail.
    35	    pub errors: Vec<String>,
    36	    /// Non-fatal validation observations.
    37	    pub warnings: Vec<String>,
    38	}
    39	
    40	impl ValidationReport {
    41	    /// Construct an empty, successful report.
    42	    pub fn ok() -> Self {
    43	        Self { errors: Vec::new(), warnings: Vec::new() }
    44	    }
    45	
    46	    /// Returns true if any errors are present.
    47	    pub fn has_errors(&self) -> bool {
    48	        !self.errors.is_empty()
    49	    }
    50	
    51	    /// Merge another report into this one.
    52	    pub fn extend(&mut self, other: ValidationReport) {
    53	        self.errors.extend(other.errors);
    54	        self.warnings.extend(other.warnings);
    55	    }
    56	}
    57	
    58	/// Trait for validating a value into a [`ValidationReport`].
    59	///
    60	/// Implementations can be provided for values that do not require external
    61	/// context. For markdown plan validation against allowed states, prefer
    62	/// [`Validator`] or [`validate_with_machine`].
    63	pub trait Validate {
    64	    /// Validate `self` and collect any errors or warnings.
    65	    fn validate(&self) -> ValidationReport;
    66	}
    67	
    68	/// A no-op validator implementation useful for smoke tests.
    69	impl Validate for () {
    70	    fn validate(&self) -> ValidationReport {
    71	        ValidationReport::ok()
    72	    }
    73	}
