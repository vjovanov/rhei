  9034	/// Rewrite the `**State:**` line for a specific task in the raw markdown.
  9035	///
  9036	/// Locates the `### Task <id>:` header and replaces the immediately following
  9037	/// `**State:**` line with the new state value.
  9038	fn rewrite_task_state(raw: &str, task_id: &str, new_state: &str) -> MietteResult<String> {
  9039	    let lines: Vec<&str> = raw.lines().collect();
  9040	    let mut result = Vec::with_capacity(lines.len());
  9041	
  9042	    // Build the task header prefix to match.
  9043	    let task_prefix = format!("### Task {}:", task_id);
  9044	
  9045	    let mut in_target_task = false;
  9046	    let mut state_replaced = false;
  9047	
  9048	    for line in &lines {
  9049	        if !state_replaced && line.starts_with("### Task ") {
  9050	            in_target_task = line.starts_with(&task_prefix);
  9051	        }
  9052	
  9053	        if in_target_task && !state_replaced && line.starts_with("**State:**") {
  9054	            let formatted = format!("**State:** {}", format_state_metadata_value(new_state));
  9055	            result.push(formatted);
  9056	            state_replaced = true;
  9057	            continue;
  9058	        }
  9059	
  9060	        result.push(line.to_string());
  9061	    }
  9062	
  9063	    if !state_replaced {
  9064	        return Err(miette!("could not find **State:** line for Task {} in the markdown", task_id));
  9065	    }
  9066	
  9067	    // Preserve trailing newline if original had one.
  9068	    let mut output = result.join("\n");
  9069	    if raw.ends_with('\n') {
  9070	        output.push('\n');
  9071	    }
  9072	    Ok(output)
  9073	}
