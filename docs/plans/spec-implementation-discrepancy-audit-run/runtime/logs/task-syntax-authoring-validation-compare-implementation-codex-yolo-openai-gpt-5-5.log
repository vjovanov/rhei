  1006	/// Parse a workspace task file (a file inside the `tasks/` directory).
  1007	pub fn parse_workspace_tasks(input: &str) -> Result<Vec<Task>> {
  1008	    let prefix = "# Rhei: _workspace_\n\n## Tasks\n\n";
  1009	    let prefix_line_count = 4;
  1010	    let synthetic = format!("{}{}", prefix, input);
  1011	    match parse(&synthetic) {
  1012	        Ok(rhei) => Ok(rhei.tasks),
  1013	        Err(mut e) => {
  1014	            if let Some(ref mut line) = e.line {
  1015	                *line = line.saturating_sub(prefix_line_count);
  1016	                if *line == 0 {
  1017	                    *line = 1;
  1018	                }
  1019	            }
  1020	            Err(e)
  1021	        }
  1022	    }
  1023	}
  1024	
  1025	/// Unescape a state value: supports backtick wrapping only.
  1026	fn unescape_state(input: &str) -> String {
  1027	    if input.starts_with('`') && input.ends_with('`') && input.len() >= 2 {
  1028	        return input[1..input.len() - 1].to_string();
  1029	    }
  1030	    input.to_string()
  1031	}
