   237	
   238	/// Progress Report output generator for human-readable terminal summaries.
   239	#[derive(Debug, Clone, Copy)]
   240	pub struct ProgressReportOutput {
   241	    pub color: bool,
   242	    pub show_dependencies: bool,
   243	}
   244	
   245	impl ProgressReportOutput {
   246	    pub fn to_string(&self, rhei: &rhei_core::ast::Rhei) -> String {
   247	        let mut out = String::new();
   248	
   249	        out.push_str("Rhei: ");
   250	        out.push_str(&rhei.title);
   251	        out.push('\n');
   252	
   253	        for section in &rhei.content_sections {
   254	            out.push_str(&section.title);
   255	            out.push_str(":\n");
   256	            for line in section.content.lines() {
   257	                let trimmed = line.trim();
   258	                if !trimmed.is_empty() {
   259	                    out.push_str("  ");
   260	                    out.push_str(trimmed);
   261	                    out.push('\n');
   262	                }
   263	            }
   264	        }
   265	
   266	        for task in &rhei.tasks {
   267	            self.render_node(task, 0, &mut out);
   268	        }
   269	
   270	        out
   271	    }
   272	
   273	    fn render_node(&self, task: &Task, indent_level: usize, out: &mut String) {
   274	        let state_upper = task.state.trim().to_ascii_uppercase();
   275	        let badge = badge_for(&state_upper, self.color);
   276	
   277	        if indent_level == 0 {
   278	            out.push_str("* ");
   279	        } else {
   280	            for _ in 0..indent_level {
   281	                out.push_str("  ");
   282	            }
   283	            out.push_str("- ");
   284	        }
   285	
   286	        out.push_str(&title_case_kind(&task.kind));
   287	        out.push(' ');
   288	        out.push_str(&task.id.to_string());
   289	        out.push_str(": ");
   290	        out.push_str(&task.title);
   291	        out.push_str("  ");
   292	        out.push_str(&badge);
   293	        out.push('\n');
   294	
   295	        if self.show_dependencies && indent_level == 0 && !task.prior.is_empty() {
   296	            out.push_str("  - Prior: ");
   297	            out.push_str(&fmt_prior_list(&task.prior));
   298	            out.push('\n');
   299	        }
