  9476	fn reset_plan_file_states(path: &Path, initial_state: &str) -> MietteResult<()> {
  9477	    let file = fs::File::open(path)
  9478	        .map_err(|err| file_io_report(path, "failed to open plan file", err))?;
  9479	    file.lock_exclusive()
  9480	        .map_err(|err| file_io_report(path, "failed to acquire file lock", err))?;
  9481	
  9482	    let raw = fs::read_to_string(path)
  9483	        .map_err(|err| file_io_report(path, "failed to read plan file", err))?;
  9484	    let new_raw = rewrite_all_states_to_initial(&raw, initial_state)?;
  9485	    let new_raw = strip_result_links(&new_raw);
  9486	    let new_raw = match rhei_core::parse(&new_raw) {
  9487	        Ok(rhei) => {
  9488	            if let Some(metadata) = clear_runtime_state_visits(rhei.metadata.as_ref()) {
  9489	                rewrite_frontmatter(&new_raw, &metadata)?
  9490	            } else {
  9491	                new_raw
  9492	            }
  9493	        }
  9494	        Err(_) => new_raw,
  9495	    };
  9496	
  9497	    let parent = path.parent().unwrap_or(Path::new("."));
  9498	    let mut tmp = tempfile::NamedTempFile::new_in(parent)
  9499	        .map_err(|err| miette!("failed to create temp file: {err}"))?;
  9500	    tmp.write_all(new_raw.as_bytes()).map_err(|err| miette!("failed to write temp file: {err}"))?;
  9501	    tmp.persist(path).map_err(|err| miette!("failed to persist temp file: {err}"))?;
  9502	
  9503	    let _ = file.unlock();
  9504	    Ok(())
  9505	}
