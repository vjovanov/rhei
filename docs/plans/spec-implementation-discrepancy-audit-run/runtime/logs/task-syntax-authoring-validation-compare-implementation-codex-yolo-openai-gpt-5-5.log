   197	/// Pop builders from the stack until its top is at depth `< level`, attaching
   198	/// each popped builder to its parent (or to the root task list when popping
   199	/// the outermost).
   200	fn unwind_to_level(
   201	    stack: &mut Vec<NodeBuilder>,
   202	    tasks: &mut Vec<Task>,
   203	    target_level: u8,
   204	) -> Result<()> {
   205	    while let Some(top) = stack.last() {
   206	        if top.level < target_level {
   207	            break;
   208	        }
   209	        let popped = stack.pop().expect("stack was non-empty");
   210	        let finished = finalize_builder(popped)?;
   211	        if let Some(parent) = stack.last_mut() {
   212	            parent.children.push(finished);
   213	        } else {
   214	            tasks.push(finished);
   215	        }
   216	    }
   217	    Ok(())
   218	}
