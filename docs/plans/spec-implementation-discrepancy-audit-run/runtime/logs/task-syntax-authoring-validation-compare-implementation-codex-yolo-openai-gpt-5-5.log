  9543	/// Remove `> **Result:** …` lines (and a single leading blank line when
  9544	/// present) inserted by `rhei complete`. Used during `rhei reset` so the
  9545	/// plan returns to a clean authored state.
  9546	fn strip_result_links(raw: &str) -> String {
  9547	    let lines: Vec<&str> = raw.lines().collect();
  9548	    let mut result: Vec<String> = Vec::with_capacity(lines.len());
  9549	
  9550	    for line in &lines {
  9551	        let trimmed = line.trim_start();
  9552	        if trimmed.starts_with("> **Result:**") {
  9553	            // Drop a single trailing blank line accumulated before the result
  9554	            // link so we don't leave a pair of blank lines behind.
  9555	            if matches!(result.last(), Some(last) if last.trim().is_empty()) {
  9556	                result.pop();
  9557	            }
  9558	            continue;
  9559	        }
  9560	        result.push((*line).to_string());
  9561	    }
  9562	
  9563	    let mut output = result.join("\n");
  9564	    if raw.ends_with('\n') {
  9565	        output.push('\n');
  9566	    }
  9567	    output
  9568	}
