    89	impl<'a> Iterator for Tokenizer<'a> {
    90	    type Item = Token;
    91	
    92	    fn next(&mut self) -> Option<Self::Item> {
    93	        for raw in self.lines.by_ref() {
    94	            let line = raw.trim();
    95	
    96	            if Self::is_fence(raw) {
    97	                self.in_code_block = !self.in_code_block;
    98	                return Some(Token::TextContent);
    99	            }
   100	
   101	            if line.is_empty() {
   102	                continue;
   103	            }
   104	
   105	            if self.in_code_block {
   106	                return Some(Token::TextContent);
   107	            }
   108	
   109	            if self.re_rhei.is_match(line) {
   110	                return Some(Token::RheiHeader);
   111	            }
   112	
   113	            if self.re_tasks.is_match(line) {
   114	                return Some(Token::TasksSection);
   115	            }
   116	
   117	            // Section header: ## <title> (non-Tasks)
   118	            if line.starts_with("## ") && !self.re_tasks.is_match(line) {
   119	                let title = line.strip_prefix("## ").unwrap_or("").trim().to_string();
   120	                if !title.is_empty() {
   121	                    return Some(Token::SectionHeader { title });
   122	                }
   123	            }
   124	
   125	            if let Some(caps) = self.re_node_header.captures(line) {
   126	                let hashes = caps.get(1).map(|m| m.as_str()).unwrap_or("");
   127	                let level = hashes.len() as u8;
   128	                let kind = caps.get(2).map(|m| m.as_str().to_string()).unwrap_or_default();
   129	                let id_str = caps.get(3).map(|m| m.as_str()).unwrap_or("");
   130	                if let Some(id) = parse_task_id(id_str) {
   131	                    return Some(Token::NodeHeader { level, kind, id });
   132	                }
   133	                // Malformed id — fall through to text content.
   134	                return Some(Token::TextContent);
   135	            }
   136	
   137	            // Metadata: States declaration (must be checked before State)
   138	            if let Some(caps) = self.re_states.captures(line) {
   139	                let name = caps.get(1).map(|m| m.as_str().trim()).unwrap_or_default();
   140	                return Some(Token::MetadataStates { name: name.to_string() });
   141	            }
   142	
   143	            // Metadata: State (with unescaping or backtick stripping)
   144	            if let Some(caps) = self.re_state.captures(line) {
   145	                let state_raw = caps.get(1).map(|m| m.as_str().trim()).unwrap_or_default();
   146	                let state = Self::unescape_state(state_raw);
   147	                return Some(Token::MetadataState { state });
   148	            }
   149	
   150	            // Metadata: Prior
   151	            if line.starts_with("**Prior:**") {
   152	                let ids = self
   153	                    .re_prior_ref
   154	                    .captures_iter(line)
   155	                    .filter_map(|c| c.get(2))
   156	                    .filter_map(|m| parse_task_id(m.as_str()))
