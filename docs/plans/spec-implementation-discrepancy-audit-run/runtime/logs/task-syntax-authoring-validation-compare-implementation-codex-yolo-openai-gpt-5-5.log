    28	/// One segment of a hierarchical task id.
    29	///
    30	/// Ids use dotted paths such as `1.2` or `api.cache.fix`. Each segment is
    31	/// either numeric (`NUMBER`) or named (`IDENTIFIER`) per the grammar.
    32	#[derive(Debug, Clone, PartialEq, Eq, Hash)]
    33	pub enum TaskIdSegment {
    34	    Number(u32),
    35	    Named(String),
    36	}
    37	
    38	impl fmt::Display for TaskIdSegment {
    39	    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
    40	        match self {
    41	            TaskIdSegment::Number(n) => write!(f, "{n}"),
    42	            TaskIdSegment::Named(s) => write!(f, "{s}"),
    43	        }
    44	    }
    45	}
    46	
    47	/// Hierarchical task identifier.
    48	///
    49	/// Root tasks have a single segment (`1`, `api`). Child tasks append one
    50	/// segment per level of nesting (`1.2`, `api.cache.fix`).
    51	#[derive(Debug, Clone, PartialEq, Eq, Hash)]
    52	pub struct TaskId {
    53	    pub segments: Vec<TaskIdSegment>,
    54	}
    55	
    56	impl TaskId {
    57	    /// Build an id from an explicit list of segments. At least one segment
    58	    /// must be present; callers are responsible for that invariant.
    59	    pub fn from_segments(segments: Vec<TaskIdSegment>) -> Self {
    60	        Self { segments }
    61	    }
    62	
    63	    /// Build a single-segment numeric id (`1`, `42`).
    64	    pub fn number(n: u32) -> Self {
    65	        Self { segments: vec![TaskIdSegment::Number(n)] }
    66	    }
    67	
    68	    /// Build a single-segment named id (`api`, `fix-cache`).
    69	    pub fn named<S: Into<String>>(s: S) -> Self {
    70	        Self { segments: vec![TaskIdSegment::Named(s.into())] }
    71	    }
    72	
    73	    /// Depth of the id path (number of segments). Always `>= 1` for
    74	    /// well-formed ids.
    75	    pub fn depth(&self) -> usize {
    76	        self.segments.len()
    77	    }
    78	
    79	    /// Whether this id is a proper extension of `other` by exactly one
    80	    /// segment.
    81	    pub fn extends(&self, other: &TaskId) -> bool {
    82	        self.segments.len() == other.segments.len() + 1
    83	            && self.segments[..other.segments.len()] == other.segments[..]
    84	    }
    85	
    86	    /// The parent id, if any (strips the trailing segment).
    87	    pub fn parent(&self) -> Option<TaskId> {
    88	        if self.segments.len() <= 1 {
    89	            return None;
    90	        }
    91	        Some(Self { segments: self.segments[..self.segments.len() - 1].to_vec() })
    92	    }
    93	
    94	    /// Extract the single segment of a top-level id, if any.
    95	    pub fn as_single(&self) -> Option<&TaskIdSegment> {
    96	        if self.segments.len() == 1 {
    97	            Some(&self.segments[0])
    98	        } else {
    99	            None
   100	        }
   101	    }
   102	
   103	    /// Return the numeric value if this id has a single numeric segment.
   104	    pub fn as_number(&self) -> Option<u32> {
   105	        match self.as_single() {
   106	            Some(TaskIdSegment::Number(n)) => Some(*n),
   107	            _ => None,
   108	        }
   109	    }
   110	
   111	    /// Return the named value if this id has a single named segment.
   112	    pub fn as_named(&self) -> Option<&str> {
   113	        match self.as_single() {
   114	            Some(TaskIdSegment::Named(s)) => Some(s.as_str()),
   115	            _ => None,
   116	        }
   117	    }
   118	}
   119	
   120	impl fmt::Display for TaskId {
   121	    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
   122	        for (i, seg) in self.segments.iter().enumerate() {
   123	            if i > 0 {
   124	                f.write_str(".")?;
   125	            }
   126	            seg.fmt(f)?;
   127	        }
   128	        Ok(())
   129	    }
   130	}
   131	
   132	impl From<u32> for TaskId {
   133	    fn from(value: u32) -> Self {
   134	        TaskId::number(value)
   135	    }
   136	}
   137	
   138	impl From<&str> for TaskId {
   139	    fn from(value: &str) -> Self {
   140	        TaskId::named(value)
   141	    }
   142	}
   143	
   144	impl From<String> for TaskId {
   145	    fn from(value: String) -> Self {
   146	        TaskId::named(value)
   147	    }
   148	}
