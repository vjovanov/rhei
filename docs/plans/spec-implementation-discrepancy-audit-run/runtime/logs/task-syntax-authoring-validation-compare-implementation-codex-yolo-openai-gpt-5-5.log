  1843	fn title_case_kind(kind: &str) -> String {
  1844	    let mut out = String::with_capacity(kind.len());
  1845	    let mut chars = kind.chars();
  1846	    if let Some(first) = chars.next() {
  1847	        for c in first.to_uppercase() {
  1848	            out.push(c);
  1849	        }
  1850	    }
  1851	    for c in chars {
  1852	        out.push(c);
  1853	    }
  1854	    out
  1855	}
