     1	use crate::ast::{TaskId, TaskIdSegment};
     2	
     3	/// Parse a single id segment (numeric or named).
     4	pub(crate) fn parse_task_id_segment(input: &str) -> TaskIdSegment {
     5	    if let Ok(n) = input.parse::<u32>() {
     6	        TaskIdSegment::Number(n)
     7	    } else {
     8	        TaskIdSegment::Named(input.to_string())
     9	    }
    10	}
    11	
    12	/// Parse a dotted task id (`1`, `1.2`, `api.cache.fix`) into a `TaskId`.
    13	///
    14	/// Returns `None` if the input is empty. Empty segments (e.g. `"1..2"`) are
    15	/// rejected as malformed.
    16	pub(crate) fn parse_task_id(input: &str) -> Option<TaskId> {
    17	    if input.is_empty() {
    18	        return None;
    19	    }
    20	    let mut segments = Vec::new();
    21	    for part in input.split('.') {
    22	        if part.is_empty() {
    23	            return None;
    24	        }
    25	        segments.push(parse_task_id_segment(part));
    26	    }
    27	    Some(TaskId::from_segments(segments))
    28	}

