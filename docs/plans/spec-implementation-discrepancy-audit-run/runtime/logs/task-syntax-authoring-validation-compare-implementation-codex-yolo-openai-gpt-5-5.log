    20	/// Parser error with a message and an optional line number.
    21	#[derive(Debug, Clone, PartialEq, Eq)]
    22	pub struct ParseError {
    23	    pub message: String,
    24	    pub line: Option<usize>,
    25	}
    26	
    27	impl ParseError {
    28	    pub fn new<M: Into<String>>(msg: M, line: Option<usize>) -> Self {
    29	        Self { message: msg.into(), line }
    30	    }
    31	}
    32	
    33	pub type Result<T> = std::result::Result<T, ParseError>;
    34	
    35	/// Extract the plan-level `structure` block from parsed frontmatter metadata.
    36	///
    37	/// Returns the default `Structure` when the block is absent. Validates shape
    38	/// (types, ranges, uniqueness) and reports parse errors inline.
    39	fn parse_structure(metadata: Option<&Metadata>, start_line: usize) -> Result<Structure> {
    40	    let Some(metadata) = metadata else {
    41	        return Ok(Structure::default());
    42	    };
    43	    let structure_key = YamlValue::String("structure".to_string());
    44	    let Some(block) = metadata.get(&structure_key) else {
    45	        return Ok(Structure::default());
    46	    };
    47	    let mapping = block.as_mapping().ok_or_else(|| {
    48	        ParseError::new("plan frontmatter `structure` must be a mapping", Some(start_line))
    49	    })?;
    50	
    51	    let mut max_levels: u8 = DEFAULT_MAX_LEVELS;
    52	    if let Some(v) = mapping.get(YamlValue::String("maxLevels".to_string())) {
    53	        let n = v.as_u64().ok_or_else(|| {
    54	            ParseError::new(
    55	                "plan frontmatter `structure.maxLevels` must be a positive integer",
    56	                Some(start_line),
    57	            )
    58	        })?;
    59	        if n == 0 || n > MAX_ALLOWED_LEVELS as u64 {
    60	            return Err(ParseError::new(
    61	                format!(
    62	                    "plan frontmatter `structure.maxLevels` must be in 1..={}",
    63	                    MAX_ALLOWED_LEVELS
    64	                ),
    65	                Some(start_line),
    66	            ));
    67	        }
    68	        max_levels = n as u8;
    69	    }
    70	
    71	    let mut node_kinds: Vec<String> = vec![DEFAULT_NODE_KIND.to_string()];
    72	    if let Some(v) = mapping.get(YamlValue::String("nodeKinds".to_string())) {
    73	        let seq = v.as_sequence().ok_or_else(|| {
    74	            ParseError::new(
    75	                "plan frontmatter `structure.nodeKinds` must be a sequence of strings",
    76	                Some(start_line),
    77	            )
    78	        })?;
    79	        if seq.is_empty() {
    80	            return Err(ParseError::new(
    81	                "plan frontmatter `structure.nodeKinds` must not be empty",
    82	                Some(start_line),
    83	            ));
    84	        }
    85	        let mut out = Vec::with_capacity(seq.len());
    86	        for entry in seq {
    87	            let name = entry.as_str().ok_or_else(|| {
    88	                ParseError::new(
    89	                    "plan frontmatter `structure.nodeKinds` entries must be strings",
    90	                    Some(start_line),
    91	                )
    92	            })?;
    93	            let canonical = name.trim().to_ascii_lowercase();
    94	            if canonical.is_empty() {
    95	                return Err(ParseError::new(
    96	                    "plan frontmatter `structure.nodeKinds` entries must be non-empty",
    97	                    Some(start_line),
    98	                ));
    99	            }
   100	            if canonical == "rhei" {
   101	                return Err(ParseError::new(
   102	                    "`rhei` is a reserved node kind and must not appear in `structure.nodeKinds`",
   103	                    Some(start_line),
   104	                ));
   105	            }
   106	            if out.iter().any(|k: &String| k == &canonical) {
   107	                return Err(ParseError::new(
   108	                    format!(
   109	                        "plan frontmatter `structure.nodeKinds` contains duplicate entry `{canonical}`"
   110	                    ),
   111	                    Some(start_line),
   112	                ));
   113	            }
   114	            out.push(canonical);
   115	        }
   116	        node_kinds = out;
   117	    }
   118	
   119	    Ok(Structure { max_levels, node_kinds })
   120	}
   121	
   122	fn parse_frontmatter(lines: &[String], start_line: usize, kind: &str) -> Result<Metadata> {
   123	    if lines.is_empty() || lines.iter().all(|line| line.trim().is_empty()) {
   124	        return Ok(Metadata::new());
   125	    }
   126	
   127	    let yaml = lines.join("\n");
   128	    let value: YamlValue = serde_yaml::from_str(&yaml).map_err(|err| {
   129	        ParseError::new(format!("failed to parse {kind} YAML frontmatter: {err}"), Some(start_line))
   130	    })?;
   131	
   132	    match value {
   133	        YamlValue::Mapping(mapping) => Ok(mapping),
   134	        _ => Err(ParseError::new(
   135	            format!("{kind} YAML frontmatter must be a mapping"),
   136	            Some(start_line),
   137	        )),
   138	    }
   139	}
