  9615	/// Find a terminal (non-cancelled) state reachable in one transition.
  9616	///
  9617	/// Prefers exact `from` matches over wildcards. Cancellation is not considered
  9618	/// a completion target for `rhei complete`.
  9619	fn find_completion_state(
  9620	    current_state: &str,
  9621	    machine: &rhei_validator::StateMachine,
  9622	) -> Option<String> {
  9623	    // Exact from-state matches first.
  9624	    for rule in machine.transitions() {
  9625	        if rule.from.0 == current_state {
  9626	            let is_terminal =
  9627	                machine.states.get(&rule.to.0).map(|def| def.terminal).unwrap_or(false);
  9628	            if is_terminal && rule.to.0 != "cancelled" {
  9629	                return Some(rule.to.0.clone());
  9630	            }
  9631	        }
  9632	    }
  9633	
  9634	    // Fall back to wildcard transitions.
  9635	    for rule in machine.transitions() {
  9636	        if rule.from.0 == "*" {
  9637	            let is_terminal =
  9638	                machine.states.get(&rule.to.0).map(|def| def.terminal).unwrap_or(false);
  9639	            if is_terminal && rule.to.0 != "cancelled" {
  9640	                return Some(rule.to.0.clone());
  9641	            }
  9642	        }
  9643	    }
  9644	
  9645	    None
  9646	}
  9647	
  9648	fn non_terminal_descendants(
  9649	    task: &rhei_core::ast::Task,
  9650	    machine: &rhei_validator::StateMachine,
  9651	) -> Vec<String> {
  9652	    fn recurse(
  9653	        task: &rhei_core::ast::Task,
  9654	        machine: &rhei_validator::StateMachine,
  9655	        out: &mut Vec<String>,
  9656	    ) {
  9657	        for child in &task.children {
  9658	            if !is_terminal_state(child.state.as_str(), machine) {
  9659	                out.push(format!(
  9660	                    "{} {} ('{}') [{}]",
  9661	                    title_case_kind(&child.kind),
  9662	                    child.id,
  9663	                    child.title,
  9664	                    child.state
  9665	                ));
  9666	            }
  9667	            recurse(child, machine, out);
  9668	        }
  9669	    }
  9670	    let mut out = Vec::new();
  9671	    recurse(task, machine, &mut out);
  9672	    out
  9673	}
  9674	
  9675	fn title_case_kind(kind: &str) -> String {
  9676	    let mut out = String::with_capacity(kind.len());
  9677	    let mut chars = kind.chars();
  9678	    if let Some(first) = chars.next() {
  9679	        for c in first.to_uppercase() {
  9680	            out.push(c);
  9681	        }
  9682	    }
  9683	    for c in chars {
  9684	        out.push(c);
  9685	    }
  9686	    out
  9687	}
