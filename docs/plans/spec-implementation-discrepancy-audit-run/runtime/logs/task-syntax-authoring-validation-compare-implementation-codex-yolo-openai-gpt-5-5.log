  8713	/// Find tasks that are ready to be claimed by `rhei next` in automatic mode.
  8714	///
  8715	/// A task is claimable when it is in the state machine's initial state, its
  8716	/// prerequisites are satisfied, and it has no `**Assignee:**` field (which
  8717	/// indicates it is already claimed by another agent). Already-claimed work
  8718	/// can still be inspected explicitly with `rhei next --task <id>`.
  8719	fn find_claimable_tasks<'a>(
  8720	    rhei: &'a rhei_core::ast::Rhei,
  8721	    machine: &rhei_validator::StateMachine,
  8722	) -> Vec<&'a rhei_core::ast::Task> {
  8723	    find_ready_tasks(rhei, machine)
  8724	        .into_iter()
  8725	        .filter(|task| task.assignee.is_none())
  8726	        .filter(|task| {
  8727	            let state = normalized_state_name(task.state.as_str(), machine);
  8728	            machine.states.get(&state).map(|def| def.initial).unwrap_or(false)
  8729	        })
  8730	        .collect()
  8731	}
