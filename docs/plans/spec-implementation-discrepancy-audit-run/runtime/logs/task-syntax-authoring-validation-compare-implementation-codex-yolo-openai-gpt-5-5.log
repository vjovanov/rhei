   141	/// In-progress builder for a node. The stack holds one builder per open
   142	/// heading level; the innermost builder is the current parse target.
   143	struct NodeBuilder {
   144	    id: TaskId,
   145	    kind: String,
   146	    title: String,
   147	    level: u8,
   148	    state: Option<String>,
   149	    prior: Vec<TaskId>,
   150	    assignee: Option<String>,
   151	    content: String,
   152	    children: Vec<Task>,
   153	    /// Once non-metadata content appears, further metadata fields become
   154	    /// errors.
   155	    metadata_closed: bool,
   156	    /// Line number of the heading (for error reporting).
   157	    heading_line: usize,
   158	}
   159	
   160	fn finalize_builder(b: NodeBuilder) -> Result<Task> {
   161	    let state = b.state.ok_or_else(|| {
   162	        ParseError::new(
   163	            format!(
   164	                "{} {} is missing mandatory **State:** metadata",
   165	                title_case_kind(&b.kind),
   166	                b.id
   167	            ),
   168	            Some(b.heading_line),
   169	        )
   170	    })?;
   171	    Ok(Task {
   172	        id: b.id,
   173	        kind: b.kind,
   174	        title: b.title,
   175	        state,
   176	        prior: b.prior,
   177	        assignee: b.assignee,
   178	        content: b.content,
   179	        children: b.children,
   180	    })
   181	}
   182	
   183	fn title_case_kind(kind: &str) -> String {
   184	    let mut out = String::with_capacity(kind.len());
   185	    let mut chars = kind.chars();
   186	    if let Some(first) = chars.next() {
   187	        for c in first.to_uppercase() {
   188	            out.push(c);
   189	        }
   190	    }
   191	    for c in chars {
   192	        out.push(c);
   193	    }
   194	    out
   195	}
