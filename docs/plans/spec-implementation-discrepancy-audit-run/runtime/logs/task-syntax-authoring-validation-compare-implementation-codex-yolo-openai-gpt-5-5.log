   220	/// Parse a markdown plan, returning the successfully parsed [`Rhei`] (if any)
   221	/// together with every recoverable error discovered along the way.
   222	///
   223	/// Recoverable errors are per-task issues like a missing `**State:**` line,
   224	/// a malformed metadata field, or an out-of-order `**Prior:**`/`**Assignee:**`.
   225	/// When one is seen the offending line (or the containing task block) is
   226	/// stripped from the input and parsing is retried. Fatal structural errors
   227	/// (missing `# Rhei:` header, unterminated YAML frontmatter, missing
   228	/// `## Tasks` section, circular parent/child references) still bail — but
   229	/// come back through the same return channel so callers can enumerate the
   230	/// full list.
   231	///
   232	/// The single-error [`parse`] wrapper still exists for callers that only
   233	/// care about the first problem.
   234	pub fn parse_collect(input: &str) -> (Option<Rhei>, Vec<ParseError>) {
   235	    let mut errors: Vec<ParseError> = Vec::new();
   236	    let mut working = input.to_string();
   237	
   238	    // Safety valve in case a recovery step fails to make progress: cap
   239	    // iterations at a generous multiple of the authored line count.
   240	    let max_iters = input.lines().count().saturating_mul(2).max(16);
   241	
   242	    for _ in 0..max_iters {
   243	        match parse(&working) {
   244	            Ok(rhei) => return (Some(rhei), errors),
   245	            Err(err) => {
   246	                // Only recover from well-understood per-task errors. For
   247	                // structural issues (missing header, unknown node kind,
   248	                // depth mismatches) stop immediately — continuing would
   249	                // produce cascading, misleading error lists.
   250	                let recoverable = is_recoverable_error(&err.message);
   251	                let Some(line) = err.line.filter(|_| recoverable) else {
   252	                    errors.push(err);
   253	                    return (None, errors);
   254	                };
   255	                let (stripped, made_progress) = strip_for_recovery(&working, line, &err.message);
   256	                errors.push(err);
   257	                if !made_progress {
   258	                    return (None, errors);
   259	                }
   260	                working = stripped;
   261	            }
   262	        }
   263	    }
   264	
   265	    (None, errors)
   266	}
   267	
   268	/// Return true when an error is safe to skip past and continue parsing.
   269	///
   270	/// Safe-to-recover errors are strictly local to a task or a single
   271	/// metadata line. Structural errors (missing plan header, mismatched
   272	/// heading depth, tasks out of order) cascade and produce misleading
   273	/// secondary errors when we try to strip them.
   274	fn is_recoverable_error(message: &str) -> bool {
   275	    const RECOVERABLE_MARKERS: &[&str] = &[
   276	        "missing mandatory **State:**",
   277	        "Malformed metadata field",
   278	        "Metadata field appears outside a task",
   279	        "Metadata fields must appear immediately",
   280	        "**State:** must appear before **Prior:**",
   281	        "**State:** must appear before **Assignee:**",
   282	        "Duplicate **Assignee:**",
   283	    ];
   284	    RECOVERABLE_MARKERS.iter().any(|m| message.contains(m))
   285	}
   286	
   287	/// Rewrite the plan source so the next `parse()` attempt skips past the
   288	/// offending line or task. Returns the new source plus a flag that is
   289	/// `false` when recovery is not possible (the caller should stop).
   290	///
   291	/// Recovery refuses to strip anything that would leave the plan with no
   292	/// tasks at all, since doing so would cascade into "Tasks section must
   293	/// contain at least one task" — an artifact of the recovery, not a real
   294	/// authoring mistake.
   295	fn strip_for_recovery(input: &str, line: usize, message: &str) -> (String, bool) {
   296	    if line == 0 {
   297	        return (input.to_string(), false);
   298	    }
   299	
   300	    // Patterns that indicate the whole surrounding task is unrecoverable and
   301	    // should be dropped. Each task is `### Task <id>: ...` through the next
   302	    // H3..=H6 heading (exclusive).
   303	    //
   304	    // Dropping only the `**State:**` line creates a cascading "missing
   305	    // mandatory **State:**" error on the next pass for the same task, which
   306	    // is spurious from the user's point of view. Treat state-related
   307	    // malformed metadata as a whole-task issue.
   308	    let whole_task_markers =
   309	        ["missing mandatory **State:**", "malformed node heading", "expected '**State:** <value>'"];
   310	    let drop_whole_task = whole_task_markers.iter().any(|m| message.contains(m));
   311	
   312	    let lines: Vec<&str> = input.lines().collect();
   313	    if line > lines.len() {
   314	        return (input.to_string(), false);
   315	    }
   316	
   317	    let idx = line - 1;
   318	    let heading_re = regex::Regex::new(r#"^#{3,6}\s+[A-Za-z][A-Za-z0-9_-]*\s+"#).expect("regex");
