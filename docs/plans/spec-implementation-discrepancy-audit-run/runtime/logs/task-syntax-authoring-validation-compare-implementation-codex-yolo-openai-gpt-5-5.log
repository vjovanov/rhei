  4357	fn find_task_by_id<'a>(
  4358	    tasks: &'a [rhei_core::ast::Task],
  4359	    target: &TaskId,
  4360	) -> Option<&'a rhei_core::ast::Task> {
  4361	    for task in tasks {
  4362	        if &task.id == target {
  4363	            return Some(task);
  4364	        }
  4365	        if let Some(found) = find_task_by_id(&task.children, target) {
  4366	            return Some(found);
  4367	        }
  4368	    }
  4369	    None
  4370	}
