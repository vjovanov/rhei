  4305	fn task_metadata_json(
  4306	    plan: Option<&rhei_core::ast::Rhei>,
  4307	    task_id_str: &str,
  4308	    state: &str,
  4309	) -> serde_json::Value {
  4310	    use serde_json::{Map, Value};
  4311	
  4312	    let mut out = Map::new();
  4313	    out.insert("state".to_string(), Value::String(state.to_string()));
  4314	
  4315	    let target = parse_task_id(task_id_str);
  4316	    let task = plan.and_then(|rhei| find_task_by_id(&rhei.tasks, &target));
  4317	    if let Some(task) = task {
  4318	        out.insert(
  4319	            "dependsOn".to_string(),
  4320	            Value::Array(task.prior.iter().map(|id| Value::String(id.to_string())).collect()),
  4321	        );
  4322	    } else {
  4323	        out.insert("dependsOn".to_string(), Value::Array(Vec::new()));
  4324	    }
  4325	
  4326	    // Merge frontmatter task metadata (`metadata.tasks.<id>`) if present.
  4327	    if let Some(rhei) = plan {
  4328	        if let Some(task_meta) = task_metadata_map(rhei.metadata.as_ref(), &target) {
  4329	            for (key, value) in task_meta {
  4330	                let Some(key_str) = key.as_str() else { continue };
  4331	                // Don't clobber canonical fields.
  4332	                if key_str == "state" || key_str == "dependsOn" {
  4333	                    continue;
  4334	                }
  4335	                if let Ok(json_value) = yaml_value_to_json(value) {
  4336	                    out.insert(key_str.to_string(), json_value);
  4337	                }
  4338	            }
  4339	        }
  4340	    }
  4341	
  4342	    Value::Object(out)
  4343	}
