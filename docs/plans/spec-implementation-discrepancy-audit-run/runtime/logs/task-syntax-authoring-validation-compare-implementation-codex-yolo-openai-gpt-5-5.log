   865	/// Parse a workspace index file (`index.rhei.md`).
   866	pub fn parse_workspace_index(input: &str) -> Result<WorkspaceIndex> {
   867	    let re_rhei = Regex::new(r#"^#\s+Rhei:\s+(.*)$"#).unwrap();
   868	    let re_states_decl = Regex::new(r#"^\*\*States:\*\*\s+(.+)$"#).unwrap();
   869	    let re_tasks = Regex::new(r#"^##\s+Tasks\s*$"#).unwrap();
   870	    let re_section_header = Regex::new(r#"^##\s+(.+)$"#).unwrap();
   871	
   872	    let mut title: Option<String> = None;
   873	    let mut states: Option<String> = None;
   874	    let mut states_checked = false;
   875	    let mut metadata: Option<Metadata> = None;
   876	    let mut structure: Structure = Structure::default();
   877	    let mut frontmatter_checked = false;
   878	    let mut in_frontmatter = false;
   879	    let mut frontmatter_start_line = 0usize;
   880	    let mut frontmatter_lines: Vec<String> = Vec::new();
   881	    let mut header_seen = false;
   882	    let mut content: Vec<ContentSection> = Vec::new();
   883	    let mut in_code_block = false;
   884	
   885	    for (idx, raw) in input.lines().enumerate() {
   886	        let line_number = idx + 1;
   887	        let line = raw.trim();
   888	
   889	        if in_frontmatter {
   890	            if line == "---" {
   891	                let parsed = parse_frontmatter(
   892	                    &frontmatter_lines,
   893	                    frontmatter_start_line,
   894	                    "workspace index",
   895	                )?;
   896	                structure = parse_structure(Some(&parsed), frontmatter_start_line)?;
   897	                metadata = Some(parsed);
   898	                in_frontmatter = false;
   899	                continue;
   900	            }
   901	            frontmatter_lines.push(raw.to_string());
   902	            continue;
   903	        }
   904	
   905	        let trimmed_start = raw.trim_start();
   906	        if trimmed_start.starts_with("```") {
   907	            in_code_block = !in_code_block;
   908	            if let Some(ContentSection { content: ref mut c, .. }) = content.last_mut() {
   909	                if !c.is_empty() {
   910	                    c.push('\n');
   911	                }
   912	                c.push_str(raw);
   913	            }
   914	            continue;
   915	        }
   916	
   917	        if in_code_block {
   918	            if let Some(ContentSection { content: ref mut c, .. }) = content.last_mut() {
   919	                if !c.is_empty() {
   920	                    c.push('\n');
   921	                }
   922	                c.push_str(raw);
   923	            }
   924	            continue;
   925	        }
   926	
   927	        if line.is_empty() {
   928	            continue;
   929	        }
   930	
   931	        if !header_seen {
   932	            if let Some(cap) = re_rhei.captures(line) {
   933	                title = Some(cap.get(1).unwrap().as_str().to_string());
   934	                header_seen = true;
   935	                continue;
   936	            }
   937	            let is_h1 = line.starts_with('#') && !line.starts_with("##");
   938	            if is_h1 {
   939	                return Err(ParseError::new(
   940	                    "Malformed rhei heading: expected '# Rhei: <title>'",
   941	                    Some(line_number),
   942	                ));
   943	            }
   944	            continue;
   945	        }
   946	
   947	        if !states_checked {
   948	            if let Some(cap) = re_states_decl.captures(line) {
   949	                states = Some(cap.get(1).unwrap().as_str().trim().to_string());
   950	                states_checked = true;
   951	                continue;
   952	            }
   953	            states_checked = true;
   954	        }
   955	
   956	        if states_checked && !frontmatter_checked {
   957	            if line == "---" {
   958	                in_frontmatter = true;
   959	                frontmatter_checked = true;
   960	                frontmatter_start_line = line_number + 1;
   961	                frontmatter_lines.clear();
   962	                continue;
   963	            }
   964	            frontmatter_checked = true;
   965	        }
   966	
   967	        if re_tasks.is_match(line) {
   968	            return Err(ParseError::new(
   969	                "Workspace index file must not contain a '## Tasks' section; tasks belong in the tasks/ directory",
   970	                Some(line_number),
   971	            ));
   972	        }
   973	
   974	        if let Some(cap) = re_section_header.captures(line) {
   975	            let section_title = cap.get(1).unwrap().as_str().trim().to_string();
   976	            content.push(ContentSection { title: section_title, content: String::new() });
   977	            continue;
   978	        }
   979	
   980	        if let Some(ContentSection { content: ref mut c, .. }) = content.last_mut() {
   981	            if !c.is_empty() {
   982	                c.push('\n');
   983	            }
   984	            c.push_str(raw);
   985	        }
   986	    }
   987	
   988	    if in_frontmatter {
   989	        return Err(ParseError::new(
   990	            "Unterminated YAML frontmatter: missing closing '---'",
   991	            Some(frontmatter_start_line.saturating_sub(1).max(1)),
   992	        ));
   993	    }
   994	
   995	    let title = title.ok_or_else(|| ParseError::new("Missing '# Rhei: <title>' header", None))?;
   996	
   997	    Ok(WorkspaceIndex {
   998	        title,
   999	        states: states.unwrap_or_else(|| "rhei".to_string()),
  1000	        structure,
  1001	        metadata,
  1002	        content_sections: content,
  1003	    })
  1004	}
