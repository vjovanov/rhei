     1	//! Line-oriented tokenizer producing a stream of tokens from markdown input.
     2	//!
     3	//! The tokenizer emits `NodeHeader` tokens for every H3..=H6 heading that
     4	//! matches the `<kind> <id>: <title>` shape, plus section, state, and prior
     5	//! metadata tokens.
     6	
     7	use crate::ast::TaskId;
     8	use crate::text::parse_task_id;
     9	use crate::tokens::Token;
    10	use regex::Regex;
    11	
    12	/// Streaming tokenizer over markdown input.
    13	pub struct Tokenizer<'a> {
    14	    lines: std::str::Lines<'a>,
    15	
    16	    re_rhei: Regex,
    17	    re_tasks: Regex,
    18	    re_node_header: Regex,
    19	    re_prior_ref: Regex,
    20	    re_states: Regex,
    21	    re_state: Regex,
    22	    re_assignee: Regex,
    23	
    24	    in_code_block: bool,
    25	}
    26	
    27	impl<'a> Tokenizer<'a> {
    28	    /// Construct a new tokenizer over the provided input.
    29	    pub fn new(input: &'a str) -> Self {
    30	        let re_rhei = Regex::new(r#"^#\s+Rhei:\s+.*$"#).unwrap();
    31	        let re_tasks = Regex::new(r#"^##\s+Tasks\s*$"#).unwrap();
    32	
    33	        // Node headers at H3..=H6: `### Task 1: Title`, `#### Bug 1.1: Title`.
    34	        // Captures: 1=hashes, 2=kind, 3=id (dotted path of NUMBER|IDENTIFIER
    35	        // segments), 4=title. Each id segment is either all digits or starts
    36	        // with a letter, matching the grammar.
    37	        let re_node_header = Regex::new(
    38	            r#"^(#{3,6})\s+([A-Za-z][A-Za-z0-9_-]*)\s+((?:[A-Za-z][A-Za-z0-9_-]*|[0-9]+)(?:\.(?:[A-Za-z][A-Za-z0-9_-]*|[0-9]+))*):\s+(.*)$"#,
    39	        )
    40	        .unwrap();
    41	
    42	        // For "**Prior:** Task 1, Bug 1.2, Task api.cache" — captures kind + id pairs.
    43	        let re_prior_ref = Regex::new(
    44	            r#"([A-Za-z][A-Za-z0-9_-]*)\s+((?:[A-Za-z][A-Za-z0-9_-]*|[0-9]+)(?:\.(?:[A-Za-z][A-Za-z0-9_-]*|[0-9]+))*)"#,
    45	        )
    46	        .unwrap();
    47	
    48	        // For "**States:** name" (must be checked before re_state)
    49	        let re_states = Regex::new(r#"^\*\*States:\*\*\s+(.+)$"#).unwrap();
    50	
    51	        // For "**State:** value"
    52	        let re_state = Regex::new(r#"^\*\*State:\*\*\s*(.+)$"#).unwrap();
    53	
    54	        // For "**Assignee:** value"
    55	        let re_assignee = Regex::new(r#"^\*\*Assignee:\*\*\s*(.+)$"#).unwrap();
    56	
    57	        Self {
    58	            lines: input.lines(),
    59	            re_rhei,
    60	            re_tasks,
    61	            re_node_header,
    62	            re_prior_ref,
    63	            re_states,
    64	            re_state,
    65	            re_assignee,
    66	            in_code_block: false,
    67	        }
    68	    }
    69	
    70	    /// Unescape a state value: supports backtick wrapping only.
    71	    fn unescape_state(input: &str) -> String {
    72	        if input.starts_with('`') && input.ends_with('`') && input.len() >= 2 {
    73	            return input[1..input.len() - 1].to_string();
    74	        }
    75	        input.to_string()
    76	    }
    77	
    78	    fn is_fence(line: &str) -> bool {
    79	        let trimmed = line.trim_start();
    80	        trimmed.starts_with("```")
    81	    }
    82	}
