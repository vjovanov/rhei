  9698	/// Append a state-transition entry to `runtime/results/<task-id>.md`.
  9699	///
  9700	/// Each entry is a markdown heading (`## from → to`) optionally followed by
  9701	/// a message body.  The file is created (with directories) on the first call.
  9702	fn append_result_entry(
  9703	    workspace_root: &Path,
  9704	    task_id: &str,
  9705	    from: &str,
  9706	    to: &str,
  9707	    message: Option<&str>,
  9708	) -> MietteResult<()> {
  9709	    let results_dir = workspace_root.join("runtime").join("results");
  9710	    fs::create_dir_all(&results_dir)
  9711	        .map_err(|err| miette!("failed to create runtime/results directory: {err}"))?;
  9712	    let result_file = results_dir.join(format!("{}.md", task_id));
  9713	
  9714	    use std::fs::OpenOptions;
  9715	    let mut file = OpenOptions::new()
  9716	        .create(true)
  9717	        .append(true)
  9718	        .open(&result_file)
  9719	        .map_err(|err| miette!("failed to open result file: {err}"))?;
  9720	
  9721	    writeln!(file, "## {} \u{2192} {}", from, to)
  9722	        .map_err(|err| miette!("failed to write result entry: {err}"))?;
  9723	    if let Some(msg) = message {
  9724	        writeln!(file).map_err(|err| miette!("failed to write result entry: {err}"))?;
  9725	        writeln!(file, "{}", msg).map_err(|err| miette!("failed to write result entry: {err}"))?;
  9726	    }
  9727	    writeln!(file).map_err(|err| miette!("failed to write result entry: {err}"))?;
  9728	
  9729	    Ok(())
  9730	}
