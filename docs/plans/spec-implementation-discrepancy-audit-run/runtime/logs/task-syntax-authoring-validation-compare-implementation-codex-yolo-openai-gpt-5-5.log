   323	            // Stripping would empty the Tasks section, which cascades into
   324	            // secondary errors. Bail instead.
   325	            return (input.to_string(), false);
   326	        }
   327	
   328	        // Walk backwards to find the task heading that owns this line.
   329	        let mut start = idx;
   330	        loop {
   331	            if heading_re.is_match(lines[start]) {
   332	                break;
   333	            }
   334	            if start == 0 {
   335	                return (input.to_string(), false);
   336	            }
   337	            start -= 1;
   338	        }
   339	        let mut end = start + 1;
   340	        while end < lines.len() && !heading_re.is_match(lines[end]) {
   341	            end += 1;
   342	        }
   343	        if start == 0 && end == lines.len() {
   344	            return (input.to_string(), false);
   345	        }
   346	        let mut kept: Vec<&str> = Vec::with_capacity(lines.len());
   347	        kept.extend_from_slice(&lines[..start]);
   348	        kept.extend_from_slice(&lines[end..]);
   349	        let mut out = kept.join("\n");
   350	        if input.ends_with('\n') {
   351	            out.push('\n');
   352	        }
   353	        return (out, true);
   354	    }
   355	
   356	    // Default recovery: drop just the offending line.
   357	    let mut kept: Vec<&str> = Vec::with_capacity(lines.len().saturating_sub(1));
