    66	
    67	fn id_segment_json(seg: &TaskIdSegment) -> Value {
    68	    match seg {
    69	        TaskIdSegment::Number(n) => json!({ "number": n }),
    70	        TaskIdSegment::Named(s) => json!({ "named": s }),
    71	    }
    72	}
    73	
    74	fn task_id_json(id: &TaskId) -> Value {
    75	    let segments: Vec<Value> = id.segments.iter().map(id_segment_json).collect();
    76	    json!({
    77	        "path": id.to_string(),
    78	        "segments": segments,
    79	    })
    80	}
    81	
    82	fn task_json(t: &Task) -> Value {
    83	    let prior = t.prior.iter().map(task_id_json).collect::<Vec<Value>>();
    84	    let children = t.children.iter().map(task_json).collect::<Vec<Value>>();
    85	
    86	    let mut obj = Map::new();
    87	    obj.insert("id".to_string(), task_id_json(&t.id));
    88	    obj.insert("kind".to_string(), Value::String(t.kind.clone()));
    89	    obj.insert("title".to_string(), Value::String(t.title.clone()));
    90	    obj.insert("state".to_string(), Value::String(t.state.clone()));
    91	    obj.insert("prior".to_string(), Value::Array(prior));
    92	    if let Some(ref assignee) = t.assignee {
    93	        obj.insert("assignee".to_string(), Value::String(assignee.clone()));
    94	    }
    95	    if !t.content.is_empty() {
    96	        obj.insert("content".to_string(), Value::String(t.content.clone()));
    97	    }
    98	    obj.insert("children".to_string(), Value::Array(children));
    99	    Value::Object(obj)
   100	}
   101	
   102	fn rhei_json(rhei: &Rhei) -> Value {
   103	    let content_sections = rhei
   104	        .content_sections
   105	        .iter()
   106	        .map(|s| {
   107	            json!({
   108	                "title": s.title,
   109	                "content": s.content,
   110	            })
   111	        })
   112	        .collect::<Vec<Value>>();
   113	
   114	    let tasks = rhei.tasks.iter().map(task_json).collect::<Vec<Value>>();
   115	
   116	    json!({
   117	        "title": rhei.title,
   118	        "states": rhei.states,
   119	        "structure": {
   120	            "max_levels": rhei.structure.max_levels,
   121	            "node_kinds": rhei.structure.node_kinds,
   122	        },
   123	        "frontmatter": rhei.metadata.as_ref().and_then(|metadata| serde_json::to_value(metadata).ok()),
   124	        "content_sections": content_sections,
   125	        "tasks": tasks
   126	    })
   127	}
