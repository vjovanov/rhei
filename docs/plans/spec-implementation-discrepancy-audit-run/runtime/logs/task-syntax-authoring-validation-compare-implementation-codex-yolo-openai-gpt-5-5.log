  4269	            "path": plan_path.display().to_string(),
  4270	            "tasks": Value::Array(Vec::new()),
  4271	        }),
  4272	    };
  4273	
  4274	    json!({
  4275	        "rhei": rhei_json,
  4276	        "task": task_json,
  4277	        "transition": {
  4278	            "from": from_state,
  4279	            "to": to_state,
  4280	            "triggeredBy": triggered_by,
  4281	            "timestamp": current_iso8601(),
