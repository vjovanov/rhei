   476	/// One entry from the `states` map in a YAML states file.
   477	#[derive(Debug, Clone, Deserialize)]
   478	pub struct StateDef {
   479	    /// Optional descriptive text; the current schema intentionally keeps this permissive.
   480	    pub description: Option<String>,
   481	    /// Optional agent-facing instructions for what to do while a task is in this state.
   482	    #[serde(default)]
   483	    pub instructions: Option<String>,
   484	    /// Optional persona/instructions that frame how an agent approaches tasks in this state.
   485	    #[serde(default)]
   486	    pub personality: Option<String>,
   487	    /// Marks this state as the initial state in the state machine.
   488	    #[serde(default)]
   489	    pub initial: bool,
   490	    /// Marks this state as a final/terminal state in the state machine.
   491	    #[serde(default, rename = "final")]
   492	    pub terminal: bool,
   493	    /// When `true`, autonomous commands must not transition out of this state.
   494	    #[serde(default)]
   495	    pub gating: bool,
   496	    /// When `true`, `rhei run` may work multiple ready tasks in this state
   497	    /// simultaneously (bounded by `--parallel`). When `false`, at most one
   498	    /// task per pass is scheduled for this state; remaining tasks are
   499	    /// deferred to a later pass.
   500	    #[serde(default)]
   501	    pub concurrent: bool,
   502	    /// Optional polling configuration. When present, the state is treated
   503	    /// as a time-triggered state: a self-loop transition is interpreted as
   504	    /// "retry after `poll.interval`", the `--parallel` slot is released
   505	    /// between attempts, and the state's visit counter is capped at
   506	    /// `poll.max_attempts`. Mutually exclusive with `visits`.
   507	    #[serde(default)]
   508	    pub poll: Option<PollConfig>,
   509	    /// Optional visit budget for returning to this state.
   510	    pub visits: Option<u32>,
   511	    /// Inline execution target selector for one run of the state.
   512	    #[serde(default)]
   513	    pub target: Option<String>,
   514	    /// Explicit list of execution target selectors for fanout execution.
   515	    #[serde(default)]
   516	    pub all_targets: Vec<String>,
   517	    /// Explicit list of declared models that should each execute this state.
   518	    #[serde(default)]
   519	    pub all_models: Vec<String>,
   520	    /// Restricts this state to one declared model.
   521	    #[serde(default)]
   522	    pub model: Option<String>,
   523	    /// The coding agent CLI that executes work in this state. Must be a
   524	    /// string id resolved against the merged `agents` registry (built-ins →
