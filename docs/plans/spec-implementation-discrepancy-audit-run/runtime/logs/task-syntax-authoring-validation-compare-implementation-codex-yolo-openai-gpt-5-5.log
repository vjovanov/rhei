   306	
   307	fn badge_for(state_upper: &str, color: bool) -> String {
   308	    if !color {
   309	        return format!("[{}]", state_upper);
   310	    }
   311	    let key = state_upper.to_ascii_lowercase().replace(' ', "-");
   312	    let code = match key.as_str() {
   313	        "pending" => 34,     // blue
   314	        "in-progress" => 33, // yellow
   315	        "blocked" => 31,     // red
   316	        "completed" => 32,   // green
   317	        "cancelled" => 90,   // bright black / gray
   318	        _ => 35,             // magenta (unknown)
   319	    };
   320	    format!("\x1b[{}m[{}]\x1b[0m", code, state_upper)
   321	}
