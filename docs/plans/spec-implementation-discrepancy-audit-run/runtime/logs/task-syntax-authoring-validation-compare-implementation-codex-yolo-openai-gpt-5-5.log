  8662	/// Check whether a dependency state satisfies a prerequisite edge.
  8663	///
  8664	/// Terminal cancellation does not satisfy dependencies: a cancelled task should
  8665	/// not unblock downstream work.
  8666	fn dependency_is_satisfied(state: &str, machine: &rhei_validator::StateMachine) -> bool {
  8667	    normalized_state_name(state, machine) != "cancelled" && is_terminal_state(state, machine)
  8668	}
