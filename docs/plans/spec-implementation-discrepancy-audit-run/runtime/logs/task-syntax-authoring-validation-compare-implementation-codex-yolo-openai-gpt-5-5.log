  4530	fn resolve_runtime_template_variable(
  4531	    variable: &str,
  4532	    context: &RuntimeTemplateContext<'_>,
  4533	) -> Option<String> {
  4534	    match variable {
  4535	        "task_id" => Some(context.task.id.to_string()),
  4536	        "task_title" => Some(context.task.title.clone()),
  4537	        "state" => Some(context.state_name.to_string()),
  4538	        "visit_count" => Some(
  4539	            render_visit_count(
  4540	                context.metadata,
  4541	                &context.task.id,
  4542	                context.state_name,
  4543	                context.current_state_raw,
  4544	                context.machine,
  4545	            )
  4546	            .to_string(),
  4547	        ),
  4548	        "visits" => state_visit_limit(context.machine, context.state_name).map(|n| n.to_string()),
  4549	        "target" => context.target.map(ExecutionTarget::selector),
  4550	        "target.slug" => context.target.map(ExecutionTarget::slug),
  4551	        "model" => context.model.map(str::to_string),
  4552	        "agent" => context.agent.map(str::to_string),
  4553	        "agent.mode" => context.agent_mode.map(str::to_string),
  4554	        "plan_title" => Some(context.plan_title.to_string()),
  4555	        "plan_path" => Some(context.plan_path.display().to_string()),
  4556	        _ => {
  4557	            if let Some(key) = variable.strip_prefix("model.") {
  4558	                return match key {
  4559	                    "provider" => context.target.and_then(|target| target.provider.clone()),
  4560	                    "name" => context.model.map(str::to_string),
  4561	                    _ => None,
  4562	                };
  4563	            }
  4564	            if let Some(key) = variable.strip_prefix("meta.") {
  4565	                return task_metadata_map(context.metadata, &context.task.id)
  4566	                    .and_then(|task_map| task_map.get(yaml_key(key)))
  4567	                    .and_then(yaml_value_to_template_string);
  4568	            }
  4569	
  4570	            let visit_count = Some(render_visit_count(
  4571	                context.metadata,
  4572	                &context.task.id,
  4573	                context.state_name,
  4574	                context.current_state_raw,
  4575	                context.machine,
  4576	            ));
  4577	            let state_def = context.machine.states.get(context.state_name)?;
  4578	
  4579	            if let Some(name) =
  4580	                variable.strip_prefix("input.").and_then(|v| v.strip_suffix(".path"))
  4581	            {
  4582	                return state_def.inputs.iter().find(|artifact| artifact.name == name).map(
  4583	                    |artifact| {
  4584	                        artifact_relative_path(
  4585	                            artifact,
  4586	                            &context.task.id.to_string(),
  4587	                            context.state_name,
  4588	                            visit_count,
  4589	                            context.target,
  4590	                            context.model,
  4591	                            context.agent,
  4592	                            context.agent_mode,
  4593	                        )
  4594	                    },
  4595	                );
  4596	            }
  4597	
  4598	            if let Some(name) =
  4599	                variable.strip_prefix("input.").and_then(|v| v.strip_suffix(".exists"))
  4600	            {
  4601	                return state_def.inputs.iter().find(|artifact| artifact.name == name).map(
  4602	                    |artifact| {
  4603	                        let (_, path) = resolve_artifact_path(
  4604	                            context.workspace_root,
  4605	                            artifact,
  4606	                            &context.task.id.to_string(),
  4607	                            context.state_name,
  4608	                            visit_count,
  4609	                            context.target,
  4610	                            context.model,
  4611	                            context.agent,
  4612	                            context.agent_mode,
  4613	                        );
  4614	                        path.exists().to_string()
  4615	                    },
  4616	                );
  4617	            }
  4618	
  4619	            if let Some(name) =
  4620	                variable.strip_prefix("output.").and_then(|v| v.strip_suffix(".path"))
  4621	            {
  4622	                return state_def.outputs.iter().find(|artifact| artifact.name == name).map(
  4623	                    |artifact| {
  4624	                        artifact_relative_path(
  4625	                            artifact,
  4626	                            &context.task.id.to_string(),
  4627	                            context.state_name,
  4628	                            visit_count,
  4629	                            context.target,
  4630	                            context.model,
  4631	                            context.agent,
  4632	                            context.agent_mode,
  4633	                        )
  4634	                    },
  4635	                );
  4636	            }
  4637	
  4638	            if let Some(name) =
  4639	                variable.strip_prefix("mcp.").and_then(|v| v.strip_suffix(".available"))
  4640	            {
  4641	                return context.tooling.map(|t| t.mcp_available(name).to_string());
  4642	            }
  4643	
  4644	            if let Some(id) =
  4645	                variable.strip_prefix("skill.").and_then(|v| v.strip_suffix(".available"))
  4646	            {
  4647	                return context.tooling.map(|t| t.skill_available(id).to_string());
  4648	            }
  4649	
  4650	            None
  4651	        }
  4652	    }
  4653	}
