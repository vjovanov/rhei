     1	//! Directory Workspace loader for multi-file Rhei plans.
     2	//!
     3	//! A Directory Workspace consists of:
     4	//! - `index.rhei.md`: root configuration with title, states, and content sections.
     5	//! - `tasks/`: a directory containing `.md` files, each with one or more task definitions.
     6	//!
     7	//! All tasks are merged into a single global task graph. Task IDs must be
     8	//! unique across the entire `tasks/` directory.
     9	
    10	use std::collections::HashMap;
    11	use std::path::{Path, PathBuf};
    12	
    13	use crate::ast::{Rhei, Task};
    14	use crate::parser::{self, ParseError};
    15	
    16	/// A loaded directory workspace: the merged plan plus a map from each task ID
    17	/// to the file it was parsed from (needed for targeted file rewrites during
    18	/// transitions).
    19	#[derive(Debug)]
    20	pub struct Workspace {
    21	    pub rhei: Rhei,
    22	    /// Maps task ID (as string) → the file path that defines it.
    23	    pub task_sources: HashMap<String, PathBuf>,
    24	}
    25	
    26	/// Returns `true` if `path` looks like a directory workspace
    27	/// (a directory containing `index.rhei.md`).
    28	pub fn is_workspace(path: &Path) -> bool {
    29	    path.is_dir() && path.join("index.rhei.md").is_file()
    30	}
    31	
    32	/// Load a directory workspace, merging all task files into a single plan.
    33	///
    34	/// Reads `index.rhei.md` for plan metadata, then discovers and parses every
    35	/// `.md` file inside the `tasks/` subdirectory. Reports duplicate task IDs
    36	/// across files and missing structure.
    37	pub fn load_workspace(dir: &Path) -> parser::Result<Workspace> {
    38	    let index_path = dir.join("index.rhei.md");
    39	    let index_content = std::fs::read_to_string(&index_path).map_err(|e| {
    40	        ParseError::new(format!("failed to read {}: {e}", index_path.display()), None)
    41	    })?;
    42	
    43	    let index = parser::parse_workspace_index(&index_content)
    44	        .map_err(|e| ParseError::new(format!("{}: {}", index_path.display(), e.message), e.line))?;
    45	
    46	    let tasks_dir = dir.join("tasks");
    47	    let mut all_tasks: Vec<Task> = Vec::new();
    48	    let mut task_sources: HashMap<String, PathBuf> = HashMap::new();
    49	
    50	    if tasks_dir.is_dir() {
    51	        let mut entries: Vec<_> = std::fs::read_dir(&tasks_dir)
    52	            .map_err(|e| ParseError::new(format!("failed to read tasks/ directory: {e}"), None))?
    53	            .filter_map(|e| e.ok())
    54	            .filter(|e| e.path().extension().map_or(false, |ext| ext == "md"))
    55	            .collect();
    56	
    57	        // Sort by filename for deterministic ordering.
    58	        entries.sort_by_key(|e| e.file_name());
    59	
    60	        for entry in entries {
    61	            let path = entry.path();
    62	            let content = std::fs::read_to_string(&path).map_err(|e| {
    63	                ParseError::new(format!("failed to read {}: {e}", path.display()), None)
    64	            })?;
    65	
    66	            let tasks = parser::parse_workspace_tasks(&content).map_err(|e| {
    67	                ParseError::new(format!("{}: {}", path.display(), e.message), e.line)
    68	            })?;
    69	
    70	            for task in &tasks {
    71	                let id_str = task.id.to_string();
    72	                if let Some(existing) = task_sources.get(&id_str) {
    73	                    return Err(ParseError::new(
    74	                        format!(
    75	                            "duplicate task ID '{}': defined in both {} and {}",
    76	                            id_str,
    77	                            existing.display(),
    78	                            path.display()
    79	                        ),
    80	                        None,
    81	                    ));
    82	                }
    83	                task_sources.insert(id_str, path.clone());
    84	            }
    85	
    86	            all_tasks.extend(tasks);
    87	        }
    88	    }
    89	
    90	    if all_tasks.is_empty() {
    91	        return Err(ParseError::new(
    92	            "workspace contains no tasks (tasks/ directory is empty or missing)",
    93	            None,
    94	        ));
    95	    }
    96	
    97	    Ok(Workspace {
    98	        rhei: Rhei {
    99	            title: index.title,
   100	            states: index.states,
   101	            structure: index.structure,
   102	            metadata: index.metadata,
   103	            content_sections: index.content_sections,
   104	            tasks: all_tasks,
   105	        },
   106	        task_sources,
   107	    })
   108	}

