  2017	/// Extract markdown links from a text block, returning `(display_text, target)` pairs.
  2018	fn extract_markdown_links(text: &str) -> Vec<(String, String)> {
  2019	    let re = Regex::new(r"\[([^\]]*)\]\(([^)]+)\)").expect("valid regex");
  2020	    re.captures_iter(text).map(|cap| (cap[1].to_string(), cap[2].to_string())).collect()
  2021	}
  2022	
  2023	/// Collect all markdown links from every content field in the plan.
  2024	///
  2025	/// Returns `(location_label, display_text, target)` triples.
  2026	fn collect_all_links(rhei: &Rhei) -> Vec<(String, String, String)> {
  2027	    let mut links = Vec::new();
  2028	
  2029	    for section in &rhei.content_sections {
  2030	        for (display, target) in extract_markdown_links(&section.content) {
  2031	            links.push((format!("section '{}'", section.title), display, target));
  2032	        }
  2033	    }
  2034	
  2035	    for_each_node(rhei, |task| {
  2036	        for (display, target) in extract_markdown_links(&task.content) {
  2037	            let label = format!("{} {}", title_case_kind(&task.kind), task.id);
  2038	            links.push((label, display, target));
  2039	        }
  2040	    });
  2041	
  2042	    links
  2043	}
  2044	
  2045	/// Returns true if the link target looks like an external URL or a fragment-only anchor.
  2046	fn is_non_file_link(target: &str) -> bool {
  2047	    target.starts_with("http://")
  2048	        || target.starts_with("https://")
  2049	        || target.starts_with("mailto:")
  2050	        || target.starts_with('#')
  2051	}
  2052	
  2053	/// Validate that relative markdown links in all content fields point to
  2054	/// existing files, resolved against `base_path`.
  2055	fn validate_markdown_links(rhei: &Rhei, base_path: &Path, report: &mut ValidationReport) {
  2056	    let links = collect_all_links(rhei);
  2057	
  2058	    for (location, display, target) in &links {
  2059	        if is_non_file_link(target) {
  2060	            continue;
  2061	        }
  2062	
  2063	        // Strip fragment (e.g. "file.md#section" → "file.md")
  2064	        let file_part = target.split('#').next().unwrap_or(target);
  2065	        if file_part.is_empty() {
  2066	            continue; // pure fragment link, already handled above
  2067	        }
  2068	
  2069	        let resolved = base_path.join(file_part);
  2070	        if !resolved.exists() {
  2071	            report.errors.push(format!(
  2072	                "{} contains a link [{}]({}) but '{}' does not exist",
  2073	                location, display, target, file_part
  2074	            ));
  2075	        }
  2076	    }
  2077	}
