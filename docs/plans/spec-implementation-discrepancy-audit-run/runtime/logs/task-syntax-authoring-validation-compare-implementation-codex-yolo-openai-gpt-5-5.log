   133	fn title_case_kind(kind: &str) -> String {
   134	    let mut out = String::with_capacity(kind.len());
   135	    let mut chars = kind.chars();
   136	    if let Some(first) = chars.next() {
   137	        for c in first.to_uppercase() {
   138	            out.push(c);
   139	        }
   140	    }
   141	    for c in chars {
   142	        out.push(c);
   143	    }
   144	    out
   145	}
   146	
   147	fn fmt_prior_list(ids: &[TaskId]) -> String {
   148	    ids.iter().map(|id| format!("Task {}", id)).collect::<Vec<String>>().join(", ")
   149	}
