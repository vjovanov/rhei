   530	    #[serde(default)]
   531	    pub agent_mode: Option<String>,
   532	    /// Maximum time an agent may work in this state (e.g., `"30m"`, `"1h"`).
   533	    #[serde(default)]
   534	    pub agent_timeout: Option<String>,
   535	    /// Deterministic program command for this state (mutually exclusive with `agent`).
   536	    #[serde(default)]
   537	    pub program: Option<serde_yaml::Value>,
   538	    /// Maximum time the program may run in this state (e.g., `"10m"`, `"1h"`).
   539	    #[serde(default)]
   540	    pub program_timeout: Option<String>,
   541	    /// Required artifacts that must exist before work can proceed in this state.
