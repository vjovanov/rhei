   151	/// GitHub issues-style Markdown output generator.
   152	#[derive(Debug, Clone, Copy)]
   153	pub struct GithubIssuesOutput {
   154	    pub include_content: bool,
   155	    pub include_metadata: bool,
   156	}
   157	
   158	impl GithubIssuesOutput {
   159	    /// Render the provided Rhei into a single GitHub-friendly Markdown document.
   160	    pub fn to_markdown(&self, rhei: &rhei_core::ast::Rhei) -> String {
   161	        let mut out = String::new();
   162	
   163	        out.push_str("# Rhei: ");
   164	        out.push_str(&rhei.title);
   165	        out.push('\n');
   166	        out.push('\n');
   167	
   168	        for section in &rhei.content_sections {
   169	            out.push_str("## ");
   170	            out.push_str(&section.title);
   171	            out.push('\n');
   172	            if !section.content.is_empty() {
   173	                out.push_str(&section.content);
   174	                out.push('\n');
   175	            }
   176	        }
   177	        if !rhei.content_sections.is_empty() {
   178	            out.push('\n');
   179	        }
   180	
   181	        out.push_str("## Tasks\n\n");
   182	        for task in &rhei.tasks {
   183	            self.render_node(task, 3, &mut out);
   184	            out.push('\n');
   185	        }
   186	
   187	        out
   188	    }
   189	
   190	    fn render_node(&self, task: &Task, level: u8, out: &mut String) {
   191	        let hashes = "#".repeat(level as usize);
   192	        out.push_str(&hashes);
   193	        out.push(' ');
   194	        out.push_str(&title_case_kind(&task.kind));
   195	        out.push(' ');
   196	        out.push_str(&task.id.to_string());
   197	        out.push_str(": ");
   198	        out.push_str(&task.title);
   199	        out.push('\n');
   200	
   201	        if self.include_metadata {
   202	            out.push_str("- State: ");
   203	            out.push_str(&task.state);
   204	            out.push('\n');
   205	            if !task.prior.is_empty() {
   206	                out.push_str("- Prior: ");
   207	                out.push_str(&fmt_prior_list(&task.prior));
   208	                out.push('\n');
   209	            }
   210	            if let Some(ref assignee) = task.assignee {
   211	                out.push_str("- Assignee: ");
   212	                out.push_str(assignee);
   213	                out.push('\n');
   214	            }
   215	        }
   216	
   217	        if self.include_content && !task.content.is_empty() {
   218	            out.push('\n');
   219	            out.push_str(&task.content);
   220	            out.push('\n');
   221	        }
   222	
   223	        for child in &task.children {
   224	            self.render_node(child, level + 1, out);
   225	        }
   226	    }
   227	}
