     1	//! Abstract Syntax Tree (AST) definitions for the Markdown Plan Compiler.
     2	//!
     3	//! These types model the hierarchical structure parsed from plan markdown,
     4	//! aligning with the specification in docs/rhei.spec.md.
     5	//!
     6	//! High-level model:
     7	//! - `Rhei`: holds the plan title, free-form content blocks prior to the Tasks
     8	//!   section, the plan-level `Structure`, and the list of root task nodes.
     9	//! - `Task`: a task node with a hierarchical id, a node kind, metadata, and
    10	//!   zero or more child task nodes.
    11	//! - `ContentSection`: a named H2 section with title and content.
    12	
    13	use serde::{Deserialize, Serialize};
    14	use std::fmt;
    15	
    16	pub type Metadata = serde_yaml::Mapping;
    17	
    18	/// Default node kind when `structure.nodeKinds` is omitted.
    19	pub const DEFAULT_NODE_KIND: &str = "task";
    20	
    21	/// Default structural depth limit when `structure.maxLevels` is omitted.
    22	pub const DEFAULT_MAX_LEVELS: u8 = 2;
    23	
    24	/// Hard cap on structural depth that a markdown plan can represent
    25	/// (matches Markdown heading depth H3..=H6).
    26	pub const MAX_ALLOWED_LEVELS: u8 = 4;
