  1945	fn validate_task_id_uniqueness(rhei: &Rhei, report: &mut ValidationReport) {
  1946	    let mut seen: HashSet<TaskId> = HashSet::new();
  1947	    for_each_node(rhei, |task| {
  1948	        if !seen.insert(task.id.clone()) {
  1949	            report.errors.push(format!("Duplicate task id: Task {}", task.id));
  1950	        }
