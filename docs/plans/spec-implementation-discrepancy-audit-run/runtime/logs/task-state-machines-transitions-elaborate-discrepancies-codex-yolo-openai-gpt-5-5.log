docs/specs/rhei-state-machine-writer.spec.md:77:    gating: true|false   # optional: if true, no autonomous exit allowed
docs/specs/rhei-state-machine-writer.spec.md:85:    description: <when and why this transition occurs>              # required
docs/specs/rhei-state-machine-writer.spec.md:100:  by_type:                           # optional: per-kind overrides
