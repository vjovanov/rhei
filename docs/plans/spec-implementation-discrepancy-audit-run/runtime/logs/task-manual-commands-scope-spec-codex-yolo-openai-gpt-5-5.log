 10927	/// Convert a parser error into an Elm-style diagnostic report.
 10928	fn parse_report(path: &Path, input: &str, err: &rhei_core::parser::ParseError) -> Report {
 10929	    miette!("{}", render_parse_diagnostic(path, input, err))
 10930	}
 10931	
 10932	/// Convert one or more parser errors into an Elm-style diagnostic report.
 10933	///
 10934	/// For a single error this is equivalent to [`parse_report`]. For multiple
 10935	/// errors the header, code-frame, and hint are printed once; each error is
 10936	/// listed numerically in the body.
 10937	fn parse_errors_report(
 10938	    path: &Path,
 10939	    input: &str,
 10940	    errors: &[rhei_core::parser::ParseError],
 10941	) -> Report {
 10942	    miette!("{}", render_multi_parse_diagnostic(path, input, errors))
 10943	}
 10944	
 10945	fn render_multi_parse_diagnostic(
 10946	    path: &Path,
 10947	    input: &str,
 10948	    errors: &[rhei_core::parser::ParseError],
 10949	) -> String {
 10950	    if errors.len() == 1 {
 10951	        return render_parse_diagnostic(path, input, &errors[0]);
 10952	    }
 10953	
 10954	    let mut lines = vec![format!(
 10955	        "-- PARSE ERROR ------------------------------------------------------------- {}",
 10956	        path.display()
 10957	    )];
 10958	    lines.push(String::new());
 10959	    lines
 10960	        .push(format!("I got stuck while reading this markdown plan ({} problems).", errors.len()));
 10961	    for (i, err) in errors.iter().enumerate() {
 10962	        lines.push(String::new());
 10963	        let prefix = format!("{}.", i + 1);
 10964	        match err.line {
 10965	            Some(line_number) => {
 10966	                lines.push(format!("{prefix} line {line_number}: {}", err.message));
 10967	                if let Some(source_line) = line_text(input, line_number) {
 10968	                    lines.push(format!("   {line_number}| {source_line}"));
 10969	                }
 10970	            }
 10971	            None => {
 10972	                lines.push(format!("{prefix} {}", err.message));
 10973	            }
 10974	        }
 10975	    }
 10976	    lines.push(String::new());
 10977	    lines.push(
 10978	        "Hint: fix the problems above — each one refers to a distinct line or task.".to_string(),
 10979	    );
 10980	    lines.join("\n")
 10981	}
