  9532	
  9533	    let parent = path.parent().unwrap_or(Path::new("."));
  9534	    let mut tmp = tempfile::NamedTempFile::new_in(parent)
  9535	        .map_err(|err| miette!("failed to create temp file: {err}"))?;
  9536	    tmp.write_all(new_raw.as_bytes()).map_err(|err| miette!("failed to write temp file: {err}"))?;
  9537	    tmp.persist(path).map_err(|err| miette!("failed to persist temp file: {err}"))?;
  9538	
  9539	    let _ = file.unlock();
  9540	    Ok(())
  9541	}
