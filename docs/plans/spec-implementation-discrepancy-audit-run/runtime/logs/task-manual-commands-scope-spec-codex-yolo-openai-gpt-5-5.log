 11026	fn render_validation_diagnostic(
 11027	    input: &Path,
 11028	    state_machine: Option<&Path>,
 11029	    errors: &[String],
 11030	) -> String {
 11031	    let mut lines = vec![format!(
 11032	        "-- VALIDATION ERROR -------------------------------------------------------- {}",
 11033	        input.display()
 11034	    )];
 11035	    lines.push(String::new());
 11036	    lines.push(format!(
 11037	        "I validated this plan using {}, but found a problem.",
 11038	        state_machine_label(state_machine),
 11039	    ));
 11040	    lines.push(String::new());
 11041	    lines.push(format_validation_errors(errors));
 11042	    lines.push(String::new());
 11043	    lines.push("I recommend fixing the problems above and running the command again.".to_string());
 11044	
 11045	    lines.join("\n")
 11046	}
