    46	}
    47	
    48	pub fn render_html(plans: &[Plan]) -> String {
    49	    let bundle: BTreeMap<&str, &Plan> =
    50	        plans.iter().map(|plan| (plan.key.as_str(), plan)).collect();
    51	    let data = serde_json::to_string(&bundle).expect("plan bundle should always serialize");
    52	    TEMPLATE.replace(DATA_PLACEHOLDER, &escape_json_for_html_script(&data))
    53	}
    54	
    55	pub fn collect_plans(
    56	    path: &Path,
    57	    example_name: &str,
    58	    machine_override: Option<&Path>,
    59	) -> io::Result<Vec<Plan>> {
    60	    if path.is_file() {
    61	        return Ok(vec![load_plan_file(path, example_name.to_string(), machine_override)?]);
    62	    }
    63	    if !path.is_dir() {
    64	        return Err(io::Error::new(
    65	            io::ErrorKind::NotFound,
    66	            format!("no such file or directory: {}", path.display()),
    67	        ));
    68	    }
    69	
    70	    let mut plans = Vec::new();
    71	
    72	    if workspace::is_workspace(path) {
    73	        let loaded = workspace::load_workspace(path).map_err(|err| {
    74	            io::Error::new(
    75	                io::ErrorKind::InvalidData,
    76	                format!("failed to load workspace {}: {}", path.display(), err.message),
    77	            )
    78	        })?;
    79	        let machine = resolve_machine_for_workspace(path, machine_override, &loaded.rhei)?;
    80	        plans.push(plan_from_rhei(
    81	            path.join("index.rhei.md"),
    82	            example_name.to_string(),
    83	            &loaded.rhei,
    84	            &machine,
    85	        ));
    86	    }
    87	
    88	    for plan_path in standalone_plan_files(path)? {
    89	        if plan_path.file_name().and_then(|name| name.to_str()) == Some("index.rhei.md") {
    90	            continue;
    91	        }
    92	        let rel = plan_path.strip_prefix(path).unwrap_or(&plan_path).to_string_lossy().to_string();
    93	        let key = format!("{example_name}::{rel}");
    94	        plans.push(load_plan_file(&plan_path, key, machine_override)?);
    95	    }
    96	
    97	    Ok(plans)
    98	}
    99	
   100	fn load_plan_file(path: &Path, key: String, machine_override: Option<&Path>) -> io::Result<Plan> {
   101	    let text = fs::read_to_string(path)?;
   102	    let rhei = parse(&text).map_err(|err| {
   103	        io::Error::new(
   104	            io::ErrorKind::InvalidData,
   105	            format!("failed to parse {}: {}", path.display(), err.message),
   106	        )
   107	    })?;
   108	    let machine = resolve_machine_for_plan(path, machine_override, &rhei)?;
   109	    Ok(plan_from_rhei(path.to_path_buf(), key, &rhei, &machine))
   110	}
   111	
   112	fn plan_from_rhei(source: PathBuf, key: String, rhei: &Rhei, machine: &StateMachine) -> Plan {
   113	    let tasks: Vec<Task> =
   114	        rhei.tasks.iter().map(|task| top_level_task_from_ast(task, machine)).collect();
   115	    let state = derive_plan_state(&tasks, machine);
   116	    Plan { key, title: rhei.title.clone(), source, state, tasks }
   117	}
   118	
   119	fn top_level_task_from_ast(task: &AstTask, machine: &StateMachine) -> Task {
   120	    let mut subtasks = Vec::new();
   121	    collect_descendants(&task.children, machine, &mut subtasks);
   122	    Task {
   123	        id: task.id.to_string(),
   124	        title: task.title.clone(),
   125	        state: normalize_state(&task.state, machine),
   126	        prior: task.prior.iter().map(ToString::to_string).collect(),
   127	        subtasks,
   128	    }
   129	}
   130	
   131	fn collect_descendants(children: &[AstTask], machine: &StateMachine, out: &mut Vec<Subtask>) {
   132	    for child in children {
   133	        out.push(Subtask {
   134	            id: child.id.to_string(),
   135	            title: child.title.clone(),
   136	            state: normalize_state(&child.state, machine),
   137	            prior: child.prior.iter().map(ToString::to_string).collect(),
   138	        });
   139	        collect_descendants(&child.children, machine, out);
   140	    }
   141	}
   142	
   143	fn normalize_state(raw_state: &str, machine: &StateMachine) -> String {
   144	    parse_task_state(raw_state, machine).state
   145	}
   146	
   147	/// Derive a level-0 plan state from the task states. See
   148	/// `docs/specs/rhei-viz.spec.md#plan-level-state-derivation`.
   149	fn derive_plan_state(tasks: &[Task], machine: &StateMachine) -> String {
   150	    if tasks.is_empty() {
   151	        return "draft".into();
   152	    }
   153	
   154	    let states: Vec<&str> = tasks.iter().map(|task| task.state.as_str()).collect();
   155	    if states.iter().all(|state| *state == "draft") {
   156	        return "draft".into();
   157	    }
   158	    if states.iter().all(|state| *state == "completed") {
   159	        return "completed".into();
   160	    }
   161	
   162	    let terminal_states: HashSet<&str> = machine
   163	        .states
   164	        .iter()
   165	        .filter_map(|(name, def)| def.terminal.then_some(name.as_str()))
   166	        .collect();
   167	    if states.iter().all(|state| terminal_states.contains(*state)) {
   168	        let first = states[0];
   169	        if states.iter().all(|state| *state == first) && first != "cancelled" && first != "archived"
   170	        {
   171	            return "completed".into();
   172	        }
   173	        return "archived".into();
   174	    }
   175	
   176	    let initial_state =
   177	        machine.states.iter().find_map(|(name, def)| def.initial.then_some(name.as_str()));
   178	    let any_active = states.iter().any(|state| {
   179	        !terminal_states.contains(*state) && *state != "draft" && Some(*state) != initial_state
   180	    });
   181	
   182	    if any_active {
   183	        "active".into()
   184	    } else {
   185	        "pending".into()
   186	    }
   187	}
   188	
   189	fn resolve_machine_for_plan(
   190	    plan_path: &Path,
   191	    machine_override: Option<&Path>,
   192	    rhei: &Rhei,
   193	) -> io::Result<StateMachine> {
   194	    if let Some(machine_path) = machine_override {
   195	        return load_machine(machine_path);
   196	    }
   197	    if rhei.states == "rhei" {
   198	        return Ok(StateMachine::builtin_default());
   199	    }
   200	    let machine_path = plan_path.parent().unwrap_or_else(|| Path::new(".")).join("states.yaml");
   201	    load_machine(&machine_path)
   202	}
   203	
   204	fn resolve_machine_for_workspace(
   205	    workspace_dir: &Path,
   206	    machine_override: Option<&Path>,
   207	    rhei: &Rhei,
   208	) -> io::Result<StateMachine> {
   209	    if let Some(machine_path) = machine_override {
   210	        return load_machine(machine_path);
   211	    }
   212	    if rhei.states == "rhei" {
   213	        return Ok(StateMachine::builtin_default());
   214	    }
   215	    load_machine(&workspace_dir.join("states.yaml"))
   216	}
   217	
   218	fn load_machine(machine_path: &Path) -> io::Result<StateMachine> {
   219	    StateMachine::from_yaml_file(machine_path).map_err(|err| {
   220	        io::Error::new(
   221	            io::ErrorKind::InvalidData,
   222	            format!("failed to load state machine {}: {err}", machine_path.display()),
   223	        )
   224	    })
   225	}
   226	
   227	fn standalone_plan_files(dir: &Path) -> io::Result<Vec<PathBuf>> {
   228	    let mut files: Vec<PathBuf> = fs::read_dir(dir)?
   229	        .filter_map(|entry| entry.ok())
   230	        .map(|entry| entry.path())
   231	        .filter(|path| path.is_file())
   232	        .filter(|path| {
   233	            path.file_name()
   234	                .and_then(|name| name.to_str())
   235	                .map(|name| name.ends_with(".rhei.md"))
   236	                .unwrap_or(false)
   237	        })
   238	        .collect();
   239	    files.sort();
   240	    Ok(files)
   241	}
   242	
   243	fn escape_json_for_html_script(data: &str) -> String {
   244	    let mut out = String::with_capacity(data.len());
   245	    for ch in data.chars() {
   246	        match ch {
   247	            '<' => out.push_str("\\u003c"),
   248	            '>' => out.push_str("\\u003e"),
   249	            '&' => out.push_str("\\u0026"),
   250	            '\u{2028}' => out.push_str("\\u2028"),
   251	            '\u{2029}' => out.push_str("\\u2029"),
   252	            _ => out.push(ch),
   253	        }
   254	    }
   255	    out
   256	}
