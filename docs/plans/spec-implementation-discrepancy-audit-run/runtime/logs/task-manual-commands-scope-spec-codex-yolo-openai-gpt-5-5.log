     5	name: rhei
     6	version: 2.0
     7	
     8	states:
     9	  draft:
    10	    description: Task requires analysis before execution — the agent studies the project and writes a concrete task description.
    11	    instructions: |
    12	      Pick up when all **Prior:** tasks are `completed`. Analyze the current
    13	      state of the project and determine the most elegant way to accomplish
    14	      the task. Based on that analysis, write a description of what should be
    15	      done. Transition to `pending` once the description is finalized.
    16	    initial: true
    17	
    18	  pending:
    19	    description: Task is ready for implementation. An **Assignee** on a pending task means work is actively in progress.
    20	    instructions: |
    21	      Pick up when all **Prior:** tasks are `completed`. Implement the task and
    22	      its subtasks, logging progress per subtask. When implementation is
    23	      complete and self-tested, either run `rhei complete` to finish directly
    24	      or transition to `agent-review` when a separate review pass is required.
    25	
    26	  agent-review:
    27	    description: A separate reviewing agent inspects the result.
    28	    instructions: |
    29	      Review the implementation against the task description, subtasks, and
    30	      repository conventions. On pass, transition to `human-review` (or
    31	      `completed` if no human gate is required). On fail, transition to
    32	      `agent-review-fix` with concrete findings.
    33	
    34	  agent-review-fix:
    35	    description: The implementing agent addresses reviewer findings.
    36	    instructions: |
    37	      Address the reviewer's findings only — no scope expansion. After
    38	      applying fixes, transition back to `agent-review` for re-review.
    39	
    40	  human-review:
    41	    description: Work is paused pending human inspection.
    42	    gating: true
    43	    instructions: |
    44	      Stop all agent work on this task. Wait for a human to approve, request
    45	      changes, or edit the rhei. Do not transition out of this state
    46	      autonomously.
    47	
    48	  completed:
    49	    description: Task finished successfully.
    50	    instructions: |
    51	      Treat as immutable. Do not re-open, re-run, or modify unless the user
    52	      explicitly requests it.
    53	    final: true
    54	
    55	  cancelled:
    56	    description: Task is no longer needed.
    57	    instructions: |
    58	      Skip entirely. Do not execute, review, or reference as a prerequisite
    59	      for new work.
    60	    final: true
