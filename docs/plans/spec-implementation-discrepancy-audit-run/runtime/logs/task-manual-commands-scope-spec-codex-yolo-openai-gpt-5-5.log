  8931	/// Parse a task ID string into a [`TaskId`].
  8932	///
  8933	/// Accepts both single-segment ids (`1`, `api`) and dotted paths (`1.2`,
  8934	/// `api.cache`). Malformed input is treated as a single named segment so
  8935	/// downstream lookups fail cleanly with a "not found" message.
  8936	fn parse_task_id(s: &str) -> TaskId {
  8937	    if s.is_empty() {
  8938	        return TaskId::named(s);
  8939	    }
  8940	    let mut segments = Vec::new();
  8941	    for part in s.split('.') {
  8942	        if part.is_empty() {
  8943	            return TaskId::named(s);
  8944	        }
  8945	        if let Ok(n) = part.parse::<u32>() {
  8946	            segments.push(rhei_core::ast::TaskIdSegment::Number(n));
  8947	        } else {
  8948	            segments.push(rhei_core::ast::TaskIdSegment::Named(part.to_string()));
  8949	        }
  8950	    }
  8951	    TaskId::from_segments(segments)
  8952	}
