  9331	    let open_children = non_terminal_descendants(task, &machine);
  9332	    if !open_children.is_empty() {
  9333	        return Err(miette!(
  9334	            "Task {} cannot be completed while child tasks remain non-terminal.\nOffending children: {}",
  9335	            task_id_str,
  9336	            open_children.join(", ")
  9337	        ));
  9338	    }
  9339	
  9340	    // Find the completion target: a non-cancelled terminal state reachable via
  9341	    // a single declared transition from the current state.
  9342	    let to_state = find_completion_state(&current_state, &machine).ok_or_else(|| {
  9343	        miette!(
  9344	            "no transition to a terminal state available from '{}' for Task {}",
  9345	            current_state_raw,
  9346	            task_id_str
  9347	        )
  9348	    })?;
  9349	
  9350	    // Execute the state transition (compare-and-swap, callbacks, atomic write).
  9351	    let task_file = loaded.task_file(task_id_str, input);
  9352	    let metadata_file = if workspace::is_workspace(input) {
  9353	        input.join("index.rhei.md")
  9354	    } else {
  9355	        task_file.clone()
  9356	    };
  9357	    execute_transition(
  9358	        TransitionFiles { task_file: &task_file, metadata_file: &metadata_file },
  9359	        &callback_paths,
  9360	        &machine,
  9361	        task_id_str,
  9362	        &current_state,
  9363	        &to_state,
  9364	        no_callbacks,
  9365	    )?;
  9366	
  9367	    // Append the completion entry to the result file.
  9368	    let root = result_workspace_root(input, &task_file);
  9369	    let result_link = format!("runtime/results/{}.md", task_id_str);
  9370	    let result_file_existed = root.join(&result_link).exists();
  9371	    append_result_entry(&root, task_id_str, current_state_raw, &to_state, Some(result_msg))?;
  9372	
  9373	    // Post-transition: remove assignee and link the result file (first time only).
  9374	    rewrite_task_completion(
  9375	        &task_file,
  9376	        task_id_str,
  9377	        task_id_str,
  9378	        &result_link,
  9379	        !result_file_existed,
  9380	    )?;
  9381	
  9382	    println!(
  9383	        "Task {} completed: '{}' → '{}' ({})",
  9384	        task_id_str, current_state_raw, to_state, result_link
  9385	    );
  9386	
  9387	    Ok(())
  9388	}
