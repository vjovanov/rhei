 10983	/// Convert file I/O failures into a consistent diagnostic message.
 10984	fn file_io_report(path: &Path, action: &str, err: impl std::fmt::Display) -> Report {
 10985	    miette!("{action} '{}': {err}", path.display())
 10986	}
