  9465	fn reset_target_files(loaded: &LoadedPlan, input: &Path) -> Vec<PathBuf> {
  9466	    if loaded.task_sources.is_empty() {
  9467	        return vec![input.to_path_buf()];
  9468	    }
  9469	
  9470	    let mut files = loaded.task_sources.values().cloned().collect::<Vec<_>>();
  9471	    files.sort();
  9472	    files.dedup();
  9473	    files
