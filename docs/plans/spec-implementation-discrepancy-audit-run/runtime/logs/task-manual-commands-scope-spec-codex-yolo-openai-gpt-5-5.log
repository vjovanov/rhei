 10988	/// Convert validation errors into a single CLI-facing diagnostic report.
 10989	fn validation_report(input: &Path, state_machine: Option<&Path>, errors: &[String]) -> Report {
 10990	    miette!("{}", render_validation_diagnostic(input, state_machine, errors))
 10991	}
 10992	
 10993	fn render_parse_diagnostic(
 10994	    path: &Path,
 10995	    input: &str,
 10996	    err: &rhei_core::parser::ParseError,
 10997	) -> String {
 10998	    let mut lines = vec![format!(
 10999	        "-- PARSE ERROR ------------------------------------------------------------- {}",
 11000	        path.display()
 11001	    )];
 11002	    lines.push(String::new());
 11003	    lines.push("I got stuck while reading this markdown plan.".to_string());
 11004	
 11005	    if let Some(line_number) = err.line {
 11006	        lines.push(String::new());
 11007	        lines.push(format!("I was partway through line {line_number} when the problem showed up."));
 11008	
 11009	        if let Some(source_line) = line_text(input, line_number) {
 11010	            lines.push(String::new());
 11011	            lines.push(format!("{line_number}| {source_line}"));
 11012	            lines.push(format!("{}{}", " ".repeat(line_number.to_string().len() + 2), "^"));
 11013	        }
 11014	    }
 11015	
 11016	    lines.push(String::new());
 11017	    lines.push(err.message.replace(" before task content", "\nbefore task content"));
 11018	    lines.push(String::new());
 11019	    lines.push(
 11020	        "Hint: check the markdown structure around the highlighted line and try again.".to_string(),
 11021	    );
 11022	
 11023	    lines.join("\n")
 11024	}
