  9446	fn initial_state_name(machine: &rhei_validator::StateMachine) -> MietteResult<String> {
  9447	    let initial_states = machine
  9448	        .states
  9449	        .iter()
  9450	        .filter(|(_, def)| def.initial)
  9451	        .map(|(name, _)| name.clone())
  9452	        .collect::<Vec<_>>();
  9453	
  9454	    match initial_states.as_slice() {
  9455	        [] => Err(miette!("state machine '{}' does not declare an initial state", machine.name)),
  9456	        [initial] => Ok(initial.clone()),
  9457	        many => Err(miette!(
  9458	            "state machine '{}' declares multiple initial states: {}",
  9459	            machine.name,
  9460	            many.join(", ")
  9461	        )),
  9462	    }
  9463	}
