  9570	fn rewrite_all_states_to_initial(raw: &str, initial_state: &str) -> MietteResult<String> {
  9571	    let lines: Vec<&str> = raw.lines().collect();
  9572	    let mut result = Vec::with_capacity(lines.len());
  9573	    let mut expecting_state = false;
  9574	    let mut rewrites = 0usize;
  9575	
  9576	    let task_heading_re =
  9577	        regex::Regex::new(r#"^#{3,6}\s+[A-Za-z][A-Za-z0-9_-]*\s+[A-Za-z0-9][A-Za-z0-9_.\-]*:\s+"#)
  9578	            .expect("task heading regex compiles");
  9579	
  9580	    for line in &lines {
  9581	        if task_heading_re.is_match(line) {
  9582	            if expecting_state {
  9583	                return Err(miette!("could not find **State:** line before the next task header"));
  9584	            }
  9585	            expecting_state = true;
  9586	            result.push((*line).to_string());
  9587	            continue;
  9588	        }
  9589	
  9590	        if expecting_state && line.starts_with("**State:**") {
  9591	            let formatted = format!("**State:** {}", format_state_metadata_value(initial_state));
  9592	            result.push(formatted);
  9593	            expecting_state = false;
  9594	            rewrites += 1;
  9595	            continue;
  9700	/// Each entry is a markdown heading (`## from → to`) optionally followed by
  9701	/// a message body.  The file is created (with directories) on the first call.
  9702	fn append_result_entry(
  9703	    workspace_root: &Path,
  9704	    task_id: &str,
  9705	    from: &str,
  9706	    to: &str,
  9707	    message: Option<&str>,
  9708	) -> MietteResult<()> {
  9709	    let results_dir = workspace_root.join("runtime").join("results");
  9710	    fs::create_dir_all(&results_dir)
  9711	        .map_err(|err| miette!("failed to create runtime/results directory: {err}"))?;
  9712	    let result_file = results_dir.join(format!("{}.md", task_id));
  9713	
  9714	    use std::fs::OpenOptions;
  9715	    let mut file = OpenOptions::new()
  9716	        .create(true)
  9717	        .append(true)
  9718	        .open(&result_file)
  9719	        .map_err(|err| miette!("failed to open result file: {err}"))?;
  9720	
  9721	    writeln!(file, "## {} \u{2192} {}", from, to)
  9722	        .map_err(|err| miette!("failed to write result entry: {err}"))?;
  9723	    if let Some(msg) = message {
  9724	        writeln!(file).map_err(|err| miette!("failed to write result entry: {err}"))?;
  9725	        writeln!(file, "{}", msg).map_err(|err| miette!("failed to write result entry: {err}"))?;
  9726	    }
  9727	    writeln!(file).map_err(|err| miette!("failed to write result entry: {err}"))?;
  9728	
  9729	    Ok(())
  9730	}
