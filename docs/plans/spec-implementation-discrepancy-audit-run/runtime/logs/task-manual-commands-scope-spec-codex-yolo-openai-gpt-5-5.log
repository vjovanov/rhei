  8670	/// Find tasks that are ready to advance: not in a terminal or gating state
  8671	/// and all prior dependencies are satisfied.
  8672	///
  8673	/// Returns task references in source order.
  8674	fn find_ready_tasks<'a>(
  8675	    rhei: &'a rhei_core::ast::Rhei,
  8676	    machine: &rhei_validator::StateMachine,
  8677	) -> Vec<&'a rhei_core::ast::Task> {
  8678	    use std::collections::HashMap;
  8679	
  8680	    // Build a map of task id → current state for dependency lookups.
  8681	    let state_map: HashMap<&TaskId, String> = rhei
  8682	        .tasks
  8683	        .iter()
  8684	        .map(|t| (&t.id, normalized_state_name(t.state.as_str(), machine)))
  8685	        .collect();
  8686	
  8687	    let mut ready = Vec::new();
  8688	
  8689	    for task in &rhei.tasks {
  8690	        let current_state = task.state.as_str();
  8691	
  8692	        // Skip tasks already in a terminal or gating state.
  8693	        let normalized_state = normalized_state_name(current_state, machine);
  8694	        if is_terminal_state(current_state, machine)
  8695	            || machine.states.get(&normalized_state).map(|def| def.gating).unwrap_or(false)
  8696	        {
  8697	            continue;
  8698	        }
  8699	
  8700	        // Check that all prior dependencies are satisfied.
  8701	        let all_priors_done = task.prior.iter().all(|dep_id| {
  8702	            state_map.get(dep_id).map(|s| dependency_is_satisfied(s, machine)).unwrap_or(false)
  8703	        });
  8704	
  8705	        if all_priors_done {
  8706	            ready.push(task);
  8707	        }
  8708	    }
  8709	
  8710	    ready
  8711	}
