    87	impl std::fmt::Display for StateMachineLoadError {
    88	    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
    89	        match self {
    90	            StateMachineLoadError::Io(e) => write!(f, "I/O error: {e}"),
    91	            StateMachineLoadError::Yaml(e) => write!(f, "YAML error: {e}"),
    92	            StateMachineLoadError::Invalid(message) => {
