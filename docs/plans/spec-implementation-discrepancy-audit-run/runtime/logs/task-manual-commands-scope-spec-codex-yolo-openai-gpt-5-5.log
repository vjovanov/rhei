  9732	/// Write `**Assignee:** <value>` into the given task's metadata block on disk.
  9733	///
  9734	/// The rewrite is atomic (temp file + rename) and holds an exclusive lock on
  9735	/// the file for the duration of the operation. No-op if the task already has
  9736	/// an assignee line.
  9737	fn write_task_assignee(task_file: &Path, task_id: &str, assignee: &str) -> MietteResult<()> {
  9738	    let handle = fs::File::open(task_file)
  9739	        .map_err(|err| file_io_report(task_file, "failed to open plan file", err))?;
  9740	    handle
  9741	        .lock_exclusive()
  9742	        .map_err(|err| file_io_report(task_file, "failed to acquire file lock", err))?;
  9743	
  9744	    let raw = fs::read_to_string(task_file)
  9745	        .map_err(|err| file_io_report(task_file, "failed to read plan file", err))?;
  9746	    let rewritten = insert_task_assignee(&raw, task_id, assignee)?;
  9747	
  9748	    let parent = task_file.parent().unwrap_or(Path::new("."));
  9749	    let mut tmp = tempfile::NamedTempFile::new_in(parent)
  9750	        .map_err(|err| miette!("failed to create temp file: {err}"))?;
  9751	    tmp.write_all(rewritten.as_bytes())
  9752	        .map_err(|err| miette!("failed to write temp file: {err}"))?;
  9753	    tmp.persist(task_file).map_err(|err| miette!("failed to persist temp file: {err}"))?;
  9754	
  9755	    let _ = handle.unlock();
  9756	    Ok(())
  9757	}
