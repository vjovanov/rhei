    48	pub fn render_html(plans: &[Plan]) -> String {
    49	    let bundle: BTreeMap<&str, &Plan> =
    50	        plans.iter().map(|plan| (plan.key.as_str(), plan)).collect();
    51	    let data = serde_json::to_string(&bundle).expect("plan bundle should always serialize");
    52	    TEMPLATE.replace(DATA_PLACEHOLDER, &escape_json_for_html_script(&data))
