  5370	/// Extract the current state of a task from raw markdown content.
  5371	///
  5372	/// Tries full-plan parsing first, falls back to workspace task-file parsing.
  5373	fn find_task_current_state(
  5374	    raw: &str,
  5375	    file_path: &Path,
  5376	    target_id: &TaskId,
  5377	    task_id_str: &str,
