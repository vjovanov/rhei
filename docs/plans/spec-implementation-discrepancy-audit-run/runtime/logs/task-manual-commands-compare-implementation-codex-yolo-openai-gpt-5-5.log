    87	fn main() -> ExitCode {
    88	    let args: Vec<String> = env::args().skip(1).collect();
    89	    let slice: Vec<&str> = args.iter().map(String::as_str).collect();
    90	    match slice.as_slice() {
    90	    match slice.as_slice() {
    91	        ["examples", "list"] => {
    92	            cmd_list();
    93	            ExitCode::SUCCESS
    94	        }
    95	        ["examples", "validate", "--all"] => cmd_validate_all(),
    96	        ["examples", "validate", name] => cmd_validate_one(name),
    97	        ["examples", "run", name] => cmd_run(name, false),
    98	        ["examples", "run", name, "--viz"] | ["examples", "run", "--viz", name] => {
    99	            cmd_run(name, true)
   100	        }
   101	        ["examples", "viz", "--all"] => cmd_viz_all(),
   102	        ["examples", "viz", name] => cmd_viz_one(name, false),
   103	        ["examples", "viz", name, "--open"] | ["examples", "viz", "--open", name] => {
   104	            cmd_viz_one(name, true)
   105	        }
   106	        _ => {
   107	            usage();
   108	            ExitCode::from(2)
   109	        }
   110	    }
   111	}
   112	
   113	fn cmd_list() {
   114	    let width = EXAMPLES.iter().map(|e| e.name.len()).max().unwrap_or(0);
   115	    for ex in EXAMPLES {
   116	        let tag = if ex.runnable { "validate, run" } else { "validate" };
   117	        println!("  {:<width$}  {}", ex.name, tag, width = width);
   118	    }
   119	}
