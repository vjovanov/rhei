  5385	
  5386	    // Try workspace task-file parse.
  5387	    if let Ok(tasks) = rhei_core::parser::parse_workspace_tasks(raw) {
  5388	        if let Some(task) = tasks.iter().find(|t| &t.id == target_id) {
  5389	            return Ok(task.state.as_str().to_string());
  5390	        }
  5391	    }
  5392	
  5393	    Err(miette!("task '{}' not found in {}", task_id_str, file_path.display()))
  5394	}
