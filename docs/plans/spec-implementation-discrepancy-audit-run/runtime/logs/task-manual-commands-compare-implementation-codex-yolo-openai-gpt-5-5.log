    75	fn usage() {
    76	    eprintln!("Usage: cargo xtask <command> [args]");
    77	    eprintln!();
    78	    eprintln!("Commands:");
    79	    eprintln!("  examples list                  List all known examples");
    80	    eprintln!("  examples validate <name>       Validate one example");
    81	    eprintln!("  examples validate --all        Validate every example");
    82	    eprintln!("  examples run <name> [--viz]    Run a runnable example in a tmp copy");
