   125	fn cmd_validate_all() -> ExitCode {
   126	    let mut failed: Vec<&str> = Vec::new();
   127	    for ex in EXAMPLES {
   128	        println!("==> validate {}", ex.name);
   129	        if !run_validate(ex) {
   130	            failed.push(ex.name);
   131	        }
   132	    }
   133	    if failed.is_empty() {
   134	        println!("\nAll {} examples validated.", EXAMPLES.len());
   135	        ExitCode::SUCCESS
   136	    } else {
   137	        eprintln!("\nFailed: {}", failed.join(", "));
   138	        ExitCode::FAILURE
   139	    }
