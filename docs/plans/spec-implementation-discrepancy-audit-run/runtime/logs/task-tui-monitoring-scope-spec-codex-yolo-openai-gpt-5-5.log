     9	/// Append-only writer for `runtime/transitions.log`.
    10	///
    11	/// Each `SlotAssigned` produces one line; its paired `SlotReleased` produces
    12	/// a second line with `exit=`, `duration=`, and `outcome=` key/value pairs.
    13	/// Journal errors never abort a run — they are logged to stderr and swallowed.
    14	pub struct JournalSink {
    15	    inner: Mutex<Inner>,
    16	    workspace_root: PathBuf,
    17	}
    18	
    19	struct Inner {
    20	    writer: Option<BufWriter<File>>,
    21	    path: PathBuf,
    22	}
    23	
    24	impl JournalSink {
    25	    /// Open (or create) `<workspace_root>/runtime/transitions.log` in append
    26	    /// mode. Missing parent directories are created.
    27	    pub fn open(workspace_root: impl AsRef<Path>) -> std::io::Result<Self> {
    28	        let workspace_root = workspace_root.as_ref().to_path_buf();
    29	        let runtime_dir = workspace_root.join("runtime");
    30	        fs::create_dir_all(&runtime_dir)?;
    31	        let path = runtime_dir.join("transitions.log");
    32	        let file = OpenOptions::new().create(true).append(true).open(&path)?;
    33	        Ok(Self {
    34	            workspace_root,
    35	            inner: Mutex::new(Inner { writer: Some(BufWriter::new(file)), path }),
    36	        })
    37	    }
    38	
    39	    fn write_line(&self, line: &str) {
    40	        let mut guard = match self.inner.lock() {
    41	            Ok(g) => g,
    42	            Err(p) => p.into_inner(),
    43	        };
    44	        if let Some(writer) = guard.writer.as_mut() {
    45	            if let Err(err) = writer.write_all(line.as_bytes()) {
    46	                eprintln!("warning: journal write failed: {}", err);
    47	                guard.writer = None;
    48	                return;
    49	            }
    50	            if let Err(err) = writer.flush() {
    51	                eprintln!("warning: journal flush failed: {}", err);
    52	                guard.writer = None;
    53	            }
    54	        }
    55	    }
    56	
    57	    /// Resolve a path as workspace-relative when inside the workspace.
    58	    fn format_path(&self, path: &Path) -> String {
    59	        match path.strip_prefix(&self.workspace_root) {
    60	            Ok(rel) => rel.display().to_string(),
    61	            Err(_) => path.display().to_string(),
    62	        }
    63	    }
    64	
    65	    /// Path of the underlying journal file (primarily for tests).
    66	    pub fn path(&self) -> PathBuf {
    67	        let guard = match self.inner.lock() {
    68	            Ok(g) => g,
    69	            Err(p) => p.into_inner(),
    70	        };
    71	        guard.path.clone()
    72	    }
    73	}
