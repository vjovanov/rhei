    75	impl EventSink for JournalSink {
    76	    fn emit(&self, event: RunEvent) {
    77	        match event {
    78	            RunEvent::SlotAssigned { task, from, to, log_path, wall_clock, .. } => {
    79	                let ts = format_rfc3339(wall_clock);
    80	                let log = self.format_path(&log_path);
    81	                let line = format!("{ts}  {task}  {from}\u{2192}{to}  {log}\n");
    82	                self.write_line(&line);
    83	            }
    84	            RunEvent::SlotReleased {
    85	                task,
    86	                from,
    87	                to,
    88	                log_path,
    89	                outcome,
    90	                wall_clock,
    91	                exit_code,
    92	                duration_ms,
    93	                ..
    94	            } => {
    95	                let ts = format_rfc3339(wall_clock);
    96	                let log = self.format_path(&log_path);
    97	                let outcome_str = match &outcome {
    98	                    TaskOutcome::Completed => "completed",
    99	                    TaskOutcome::Failed(_) => "failed",
   100	                    TaskOutcome::Cancelled => "cancelled",
   101	                    TaskOutcome::TimedOut => "timeout",
   102	                };
   103	                let mut meta_parts: Vec<String> = Vec::new();
   104	                if let Some(code) = exit_code {
   105	                    meta_parts.push(format!("exit={code}"));
   106	                }
   107	                meta_parts.push(format!("duration={}", format_duration(duration_ms)));
   108	                meta_parts.push(format!("outcome={outcome_str}"));
   109	                let meta = meta_parts.join(",");
   110	                let line = format!("{ts}  {task}  {from}\u{2192}{to}  {log}  {meta}\n");
   111	                self.write_line(&line);
   112	            }
   113	            _ => {}
   114	        }
   115	    }
   116	}
