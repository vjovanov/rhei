   611	    #[test]
   612	    fn slot_lines_reserve_rows_for_later_slots() {
   613	        let mut state = UiState::new(3, 3);
   614	        for slot in 0..3 {
   615	            state.apply(&RunEvent::SlotAssigned {
   616	                slot,
   617	                task: format!("task-{slot}"),
   618	                from: "fetch".to_string(),
