   111	/// Composite sink that forwards every event to each inner sink in order.
   112	#[derive(Clone)]
   113	pub struct Tee {
   114	    inners: Arc<Vec<Arc<dyn EventSink>>>,
   115	}
   116	
   117	impl Tee {
   118	    pub fn new(sinks: Vec<Arc<dyn EventSink>>) -> Self {
   119	        Self { inners: Arc::new(sinks) }
   120	    }
   121	}
   122	
   123	impl EventSink for Tee {
   124	    fn emit(&self, event: RunEvent) {
   125	        for sink in self.inners.iter() {
   126	            sink.emit(event.clone());
   127	        }
   128	    }
   129	}
