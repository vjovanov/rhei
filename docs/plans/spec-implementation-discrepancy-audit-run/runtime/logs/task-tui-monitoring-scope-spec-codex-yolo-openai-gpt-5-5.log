   620	                agent: Some("codex".to_string()),
   621	                log_path: PathBuf::from(format!("task-{slot}.log")),
   622	                started_at: Instant::now(),
   623	                wall_clock: SystemTime::now(),
   624	            });
   625	        }
   626	        for i in 0..10 {
   627	            state.apply(&RunEvent::AgentOutput {
   628	                slot: 0,
   629	                task: "task-0".to_string(),
   630	                stream: AgentStream::Stdout,
