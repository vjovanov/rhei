  7172	                        match child.try_wait() {
  7173	                            Ok(Some(status)) => break Ok(status),
  7174	                            _ => {
  7175	                                let _ = child.kill();
  7176	                                break child.wait().map_err(|e| {
  7177	                                    miette!("failed to wait for program after kill: {e}")
  7178	                                });
  7179	                            }
  7180	                        }
  7181	                    }
  7182	                    std::thread::sleep(Duration::from_millis(200));
  7183	                }
  7184	                Err(e) => break Err(miette!("error waiting for program: {e}")),
  7185	            }
  7186	        }
