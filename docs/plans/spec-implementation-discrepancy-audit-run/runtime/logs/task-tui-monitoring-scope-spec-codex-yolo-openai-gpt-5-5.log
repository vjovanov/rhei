    10	/// Caller-selected frontend override.
    11	#[derive(Debug, Clone, Copy, PartialEq, Eq)]
    12	pub enum FrontendKind {
    13	    /// Force TUI mode.
    14	    Tui,
    15	    /// Force plain stdout mode.
    16	    Stdout,
    17	    /// Auto-detect from `stdout.is_terminal()`.
    18	    Auto,
    19	}
    20	
    21	/// Result of selecting a frontend: an event sink and a flag describing which
    22	/// frontend was picked (so the engine can suppress stdout when a TUI is in
    23	/// charge of the terminal).
    24	pub struct Frontend {
    25	    pub sink: Arc<dyn EventSink>,
    26	    /// True when a `TuiSink` is the active frontend. The engine uses this to
    27	    /// decide whether its own `println!` output should be suppressed.
    28	    pub is_tui: bool,
    29	    _tui: Option<Arc<TuiSink>>,
    30	}
    31	
    32	/// Choose a frontend and compose it with a `JournalSink` into a single
    33	/// `EventSink`. The journal is always written; the frontend is either a
    34	/// `TuiSink` (interactive) or `StdoutSink` (backward-compatible).
    35	///
    36	/// `parallel` and `total_tasks` are passed to the TUI for its initial layout.
    37	/// When TUI construction fails (e.g., the backend cannot enter raw mode),
    38	/// this falls back to `StdoutSink` and logs a warning to stderr.
    39	pub fn select_frontend(
    40	    workspace_root: &Path,
    41	    kind: FrontendKind,
    42	    parallel: u16,
    43	    total_tasks: usize,
    44	) -> Frontend {
    45	    let want_tui = match kind {
    46	        FrontendKind::Tui => true,
    47	        FrontendKind::Stdout => false,
    48	        FrontendKind::Auto => std::io::stdout().is_terminal(),
    49	    };
    50	
    51	    let journal: Arc<dyn EventSink> = match JournalSink::open(workspace_root) {
    52	        Ok(j) => Arc::new(j),
    53	        Err(err) => {
    54	            eprintln!(
    55	                "warning: could not open transition journal at {}/runtime/transitions.log: {}",
    56	                workspace_root.display(),
    57	                err
    58	            );
    59	            Arc::new(NullSink)
    60	        }
    61	    };
    62	
    63	    if want_tui {
    64	        match TuiSink::start(parallel.max(1), total_tasks) {
    65	            Ok(tui) => {
    66	                let tui = Arc::new(tui);
    67	                let frontend: Arc<dyn EventSink> = tui.clone();
    68	                let sink = Arc::new(Tee::new(vec![journal, frontend]));
    69	                return Frontend { sink, is_tui: true, _tui: Some(tui) };
    70	            }
    71	            Err(err) => {
    72	                eprintln!("warning: could not start TUI ({}); falling back to stdout", err);
    73	            }
    74	        }
    75	    }
    76	
    77	    let stdout: Arc<dyn EventSink> = Arc::new(StdoutSink::new());
    78	    let sink = Arc::new(Tee::new(vec![journal, stdout]));
    79	    Frontend { sink, is_tui: false, _tui: None }
    80	}
