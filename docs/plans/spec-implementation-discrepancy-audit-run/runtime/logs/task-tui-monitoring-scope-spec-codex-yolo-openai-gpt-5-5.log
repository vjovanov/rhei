  9973	        RenderFormat::Github => Ok(rhei_output::GithubIssuesOutput {
  9974	            include_content: !no_content,
  9975	            include_metadata: !no_metadata,
  9976	        }
  9977	        .to_markdown(rhei)),
  9978	        RenderFormat::Progress => {
  9979	            let color = should_use_color(no_color);
  9980	            Ok(rhei_output::ProgressReportOutput { color, show_dependencies: true }.to_string(rhei))
  9981	        }
  9982	    }
  9983	}
  9984	
  9985	/// Decide whether ANSI color should be emitted for progress output.
  9986	///
  9987	/// Precedence: explicit `--no-color` always wins. Otherwise honour the
  9988	/// `NO_COLOR` environment variable (any non-empty value disables color) and
  9989	/// fall back to stdout TTY detection.
  9990	fn should_use_color(no_color_flag: bool) -> bool {
  9991	    use std::io::IsTerminal;
  9992	    if no_color_flag {
  9993	        return false;
  9994	    }
  9995	    if std::env::var_os("NO_COLOR").is_some_and(|v| !v.is_empty()) {
  9996	        return false;
  9997	    }
  9998	    std::io::stdout().is_terminal()
  9999	}
