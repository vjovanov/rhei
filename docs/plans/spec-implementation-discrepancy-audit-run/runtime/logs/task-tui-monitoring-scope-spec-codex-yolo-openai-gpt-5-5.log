  7018	fn build_program_command(
  7019	    resolved: &ResolvedProgram,
  7020	    render_context: &RuntimeTemplateContext<'_>,
  7021	) -> MietteResult<std::process::Command> {
  7022	    let working_dir = resolved
  7023	        .program
  7024	        .working_directory
  7025	        .as_deref()
  7026	        .map(|path| resolve_runtime_template_text(path, render_context))
  7027	        .map(|path| render_context.workspace_root.join(path))
  7028	        .unwrap_or_else(|| render_context.workspace_root.to_path_buf());
  7029	
  7030	    let mut cmd = if resolved.program.shell {
  7031	        let mut command = std::process::Command::new("sh");
  7032	        command.arg("-c");
  7033	        let rendered = match &resolved.program.command {
  7034	            ProgramCommand::Shell(command) => {
  7035	                resolve_runtime_template_text(command, render_context)
  7036	            }
  7037	            ProgramCommand::Exec(args) => args
  7038	                .iter()
  7039	                .map(|arg| resolve_runtime_template_text(arg, render_context))
  7040	                .collect::<Vec<_>>()
  7041	                .join(" "),
  7042	        };
  7043	        command.arg(rendered);
  7044	        command
  7045	    } else {
  7046	        let ProgramCommand::Exec(args) = &resolved.program.command else {
  7047	            return Err(miette!("program command cannot disable shell when command is a string"));
  7048	        };
  7049	        let rendered = args
  7050	            .iter()
  7051	            .map(|arg| resolve_runtime_template_text(arg, render_context))
  7052	            .collect::<Vec<_>>();
  7053	        let mut command = std::process::Command::new(&rendered[0]);
  7054	        for arg in &rendered[1..] {
  7055	            command.arg(arg);
  7056	        }
  7057	        command
  7058	    };
  7059	
  7060	    cmd.current_dir(working_dir)
  7061	        .env("RHEI_PLAN_PATH", render_context.plan_path)
  7062	        .env("RHEI_TASK_ID", render_context.task.id.to_string())
  7063	        .env("RHEI_STATE", render_context.state_name)
  7064	        .env(
  7065	            "RHEI_VISIT_COUNT",
  7066	            render_visit_count(
  7067	                render_context.metadata,
  7068	                &render_context.task.id,
  7069	                render_context.state_name,
  7070	                render_context.current_state_raw,
  7071	                render_context.machine,
  7072	            )
  7073	            .to_string(),
  7074	        );
  7075	    if let Some(path) = render_context.state_machine_path {
  7076	        cmd.env("RHEI_STATE_MACHINE_PATH", path);
  7077	    }
  7078	    if let Some(model) = render_context.model {
  7079	        cmd.env("RHEI_MODEL", model);
  7080	    }
  7081	
  7082	    // Expose declared input artifact paths and existence flags so programs
  7083	    // can branch on optional inputs without shelling out to test -f.
  7084	    let input_visit_count = Some(render_visit_count(
  7085	        render_context.metadata,
  7086	        &render_context.task.id,
  7087	        render_context.state_name,
  7088	        render_context.current_state_raw,
  7089	        render_context.machine,
  7090	    ));
