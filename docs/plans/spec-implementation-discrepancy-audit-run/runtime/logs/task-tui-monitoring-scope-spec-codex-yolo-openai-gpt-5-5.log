   532	        let action = handle_key_event(&mut state, KeyCode::Char('c'), KeyModifiers::CONTROL);
   533	
   534	        assert!(matches!(action, InputAction::ForwardSigint));
   535	        assert_eq!(
   536	            state.journal.back().map(String::as_str),
   537	            Some("(ctrl+c received — forwarding SIGINT)")
