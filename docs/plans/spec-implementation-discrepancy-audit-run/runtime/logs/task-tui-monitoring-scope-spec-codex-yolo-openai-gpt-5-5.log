  9955	/// Render a parsed rhei into the requested output representation.
  9956	fn render_rhei(
  9957	    rhei: &rhei_core::ast::Rhei,
  9958	    format: RenderFormat,
  9959	    pretty: bool,
  9960	    no_color: bool,
