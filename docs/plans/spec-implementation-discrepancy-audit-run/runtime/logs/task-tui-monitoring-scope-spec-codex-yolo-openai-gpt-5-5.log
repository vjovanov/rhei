    70	        self.journal.push_back(line);
    71	    }
    72	
    73	    fn apply(&mut self, event: &RunEvent) {
    74	        match event {
    75	            RunEvent::RunStarted { parallel, total_tasks, .. } => {
    76	                self.parallel = (*parallel).max(1);
    77	                self.total_tasks = *total_tasks;
    78	                self.slots = vec![SlotState::default(); self.parallel as usize];
    79	                self.push_journal(format!(
    80	                    "run started — parallel={} total={}",
    81	                    self.parallel, self.total_tasks
    82	                ));
    83	            }
    84	            RunEvent::PassStarted { pass, ready } => {
    85	                self.push_journal(format!("pass {}: {} ready", pass, ready.len()));
    86	            }
    87	            RunEvent::SlotAssigned {
    88	                slot, task, from, to, agent, log_path, started_at, ..
    89	            } => {
    90	                if let Some(s) = self.slots.get_mut(*slot as usize) {
    91	                    s.task = Some(task.clone());
    92	                    s.agent = agent.clone();
    93	                    s.state = to.clone();
    94	                    s.started_at = Some(*started_at);
    95	                    s.log_path = Some(log_path.clone());
    96	                    s.last_event_display = Some(format!("{from}→{to}"));
    97	                }
    98	                self.push_journal(format!("▶ slot {}: {} {}→{}", slot, task, from, to));
    99	            }
   100	            RunEvent::SlotReleased { slot, task, outcome, duration_ms, .. } => {
   101	                let sym = match outcome {
   102	                    TaskOutcome::Completed => "✓",
   103	                    TaskOutcome::Failed(_) => "✗",
   104	                    TaskOutcome::Cancelled => "⊘",
   105	                    TaskOutcome::TimedOut => "⏱",
   106	                };
   107	                if let Some(s) = self.slots.get_mut(*slot as usize) {
   108	                    *s = SlotState::default();
   109	                }
   110	                self.push_journal(format!("{} slot {}: {} ({}ms)", sym, slot, task, duration_ms));
   111	            }
   112	            RunEvent::AgentOutput { slot, stream, line, .. } => {
   113	                let line = sanitize_terminal_text(line);
   114	                let stream_label = stream_label(*stream);
   115	                let journal_prefix = match stream {
   116	                    AgentStream::Stdout => "·",
   117	                    AgentStream::Stderr => "!",
   118	                };
   119	                if let Some(s) = self.slots.get_mut(*slot as usize) {
   120	                    if s.traffic.len() == SLOT_TRAFFIC_BUFFER {
   121	                        s.traffic.pop_front();
   122	                    }
   123	                    s.traffic.push_back(TrafficLine { stream: *stream, text: line.clone() });
   124	                }
   125	                self.push_journal(format!(
   126	                    "{journal_prefix} [slot {slot} {stream_label}] {}",
   127	                    truncate_chars(&line, JOURNAL_TRAFFIC_WIDTH)
   128	                ));
   129	            }
   130	            RunEvent::PassEnded { pass, progressed } => {
   131	                self.push_journal(format!("pass {} ended — progressed={}", pass, progressed));
   132	            }
   133	            RunEvent::RunFinished { summary } => {
   134	                self.finished = true;
   135	                self.push_journal(format!(
   136	                    "run finished — agents={} programs={} terminal={}/{}",
   137	                    summary.agents_spawned,
   138	                    summary.programs_spawned,
   139	                    summary.terminal_tasks,
   140	                    summary.total_tasks
   141	                ));
   142	            }
   143	            RunEvent::Message { level, text } => {
   144	                let prefix = match level {
   145	                    MessageLevel::Info => "·",
   146	                    MessageLevel::Warn => "!",
   147	                    MessageLevel::Error => "✗",
   148	                };
   149	                self.push_journal(format!("{prefix} {text}"));
   150	            }
   151	        }
   152	    }
   153	}
   154	
   155	/// Live TUI frontend backed by ratatui + crossterm.
   156	///
   157	/// The sink owns a bounded event channel and a render thread. Drop (or
   158	/// `finish`) joins the render thread and restores the terminal.
   159	pub struct TuiSink {
   160	    tx: Sender<Msg>,
   161	    join: Mutex<Option<JoinHandle<()>>>,
   162	}
   163	
   164	enum Msg {
   165	    Event(RunEvent),
   166	    Shutdown,
   167	}
   168	
   169	enum InputAction {
   170	    Continue,
   171	    ForwardSigint,
   172	}
   173	
   174	impl TuiSink {
   175	    pub fn start(parallel: u16, total_tasks: usize) -> io::Result<Self> {
   176	        enable_raw_mode()?;
   177	        let mut stdout = io::stdout();
   178	        stdout.execute(EnterAlternateScreen)?;
   179	
   180	        // Panic hook: if the engine panics, restore the terminal before the
   181	        // default handler prints its message, so the user sees the panic.
   182	        let prev_hook = std::panic::take_hook();
   183	        std::panic::set_hook(Box::new(move |info| {
   184	            let _ = disable_raw_mode();
   185	            let _ = io::stdout().execute(LeaveAlternateScreen);
   186	            prev_hook(info);
   187	        }));
   188	
   189	        let backend = CrosstermBackend::new(stdout);
   190	        let terminal = Terminal::new(backend)?;
   191	
   192	        let (tx, rx) = bounded::<Msg>(CHANNEL_CAPACITY);
   193	        let state = Arc::new(Mutex::new(UiState::new(parallel, total_tasks)));
   194	
   195	        let handle = thread::spawn({
   196	            let state = Arc::clone(&state);
   197	            move || render_loop(terminal, rx, state)
   198	        });
   199	
   200	        Ok(Self { tx, join: Mutex::new(Some(handle)) })
   201	    }
   202	
   203	    /// Signal the render thread to exit and wait for it. Safe to call twice.
   204	    pub fn finish(&self) {
   205	        let _ = self.tx.send(Msg::Shutdown);
   206	        let mut guard = match self.join.lock() {
   207	            Ok(g) => g,
   208	            Err(p) => p.into_inner(),
   209	        };
   210	        if let Some(handle) = guard.take() {
   211	            let _ = handle.join();
   212	        }
   213	    }
   214	}
   215	
   216	impl Drop for TuiSink {
   217	    fn drop(&mut self) {
   218	        self.finish();
   219	    }
   220	}
   221	
   222	impl EventSink for TuiSink {
   223	    fn emit(&self, event: RunEvent) {
   224	        if matches!(event, RunEvent::AgentOutput { .. }) {
   225	            // Agent output is best-effort because the durable per-task log has
   226	            // the full transcript. Dropping here keeps output bursts from
   227	            // filling the shared channel indefinitely.
   228	            let _ = self.tx.try_send(Msg::Event(event));
   229	        } else {
   230	            // Lifecycle events define slot state. Preserve them even during
   231	            // output floods so the UI cannot get stuck showing stale work.
   232	            let _ = self.tx.send(Msg::Event(event));
   233	        }
   234	    }
   235	}
   236	
   237	fn render_loop(
   238	    mut terminal: Terminal<CrosstermBackend<Stdout>>,
   239	    rx: crossbeam_channel::Receiver<Msg>,
   240	    state: Arc<Mutex<UiState>>,
   241	) {
   242	    let tick = Duration::from_millis(250);
   243	    let mut last_draw = Instant::now().checked_sub(tick).unwrap_or_else(Instant::now);
   244	
   245	    loop {
   246	        // Drain any pending events until the channel is empty or timeout.
   247	        let deadline = Instant::now() + tick;
   248	        loop {
   249	            let remaining = deadline.saturating_duration_since(Instant::now());
   250	            match rx.recv_timeout(remaining) {
   251	                Ok(Msg::Event(event)) => {
   252	                    if let Ok(mut s) = state.lock() {
   253	                        s.apply(&event);
   254	                    }
   255	                }
   256	                Ok(Msg::Shutdown) => {
   257	                    draw(&mut terminal, &state);
   258	                    break_out(terminal);
   259	                    return;
   260	                }
   261	                Err(crossbeam_channel::RecvTimeoutError::Timeout) => break,
   262	                Err(crossbeam_channel::RecvTimeoutError::Disconnected) => {
   263	                    draw(&mut terminal, &state);
   264	                    break_out(terminal);
   265	                    return;
   266	                }
   267	            }
   268	        }
   269	
   270	        // Drain terminal input (non-blocking) so Ctrl+C etc. is visible in the
   271	        // logs. In raw mode Ctrl+C no longer generates SIGINT automatically,
   272	        // so the TUI has to forward it to the process itself.
   273	        while ctevent::poll(Duration::from_millis(0)).unwrap_or(false) {
   274	            if let Ok(CtEvent::Key(key)) = ctevent::read() {
   275	                let action = match state.lock() {
   276	                    Ok(mut s) => handle_key_event(&mut s, key.code, key.modifiers),
   277	                    Err(p) => {
   278	                        let mut s = p.into_inner();
   279	                        handle_key_event(&mut s, key.code, key.modifiers)
   280	                    }
   281	                };
   282	                if matches!(action, InputAction::ForwardSigint) {
   283	                    draw(&mut terminal, &state);
   284	                    break_out(terminal);
   285	                    let _ = forward_sigint_to_self();
   286	                    return;
   287	                }
   288	            }
   289	        }
   290	
   291	        if last_draw.elapsed() >= tick {
   292	            draw(&mut terminal, &state);
   293	            last_draw = Instant::now();
   294	        }
   295	    }
   296	}
   297	
   298	fn break_out(mut terminal: Terminal<CrosstermBackend<Stdout>>) {
   299	    let _ = terminal.show_cursor();
   300	    let _ = disable_raw_mode();
   301	    let _ = io::stdout().execute(LeaveAlternateScreen);
   302	}
   303	
   304	fn handle_key_event(state: &mut UiState, code: KeyCode, modifiers: KeyModifiers) -> InputAction {
   305	    if code == KeyCode::Char('c') && modifiers.contains(KeyModifiers::CONTROL) {
   306	        state.push_journal("(ctrl+c received — forwarding SIGINT)".to_string());
   307	        return InputAction::ForwardSigint;
   308	    }
   309	
   310	    InputAction::Continue
   311	}
   312	
   313	fn forward_sigint_to_self() -> nix::Result<()> {
   314	    raise(Signal::SIGINT)
   315	}
   316	
   317	fn draw(terminal: &mut Terminal<CrosstermBackend<Stdout>>, state: &Arc<Mutex<UiState>>) {
   318	    let snapshot = match state.lock() {
   319	        Ok(s) => s.clone_snapshot(),
   320	        Err(p) => p.into_inner().clone_snapshot(),
   321	    };
   322	
   323	    let _ = terminal.draw(|f| {
   324	        let area = f.size();
   325	        if area.height < 4 || area.width < 20 {
   326	            // Terminal too small — render a single line.
   327	            let msg = Paragraph::new("rhei run (terminal too small)")
   328	                .style(Style::default().fg(Color::Yellow));
   329	            f.render_widget(msg, area);
   330	            return;
   331	        }
   332	
   333	        let chunks = Layout::default()
   334	            .direction(Direction::Vertical)
   335	            .constraints([
   336	                Constraint::Length(3), // header
   337	                Constraint::Min(snapshot.parallel.max(1) + 2),
   338	                Constraint::Min(5), // journal pane
   339	            ])
   340	            .split(area);
   341	
   342	        render_header(f, chunks[0], &snapshot);
   343	        render_slots(f, chunks[1], &snapshot);
   344	        render_journal(f, chunks[2], &snapshot);
   345	    });
   346	}
   347	
   348	fn render_header(f: &mut ratatui::Frame, area: Rect, snapshot: &UiStateSnapshot) {
   349	    let active = snapshot.slots.iter().filter(|s| s.task.is_some()).count();
   350	    let line = Line::from(vec![
   351	        Span::styled("rhei run", Style::default().add_modifier(Modifier::BOLD)),
   352	        Span::raw(format!(
   353	            "  parallel={} active={} total_tasks={}{}",
   354	            snapshot.parallel,
   355	            active,
   356	            snapshot.total_tasks,
   357	            if snapshot.finished { "  [finished]" } else { "" },
   358	        )),
   359	    ]);
   360	    let block = Block::default().borders(Borders::BOTTOM);
   361	    f.render_widget(Paragraph::new(line).block(block), area);
   362	}
   363	
   364	fn render_slots(f: &mut ratatui::Frame, area: Rect, snapshot: &UiStateSnapshot) {
   365	    let block = Block::default().title(" slots ").borders(Borders::ALL);
   366	    let inner = block.inner(area);
   367	    f.render_widget(block, area);
   368	    if inner.height == 0 {
   369	        return;
   370	    }
   371	
   372	    let lines = slot_lines(snapshot, inner.width, inner.height);
   373	    f.render_widget(Paragraph::new(lines), inner);
   374	}
   375	
   376	fn slot_lines(snapshot: &UiStateSnapshot, width: u16, height: u16) -> Vec<Line<'static>> {
   377	    let mut lines: Vec<Line> = Vec::new();
   378	    for (idx, s) in snapshot.slots.iter().enumerate() {
   379	        let remaining_slots = snapshot.slots.len().saturating_sub(idx + 1);
   380	        let available_rows = height as usize;
   381	        if lines.len() >= available_rows {
   382	            break;
   383	        }
   384	
   385	        let i = idx as Slot;
   386	        if let Some(task) = &s.task {
   387	            let elapsed = s.started_at.map(|t| t.elapsed()).unwrap_or_default();
   388	            let elapsed_s = elapsed.as_secs();
   389	            let transition = s.last_event_display.as_deref().unwrap_or(&s.state);
   390	            let task_label = s
   391	                .agent
   392	                .as_ref()
   393	                .map(|agent| format!("{task} ({agent})"))
   394	                .unwrap_or_else(|| task.clone());
   395	            lines.push(Line::from(vec![
   396	                Span::styled(format!("[{i:>2}] "), Style::default().fg(Color::Cyan)),
   397	                Span::styled(
   398	                    format!("{task_label:<28}"),
   399	                    Style::default().add_modifier(Modifier::BOLD),
   400	                ),
   401	                Span::raw(" "),
   402	                Span::styled(transition.to_string(), Style::default().fg(Color::Green)),
   403	                Span::raw(format!("  {:>4}s", elapsed_s)),
   404	            ]));
   405	            let traffic_room =
   406	                available_rows.saturating_sub(lines.len()).saturating_sub(remaining_slots);
   407	            let traffic_tail = traffic_room.min(5);
   408	            if traffic_tail > 0 {
   409	                for traffic in s.traffic.iter().rev().take(traffic_tail).rev() {
   410	                    let (label, style) = match traffic.stream {
   411	                        AgentStream::Stdout => ("out", Style::default().fg(Color::Gray)),
   412	                        AgentStream::Stderr => ("err", Style::default().fg(Color::Yellow)),
   413	                    };
   414	                    lines.push(Line::from(vec![
   415	                        Span::raw("     "),
   416	                        Span::styled(format!("{label}> "), style),
   417	                        Span::raw(truncate_chars(&traffic.text, width.saturating_sub(11) as usize)),
   418	                    ]));
   419	                }
   420	            }
   421	        } else {
   422	            lines.push(Line::from(vec![
   423	                Span::styled(format!("[{i:>2}] "), Style::default().fg(Color::DarkGray)),
   424	                Span::styled("— idle —", Style::default().fg(Color::DarkGray)),
   425	            ]));
   426	        }
   427	    }
   428	    lines
   429	}
   430	
   431	fn stream_label(stream: AgentStream) -> &'static str {
   432	    match stream {
   433	        AgentStream::Stdout => "stdout",
   434	        AgentStream::Stderr => "stderr",
   435	    }
   436	}
   437	
   438	fn truncate_chars(value: &str, max_chars: usize) -> String {
   439	    if max_chars == 0 {
   440	        return String::new();
   441	    }
   442	    let mut chars = value.chars();
   443	    let mut out = String::new();
   444	    for _ in 0..max_chars {
   445	        if let Some(ch) = chars.next() {
   446	            out.push(ch);
   447	        } else {
   448	            return out;
   449	        }
   450	    }
   451	    if chars.next().is_some() {
   452	        if max_chars > 1 {
   453	            out.pop();
   454	        }
   455	        out.push('…');
   456	    }
   457	    out
   458	}
   459	
   460	fn sanitize_terminal_text(value: &str) -> String {
   461	    let mut out = String::with_capacity(value.len());
   462	    let mut chars = value.chars().peekable();
   463	    while let Some(ch) = chars.next() {
   464	        if ch == '\u{1b}' {
   465	            if matches!(chars.peek(), Some('[')) {
   466	                chars.next();
   467	                for next in chars.by_ref() {
   468	                    if ('@'..='~').contains(&next) {
   469	                        break;
   470	                    }
   471	                }
   472	            }
   473	            continue;
   474	        }
   475	        if ch.is_control() && ch != '\t' {
   476	            continue;
   477	        }
   478	        out.push(ch);
   479	    }
   480	    out
   481	}
   482	
   483	fn render_journal(f: &mut ratatui::Frame, area: Rect, snapshot: &UiStateSnapshot) {
   484	    let block = Block::default().title(" journal ").borders(Borders::ALL);
   485	    let inner = block.inner(area);
   486	    f.render_widget(block, area);
   487	    if inner.height == 0 {
   488	        return;
   489	    }
   490	
   491	    let height = inner.height as usize;
   492	    let lines: Vec<Line> =
   493	        snapshot.journal.iter().rev().take(height).rev().map(|l| Line::from(l.clone())).collect();
   494	    f.render_widget(Paragraph::new(lines), inner);
   495	}
   496	
   497	struct UiStateSnapshot {
   498	    parallel: u16,
   499	    total_tasks: usize,
   500	    slots: Vec<SlotState>,
   501	    journal: Vec<String>,
   502	    finished: bool,
   503	}
   504	
   505	impl UiState {
   506	    fn clone_snapshot(&self) -> UiStateSnapshot {
   507	        UiStateSnapshot {
   508	            parallel: self.parallel,
   509	            total_tasks: self.total_tasks,
   510	            slots: self.slots.clone(),
   511	            journal: self.journal.iter().cloned().collect(),
   512	            finished: self.finished,
   513	        }
   514	    }
   515	}
