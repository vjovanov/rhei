  7197	        let _ = writeln!(f, "\n=== exit ===");
  7198	        let _ = writeln!(f, "code: {}", status.code().unwrap_or(-1));
  7199	        let _ = writeln!(f, "duration: {}s", start.elapsed().as_secs());
  7200	        let _ = writeln!(f, "===");
  7201	    }
  7202	
  7203	    Ok(status)
  7204	}
