  6850	/// Spawn an agent, capture output to a log file, and wait with timeout.
  6851	///
  6852	/// Returns the exit status (or an error on timeout/failure).
  6853	#[allow(clippy::too_many_arguments)]
  6854	fn spawn_and_wait_agent(
  6855	    resolved: &ResolvedAgent,
  6856	    prompt: &str,
  6857	    working_dir: &Path,
  6858	    plan_path: &Path,
  6859	    state_machine_path: Option<&Path>,
  6860	    task_id: &str,
  6861	    state_name: &str,
  6862	    tooling: &ResolvedTooling,
  6863	    log_path: &Path,
  6864	    slot: rhei_tui::Slot,
  6865	    sink: Arc<dyn rhei_tui::EventSink>,
  6866	) -> MietteResult<std::process::ExitStatus> {
  6867	    // Ensure log directory exists.
  6868	    if let Some(parent) = log_path.parent() {
  6869	        fs::create_dir_all(parent)
  6870	            .map_err(|e| miette!("failed to create log directory '{}': {e}", parent.display()))?;
  6871	    }
  6872	
  6873	    let log_file = Arc::new(Mutex::new(
  6874	        fs::File::create(log_path)
  6875	            .map_err(|e| miette!("failed to create log file '{}': {e}", log_path.display()))?,
  6876	    ));
  6877	
  6878	    // Write log header.
  6879	    with_agent_log(&log_file, |f| {
  6880	        writeln!(f, "=== rhei agent log ===")?;
  6881	        writeln!(f, "agent: {}", resolved.agent.id())?;
  6882	        if let Some(mode) = &resolved.mode {
  6883	            writeln!(f, "mode: {mode}")?;
  6884	        }
  6885	        if let Some(target) = &resolved.target {
  6886	            writeln!(f, "target: {}", target.selector())?;
  6887	        }
  6888	        if let Some(m) = &resolved.model {
  6889	            writeln!(f, "model: {m}")?;
  6890	        }
  6891	        writeln!(f, "task: {task_id}")?;
  6892	        writeln!(f, "state: {state_name}")?;
  6893	        if let Some(t) = resolved.timeout_secs {
  6894	            writeln!(f, "timeout: {t}s")?;
  6895	        }
  6896	        writeln!(f, "plan: {}", plan_path.display())?;
  6897	        let mcp_line = format_tooling_log_line(&tooling.mcp_servers, |e| {
  6898	            (e.id.as_str(), e.optional, e.definition.is_some())
  6899	        });
  6900	        if let Some(line) = mcp_line {
  6901	            writeln!(f, "mcp_servers: {line}")?;
  6902	        }
  6903	        let skill_line = format_tooling_log_line(&tooling.skills, |e| {
  6904	            (e.id.as_str(), e.optional, e.definition.is_some())
  6905	        });
  6906	        if let Some(line) = skill_line {
  6907	            writeln!(f, "skills: {line}")?;
  6908	        }
  6909	        writeln!(f, "===\n")?;
  6910	        f.flush()
  6911	    })
  6912	    .map_err(|e| miette!("failed to write log header '{}': {e}", log_path.display()))?;
  6913	
  6914	    let mut cmd = build_agent_command(
  6915	        resolved,
  6916	        prompt,
  6917	        working_dir,
  6918	        plan_path,
  6919	        state_machine_path,
  6920	        task_id,
  6921	        state_name,
  6922	        tooling,
  6923	    );
  6924	    cmd.stdout(std::process::Stdio::piped()).stderr(std::process::Stdio::piped());
  6925	
  6926	    let mut child =
  6927	        cmd.spawn().map_err(|e| miette!("failed to spawn agent '{}': {e}", resolved.agent.id()))?;
  6928	
  6929	    let stdout_handle = child.stdout.take().map(|stdout| {
  6930	        spawn_agent_output_reader(
  6931	            stdout,
  6932	            rhei_tui::AgentStream::Stdout,
  6933	            log_file.clone(),
  6934	            sink.clone(),
  6935	            slot,
  6936	            task_id.to_string(),
  6937	        )
  6938	    });
  6939	    let stderr_handle = child.stderr.take().map(|stderr| {
  6940	        spawn_agent_output_reader(
  6941	            stderr,
  6942	            rhei_tui::AgentStream::Stderr,
  6943	            log_file.clone(),
  6944	            sink.clone(),
  6945	            slot,
  6946	            task_id.to_string(),
  6947	        )
  6948	    });
  6949	
  6950	    // If stdin_prompt, write prompt to stdin.
  6951	    if resolved.profile.stdin_prompt {
  6952	        if let Some(mut stdin) = child.stdin.take() {
  6953	            use std::io::Write as _;
  6954	            let _ = stdin.write_all(prompt.as_bytes());
  6955	            drop(stdin);
  6956	        }
  6957	    }
  6958	
  6959	    let start = Instant::now();
  6960	
  6961	    // Wait with optional timeout.
  6962	    let status = if let Some(timeout_secs) = resolved.timeout_secs {
  6963	        let timeout = Duration::from_secs(timeout_secs);
  6964	        loop {
  6965	            match child.try_wait() {
  6966	                Ok(Some(status)) => break Ok(status),
  6967	                Ok(None) => {
  6968	                    if start.elapsed() > timeout {
  6969	                        // Send SIGTERM.
  6970	                        let pid = Pid::from_raw(child.id() as i32);
  6971	                        let _ = signal::kill(pid, Signal::SIGTERM);
  6972	                        // Grace period.
  6973	                        std::thread::sleep(AGENT_TERMINATE_GRACE);
  6974	                        match child.try_wait() {
  6975	                            Ok(Some(status)) => break Ok(status),
  6976	                            _ => {
  6977	                                let _ = child.kill(); // SIGKILL
  6978	                                break child.wait().map_err(|e| {
  6979	                                    miette!("failed to wait for agent after kill: {e}")
  6980	                                });
  6981	                            }
  6982	                        }
  6983	                    }
  6984	                    std::thread::sleep(Duration::from_millis(500));
  6985	                }
  6986	                Err(e) => break Err(miette!("error waiting for agent: {e}")),
  6987	            }
  6988	        }
  6989	    } else {
  6990	        child.wait().map_err(|e| miette!("failed to wait for agent: {e}"))
  6991	    }?;
  6992	
  6993	    if let Some(handle) = stdout_handle {
  6994	        drain_agent_output_reader(handle, rhei_tui::AgentStream::Stdout)?;
  6995	    }
  6996	    if let Some(handle) = stderr_handle {
  6997	        drain_agent_output_reader(handle, rhei_tui::AgentStream::Stderr)?;
  6998	    }
  6999	
  7000	    // Write log footer.
  7001	    with_agent_log(&log_file, |f| {
  7002	        writeln!(f, "\n=== exit ===")?;
  7003	        writeln!(f, "code: {}", status.code().unwrap_or(-1))?;
  7004	        let elapsed = start.elapsed();
  7005	        writeln!(f, "duration: {}s", elapsed.as_secs())?;
  7006	        writeln!(f, "===")?;
  7007	        f.flush()
  7008	    })
  7009	    .map_err(|e| miette!("failed to append to log file '{}': {e}", log_path.display()))?;
  7010	
  7011	    Ok(status)
  7012	}
