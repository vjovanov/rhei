  6279	/// Enforce the orchestrator Completion Authority contract:
  6280	/// every agent invocation that `rhei run` is about to spawn must resolve to
  6281	/// a finite timeout through the chain
  6282	/// `state.agent_timeout > models.<id>.agents.<agent>.timeout > agents.<id>.timeout > defaults.agent_timeout`.
  6283	///
  6284	/// This is the runtime counterpart to the Completion Authority / Completion
  6285	/// Condition rules in `docs/specs/rhei-agents.spec.md`. A missing timeout
  6286	/// would mean the subprocess could hang indefinitely without a deterministic
  6287	/// fallback, which defeats deterministic completion under `rhei run`.
  6288	fn ensure_orchestrator_timeout(resolved: &ResolvedAgent, state_name: &str) -> MietteResult<()> {
  6289	    if resolved.timeout_secs.is_some() {
  6290	        return Ok(());
  6291	    }
  6292	    Err(miette!(
  6293	        "state '{}' is driven by `rhei run` (orchestrator completion authority) \
  6294	         but no `agent_timeout` resolves for agent '{}'. Deterministic completion \
  6295	         requires a finite timeout. Set `agent_timeout` on the state, on \
  6296	         `models.<id>.agents.{}.timeout`, on `agents.{}.timeout`, or on \
  6297	         `defaults.agent_timeout` in settings.json.",
  6298	        state_name,
  6299	        resolved.agent.id(),
  6300	        resolved.agent.id(),
  6301	        resolved.agent.id(),
  6302	    ))
  6303	}
