  7152	
  7153	    let log_stdout =
  7154	        log_file.try_clone().map_err(|e| miette!("failed to clone log file handle: {e}"))?;
  7155	    let log_stderr =
  7156	        log_file.try_clone().map_err(|e| miette!("failed to clone log file handle: {e}"))?;
