   118	fn format_rfc3339(t: SystemTime) -> String {
   119	    let secs = t.duration_since(UNIX_EPOCH).map(|d| d.as_secs() as i64).unwrap_or(0);
   120	    let (year, month, day, hour, minute, second) = civil_from_epoch_secs(secs);
   121	    format!("{:04}-{:02}-{:02}T{:02}:{:02}:{:02}Z", year, month, day, hour, minute, second)
   122	}
   123	
   124	/// Convert a Unix timestamp (UTC) to (year, month, day, hour, minute, second).
   125	///
   126	/// Uses the algorithm from Howard Hinnant's date library (public domain). Valid
   127	/// for all year values representable in i32; we only need recent timestamps.
   128	fn civil_from_epoch_secs(secs: i64) -> (i32, u32, u32, u32, u32, u32) {
   129	    let days = secs.div_euclid(86_400);
   130	    let time_of_day = secs.rem_euclid(86_400) as u32;
   131	    let hour = time_of_day / 3600;
   132	    let minute = (time_of_day % 3600) / 60;
   133	    let second = time_of_day % 60;
   134	
   135	    let z = days + 719_468;
   136	    let era = if z >= 0 { z } else { z - 146_096 } / 146_097;
   137	    let doe = (z - era * 146_097) as u32;
   138	    let yoe = (doe - doe / 1460 + doe / 36_524 - doe / 146_096) / 365;
   139	    let y = yoe as i64 + era * 400;
   140	    let doy = doe - (365 * yoe + yoe / 4 - yoe / 100);
   141	    let mp = (5 * doy + 2) / 153;
   142	    let d = doy - (153 * mp + 2) / 5 + 1;
   143	    let m = if mp < 10 { mp + 3 } else { mp - 9 };
   144	    let y = y + if m <= 2 { 1 } else { 0 };
   145	    (y as i32, m, d, hour, minute, second)
   146	}
   147	
   148	fn format_duration(millis: u64) -> String {
   149	    let total_secs = millis / 1000;
   150	    if total_secs >= 60 {
   151	        let minutes = total_secs / 60;
   152	        let seconds = total_secs % 60;
   153	        format!("{minutes}m{seconds}s")
   154	    } else if total_secs > 0 {
   155	        let frac = (millis % 1000) / 100;
   156	        if frac == 0 {
   157	            format!("{total_secs}s")
   158	        } else {
   159	            format!("{total_secs}.{frac}s")
   160	        }
   161	    } else {
   162	        format!("{millis}ms")
   163	    }
   164	}
