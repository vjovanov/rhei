  1874	    fn template_input_help(input: &TemplateInputDef) -> String {
  1875	        let requirement = if let Some(default) = input.schema.default.as_ref() {
  1876	            format!("default {}", format_version(default))
  1877	        } else if input.is_required() {
  1878	            "required".to_string()
  1879	        } else {
  1880	            "optional".to_string()
  1881	        };
  1882	        let positional =
  1883	            input.positional.map(|index| format!(", positional {index}")).unwrap_or_default();
  1884	        format!(
  1885	            "{}, {}{} - {}",
  1886	            input.value_type().as_str(),
  1887	            requirement,
  1888	            positional,
  1889	            input.description
