 10640	/// Create a symlink from `dest` to `src`.
 10641	///
 10642	/// For local installs, callers should pass a relative `src` path so the
 10643	/// project stays portable. Prints `✓ <dest> → <src>` on success.
 10644	fn link_skill(src: &Path, dest: &Path, dry_run: bool) -> MietteResult<()> {
 10645	    if dry_run {
 10646	        println!("  [dry-run] would symlink {} → {}", dest.display(), src.display());
 10647	        return Ok(());
 10648	    }
 10649	
 10650	    if let Some(parent) = dest.parent() {
 10651	        fs::create_dir_all(parent)
 10652	            .map_err(|e| miette!("failed to create directory '{}': {e}", parent.display()))?;
 10653	    }
 10654	
 10655	    // Remove existing symlink or directory.
 10656	    if dest.symlink_metadata().is_ok() {
 10657	        if dest.is_dir() && !dest.is_symlink() {
 10658	            fs::remove_dir_all(dest)
 10659	                .map_err(|e| miette!("failed to remove existing '{}': {e}", dest.display()))?;
 10660	        } else {
 10661	            fs::remove_file(dest)
 10662	                .map_err(|e| miette!("failed to remove existing '{}': {e}", dest.display()))?;
 10663	        }
 10664	    }
 10665	
 10666	    #[cfg(unix)]
 10667	    std::os::unix::fs::symlink(src, dest).map_err(|e| {
 10668	        miette!("failed to symlink '{}' → '{}': {e}", dest.display(), src.display())
 10669	    })?;
 10670	
 10671	    #[cfg(not(unix))]
 10672	    return Err(miette!("symlinks are only supported on Unix platforms"));
 10673	
 10674	    println!("  ✓ {} → {}", dest.display(), src.display());
 10675	    Ok(())
 10676	}
