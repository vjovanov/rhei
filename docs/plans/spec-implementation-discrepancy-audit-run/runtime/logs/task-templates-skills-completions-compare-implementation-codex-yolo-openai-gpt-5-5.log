   396	      during the next deployment window.
   397	
   398	  released:
   399	    description: Feature is deployed to production.
   400	    instructions: |
   401	      Terminal state. Do not modify.
   402	    final: true
   403	
   404	  cancelled:
   405	    description: Feature is abandoned.
   406	    instructions: |
   407	      Terminal state. Skip entirely.
   408	    final: true
   409	
   410	transitions:
   411	  - from: design
   412	    to: ready-for-dev
   413	    description: Feature spec complete and approved
   414	  - from: ready-for-dev
   415	    to: implementing
   416	    description: Engineering picks up the feature
   417	  - from: implementing
   418	    to: security-review
   419	    description: Implementation complete, ready for security review
   420	  - from: security-review
   421	    to: qa
   422	    description: Security review passed
   423	  - from: security-review
   424	    to: security-fix
