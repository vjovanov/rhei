 10196	/// Inject or replace a `# rhei` section in a CLAUDE.md file.
 10197	fn inject_claude_md_section(file: &Path, content: &str, dry_run: bool) -> MietteResult<()> {
 10198	    let existing = if file.exists() {
 10199	        fs::read_to_string(file).map_err(|e| miette!("failed to read '{}': {e}", file.display()))?
 10200	    } else {
 10201	        String::new()
 10202	    };
 10203	
 10204	    // Check for existing `# rhei` section and replace it.
 10205	    let lines: Vec<&str> = existing.lines().collect();
 10206	    let mut new_lines: Vec<String> = Vec::new();
 10207	    let mut in_rhei_block = false;
 10208	    let mut replaced = false;
 10209	
 10210	    for line in &lines {
 10211	        if !in_rhei_block {
 10212	            if *line == "# rhei" || *line == "## rhei" {
 10213	                in_rhei_block = true;
 10214	                // Insert new content here.
 10215	                for cl in content.lines() {
 10216	                    new_lines.push(cl.to_string());
 10217	                }
 10218	                replaced = true;
 10219	                continue;
 10220	            }
 10221	            new_lines.push(line.to_string());
 10222	        } else {
 10223	            // Check if we've hit a new heading of equal or higher level.
 10224	            let level = line.chars().take_while(|&c| c == '#').count();
 10225	            if level > 0 && level <= 2 && !line.starts_with("###") {
 10226	                in_rhei_block = false;
 10227	                new_lines.push(line.to_string());
 10228	            }
 10229	            // Skip lines in the old rhei block.
 10230	        }
 10231	    }
 10232	
 10233	    if !replaced {
 10234	        // Append the section.
 10235	        if !new_lines.is_empty() && !new_lines.last().map(|l| l.is_empty()).unwrap_or(true) {
 10236	            new_lines.push(String::new());
 10237	        }
 10238	        for cl in content.lines() {
 10239	            new_lines.push(cl.to_string());
 10240	        }
 10241	    }
 10242	
 10243	    let mut final_content = new_lines.join("\n");
 10244	    if !final_content.ends_with('\n') {
 10245	        final_content.push('\n');
 10246	    }
 10247	
 10248	    if dry_run {
 10249	        println!("  [dry-run] would update {}", file.display());
 10250	        return Ok(());
 10251	    }
 10252	
 10253	    if let Some(parent) = file.parent() {
 10254	        fs::create_dir_all(parent)
 10255	            .map_err(|e| miette!("failed to create directory '{}': {e}", parent.display()))?;
 10256	    }
 10257	    fs::write(file, &final_content)
 10258	        .map_err(|e| miette!("failed to write '{}': {e}", file.display()))?;
 10259	
 10260	    Ok(())
 10261	}
