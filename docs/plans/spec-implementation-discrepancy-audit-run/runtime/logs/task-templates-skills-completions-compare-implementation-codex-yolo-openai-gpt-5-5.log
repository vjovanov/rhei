     1	name: changeset-review
     2	version: 1.0.0
     3	description: Review a code change (PR, branch, commit, or diff) — split into parts, multi-target review each, score findings, human-gate, then fan out fixes.
     4	
     5	inputs:
     6	  - name: change_ref
     7	    description: The change to review. Any of — a PR URL or number, a branch name, a commit SHA (or range `base..head`), or a path to a .diff/.patch file. The coordinator resolves it to an actual set of files before splitting.
     8	    type: string
     9	
    10	  - name: review_targets
    11	    description: Execution targets that independently review each part of the change (one parallel pass per target)
    12	    type: array
    13	    items:
    14	      type: string
    15	    default:
    16	      - claude-code[yolo]:anthropic:claude-opus-4-7
    17	      - codex[yolo]:openai:gpt-5.4
    18	
    19	  - name: review_focus
    20	    description: Optional focus areas each reviewer must address as its own subsection (e.g., performance, security, concurrency). Empty means a general review.
    21	    type: array
    22	    items:
    23	      type: string
    24	    default: []
    25	
    26	  - name: aggregator_target
    27	    description: Execution target that deduplicates per-part findings and produces the scored issue list
    28	    type: string
    29	    default: claude-code[yolo]:anthropic:claude-opus-4-7
    30	
    31	  - name: fix_target
    32	    description: Execution target that implements each human-approved fix
    33	    type: string
    34	    default: claude-code[yolo]:anthropic:claude-opus-4-7
    35	
    36	  - name: fix_prepare
    37	    description: Optional pre-fix workspace isolation. One of — none (apply in-tree), branch (create a new branch), worktree (create a git worktree), fork (fork the repo before working).
    38	    type: string
    39	    default: none
    40	    validate: "^(none|branch|worktree|fork)$"
    41	
    42	  - name: fix_commit
