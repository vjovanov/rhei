  2324	    fn ready_tasks_from_flat<'a>(
  2325	        tasks: &[&'a rhei_core::ast::Task],
  2326	        machine: &rhei_validator::StateMachine,
  2327	    ) -> Vec<&'a rhei_core::ast::Task> {
  2328	        let state_map: HashMap<&TaskId, String> = tasks
  2329	            .iter()
  2330	            .map(|task| (&task.id, normalized_state_name(task.state.as_str(), machine)))
  2331	            .collect();
  2332	
  2333	        tasks
  2334	            .iter()
  2335	            .copied()
  2336	            .filter(|task| {
  2337	                let state = normalized_state_name(task.state.as_str(), machine);
  2338	                let gating = machine.states.get(&state).map(|def| def.gating).unwrap_or(false);
  2339	                !gating && !is_terminal_state(task.state.as_str(), machine)
  2340	            })
  2341	            .filter(|task| {
  2342	                task.prior.iter().all(|dep| {
  2343	                    state_map
  2344	                        .get(dep)
  2345	                        .map(|state| dependency_is_satisfied(state, machine))
  2346	                        .unwrap_or(false)
  2347	                })
  2348	            })
  2349	            .collect()
  2350	    }
  2351	
  2352	    fn blocked_tasks_from_flat<'a>(
  2353	        tasks: &[&'a rhei_core::ast::Task],
  2354	        machine: &rhei_validator::StateMachine,
  2355	    ) -> Vec<&'a rhei_core::ast::Task> {
  2356	        let state_map: HashMap<&TaskId, String> = tasks
  2357	            .iter()
  2358	            .map(|task| (&task.id, normalized_state_name(task.state.as_str(), machine)))
  2359	            .collect();
  2360	
  2361	        tasks
  2362	            .iter()
  2363	            .copied()
  2364	            .filter(|task| !is_terminal_state(task.state.as_str(), machine))
  2365	            .filter(|task| {
  2366	                task.prior.iter().any(|dep| {
  2367	                    !state_map
  2368	                        .get(dep)
  2369	                        .map(|state| dependency_is_satisfied(state, machine))
  2370	                        .unwrap_or(false)
  2371	                })
  2372	            })
  2373	            .collect()
  2374	    }
