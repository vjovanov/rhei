   651	fn write_completion_registration(
   652	    shell: CompletionShell,
   653	    writer: &mut dyn std::io::Write,
   654	) -> MietteResult<()> {
   655	    let command = cli_command();
   656	    let completer = std::env::current_exe()
   657	        .ok()
   658	        .and_then(|path| path.into_os_string().into_string().ok())
   659	        .unwrap_or_else(|| "rhei".to_string());
   660	    completion_env_completer(shell)
   661	        .write_registration("COMPLETE", command.get_name(), "rhei", &completer, writer)
   662	        .map_err(|err| miette!("failed to generate {} completions: {err}", shell.as_str()))
   663	}
