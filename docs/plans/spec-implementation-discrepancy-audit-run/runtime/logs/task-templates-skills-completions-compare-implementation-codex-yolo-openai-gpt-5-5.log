  1079	fn completion_plan_path() -> Option<PathBuf> {
  1080	    let words = completion_words();
  1081	    let command = completion_command_name(&words)?;
  1082	    first_command_positional(&words, &command).map(PathBuf::from)
  1083	}
  1084	
  1085	fn completion_command_name(words: &[String]) -> Option<String> {
  1086	    let mut expect_value = false;
  1087	    for word in words.iter().skip(1) {
  1088	        if word.is_empty() {
  1089	            break;
  1090	        }
  1091	        if expect_value {
  1092	            expect_value = false;
  1093	            continue;
  1094	        }
  1095	        if let Some(option) = word.strip_prefix("--") {
  1096	            if option.split_once('=').is_none() && option == "state-machine" {
  1097	                expect_value = true;
  1098	            }
  1099	            continue;
  1100	        }
  1101	        return Some(word.clone());
  1102	    }
  1103	    None
  1104	}
  1105	
  1106	fn first_command_positional(words: &[String], command: &str) -> Option<String> {
  1107	    let command_index = words.iter().position(|word| word == command)?;
  1108	    let mut expect_value_for: Option<&str> = None;
  1109	    for word in words.iter().skip(command_index + 1) {
  1110	        if word.is_empty() {
  1111	            break;
  1112	        }
  1113	        if let Some(option) = expect_value_for.take() {
  1114	            if option != "set" && option != "set-file" && option != "values" && option != "output" {
  1115	                continue;
  1116	            }
  1117	            continue;
  1118	        }
  1119	        if let Some(option) = word.strip_prefix("--") {
  1120	            if let Some((_, _)) = option.split_once('=') {
  1121	                continue;
  1122	            }
  1123	            if matches!(
  1124	                option,
  1125	                "task"
  1126	                    | "from"
  1127	                    | "to"
  1128	                    | "result"
  1129	                    | "set"
  1130	                    | "set-file"
  1131	                    | "values"
  1132	                    | "output"
  1133	                    | "agent"
  1134	                    | "agent-mode"
  1135	                    | "model"
  1136	                    | "program-timeout"
  1137	                    | "parallel"
  1138	                    | "state-machine"
  1139	                    | "state"
  1140	                    | "assignee"
  1141	                    | "kind"
  1142	                    | "has-prior"
  1143	                    | "parent"
  1144	                    | "contains"
  1145	                    | "limit"
  1146	            ) {
  1147	                expect_value_for = Some(option);
  1148	            }
  1149	            continue;
  1150	        }
  1151	        return Some(word.clone());
  1152	    }
  1153	    None
  1154	}
  1155	
  1156	fn completion_option_value(name: &str) -> Option<String> {
  1157	    let words = completion_words();
  1158	    let flag = format!("--{name}");
  1159	    let prefix = format!("--{name}=");
  1160	    let mut iter = words.iter().peekable();
  1161	    while let Some(word) = iter.next() {
  1162	        if let Some(value) = word.strip_prefix(&prefix) {
  1163	            return Some(value.to_string());
  1164	        }
  1165	        if word == &flag {
  1166	            return iter.peek().filter(|value| !value.is_empty()).map(|value| (*value).clone());
  1167	        }
  1168	    }
  1169	    None
  1170	}
  1171	
  1172	fn completion_words() -> Vec<String> {
  1173	    let args = std::env::args_os().collect::<Vec<_>>();
  1174	    let start = args.iter().position(|arg| arg == "--").map(|idx| idx + 1).unwrap_or(1);
  1175	    args.into_iter().skip(start).map(|arg| arg.to_string_lossy().to_string()).collect()
