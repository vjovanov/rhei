  2398	    fn format_template_instantiation_command(
  2399	        template: &str,
  2400	        input_args: &[String],
  2401	        set_values: &[String],
  2402	        set_files: &[String],
  2403	        values_files: &[PathBuf],
  2404	        output_dir: &Path,
  2405	    ) -> String {
  2406	        let mut parts = vec!["rhei".to_string(), "instantiate".to_string(), template.to_string()];
  2407	        for values_file in values_files {
  2408	            parts.push("--values".to_string());
  2409	            parts.push(values_file.display().to_string());
  2410	        }
  2411	        parts.extend(input_args.iter().cloned());
  2412	        for value in set_values {
  2413	            parts.push("--set".to_string());
  2414	            parts.push(value.clone());
  2415	        }
  2416	        for value in set_files {
  2417	            parts.push("--set-file".to_string());
  2418	            parts.push(value.clone());
  2419	        }
  2420	        parts.push("--output".to_string());
  2421	        parts.push(output_dir.display().to_string());
  2422	
  2423	        parts.iter().map(|part| shell_quote(part)).collect::<Vec<_>>().join(" ")
  2424	    }
