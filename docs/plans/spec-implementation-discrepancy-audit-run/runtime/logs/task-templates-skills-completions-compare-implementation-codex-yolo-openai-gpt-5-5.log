 10595	/// Recursively copy a skill directory to a destination.
 10596	///
 10597	/// Creates parent directories as needed. Prints `✓ <dest> — written` on
 10598	/// success.
 10599	fn copy_skill(src: &Path, dest: &Path, dry_run: bool) -> MietteResult<()> {
 10600	    if dry_run {
 10601	        println!("  [dry-run] would copy {} → {}", src.display(), dest.display());
 10602	        return Ok(());
 10603	    }
 10604	
 10605	    if dest.exists() {
 10606	        fs::remove_dir_all(dest)
 10607	            .map_err(|e| miette!("failed to remove existing '{}': {e}", dest.display()))?;
 10608	    }
 10609	
 10610	    copy_dir_recursive(src, dest)?;
 10611	
 10612	    println!("  ✓ {} — written", dest.display());
 10613	    Ok(())
 10614	}
