   715	fn complete_rhei_plan_path(current: &OsStr) -> Vec<CompletionCandidate> {
   716	    let current_path = Path::new(current);
   717	    let parent = current_path.parent().filter(|p| !p.as_os_str().is_empty());
   718	    let file_prefix =
   719	        current_path.file_name().and_then(|s| s.to_str()).unwrap_or_default().to_string();
   720	    let dir = parent.unwrap_or_else(|| Path::new("."));
   721	    let mut candidates = Vec::new();
   722	
   723	    if let Ok(entries) = fs::read_dir(dir) {
   724	        let mut entries = entries.filter_map(Result::ok).collect::<Vec<_>>();
   725	        entries.sort_by_key(|entry| entry.file_name());
   726	        for entry in entries {
   727	            let path = entry.path();
   728	            let name = entry.file_name().to_string_lossy().to_string();
   729	            if !name.starts_with(&file_prefix) {
   730	                continue;
   731	            }
   732	            let include = if path.is_dir() { true } else { name.ends_with(".rhei.md") };
   733	            if include {
   734	                candidates.push(path_completion_candidate(parent, &name, path.is_dir()));
   735	            }
   736	        }
   737	    }
   738	
   739	    candidates
   740	}
   741	
   742	fn complete_path_with_extensions(current: &OsStr, extensions: &[&str]) -> Vec<CompletionCandidate> {
   743	    let current_path = Path::new(current);
   744	    let parent = current_path.parent().filter(|p| !p.as_os_str().is_empty());
   745	    let file_prefix =
   746	        current_path.file_name().and_then(|s| s.to_str()).unwrap_or_default().to_string();
   747	    let dir = parent.unwrap_or_else(|| Path::new("."));
   748	    let mut candidates = Vec::new();
   749	
   750	    if let Ok(entries) = fs::read_dir(dir) {
   751	        let mut entries = entries.filter_map(Result::ok).collect::<Vec<_>>();
   752	        entries.sort_by_key(|entry| entry.file_name());
   753	        for entry in entries {
   754	            let path = entry.path();
   755	            let name = entry.file_name().to_string_lossy().to_string();
   756	            if !name.starts_with(&file_prefix) {
   757	                continue;
   758	            }
   759	            let include = if path.is_dir() {
   760	                true
   761	            } else {
   762	                path.extension()
   763	                    .and_then(|ext| ext.to_str())
   764	                    .is_some_and(|ext| extensions.iter().any(|allowed| ext == *allowed))
   765	            };
   766	            if include {
   767	                candidates.push(path_completion_candidate(parent, &name, path.is_dir()));
   768	            }
   769	        }
   770	    }
   771	
   772	    candidates
   773	}
