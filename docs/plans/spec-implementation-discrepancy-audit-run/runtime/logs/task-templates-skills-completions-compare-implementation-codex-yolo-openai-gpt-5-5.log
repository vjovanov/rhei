  2546	    fn load_template_manifest(template_dir: &Path) -> MietteResult<TemplateManifest> {
  2547	        let manifest_path = template_dir.join("template.yaml");
  2548	        let raw = fs::read_to_string(&manifest_path).map_err(|err| {
  2549	            file_io_report(&manifest_path, "failed to read template manifest", err)
  2550	        })?;
  2551	        let manifest: TemplateManifest = serde_yaml::from_str(&raw)
  2552	            .map_err(|err| miette!("failed to parse '{}': {err}", manifest_path.display()))?;
  2553	        validate_template_manifest(&manifest, template_dir)?;
  2554	        Ok(manifest)
  2555	    }
