  1059	fn completion_state_machine() -> Option<rhei_validator::StateMachine> {
  1060	    let state_machine = completion_option_value("state-machine").map(PathBuf::from);
  1061	    let plan = completion_plan_path();
  1062	    match (plan.as_deref(), state_machine.as_deref()) {
  1063	        (Some(plan), sm) => load_plan(plan)
  1064	            .ok()
  1065	            .and_then(|loaded| resolve_state_machine_for_loaded_plan(plan, &loaded, sm).ok())
  1066	            .map(|resolved| resolved.machine),
  1067	        (None, Some(sm)) => load_state_machine(Some(sm)).ok(),
  1068	        (None, None) => Some(rhei_validator::StateMachine::builtin_default()),
  1069	    }
  1070	}
