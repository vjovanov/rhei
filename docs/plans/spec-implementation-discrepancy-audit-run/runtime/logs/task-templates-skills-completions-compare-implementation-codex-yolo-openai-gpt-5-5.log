  2522	    fn resolve_template_reference(reference: &str) -> MietteResult<PathBuf> {
  2523	        if template_reference_is_path(reference) {
  2524	            let path = PathBuf::from(reference);
  2525	            if !path.is_dir() {
  2526	                return Err(miette!("template directory '{}' does not exist", path.display()));
  2527	            }
  2528	            return Ok(path);
  2529	        }
  2530	
  2531	        for (_, root) in template_search_roots(TemplateSourceFilter::All)? {
  2532	            let candidate = root.join(reference);
  2533	            if candidate.is_dir() {
  2534	                return Ok(candidate);
  2535	            }
  2536	        }
  2537	
  2538	        Err(miette!("template '{}' not found in project or user template directories", reference))
  2539	    }
