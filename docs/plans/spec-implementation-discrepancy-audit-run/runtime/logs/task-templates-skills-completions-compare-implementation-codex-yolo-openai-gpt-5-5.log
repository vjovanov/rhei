 10724	fn resolve_skill_source(skill_name: &str) -> MietteResult<PathBuf> {
 10725	    // 1. Binary-relative installed path.
 10726	    if let Ok(exe) = std::env::current_exe() {
 10727	        if let Some(bin_dir) = exe.parent() {
 10728	            let installed = bin_dir.join("../share/rhei/skills").join(skill_name);
 10729	            if installed.is_dir() {
 10730	                return installed
 10731	                    .canonicalize()
 10732	                    .map_err(|e| miette!("failed to canonicalize '{}': {e}", installed.display()));
 10733	            }
 10734	        }
 10735	    }
