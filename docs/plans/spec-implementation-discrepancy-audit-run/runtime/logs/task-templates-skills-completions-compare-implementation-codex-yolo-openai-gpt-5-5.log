  1893	    fn next_positional_input<'a>(
  1894	        manifest: &'a TemplateManifest,
  1895	        prior_input_args: &[String],
  1896	    ) -> Option<&'a TemplateInputDef> {
  1897	        let positional_count = prior_input_args
  1898	            .iter()
  1899	            .filter(|value| !template_input_arg_is_assignment(manifest, value))
  1900	            .count();
  1901	        let next_position = positional_count + 1;
  1902	        if let Some(input) =
  1903	            manifest.inputs.iter().find(|input| input.positional == Some(next_position))
  1904	        {
  1905	            return Some(input);
  1906	        }
  1907	        if manifest.inputs.iter().all(|input| input.positional.is_none()) && positional_count == 0 {
  1908	            let required =
  1909	                manifest.inputs.iter().filter(|input| input.is_required()).collect::<Vec<_>>();
  1910	            if required.len() == 1 {
  1911	                return Some(required[0]);
  1912	            }
  1913	        }
  1914	        None
  1915	    }
  1916	
  1917	    fn supplied_template_input_keys<'a>(
  1918	        manifest: &'a TemplateManifest,
  1919	        prior_input_args: &'a [String],
  1920	    ) -> HashSet<&'a str> {
  1921	        let mut supplied = HashSet::new();
  1922	        let mut positional_index = 1;
  1923	        for value in prior_input_args {
  1924	            if let Some((key, _)) = value.split_once('=') {
  1925	                if manifest.inputs.iter().any(|input| input.name == key) {
  1926	                    supplied.insert(key);
  1927	                    continue;
  1928	                }
  1929	            }
  1930	            if let Some(input) =
  1931	                manifest.inputs.iter().find(|input| input.positional == Some(positional_index))
  1932	            {
  1933	                supplied.insert(input.name.as_str());
  1934	                positional_index += 1;
  1935	            } else if manifest.inputs.iter().all(|input| input.positional.is_none()) {
  1936	                let required =
  1937	                    manifest.inputs.iter().filter(|input| input.is_required()).collect::<Vec<_>>();
  1938	                if required.len() == 1 && positional_index == 1 {
  1939	                    supplied.insert(required[0].name.as_str());
  1940	                    positional_index += 1;
  1941	                }
  1942	            }
  1943	        }
  1944	        supplied
  1945	    }
  1946	
  1947	    fn template_input_arg_is_assignment(manifest: &TemplateManifest, value: &str) -> bool {
  1948	        value
  1949	            .split_once('=')
  1950	            .is_some_and(|(key, _)| manifest.inputs.iter().any(|input| input.name == key))
  1951	    }
