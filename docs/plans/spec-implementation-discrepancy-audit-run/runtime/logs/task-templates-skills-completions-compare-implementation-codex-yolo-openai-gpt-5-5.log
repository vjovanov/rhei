 10737	    // 2. Dev-build fallback: walk up from binary to find repo root (Cargo.toml).
 10738	    if let Ok(exe) = std::env::current_exe() {
 10739	        let mut dir = exe.parent().map(|p| p.to_path_buf());
 10740	        while let Some(d) = dir {
 10741	            if d.join("Cargo.toml").is_file() {
 10742	                let dev_path = d.join("skills").join(skill_name);
 10743	                if dev_path.is_dir() {
 10744	                    return dev_path.canonicalize().map_err(|e| {
 10745	                        miette!("failed to canonicalize '{}': {e}", dev_path.display())
 10746	                    });
 10747	                }
 10748	                break;
 10749	            }
 10750	            dir = d.parent().map(|p| p.to_path_buf());
 10751	        }
 10752	    }
