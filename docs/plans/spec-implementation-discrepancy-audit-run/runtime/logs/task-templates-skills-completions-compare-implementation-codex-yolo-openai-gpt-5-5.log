  2177	    fn print_output_tree(root: &Path, prefix: &str) -> MietteResult<()> {
  2178	        let mut entries = fs::read_dir(root)
  2179	            .map_err(|err| file_io_report(root, "failed to read instantiated output tree", err))?
  2180	            .collect::<Result<Vec<_>, _>>()
  2181	            .map_err(|err| miette!("failed to read dir entry in '{}': {err}", root.display()))?;
  2182	        entries.sort_by_key(|entry| entry.file_name());
  2183	
  2184	        let count = entries.len();
  2185	        for (idx, entry) in entries.into_iter().enumerate() {
  2186	            let path = entry.path();
  2187	            let file_type = entry.file_type().map_err(|err| {
  2188	                file_io_report(&path, "failed to read instantiated output entry", err)
  2189	            })?;
  2190	            let is_last = idx + 1 == count;
  2191	            let connector = if is_last { "`-- " } else { "|-- " };
  2192	            let child_prefix = if is_last { "    " } else { "|   " };
  2193	            let name = entry.file_name().to_string_lossy().to_string();
  2194	
  2195	            if file_type.is_dir() {
  2196	                println!("{prefix}{connector}{name}/");
  2197	                print_output_tree(&path, &format!("{prefix}{child_prefix}"))?;
  2198	            } else {
  2199	                println!("{prefix}{connector}{name}");
  2200	            }
  2201	        }
  2202	
  2203	        Ok(())
  2204	    }
