  2733	    fn detect_template_layout(template_dir: &Path) -> MietteResult<TemplateLayout> {
  2734	        let plan_path = template_dir.join("plan.rhei.md");
  2735	        let index_path = template_dir.join("index.rhei.md");
  2736	        let has_plan = plan_path.is_file();
  2737	        let has_index = index_path.is_file();
  2738	
  2739	        match (has_plan, has_index) {
  2740	            (true, false) => Ok(TemplateLayout::SingleFile),
  2741	            (false, true) => {
  2742	                let tasks_dir = template_dir.join("tasks");
  2743	                if !tasks_dir.is_dir() {
  2744	                    return Err(miette!(
  2745	                        "template '{}' is a workspace template but is missing tasks/",
  2746	                        template_dir.display()
  2747	                    ));
  2748	                }
  2749	                Ok(TemplateLayout::Workspace)
  2750	            }
  2751	            (true, true) => Err(miette!(
  2752	                "template '{}' contains both plan.rhei.md and index.rhei.md",
  2753	                template_dir.display()
  2754	            )),
  2755	            (false, false) => Err(miette!(
  2756	                "template '{}' must contain either plan.rhei.md or index.rhei.md",
  2757	                template_dir.display()
  2758	            )),
  2759	        }
  2760	    }
