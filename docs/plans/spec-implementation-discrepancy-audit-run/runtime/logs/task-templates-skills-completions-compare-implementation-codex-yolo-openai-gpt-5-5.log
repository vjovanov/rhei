   426	  - from: security-fix
   427	    to: security-review
   428	    description: Security fixes applied, ready for re-review
   429	  - from: qa
   430	    to: release-ready
   431	    description: QA validation passed
   432	  - from: qa
   433	    to: implementing
   434	    description: QA found defects, needs rework
   435	  - from: release-ready
   436	    to: released
   437	    description: Deployed to production
   438	  - from: "*"
   439	    to: cancelled
