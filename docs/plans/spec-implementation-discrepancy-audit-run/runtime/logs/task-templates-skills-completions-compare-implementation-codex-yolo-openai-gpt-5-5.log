   995	fn complete_transition_to_state(current: &OsStr) -> Vec<CompletionCandidate> {
   996	    let Some(machine) = completion_state_machine() else {
   997	        return Vec::new();
   998	    };
   999	    let from = completion_option_value("from").or_else(|| {
  1000	        completion_plan_path()
  1001	            .zip(completion_option_value("task"))
  1002	            .and_then(|(plan, task)| current_task_state(&plan, &task).ok())
  1003	    });
  1004	    let mut targets = BTreeSet::new();
  1005	    if let Some(from) = from {
  1006	        let normalized = normalized_state_name(&from, &machine);
  1007	        for rule in machine.transitions() {
  1008	            if rule.from.0 == normalized || rule.from.0 == "*" {
  1009	                targets.insert(rule.to.0.clone());
  1010	            }
  1011	        }
  1012	    } else {
  1013	        targets.extend(machine.states.keys().cloned());
  1014	    }
  1015	    let prefix = current.to_string_lossy();
  1016	    targets
  1017	        .into_iter()
  1018	        .filter(|state| state.starts_with(prefix.as_ref()))
  1019	        .map(|state| {
  1020	            let help = machine.states.get(&state).and_then(|def| def.description.clone());
  1021	            CompletionCandidate::new(state).help(help.map(Into::into))
  1022	        })
  1023	        .collect()
  1024	}
