 10678	/// Compute a relative path from `from_dir` to `to_path`.
 10679	///
 10680	/// Makes both paths absolute without resolving symlinks (to avoid
 10681	/// symlink targets collapsing path differences). Then walks back from
 10682	/// `from_dir` and forward to `to_path` via the common ancestor.
 10683	fn relative_path(from_dir: &Path, to_path: &Path) -> PathBuf {
 10684	    // Make absolute without canonicalizing (no symlink resolution).
 10685	    let make_absolute = |p: &Path| -> PathBuf {
 10686	        if p.is_absolute() {
 10687	            p.to_path_buf()
 10688	        } else if let Ok(cwd) = std::env::current_dir() {
 10689	            cwd.join(p)
 10690	        } else {
 10691	            p.to_path_buf()
 10692	        }
 10693	    };
 10694	
 10695	    let from = make_absolute(from_dir);
 10696	    let to = make_absolute(to_path);
 10697	
 10698	    let from_components: Vec<_> = from.components().collect();
 10699	    let to_components: Vec<_> = to.components().collect();
 10700	
 10701	    // Find the common prefix length.
 10702	    let common =
 10703	        from_components.iter().zip(to_components.iter()).take_while(|(a, b)| a == b).count();
 10704	
 10705	    let mut result = PathBuf::new();
 10706	    // Go up from `from_dir` to the common ancestor.
 10707	    for _ in common..from_components.len() {
 10708	        result.push("..");
 10709	    }
 10710	    // Go down to `to_path` from the common ancestor.
 10711	    for component in &to_components[common..] {
 10712	        result.push(component);
 10713	    }
 10714	
 10715	    result
 10716	}
