 10574	/// Remove a file or directory, printing what was done.
 10575	fn remove_path(path: &Path, dry_run: bool) -> MietteResult<()> {
 10576	    if !path.exists() && path.symlink_metadata().is_err() {
 10577	        return Ok(());
 10578	    }
 10579	
 10580	    if dry_run {
 10581	        println!("  [dry-run] would remove {}", path.display());
 10582	        return Ok(());
 10583	    }
 10584	
 10585	    if path.is_dir() && !path.is_symlink() {
 10586	        fs::remove_dir_all(path)
 10587	            .map_err(|e| miette!("failed to remove '{}': {e}", path.display()))?;
 10588	    } else {
 10589	        fs::remove_file(path).map_err(|e| miette!("failed to remove '{}': {e}", path.display()))?;
 10590	    }
 10591	
 10592	    Ok(())
 10593	}
