  2653	    fn validate_template_value_schema(
  2654	        template_name: &str,
  2655	        label: &str,
  2656	        schema: &TemplateValueSchema,
  2657	    ) -> MietteResult<()> {
  2658	        if let Some(pattern) = schema.validate.as_deref() {
  2659	            if matches!(schema.value_type, TemplateInputType::Array | TemplateInputType::Object) {
  2660	                return Err(miette!(
  2661	                    "template '{}' input '{}' cannot set validate on {} values",
  2662	                    template_name,
  2663	                    label,
  2664	                    schema.value_type.as_str()
  2665	                ));
  2666	            }
  2667	            let _ = compile_full_match_regex(pattern).map_err(|err| {
  2668	                miette!(
  2669	                    "template '{}' input '{}' has invalid validate regex: {err}",
  2670	                    template_name,
  2671	                    label
  2672	                )
  2673	            })?;
  2674	        }
  2675	
  2676	        match schema.value_type {
  2677	            TemplateInputType::Array => {
  2678	                let Some(items) = schema.items.as_deref() else {
  2679	                    return Err(miette!(
  2680	                        "template '{}' input '{}' with type array must declare items",
  2681	                        template_name,
  2682	                        label
  2683	                    ));
  2684	                };
  2685	                if !schema.properties.is_empty() {
  2686	                    return Err(miette!(
  2687	                        "template '{}' input '{}' with type array cannot declare properties",
  2688	                        template_name,
  2689	                        label
  2690	                    ));
  2691	                }
  2692	                validate_template_value_schema(template_name, label, items)?;
  2693	            }
  2694	            TemplateInputType::Object => {
  2695	                if schema.items.is_some() {
  2696	                    return Err(miette!(
  2697	                        "template '{}' input '{}' with type object cannot declare items",
  2698	                        template_name,
  2699	                        label
  2700	                    ));
  2701	                }
  2702	                for (property, property_schema) in &schema.properties {
  2703	                    validate_template_value_schema(
  2704	                        template_name,
  2705	                        &format!("{label}.{property}"),
  2706	                        property_schema,
  2707	                    )?;
  2708	                }
  2709	            }
  2710	            _ => {
  2711	                if schema.items.is_some() {
  2712	                    return Err(miette!(
  2713	                        "template '{}' input '{}' with type {} cannot declare items",
  2714	                        template_name,
  2715	                        label,
  2716	                        schema.value_type.as_str()
  2717	                    ));
  2718	                }
  2719	                if !schema.properties.is_empty() {
  2720	                    return Err(miette!(
  2721	                        "template '{}' input '{}' with type {} cannot declare properties",
  2722	                        template_name,
  2723	                        label,
  2724	                        schema.value_type.as_str()
  2725	                    ));
  2726	                }
  2727	            }
  2728	        }
  2729	
  2730	        Ok(())
  2731	    }
