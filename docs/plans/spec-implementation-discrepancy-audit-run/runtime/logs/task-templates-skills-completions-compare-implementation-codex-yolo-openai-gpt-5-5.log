  3322	    fn render_template_text(
  3323	        raw: &str,
  3324	        values: &BTreeMap<String, serde_json::Value>,
  3325	        path: &Path,
  3326	    ) -> MietteResult<String> {
  3327	        let literal_open = "__RHEI_TEMPLATE_LITERAL_OPEN__";
  3328	        let preprocessed = raw.replace(r"\{{", literal_open);
  3329	        let mut env = MiniJinjaEnvironment::new();
  3330	        env.set_undefined_behavior(UndefinedBehavior::Strict);
  3331	        env.add_filter("slug", |value: String| slugify_target_value(&value));
  3332	
  3333	        let template = env
  3334	            .template_from_str(&preprocessed)
  3335	            .map_err(|err| miette!("failed to parse template '{}': {err}", path.display()))?;
  3336	        let rendered = template
  3337	            .render(values)
  3338	            .map_err(|err| miette!("failed to render template '{}': {err}", path.display()))?;

