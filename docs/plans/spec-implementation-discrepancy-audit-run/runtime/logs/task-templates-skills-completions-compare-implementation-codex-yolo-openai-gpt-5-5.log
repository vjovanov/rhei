  1953	    fn completion_template_context() -> Option<(TemplateManifest, Vec<String>)> {
  1954	        let words = completion_words();
  1955	        let instantiate_index = words.iter().position(|word| word == "instantiate")?;
  1956	        let words = words.get(instantiate_index + 1..)?;
  1957	        let before_current = words.get(..words.len().saturating_sub(1)).unwrap_or(words);
  1958	        let (template, input_args) = completion_template_and_inputs(before_current)?;
  1959	        let template_dir = resolve_template_reference(&template).ok()?;
  1960	        let manifest = load_template_manifest(&template_dir).ok()?;
  1961	        Some((manifest, input_args))
  1962	    }
  1963	
  1964	    fn completion_template_and_inputs(words: &[String]) -> Option<(String, Vec<String>)> {
  1965	        let mut template = None;
  1966	        let mut input_args = Vec::new();
  1967	        let mut expects_value_for: Option<&str> = None;
  1968	
  1969	        for word in words {
  1970	            if word.is_empty() {
  1971	                break;
  1972	            }
  1973	            if let Some(option) = expects_value_for.take() {
  1974	                if matches!(option, "set" | "set-file") {
  1975	                    input_args.push(word.clone());
  1976	                }
  1977	                continue;
  1978	            }
  1979	            if let Some(option) = word.strip_prefix("--") {
  1980	                if let Some((name, value)) = option.split_once('=') {
  1981	                    if matches!(name, "set" | "set-file") {
  1982	                        input_args.push(value.to_string());
  1983	                    }
  1984	                    continue;
  1985	                }
  1986	                if matches!(option, "set" | "set-file" | "values" | "output") {
  1987	                    expects_value_for = Some(option);
  1988	                }
  1989	                continue;
  1990	            }
  1991	            if template.is_none() {
  1992	                template = Some(word.clone());
  1993	            } else {
  1994	                input_args.push(word.clone());
  1995	            }
  1996	        }
  1997	
  1998	        template.map(|template| (template, input_args))
  1999	    }
