 10452	/// Build the content for marker-injected agents (Windsurf, Copilot).
 10453	fn build_marker_content(skill_sources: &[(String, PathBuf)]) -> MietteResult<String> {
 10454	    let mut parts = Vec::new();
 10455	    for (name, source) in skill_sources {
 10456	        let skill_md = source.join("SKILL.md");
 10457	        let content = fs::read_to_string(&skill_md)
 10458	            .map_err(|e| miette!("failed to read '{}': {e}", skill_md.display()))?;
 10459	        parts.push(format!(
 10460	            "## rhei-{name}\n\nWhen the user asks to create/execute a Rhei plan, follow these instructions:\n\n{content}"
 10461	        ));
 10462	    }
 10463	    Ok(parts.join("\n\n"))
 10464	}
