  2426	    fn shell_quote(value: &str) -> String {
  2427	        if value.is_empty() {
  2428	            return "''".to_string();
  2429	        }
  2430	        if value.bytes().all(|byte| {
  2431	            matches!(
  2432	                byte,
  2433	                b'a'..=b'z'
  2434	                    | b'A'..=b'Z'
  2435	                    | b'0'..=b'9'
  2436	                    | b'_'
  2437	                    | b'-'
  2438	                    | b'.'
  2439	                    | b'/'
  2440	                    | b':'
  2441	                    | b'@'
  2442	                    | b'%'
  2443	                    | b'+'
  2444	                    | b'='
  2445	                    | b','
  2446	            )
  2447	        }) {
  2448	            return value.to_string();
  2449	        }
  2450	        format!("'{}'", value.replace('\'', "'\"'\"'"))
  2451	    }
