  2864	    fn parse_template_input_args(
  2865	        manifest: &TemplateManifest,
  2866	        input_args: &[String],
  2867	    ) -> MietteResult<ParsedTemplateInputArgs> {
  2868	        let ident = Regex::new(r"^[A-Za-z][A-Za-z0-9_-]*$")
  2869	            .expect("template identifier regex should be valid");
  2870	        let declared_inputs =
  2871	            manifest.inputs.iter().map(|input| input.name.as_str()).collect::<HashSet<_>>();
  2872	        let mut positional_values = Vec::new();
  2873	        let mut assignments = Vec::new();
  2874	
  2875	        for value in input_args {
  2876	            if let Some((key, rhs)) = value.split_once('=') {
  2877	                if ident.is_match(key) {
  2878	                    if !declared_inputs.contains(key) {
  2879	                        return Err(miette!(
  2880	                            "template '{}' does not declare an input named '{}'",
  2881	                            manifest.name,
  2882	                            key
  2883	                        ));
  2884	                    }
  2885	                    assignments.push((key.to_string(), rhs.to_string()));
  2886	                    continue;
  2887	                }
  2888	            }
  2889	
  2890	            positional_values.push(value.clone());
  2891	        }
  2892	
  2893	        let positional_values = map_template_positional_inputs(manifest, &positional_values)?;
  2894	        Ok(ParsedTemplateInputArgs { positional_values, assignments })
  2895	    }
