  2557	    fn validate_template_manifest(
  2558	        manifest: &TemplateManifest,
  2559	        template_dir: &Path,
  2560	    ) -> MietteResult<()> {
  2561	        let dir_name =
  2562	            template_dir.file_name().and_then(|name| name.to_str()).ok_or_else(|| {
  2563	                miette!("template path '{}' has no directory name", template_dir.display())
  2564	            })?;
  2565	        let ident = Regex::new(r"^[A-Za-z][A-Za-z0-9_-]*$")
  2566	            .expect("template identifier regex should be valid");
  2567	
  2568	        if manifest.name != dir_name {
  2569	            return Err(miette!(
  2570	                "template manifest name '{}' does not match directory '{}'",
  2571	                manifest.name,
  2572	                dir_name
  2573	            ));
  2574	        }
  2575	        if !ident.is_match(&manifest.name) {
  2576	            return Err(miette!("template name '{}' is not a valid identifier", manifest.name));
  2577	        }
  2578	        if manifest.description.trim().is_empty() {
  2579	            return Err(miette!(
  2580	                "template '{}' must include a non-empty description",
  2581	                manifest.name
  2582	            ));
  2583	        }
  2584	
  2585	        let cwd = std::env::current_dir()
  2586	            .map_err(|err| miette!("failed to determine working directory: {err}"))?;
  2587	        let mut seen = HashSet::new();
  2588	        let mut positional_indexes = Vec::new();
  2589	
  2590	        for input in &manifest.inputs {
  2591	            if !ident.is_match(&input.name) {
  2592	                return Err(miette!(
  2593	                    "template '{}' input '{}' is not a valid identifier",
  2594	                    manifest.name,
  2595	                    input.name
  2596	                ));
  2597	            }
  2598	            if !seen.insert(input.name.as_str()) {
  2599	                return Err(miette!(
  2600	                    "template '{}' declares duplicate input '{}'",
  2601	                    manifest.name,
  2602	                    input.name
  2603	                ));
  2604	            }
  2605	            if input.description.trim().is_empty() {
  2606	                return Err(miette!(
  2607	                    "template '{}' input '{}' must include a description",
  2608	                    manifest.name,
  2609	                    input.name
  2610	                ));
  2611	            }
  2612	            if let Some(index) = input.positional {
  2613	                if index == 0 {
  2614	                    return Err(miette!(
  2615	                        "template '{}' input '{}' positional index must be >= 1",
  2616	                        manifest.name,
  2617	                        input.name
  2618	                    ));
  2619	                }
  2620	                positional_indexes.push((index, input.name.as_str()));
  2621	            }
  2622	            if input.schema.required == Some(true) && input.schema.default.is_some() {
  2623	                return Err(miette!(
  2624	                    "template '{}' input '{}' cannot set both required: true and default",
  2625	                    manifest.name,
  2626	                    input.name
  2627	                ));
  2628	            }
  2629	            validate_template_value_schema(&manifest.name, &input.name, &input.schema)?;
  2630	            if let Some(default) = input.schema.default.as_ref() {
  2631	                let _ = coerce_template_input_value(input, default, &cwd, true)?;
  2632	            }
  2633	        }
  2634	
  2635	        positional_indexes.sort_by_key(|(index, _)| *index);
  2636	        for (expected, (actual, name)) in positional_indexes.iter().enumerate() {
  2637	            let expected = expected + 1;
  2638	            if *actual != expected {
  2639	                return Err(miette!(
  2640	                    "template '{}' input '{}' declares positional {}, but positional indexes must be unique and contiguous starting at 1",
  2641	                    manifest.name,
  2642	                    name,
  2643	                    actual
  2644	                ));
  2645	            }
  2646	        }
  2647	
  2648	        let _ = detect_template_layout(template_dir)?;
  2649	
  2650	        Ok(())
  2651	    }
