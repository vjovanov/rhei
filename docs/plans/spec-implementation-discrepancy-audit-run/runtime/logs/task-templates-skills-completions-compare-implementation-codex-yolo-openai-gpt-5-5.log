  2453	    fn parse_template_source_filter(value: &str) -> MietteResult<TemplateSourceFilter> {
  2454	        match value.trim().to_ascii_lowercase().as_str() {
  2455	            "project" => Ok(TemplateSourceFilter::Project),
  2456	            "user" => Ok(TemplateSourceFilter::User),
  2457	            "all" => Ok(TemplateSourceFilter::All),
  2458	            other => Err(miette!(
