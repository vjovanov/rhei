   153	fn generates_all_supported_shell_completions() {
   154	    let cases = [
   155	        ("bash", "_clap_complete_rhei"),
   156	        ("zsh", "#compdef rhei"),
   157	        ("fish", "complete --keep-order --exclusive --command rhei"),
   158	        ("powershell", "Register-ArgumentCompleter"),
   159	        ("elvish", "set edit:completion:arg-completer[rhei]"),
   160	    ];
   161	
   162	    for (shell, marker) in cases {
   163	        let result = run_completions(shell);
   164	        assert!(
   165	            result.status.success(),
   166	            "{shell} completions should succeed\nstdout:\n{}\nstderr:\n{}",
   167	            result.stdout,
   168	            result.stderr
   169	        );
   170	        assert!(result.stdout.contains(marker), "{shell} output should contain shell marker");
   171	        assert!(
   172	            result.stdout.contains("COMPLETE"),
   173	            "{shell} output should call back into rhei through COMPLETE"
   174	        );
   175	    }
   176	}
