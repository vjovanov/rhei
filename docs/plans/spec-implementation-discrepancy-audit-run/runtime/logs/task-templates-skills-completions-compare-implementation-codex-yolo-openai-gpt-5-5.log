  2465	    fn discover_templates(filter: TemplateSourceFilter) -> MietteResult<Vec<DiscoveredTemplate>> {
  2466	        let mut templates = Vec::new();
  2467	        let mut seen = HashSet::new();
  2468	
  2469	        for (source, root) in template_search_roots(filter)? {
  2470	            if !root.is_dir() {
  2471	                continue;
  2472	            }
  2473	
  2474	            let mut entries = fs::read_dir(&root)
  2475	                .map_err(|err| file_io_report(&root, "failed to read template directory", err))?
  2476	                .collect::<Result<Vec<_>, _>>()
  2477	                .map_err(|err| {
  2478	                    miette!("failed to read dir entry in '{}': {err}", root.display())
  2479	                })?;
  2480	            entries.sort_by_key(|entry| entry.file_name());
  2481	
  2482	            for entry in entries {
  2483	                let path = entry.path();
  2484	                let name = entry.file_name().to_string_lossy().to_string();
  2485	                if name.starts_with('.') || !path.is_dir() || seen.contains(&name) {
  2486	                    continue;
  2487	                }
  2488	
  2489	                let Ok(manifest) = load_template_manifest(&path) else {
  2490	                    continue;
  2491	                };
  2492	
  2493	                seen.insert(name);
  2494	                templates.push(DiscoveredTemplate { manifest, path, source });
  2495	            }
  2496	        }
  2497	
  2498	        Ok(templates)
  2499	    }
