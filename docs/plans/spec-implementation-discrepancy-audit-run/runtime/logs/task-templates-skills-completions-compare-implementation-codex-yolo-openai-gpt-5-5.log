 10616	/// Recursively copy a directory tree.
 10617	fn copy_dir_recursive(src: &Path, dest: &Path) -> MietteResult<()> {
 10618	    fs::create_dir_all(dest)
 10619	        .map_err(|e| miette!("failed to create directory '{}': {e}", dest.display()))?;
 10620	
 10621	    for entry in fs::read_dir(src)
 10622	        .map_err(|e| miette!("failed to read directory '{}': {e}", src.display()))?
 10623	    {
 10624	        let entry = entry.map_err(|e| miette!("failed to read dir entry: {e}"))?;
 10625	        let src_path = entry.path();
 10626	        let dest_path = dest.join(entry.file_name());
 10627	
 10628	        if src_path.is_dir() {
 10629	            copy_dir_recursive(&src_path, &dest_path)?;
 10630	        } else {
 10631	            fs::copy(&src_path, &dest_path).map_err(|e| {
 10632	                miette!("failed to copy '{}' → '{}': {e}", src_path.display(), dest_path.display())
 10633	            })?;
 10634	        }
 10635	    }
 10636	
 10637	    Ok(())
 10638	}
