   637	        .parent()
   638	        .filter(|parent| !parent.as_os_str().is_empty())
   639	        .unwrap_or_else(|| Path::new("."));
   640	    let mut temp = tempfile::NamedTempFile::new_in(parent).map_err(|err| {
   641	        file_io_report(parent, "failed to create temporary completions file", err)
   642	    })?;
   643	    temp.write_all(&buffer)
   644	        .map_err(|err| file_io_report(path, "failed to write completions file", err))?;
   645	    temp.flush().map_err(|err| file_io_report(path, "failed to flush completions file", err))?;
   646	    temp.persist(path)
   647	        .map_err(|err| file_io_report(path, "failed to install completions file", err.error))?;
   648	    Ok(())
   649	}
