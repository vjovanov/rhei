  2249	    fn describe_instantiation_stop(
  2250	        rhei: &rhei_core::ast::Rhei,
  2251	        machine: &rhei_validator::StateMachine,
  2252	        entrypoint: &Path,
  2253	        dry_run: bool,
  2254	    ) -> String {
  2255	        let tasks = flatten_tasks(rhei);
  2256	        if dry_run {
  2257	            return "dry run stopped after rendering and validation; no files were written to the requested output path.".to_string();
  2258	        }
  2259	        if tasks.is_empty() {
  2260	            return "instantiation stopped after validation because the rendered workspace has no tasks.".to_string();
  2261	        }
  2262	
  2263	        let terminal =
  2264	            tasks.iter().filter(|task| is_terminal_state(task.state.as_str(), machine)).count();
  2265	        if terminal == tasks.len() {
  2266	            return format!(
  2267	                "instantiation stopped with the plan already complete: {terminal}/{} tasks are terminal.",
  2268	                tasks.len()
  2269	            );
  2270	        }
  2271	
  2272	        let gating = tasks
  2273	            .iter()
  2274	            .copied()
  2275	            .filter(|task| {
  2276	                let state = normalized_state_name(task.state.as_str(), machine);
  2277	                machine.states.get(&state).map(|def| def.gating).unwrap_or(false)
  2278	            })
  2279	            .collect::<Vec<_>>();
  2280	        if !gating.is_empty() {
  2281	            let labels = gating
  2282	                .iter()
  2283	                .take(3)
  2284	                .map(|task| format_task_summary_line(task))
  2285	                .collect::<Vec<_>>()
  2286	                .join(", ");
  2287	            let suffix = if gating.len() > 3 {
  2288	                format!(" (+{} more)", gating.len() - 3)
  2289	            } else {
  2290	                String::new()
  2291	            };
  2292	            return format!("instantiation stopped at a human gate: {labels}{suffix}.");
  2293	        }
  2294	
  2295	        let ready = ready_tasks_from_flat(&tasks, machine);
  2296	        if let Some(task) = ready.first() {
  2297	            return format!(
  2298	                "instantiation stopped before execution; next ready task is {}. Run `rhei run {}` or claim it with `rhei next {}`.",
  2299	                format_task_summary_line(task),
  2300	                entrypoint.display(),
  2301	                entrypoint.display()
  2302	            );
  2303	        }
  2304	
  2305	        let blocked = blocked_tasks_from_flat(&tasks, machine);
  2306	        if !blocked.is_empty() {
  2307	            let labels = blocked
  2308	                .iter()
  2309	                .take(3)
  2310	                .map(|task| format_task_summary_line(task))
  2311	                .collect::<Vec<_>>()
  2312	                .join(", ");
  2313	            let suffix = if blocked.len() > 3 {
  2314	                format!(" (+{} more)", blocked.len() - 3)
  2315	            } else {
  2316	                String::new()
  2317	            };
  2318	            return format!("instantiation stopped with tasks blocked by incomplete prerequisites: {labels}{suffix}.");
  2319	        }
  2320	
  2321	        "instantiation stopped after validation; no claimable task was found.".to_string()
  2322	    }
