 10138	/// Install skills for Claude Code.
 10139	fn install_claude_code(
 10140	    skill_sources: &[(String, PathBuf)],
 10141	    local: bool,
 10142	    link: bool,
 10143	    dry_run: bool,
 10144	    project_root: Option<&Path>,
 10145	) -> MietteResult<()> {
 10146	    let base = if local {
 10147	        project_root.ok_or_else(|| miette!("--local requires a project root"))?.join(".claude")
 10148	    } else {
 10149	        home_dir()?.join(".claude")
 10150	    };
 10151	
 10152	    let skills_dir = base.join("skills");
 10153	
 10154	    // Install each skill directory.
 10155	    for (name, source) in skill_sources {
 10156	        let dest = skills_dir.join(name);
 10157	        if link {
 10158	            let src =
 10159	                if local { relative_path(dest.parent().unwrap(), source) } else { source.clone() };
 10160	            link_skill(&src, &dest, dry_run)?;
 10161	        } else {
 10162	            copy_skill(source, &dest, dry_run)?;
 10163	        }
 10164	    }
 10165	
 10166	    // Generate and inject registration block into CLAUDE.md.
 10167	    let claude_md = base.join("CLAUDE.md");
 10168	    let mut block = String::from("# rhei\n");
 10169	    for (name, _) in skill_sources {
 10170	        let skill_path = if local {
 10171	            format!(".claude/skills/{name}/SKILL.md")
 10172	        } else {
 10173	            format!("~/.claude/skills/{name}/SKILL.md")
 10174	        };
 10175	        let description = skill_description(name);
 10176	        let trigger = format!("/{name}");
 10177	        block.push_str(&format!(
 10178	            "- **{name}** (`{skill_path}`) — {description}. Trigger: `{trigger}`\n"
 10179	        ));
 10180	    }
 10181	    let trigger_list: Vec<String> =
 10182	        skill_sources.iter().map(|(name, _)| format!("`/{name}`")).collect();
 10183	    block.push_str(&format!(
 10184	        "When the user types {}, invoke the Skill tool with the corresponding skill name before doing anything else.\n",
 10185	        trigger_list.join(", ")
 10186	    ));
 10187	
 10188	    // Use heading-based injection for Claude Code (not HTML markers).
 10189	    inject_claude_md_section(&claude_md, &block, dry_run)?;
 10190	
 10191	    println!("  ✓ {} — registered {} skills", claude_md.display(), skill_sources.len());
 10192	
 10193	    Ok(())
 10194	}
