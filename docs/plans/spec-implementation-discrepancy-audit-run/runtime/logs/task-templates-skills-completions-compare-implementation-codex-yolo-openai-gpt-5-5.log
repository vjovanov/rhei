  3342	
  3343	fn render_state_machine_text(machine: &rhei_validator::StateMachine) -> String {
  3344	    let mut out = String::new();
  3345	    out.push_str(&format!(
  3346	        "State machine: {} (version: {})\n",
  3347	        machine.name,
  3348	        format_version(&machine.version)
  3349	    ));
  3350	    if !machine.models.is_empty() {
  3351	        out.push_str(&format!("Models: {}\n", machine.models.join(", ")));
  3352	    }
  3353	
  3354	    out.push_str("\nStates:\n");
  3355	    if machine.states.is_empty() {
  3356	        out.push_str("  (none defined)\n");
  3357	    } else {
  3358	        for (idx, (name, def)) in machine.states.iter().enumerate() {
  3359	            if idx > 0 {
  3360	                out.push('\n');
  3361	            }
  3362	            let mut flags = Vec::new();
  3363	            if def.initial {
  3364	                flags.push("initial");
  3365	            }
  3366	            if def.terminal {
  3367	                flags.push("final");
  3368	            }
  3369	            let flag_suffix =
  3370	                if flags.is_empty() { String::new() } else { format!(" [{}]", flags.join(", ")) };
  3371	            let description = def.description.as_deref().unwrap_or("");
  3372	            out.push_str(&format!("  {name}{flag_suffix}"));
  3373	            if !description.is_empty() {
  3374	                out.push_str(&format!(" — {description}"));
  3375	            }

