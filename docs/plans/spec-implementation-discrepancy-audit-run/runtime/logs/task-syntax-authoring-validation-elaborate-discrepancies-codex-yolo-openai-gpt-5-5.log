  1794	    report: &mut ValidationReport,
  1795	) {
  1796	    fn recurse(
  1797	        task: &Task,
  1798	        ancestors: &mut Vec<TaskId>,
  1799	        index: &HashMap<TaskId, &Task>,
  1800	        report: &mut ValidationReport,
  1801	    ) {
  1802	        for dep in &task.prior {
  1803	            if !index.contains_key(dep) {
  1804	                report.errors.push(format!("Task {} depends on missing Task {}", task.id, dep));
  1805	            }
  1806	            if ancestors.iter().any(|ancestor| ancestor == dep) {
  1807	                report.errors.push(format!(
  1808	                    "Task {} cannot list ancestor Task {} as **Prior:**; parent/child structure already defines containment. Make the dependent work a top-level sibling if it must wait for Task {}.",
  1809	                    task.id, dep, dep
  1810	                ));
  1811	            }
  1812	        }
  1813	        ancestors.push(task.id.clone());
  1814	        for child in &task.children {
  1815	            recurse(child, ancestors, index, report);
  1816	        }
  1817	        ancestors.pop();
  1818	    }
  1819	
  1820	    let mut ancestors = Vec::new();
  1821	    for task in &rhei.tasks {
  1822	        recurse(task, &mut ancestors, index, report);
  1823	    }
  1824	}
