   101	                return Err(ParseError::new(
   102	                    "`rhei` is a reserved node kind and must not appear in `structure.nodeKinds`",
   103	                    Some(start_line),
   104	                ));
   105	            }
   106	            if out.iter().any(|k: &String| k == &canonical) {
   107	                return Err(ParseError::new(
   108	                    format!(
   109	                        "plan frontmatter `structure.nodeKinds` contains duplicate entry `{canonical}`"
   110	                    ),
   111	                    Some(start_line),
   112	                ));
   113	            }
   114	            out.push(canonical);
   115	        }
   116	        node_kinds = out;
   117	    }
   118	
   119	    Ok(Structure { max_levels, node_kinds })
   120	}
   121	
   122	fn parse_frontmatter(lines: &[String], start_line: usize, kind: &str) -> Result<Metadata> {
   123	    if lines.is_empty() || lines.iter().all(|line| line.trim().is_empty()) {
   124	        return Ok(Metadata::new());
   125	    }
   126	
   127	    let yaml = lines.join("\n");
   128	    let value: YamlValue = serde_yaml::from_str(&yaml).map_err(|err| {
   129	        ParseError::new(format!("failed to parse {kind} YAML frontmatter: {err}"), Some(start_line))
   130	    })?;
   360	        kept.extend_from_slice(&lines[idx + 1..]);
   361	    }
   362	    let mut out = kept.join("\n");
   363	    if input.ends_with('\n') {
   364	        out.push('\n');
   365	    }
   366	    (out, true)
   367	}
   368	
   369	/// Parse a markdown plan into a Rhei AST.
   370	pub fn parse(input: &str) -> Result<Rhei> {
   371	    let re_rhei = Regex::new(r#"^#\s+Rhei:\s+(.*)$"#).unwrap();
   372	    let re_tasks = Regex::new(r#"^##\s+Tasks\s*$"#).unwrap();
   373	    let re_node_header = Regex::new(
   374	        r#"^(#{3,6})\s+([A-Za-z][A-Za-z0-9_-]*)\s+((?:[A-Za-z][A-Za-z0-9_-]*|[0-9]+)(?:\.(?:[A-Za-z][A-Za-z0-9_-]*|[0-9]+))*):\s+(.*)$"#,
   375	    )
   376	    .unwrap();
   377	    let re_any_h3_to_h6 = Regex::new(r#"^#{3,6}\s+\S.*$"#).unwrap();
   378	    let re_states_decl = Regex::new(r#"^\*\*States:\*\*\s+(.+)$"#).unwrap();
   379	    let re_state = Regex::new(r#"^\*\*State:\*\*\s*(.+)$"#).unwrap();
   380	    let re_state_like = Regex::new(r#"^\*\*State\b.*$"#).unwrap();
   381	    let re_prior_ref = Regex::new(
   382	        r#"([A-Za-z][A-Za-z0-9_-]*)\s+((?:[A-Za-z][A-Za-z0-9_-]*|[0-9]+)(?:\.(?:[A-Za-z][A-Za-z0-9_-]*|[0-9]+))*)"#,
   383	    )
   384	    .unwrap();
   385	    let re_prior_like = Regex::new(r#"^\*\*Prior\b.*$"#).unwrap();
   386	    let re_assignee = Regex::new(r#"^\*\*Assignee:\*\*\s*(.+)$"#).unwrap();
   387	    let re_assignee_like = Regex::new(r#"^\*\*Assignee\b.*$"#).unwrap();
   388	    let re_h2_heading = Regex::new(r#"^##\s+\S.*$"#).unwrap();
   389	    let re_section_header = Regex::new(r#"^##\s+(.+)$"#).unwrap();
   390	
   391	    let mut in_code_block = false;
   392	    let mut in_tasks_section = false;
   393	    let mut tasks_section_line: Option<usize> = None;
   394	    let mut pre_tasks_h2_seen = false;
   395	    let mut first_nonempty_line: Option<usize> = None;
   396	
   397	    let mut rhei_title: Option<String> = None;
   398	    let mut rhei_header_seen = false;
   399	    let mut rhei_states: Option<String> = None;
   400	    let mut rhei_states_checked = false;
   401	    let mut rhei_metadata: Option<Metadata> = None;
   402	    let mut frontmatter_checked = false;
   403	    let mut in_frontmatter = false;
   404	    let mut frontmatter_start_line = 0usize;
   405	    let mut frontmatter_lines: Vec<String> = Vec::new();
   406	    let mut rhei_content: Vec<ContentSection> = Vec::new();
   407	    let mut tasks: Vec<Task> = Vec::new();
   408	    let mut node_stack: Vec<NodeBuilder> = Vec::new();
   409	
   410	    // Structure is finalised once the frontmatter boundary is passed.
   411	    let mut structure: Structure = Structure::default();
   412	    let mut structure_finalised = false;
   413	
   414	    for (idx, raw) in input.lines().enumerate() {
   415	        let line_number = idx + 1;
   416	        let line = raw.trim();
   417	
   418	        if !line.is_empty() {
   419	            first_nonempty_line.get_or_insert(line_number);
   420	        }
   421	
   422	        if in_frontmatter {
   423	            if line == "---" {
   424	                let metadata =
   425	                    parse_frontmatter(&frontmatter_lines, frontmatter_start_line, "plan")?;
   426	                structure = parse_structure(Some(&metadata), frontmatter_start_line)?;
   427	                structure_finalised = true;
   428	                rhei_metadata = Some(metadata);
   429	                in_frontmatter = false;
   430	                continue;
   431	            }
   432	            frontmatter_lines.push(raw.to_string());
   433	            continue;
   434	        }
   435	
   436	        let trimmed_start = raw.trim_start();
   437	        let is_fence = trimmed_start.starts_with("```");
   438	        if is_fence {
   439	            in_code_block = !in_code_block;
   440	
   441	            if in_tasks_section {
   442	                if let Some(top) = node_stack.last_mut() {
   443	                    top.metadata_closed = true;
   444	                    if !top.content.is_empty() {
   445	                        top.content.push('\n');
   446	                    }
   447	                    top.content.push_str(raw);
   448	                }
   449	            } else if let Some(ContentSection { content, .. }) = rhei_content.last_mut() {
   450	                if !content.is_empty() {
   451	                    content.push('\n');
   452	                }
   453	                content.push_str(raw);
   454	            }
   455	            continue;
   456	        }
   457	
   458	        if line.is_empty() {
   459	            if in_tasks_section {
   460	                if let Some(top) = node_stack.last_mut() {
   520	                tasks_section_line = Some(line_number);
   521	                continue;
   522	            }
   523	
   524	            if re_h2_heading.is_match(line) {
   525	                pre_tasks_h2_seen = true;
   526	                if let Some(cap) = re_section_header.captures(line) {
   527	                    let section_title = cap.get(1).unwrap().as_str().trim().to_string();
   528	                    rhei_content
   529	                        .push(ContentSection { title: section_title, content: String::new() });
   530	                }
   531	                continue;
   532	            }
   533	
   534	            if re_state_like.is_match(line)
   535	                || re_prior_like.is_match(line)
   536	                || re_assignee_like.is_match(line)
   537	            {
   538	                return Err(ParseError::new(
   539	                    "Metadata field appears outside a task",
   540	                    Some(line_number),
   541	                ));
   542	            }
   543	
   544	            if let Some(ContentSection { content, .. }) = rhei_content.last_mut() {
   545	                if !content.is_empty() {
   546	                    content.push('\n');
   547	                }
   548	                content.push_str(raw);
   549	            }
   550	            continue;
   551	        }
   552	
   553	        // In the tasks section.
   554	        if in_code_block {
   555	            if let Some(top) = node_stack.last_mut() {
   556	                if !top.content.is_empty() {
   557	                    top.content.push('\n');
   558	                }
   559	                top.content.push_str(raw);
   560	            }
   561	            continue;
   562	        }
   563	
   564	        // Node heading (H3..=H6)?
   565	        if let Some(caps) = re_node_header.captures(line) {
   566	            let hashes = caps.get(1).unwrap().as_str();
   567	            let level = hashes.len() as u8;
   568	            let kind_raw = caps.get(2).unwrap().as_str();
   569	            let id_str = caps.get(3).unwrap().as_str();
   570	            let title = caps.get(4).unwrap().as_str().to_string();
   571	
   572	            let kind_canonical = kind_raw.to_ascii_lowercase();
   573	            if !structure.accepts_kind(&kind_canonical) {
   574	                return Err(ParseError::new(
   575	                    format!(
   576	                        "unknown node kind `{}` at heading; declared kinds are {:?}",
   577	                        kind_raw, structure.node_kinds
   578	                    ),
   579	                    Some(line_number),
   580	                ));
   581	            }
   582	
   583	            let depth = level.saturating_sub(2); // H3 -> depth 1
   584	            if depth == 0 || depth > MAX_ALLOWED_LEVELS {
   585	                return Err(ParseError::new(
   586	                    format!("node heading depth out of range at level {level}"),
   587	                    Some(line_number),
   588	                ));
   589	            }
   590	            if depth > structure.max_levels {
   591	                return Err(ParseError::new(
   592	                    format!(
   593	                        "node depth {depth} exceeds `structure.maxLevels` ({})",
   594	                        structure.max_levels
   595	                    ),
   596	                    Some(line_number),
   597	                ));
   598	            }
   599	
   600	            let id = parse_task_id(id_str).ok_or_else(|| {
   601	                ParseError::new(
   602	                    format!("malformed task id `{id_str}` in node heading"),
   603	                    Some(line_number),
   604	                )
   605	            })?;
   606	
   607	            if id.depth() as u8 != depth {
   608	                return Err(ParseError::new(
   609	                    format!(
   610	                        "heading depth {depth} does not match id path depth {}; \
   611	                         level-{level} nodes require {depth}-segment ids",
   612	                        id.depth()
   613	                    ),
   614	                    Some(line_number),
   615	                ));
   616	            }
   617	
   618	            if title.trim().is_empty() {
   619	                return Err(ParseError::new(
   620	                    format!(
   621	                        "malformed node heading: expected '{} {} <id>: <title>'",
   622	                        "#".repeat(level as usize),
   623	                        title_case_kind(&kind_canonical)
   624	                    ),
   625	                    Some(line_number),
   626	                ));
   627	            }
   628	
   629	            // Finalise any open nodes at >= this depth and attach them.
   630	            unwind_to_level(&mut node_stack, &mut tasks, level)?;
   631	
   632	            if depth > 1 {
   633	                let Some(parent) = node_stack.last() else {
   634	                    return Err(ParseError::new(
   635	                        format!("level-{level} node `{id}` has no enclosing parent task"),
   636	                        Some(line_number),
   637	                    ));
   638	                };
   639	                if !id.extends(&parent.id) {
   640	                    return Err(ParseError::new(
   641	                        format!(
   642	                            "child id `{id}` must extend parent id `{}` by exactly one segment",
   643	                            parent.id
   644	                        ),
   645	                        Some(line_number),
   646	                    ));
   647	                }
   648	            }
   649	
   650	            node_stack.push(NodeBuilder {
   651	                id,
   652	                kind: kind_canonical,
   653	                title,
   654	                level,
   655	                state: None,
   656	                prior: Vec::new(),
   657	                assignee: None,
   658	                content: String::new(),
   659	                children: Vec::new(),
   660	                metadata_closed: false,
   661	                heading_line: line_number,
   662	            });
   663	            continue;
   664	        }
   665	
   666	        if re_any_h3_to_h6.is_match(line) {
   667	            return Err(ParseError::new(
   668	                "Malformed node heading: expected '### <Kind> <id>: <title>' (for example `### Task 1: Title`)",
   669	                Some(line_number),
   670	            ));
   671	        }
   672	
   673	        // **State:** metadata
   674	        if let Some(caps) = re_state.captures(line) {
   675	            let Some(top) = node_stack.last_mut() else {
   676	                return Err(ParseError::new(
   677	                    "Metadata field appears outside a task",
   678	                    Some(line_number),
   679	                ));
   680	            };
   681	            if top.metadata_closed {
   682	                return Err(ParseError::new(
   683	                    "Metadata fields must appear immediately after the task heading before task content",
   684	                    Some(line_number),
   685	                ));
   686	            }
   687	            let raw_state = caps.get(1).unwrap().as_str().trim();
   688	            top.state = Some(unescape_state(raw_state));
   689	            continue;
   690	        }
   691	
   692	        if re_state_like.is_match(line) {
   693	            if node_stack.last().is_some() {
   694	                return Err(ParseError::new(
   695	                    "Malformed metadata field: expected '**State:** <value>'",
   696	                    Some(line_number),
   697	                ));
   698	            }
   699	            return Err(ParseError::new(
   700	                "Metadata field appears outside a task",
   701	                Some(line_number),
   702	            ));
   703	        }
   704	
   705	        // **Prior:** metadata
   706	        if line.starts_with("**Prior:**") {
   707	            let Some(top) = node_stack.last_mut() else {
   708	                return Err(ParseError::new(
   709	                    "Metadata field appears outside a task",
   710	                    Some(line_number),
   711	                ));
   712	            };
   713	            if top.metadata_closed {
   714	                return Err(ParseError::new(
   715	                    "Metadata fields must appear immediately after the task heading before task content",
   716	                    Some(line_number),
   717	                ));
   718	            }
   719	            if top.state.is_none() {
   720	                return Err(ParseError::new(
   721	                    format!("**State:** must appear before **Prior:** for Task {}", top.id),
   722	                    Some(line_number),
   723	                ));
   724	            }
   725	            let ids: Vec<TaskId> = re_prior_ref
   726	                .captures_iter(line)
   727	                .filter_map(|c| c.get(2))
   728	                .filter_map(|m| parse_task_id(m.as_str()))
   729	                .collect();
   730	            top.prior.extend(ids);
   731	            continue;
   732	        }
   733	
   734	        if re_prior_like.is_match(line) {
   735	            if node_stack.last().is_some() {
   736	                return Err(ParseError::new(
   737	                    "Malformed metadata field: expected '**Prior:** Task <id>[, Task <id>...]'",
   738	                    Some(line_number),
   739	                ));
   740	            }
   741	            return Err(ParseError::new(
   742	                "Metadata field appears outside a task",
   743	                Some(line_number),
   744	            ));
   745	        }
   746	
   747	        // **Assignee:** metadata
   748	        if let Some(caps) = re_assignee.captures(line) {
   749	            let Some(top) = node_stack.last_mut() else {
   750	                return Err(ParseError::new(
   751	                    "Metadata field appears outside a task",
   752	                    Some(line_number),
   753	                ));
   754	            };
   755	            if top.metadata_closed {
   756	                return Err(ParseError::new(
   757	                    "Metadata fields must appear immediately after the task heading before task content",
   758	                    Some(line_number),
   759	                ));
   760	            }
   761	            if top.state.is_none() {
   762	                return Err(ParseError::new(
   763	                    format!("**State:** must appear before **Assignee:** for Task {}", top.id),
   764	                    Some(line_number),
   765	                ));
   766	            }
   767	            if top.assignee.is_some() {
   768	                return Err(ParseError::new(
   769	                    format!("Duplicate **Assignee:** metadata for Task {}", top.id),
   770	                    Some(line_number),
   771	                ));
   772	            }
   773	            top.assignee = Some(caps.get(1).unwrap().as_str().trim().to_string());
   774	            continue;
   775	        }
   776	
   777	        if re_assignee_like.is_match(line) {
   778	            if node_stack.last().is_some() {
   779	                return Err(ParseError::new(
   780	                    "Malformed metadata field: expected '**Assignee:** <value>'",
   781	                    Some(line_number),
   782	                ));
   783	            }
   784	            return Err(ParseError::new(
   785	                "Metadata field appears outside a task",
   786	                Some(line_number),
   787	            ));
   788	        }
   789	
   790	        if re_h2_heading.is_match(line) {
   791	            return Err(ParseError::new(
   792	                "Tasks section must be the final '##' chapter and appear as '## Tasks'",
   793	                Some(line_number),
   794	            ));
   795	        }
   796	
   797	        // Content line: append to the innermost open node.
   798	        if let Some(top) = node_stack.last_mut() {
   799	            top.metadata_closed = true;
   800	            if !top.content.is_empty() {
   801	                top.content.push('\n');
   802	            }
   803	            top.content.push_str(raw);
   804	        }
   805	    }
   806	
   807	    if in_frontmatter {
   808	        return Err(ParseError::new(
   809	            "Unterminated YAML frontmatter: missing closing '---'",
   810	            Some(frontmatter_start_line.saturating_sub(1).max(1)),
   811	        ));
   812	    }
   813	
   814	    // Finalise remaining open nodes.
   815	    unwind_to_level(&mut node_stack, &mut tasks, 0)?;
   816	
   817	    let title = match rhei_title {
   818	        Some(t) => t,
   819	        None => {
   820	            return Err(ParseError::new(
   960	                frontmatter_start_line = line_number + 1;
   961	                frontmatter_lines.clear();
   962	                continue;
   963	            }
   964	            frontmatter_checked = true;
   965	        }
   966	
   967	        if re_tasks.is_match(line) {
   968	            return Err(ParseError::new(
   969	                "Workspace index file must not contain a '## Tasks' section; tasks belong in the tasks/ directory",
   970	                Some(line_number),
   971	            ));
   972	        }
   973	
   974	        if let Some(cap) = re_section_header.captures(line) {
   975	            let section_title = cap.get(1).unwrap().as_str().trim().to_string();
   976	            content.push(ContentSection { title: section_title, content: String::new() });
   977	            continue;
   978	        }
   979	
   980	        if let Some(ContentSection { content: ref mut c, .. }) = content.last_mut() {
   981	            if !c.is_empty() {
   982	                c.push('\n');
   983	            }
   984	            c.push_str(raw);
   985	        }
   986	    }
   987	
   988	    if in_frontmatter {
   989	        return Err(ParseError::new(
   990	            "Unterminated YAML frontmatter: missing closing '---'",
   991	            Some(frontmatter_start_line.saturating_sub(1).max(1)),
   992	        ));
   993	    }
   994	
   995	    let title = title.ok_or_else(|| ParseError::new("Missing '# Rhei: <title>' header", None))?;
   996	
   997	    Ok(WorkspaceIndex {
   998	        title,
   999	        states: states.unwrap_or_else(|| "rhei".to_string()),
  1000	        structure,
  1001	        metadata,
  1002	        content_sections: content,
  1003	    })
  1004	}
  1005	
  1006	/// Parse a workspace task file (a file inside the `tasks/` directory).
  1007	pub fn parse_workspace_tasks(input: &str) -> Result<Vec<Task>> {
  1008	    let prefix = "# Rhei: _workspace_\n\n## Tasks\n\n";
  1009	    let prefix_line_count = 4;
  1010	    let synthetic = format!("{}{}", prefix, input);
  1011	    match parse(&synthetic) {
  1012	        Ok(rhei) => Ok(rhei.tasks),
  1013	        Err(mut e) => {
  1014	            if let Some(ref mut line) = e.line {
  1015	                *line = line.saturating_sub(prefix_line_count);
  1016	                if *line == 0 {
  1017	                    *line = 1;
  1018	                }
  1019	            }
  1020	            Err(e)
  1021	        }
  1022	    }
  1023	}
  1024	
  1025	/// Unescape a state value: supports backtick wrapping only.
  1026	fn unescape_state(input: &str) -> String {
  1027	    if input.starts_with('`') && input.ends_with('`') && input.len() >= 2 {
  1028	        return input[1..input.len() - 1].to_string();
  1029	    }
  1030	    input.to_string()
  1031	}
