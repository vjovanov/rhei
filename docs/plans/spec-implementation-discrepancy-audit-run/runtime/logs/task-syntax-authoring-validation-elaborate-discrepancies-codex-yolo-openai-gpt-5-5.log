  1764	fn build_task_index(rhei: &Rhei) -> HashMap<TaskId, &Task> {
  1765	    fn visit<'a>(task: &'a Task, map: &mut HashMap<TaskId, &'a Task>) {
  1766	        map.insert(task.id.clone(), task);
  1767	        for child in &task.children {
  1768	            visit(child, map);
  1769	        }
  1770	    }
  1771	    let mut map = HashMap::new();
  1772	    for t in &rhei.tasks {
  1773	        visit(t, &mut map);
  1774	    }
  1775	    map
  1776	}
  1777	
  1778	/// Call `f` for every node in the tree, depth-first.
  1779	fn for_each_node<'a>(rhei: &'a Rhei, mut f: impl FnMut(&'a Task)) {
  1780	    fn recurse<'a>(task: &'a Task, f: &mut impl FnMut(&'a Task)) {
  1781	        f(task);
  1782	        for child in &task.children {
  1783	            recurse(child, f);
  1784	        }
  1785	    }
  1786	    for t in &rhei.tasks {
  1787	        recurse(t, &mut f);
  1788	    }
  1789	}
