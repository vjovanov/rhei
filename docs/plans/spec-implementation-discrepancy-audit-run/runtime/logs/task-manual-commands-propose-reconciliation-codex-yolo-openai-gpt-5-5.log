        env.add_filter("slug", |value: String| slugify_target_value(&value));

        let template = env
            .template_from_str(&preprocessed)
            .map_err(|err| miette!("failed to parse template '{}': {err}", path.display()))?;
        let rendered = template
            .render(values)
            .map_err(|err| miette!("failed to render template '{}': {err}", path.display()))?;
        Ok(rendered.replace(literal_open, "{{"))
    }
}

fn render_state_machine_text(machine: &rhei_validator::StateMachine) -> String {
    let mut out = String::new();
    out.push_str(&format!(
        "State machine: {} (version: {})\n",
        machine.name,
        format_version(&machine.version)
    ));
    if !machine.models.is_empty() {
        out.push_str(&format!("Models: {}\n", machine.models.join(", ")));
    }


