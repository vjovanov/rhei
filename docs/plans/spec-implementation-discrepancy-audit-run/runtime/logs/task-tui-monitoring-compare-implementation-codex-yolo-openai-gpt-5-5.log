  6764	fn with_agent_log<T>(
  6765	    log_file: &Arc<Mutex<fs::File>>,
  6766	    write: impl FnOnce(&mut fs::File) -> std::io::Result<T>,
  6767	) -> std::io::Result<T> {
  6768	    let mut guard = log_file
  6769	        .lock()
  6770	        .map_err(|_| std::io::Error::new(std::io::ErrorKind::Other, "agent log lock poisoned"))?;
  6771	    write(&mut guard)
  6772	}
