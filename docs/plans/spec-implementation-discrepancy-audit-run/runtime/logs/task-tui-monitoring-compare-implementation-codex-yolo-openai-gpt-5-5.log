  7217	fn find_program_exit_transition(
  7218	    machine: &rhei_validator::StateMachine,
  7219	    metadata: Option<&Metadata>,
  7220	    task: &rhei_core::ast::Task,
  7221	    current_state: &str,
  7222	    exit_code: i32,
  7223	) -> MietteResult<Option<String>> {
  7224	    let specific_matches = machine
  7225	        .transitions
  7226	        .iter()
  7227	        .filter(|rule| rule.from.0 == current_state)
  7228	        .filter(|rule| {
  7229	            matches!(rule.exit_code, Some(YamlValue::Number(_)) | Some(YamlValue::Sequence(_)))
  7230	        })
  7231	        .filter(|rule| transition_matches_exit_code(rule, exit_code))
  7232	        .filter(|rule| {
  7233	            transition_rule_is_applicable(
  7234	                rule,
  7235	                machine,
  7236	                metadata,
  7237	                &task.id,
  7238	                current_state,
  7239	                task.state.as_str(),
  7240	            )
  7241	            .unwrap_or(false)
  7242	        })
  7243	        .collect::<Vec<_>>();
  7244	    if specific_matches.len() > 1 {
  7245	        return Err(miette!(
  7246	            "multiple exit_code transitions matched exit code {} from state '{}'",
  7247	            exit_code,
  7248	            current_state
  7249	        ));
  7250	    }
  7251	    if let Some(rule) = specific_matches.first() {
  7252	        return Ok(Some(rule.to.0.clone()));
  7253	    }
  7254	    if exit_code == 0 {
  7255	        return Ok(None);
  7256	    }
  7257	
  7258	    let nonzero_matches = machine
  7259	        .transitions
  7260	        .iter()
  7261	        .filter(|rule| rule.from.0 == current_state)
  7262	        .filter(|rule| matches!(rule.exit_code, Some(YamlValue::String(ref value)) if value == "nonzero"))
  7263	        .filter(|rule| {
  7264	            transition_rule_is_applicable(
  7265	                rule,
  7266	                machine,
  7267	                metadata,
  7268	                &task.id,
  7269	                current_state,
  7270	                task.state.as_str(),
  7271	            )
  7272	            .unwrap_or(false)
  7273	        })
  7274	        .collect::<Vec<_>>();
  7275	    if nonzero_matches.len() > 1 {
  7276	        return Err(miette!(
  7277	            "multiple nonzero exit_code transitions matched exit code {} from state '{}'",
  7278	            exit_code,
  7279	            current_state
  7280	        ));
  7281	    }
  7282	
  7283	    Ok(nonzero_matches.first().map(|rule| rule.to.0.clone()))
  7284	}
