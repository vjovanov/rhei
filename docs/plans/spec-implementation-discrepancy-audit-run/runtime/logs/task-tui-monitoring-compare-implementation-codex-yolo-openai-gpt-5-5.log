   317	fn draw(terminal: &mut Terminal<CrosstermBackend<Stdout>>, state: &Arc<Mutex<UiState>>) {
   318	    let snapshot = match state.lock() {
   319	        Ok(s) => s.clone_snapshot(),
   320	        Err(p) => p.into_inner().clone_snapshot(),
   321	    };
   322	
   323	    let _ = terminal.draw(|f| {
   324	        let area = f.size();
   325	        if area.height < 4 || area.width < 20 {
   326	            // Terminal too small — render a single line.
   327	            let msg = Paragraph::new("rhei run (terminal too small)")
   328	                .style(Style::default().fg(Color::Yellow));
   329	            f.render_widget(msg, area);
   330	            return;
   331	        }
   332	
   333	        let chunks = Layout::default()
   334	            .direction(Direction::Vertical)
   335	            .constraints([
   336	                Constraint::Length(3), // header
   337	                Constraint::Min(snapshot.parallel.max(1) + 2),
   338	                Constraint::Min(5), // journal pane
   339	            ])
   340	            .split(area);
   341	
   342	        render_header(f, chunks[0], &snapshot);
   343	        render_slots(f, chunks[1], &snapshot);
   344	        render_journal(f, chunks[2], &snapshot);
