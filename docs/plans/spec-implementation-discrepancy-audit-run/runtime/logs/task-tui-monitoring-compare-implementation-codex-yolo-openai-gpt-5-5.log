   376	fn slot_lines(snapshot: &UiStateSnapshot, width: u16, height: u16) -> Vec<Line<'static>> {
   377	    let mut lines: Vec<Line> = Vec::new();
   378	    for (idx, s) in snapshot.slots.iter().enumerate() {
   379	        let remaining_slots = snapshot.slots.len().saturating_sub(idx + 1);
   380	        let available_rows = height as usize;
   381	        if lines.len() >= available_rows {
   382	            break;
   383	        }
   384	
   385	        let i = idx as Slot;
   386	        if let Some(task) = &s.task {
   387	            let elapsed = s.started_at.map(|t| t.elapsed()).unwrap_or_default();
   388	            let elapsed_s = elapsed.as_secs();
   389	            let transition = s.last_event_display.as_deref().unwrap_or(&s.state);
   390	            let task_label = s
   391	                .agent
   392	                .as_ref()
   393	                .map(|agent| format!("{task} ({agent})"))
   394	                .unwrap_or_else(|| task.clone());
   395	            lines.push(Line::from(vec![
   396	                Span::styled(format!("[{i:>2}] "), Style::default().fg(Color::Cyan)),
   397	                Span::styled(
   398	                    format!("{task_label:<28}"),
   399	                    Style::default().add_modifier(Modifier::BOLD),
   400	                ),
   401	                Span::raw(" "),
   402	                Span::styled(transition.to_string(), Style::default().fg(Color::Green)),
   403	                Span::raw(format!("  {:>4}s", elapsed_s)),
   404	            ]));
   405	            let traffic_room =
   406	                available_rows.saturating_sub(lines.len()).saturating_sub(remaining_slots);
   407	            let traffic_tail = traffic_room.min(5);
   408	            if traffic_tail > 0 {
   409	                for traffic in s.traffic.iter().rev().take(traffic_tail).rev() {
   410	                    let (label, style) = match traffic.stream {
   411	                        AgentStream::Stdout => ("out", Style::default().fg(Color::Gray)),
   412	                        AgentStream::Stderr => ("err", Style::default().fg(Color::Yellow)),
   413	                    };
   414	                    lines.push(Line::from(vec![
   415	                        Span::raw("     "),
   416	                        Span::styled(format!("{label}> "), style),
   417	                        Span::raw(truncate_chars(&traffic.text, width.saturating_sub(11) as usize)),
   418	                    ]));
   419	                }
   420	            }
   421	        } else {
   422	            lines.push(Line::from(vec![
   423	                Span::styled(format!("[{i:>2}] "), Style::default().fg(Color::DarkGray)),
   424	                Span::styled("— idle —", Style::default().fg(Color::DarkGray)),
   425	            ]));
   426	        }
   427	    }
   428	    lines
   429	}
