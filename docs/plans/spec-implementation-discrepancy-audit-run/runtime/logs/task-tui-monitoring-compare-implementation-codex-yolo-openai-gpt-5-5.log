   155	/// Live TUI frontend backed by ratatui + crossterm.
   156	///
   157	/// The sink owns a bounded event channel and a render thread. Drop (or
   158	/// `finish`) joins the render thread and restores the terminal.
   159	pub struct TuiSink {
   160	    tx: Sender<Msg>,
   161	    join: Mutex<Option<JoinHandle<()>>>,
   162	}
   163	
   164	enum Msg {
   165	    Event(RunEvent),
   166	    Shutdown,
   167	}
   168	
   169	enum InputAction {
   170	    Continue,
   171	    ForwardSigint,
   172	}
   173	
   174	impl TuiSink {
   175	    pub fn start(parallel: u16, total_tasks: usize) -> io::Result<Self> {
   176	        enable_raw_mode()?;
   177	        let mut stdout = io::stdout();
   178	        stdout.execute(EnterAlternateScreen)?;
   179	
   180	        // Panic hook: if the engine panics, restore the terminal before the
   181	        // default handler prints its message, so the user sees the panic.
   182	        let prev_hook = std::panic::take_hook();
   183	        std::panic::set_hook(Box::new(move |info| {
   184	            let _ = disable_raw_mode();
   185	            let _ = io::stdout().execute(LeaveAlternateScreen);
   186	            prev_hook(info);
   187	        }));
   188	
   189	        let backend = CrosstermBackend::new(stdout);
   190	        let terminal = Terminal::new(backend)?;
   191	
   192	        let (tx, rx) = bounded::<Msg>(CHANNEL_CAPACITY);
   193	        let state = Arc::new(Mutex::new(UiState::new(parallel, total_tasks)));
   194	
   195	        let handle = thread::spawn({
   196	            let state = Arc::clone(&state);
   197	            move || render_loop(terminal, rx, state)
   198	        });
   199	
   200	        Ok(Self { tx, join: Mutex::new(Some(handle)) })
   201	    }
   202	
   203	    /// Signal the render thread to exit and wait for it. Safe to call twice.
   204	    pub fn finish(&self) {
   205	        let _ = self.tx.send(Msg::Shutdown);
   206	        let mut guard = match self.join.lock() {
   207	            Ok(g) => g,
   208	            Err(p) => p.into_inner(),
   209	        };
   210	        if let Some(handle) = guard.take() {
   211	            let _ = handle.join();
   212	        }
   213	    }
   214	}
   215	
   216	impl Drop for TuiSink {
   217	    fn drop(&mut self) {
   218	        self.finish();
   219	    }
   220	}
   221	
   222	impl EventSink for TuiSink {
   223	    fn emit(&self, event: RunEvent) {
   224	        if matches!(event, RunEvent::AgentOutput { .. }) {
   225	            // Agent output is best-effort because the durable per-task log has
   226	            // the full transcript. Dropping here keeps output bursts from
   227	            // filling the shared channel indefinitely.
   228	            let _ = self.tx.try_send(Msg::Event(event));
   229	        } else {
   230	            // Lifecycle events define slot state. Preserve them even during
   231	            // output floods so the UI cannot get stuck showing stale work.
   232	            let _ = self.tx.send(Msg::Event(event));
   233	        }
   234	    }
   235	}
   236	
   237	fn render_loop(
   238	    mut terminal: Terminal<CrosstermBackend<Stdout>>,
   239	    rx: crossbeam_channel::Receiver<Msg>,
   240	    state: Arc<Mutex<UiState>>,
   241	) {
   242	    let tick = Duration::from_millis(250);
   243	    let mut last_draw = Instant::now().checked_sub(tick).unwrap_or_else(Instant::now);
   244	
   245	    loop {
   246	        // Drain any pending events until the channel is empty or timeout.
   247	        let deadline = Instant::now() + tick;
   248	        loop {
   249	            let remaining = deadline.saturating_duration_since(Instant::now());
   250	            match rx.recv_timeout(remaining) {
   251	                Ok(Msg::Event(event)) => {
   252	                    if let Ok(mut s) = state.lock() {
   253	                        s.apply(&event);
   254	                    }
   255	                }
   256	                Ok(Msg::Shutdown) => {
   257	                    draw(&mut terminal, &state);
   258	                    break_out(terminal);
   259	                    return;
   260	                }

