   483	fn render_journal(f: &mut ratatui::Frame, area: Rect, snapshot: &UiStateSnapshot) {
   484	    let block = Block::default().title(" journal ").borders(Borders::ALL);
   485	    let inner = block.inner(area);
   486	    f.render_widget(block, area);
   487	    if inner.height == 0 {
   488	        return;
   489	    }
   490	
   491	    let height = inner.height as usize;
   492	    let lines: Vec<Line> =
   493	        snapshot.journal.iter().rev().take(height).rev().map(|l| Line::from(l.clone())).collect();
   494	    f.render_widget(Paragraph::new(lines), inner);
   495	}
