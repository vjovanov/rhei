  7206	fn transition_matches_exit_code(rule: &rhei_core::ast::TransitionRule, exit_code: i32) -> bool {
  7207	    match rule.exit_code.as_ref() {
  7208	        Some(YamlValue::Number(number)) => number.as_i64() == Some(i64::from(exit_code)),
  7209	        Some(YamlValue::Sequence(values)) => {
  7210	            values.iter().filter_map(YamlValue::as_i64).any(|value| value == i64::from(exit_code))
  7211	        }
  7212	        Some(YamlValue::String(value)) if value == "nonzero" => exit_code != 0,
  7213	        _ => false,
  7214	    }
  7215	}
