 11990	    fn output_reader_logs_and_emits_complete_and_partial_lines() {
 11991	        let dir = tempfile::tempdir().expect("tmpdir");
 11992	        let log_path = dir.path().join("agent.log");
 11993	        let log_file = Arc::new(Mutex::new(fs::File::create(&log_path).expect("log file")));
 11994	        let recorder = Arc::new(RecordingSink::default());
 11995	        let sink: Arc<dyn rhei_tui::EventSink> = recorder.clone();
 11996	
 11997	        let handle = spawn_agent_output_reader(
 11998	            std::io::Cursor::new(b"first\npartial".to_vec()),
 11999	            rhei_tui::AgentStream::Stdout,
 12000	            log_file,
 12001	            sink,
 12002	            3,
 12003	            "task-live".to_string(),
 12004	        );
 12005	
 12006	        drain_agent_output_reader(handle, rhei_tui::AgentStream::Stdout).expect("reader drains");
 12007	
 12008	        let log = fs::read_to_string(&log_path).expect("read log");
 12009	        assert_eq!(log, "first\npartial");
 12010	
 12011	        let events = recorder.events.lock().expect("events");
