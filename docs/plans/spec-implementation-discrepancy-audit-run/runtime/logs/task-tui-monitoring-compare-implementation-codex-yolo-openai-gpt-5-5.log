  6787	fn spawn_agent_output_reader<R>(
  6788	    reader: R,
  6789	    stream: rhei_tui::AgentStream,
  6790	    log_file: Arc<Mutex<fs::File>>,
  6791	    sink: Arc<dyn rhei_tui::EventSink>,
  6792	    slot: rhei_tui::Slot,
  6793	    task_id: String,
  6794	) -> std::thread::JoinHandle<std::io::Result<()>>
  6795	where
  6796	    R: Read + Send + 'static,
  6797	{
  6798	    std::thread::spawn(move || {
  6799	        let mut reader = BufReader::new(reader);
  6800	        let mut buf = Vec::new();
  6801	        loop {
  6802	            buf.clear();
  6803	            let read = reader.read_until(b'\n', &mut buf)?;
  6804	            if read == 0 {
  6805	                break;
  6806	            }
  6807	
  6808	            with_agent_log(&log_file, |f| {
  6809	                f.write_all(&buf)?;
  6810	                f.flush()
  6811	            })?;
  6812	
  6813	            sink.emit(rhei_tui::RunEvent::AgentOutput {
  6814	                slot,
  6815	                task: task_id.clone(),
  6816	                stream,
  6817	                line: output_line(&buf),
  6818	                wall_clock: std::time::SystemTime::now(),
  6819	            });
  6820	        }
  6821	        Ok(())
  6822	    })
  6823	}
  6824	
  6825	fn drain_agent_output_reader(
  6826	    handle: std::thread::JoinHandle<std::io::Result<()>>,
  6827	    stream: rhei_tui::AgentStream,
  6828	) -> MietteResult<()> {
  6829	    let deadline = Instant::now() + AGENT_OUTPUT_DRAIN_GRACE;
  6830	    while !handle.is_finished() {
  6831	        if Instant::now() >= deadline {
  6832	            // A descendant may still hold the inherited pipe open after the
  6833	            // direct agent process exits. Detach the reader instead of
  6834	            // blocking run completion forever; future bytes may still be
  6835	            // captured best-effort until process exit.
  6836	            return Ok(());
  6837	        }
  6838	        std::thread::sleep(Duration::from_millis(1));
  6839	    }
  6840	
  6841	    match handle.join() {
  6842	        Ok(Ok(())) => Ok(()),
  6843	        Ok(Err(err)) => {
  6844	            Err(miette!("failed to capture agent {}: {err}", agent_stream_label(stream)))
  6845	        }
  6846	        Err(_) => Err(miette!("agent {} capture thread panicked", agent_stream_label(stream))),
  6847	    }
  6848	}
