   438	fn truncate_chars(value: &str, max_chars: usize) -> String {
   439	    if max_chars == 0 {
   440	        return String::new();
   441	    }
   442	    let mut chars = value.chars();
   443	    let mut out = String::new();
   444	    for _ in 0..max_chars {
   445	        if let Some(ch) = chars.next() {
   446	            out.push(ch);
   447	        } else {
   448	            return out;
   449	        }
   450	    }
   451	    if chars.next().is_some() {
   452	        if max_chars > 1 {
   453	            out.pop();
   454	        }
   455	        out.push('…');
   456	    }
   457	    out
   458	}
   459	
   460	fn sanitize_terminal_text(value: &str) -> String {
   461	    let mut out = String::with_capacity(value.len());
   462	    let mut chars = value.chars().peekable();
   463	    while let Some(ch) = chars.next() {
   464	        if ch == '\u{1b}' {
   465	            if matches!(chars.peek(), Some('[')) {
   466	                chars.next();
   467	                for next in chars.by_ref() {
   468	                    if ('@'..='~').contains(&next) {
   469	                        break;
   470	                    }
   471	                }
   472	            }
   473	            continue;
   474	        }
   475	        if ch.is_control() && ch != '\t' {
   476	            continue;
   477	        }
   478	        out.push(ch);
   479	    }
   480	    out
   481	}
