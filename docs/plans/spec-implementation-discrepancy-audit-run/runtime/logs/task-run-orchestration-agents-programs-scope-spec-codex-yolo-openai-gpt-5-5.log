 12081	    #[cfg(unix)]
 12082	    fn run_fake_agent_profile(
 12083	        profile: CustomAgentProfile,
 12084	        agent_id: &str,
 12085	        prompt: &str,
 12086	    ) -> (String, Vec<rhei_tui::RunEvent>) {
 12087	        let dir = tempfile::tempdir().expect("tmpdir");
 12088	        let log_path = dir.path().join("agent.log");
 12089	        let recorder = Arc::new(RecordingSink::default());
 12090	        let resolved = ResolvedAgent {
 12091	            agent: AgentConfig::from(agent_id),
 12092	            profile,
 12093	            mode: None,
 12094	            target: None,
 12095	            model: None,
 12096	            timeout_secs: Some(10),
 12097	        };
 12098	        let tooling = ResolvedTooling { mcp_servers: Vec::new(), skills: Vec::new() };
 12099	        let status = spawn_and_wait_agent(
 12100	            &resolved,
 12101	            prompt,
 12102	            dir.path(),
 12103	            dir.path(),
 12104	            None,
 12105	            "task-live",
 12106	            "pending",
 12107	            &tooling,
 12108	            &log_path,
 12109	            0,
 12110	            recorder.clone(),
 12111	        )
 12112	        .expect("fake agent runs");
 12113	
 12114	        assert!(status.success());
 12115	        let log = fs::read_to_string(&log_path).expect("read log");
 12116	        let events = recorder.events.lock().expect("events").clone();
 12117	        (log, events)
 12118	    }
