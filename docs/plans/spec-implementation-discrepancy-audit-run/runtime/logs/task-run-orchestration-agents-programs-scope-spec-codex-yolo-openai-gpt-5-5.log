  4222	
  4223	/// Build the cross-language `TransitionContext` JSON payload that is
  4224	/// delivered to callbacks on stdin.
  4225	///
  4226	/// Shape matches `docs/specs/rhei-transitions.spec.md` #transitioncontext-data-structure.
  4227	/// The `triggered_by` field must be one of `"user" | "callback" | "system" | "engine"`.
  4228	/// `transition_data` seeds the `transitionData` slot; pass `serde_json::Value::Object(Map::new())`
  4229	/// for the initial `on_leave` call, and the accumulated data from `on_leave` for `on_enter`.
  4230	#[allow(clippy::too_many_arguments)]
  4231	fn build_transition_context_json(
  4232	    plan: Option<&rhei_core::ast::Rhei>,
  4233	    plan_path: &Path,
  4234	    task_id_str: &str,
  4235	    from_state: &str,
  4236	    to_state: &str,
  4237	    triggered_by: &str,
  4238	    transition_data: &serde_json::Value,
  4239	    working_dir: &Path,
  4240	) -> serde_json::Value {
  4241	    use serde_json::{json, Map, Value};
  4242	
  4243	    let task_node = plan.and_then(|rhei| find_task_by_id_str(&rhei.tasks, task_id_str));
  4244	
  4245	    let task_json = match task_node {
  4246	        Some(task) => json!({
  4247	            "id": task_id_to_json(&task.id),
  4248	            "kind": task.kind,
  4249	            "title": task.title,
  4250	            "content": task.content,
  4251	            "metadata": task_metadata_json(plan, task_id_str, from_state),
  4252	            "children": task.children.iter().map(task_summary_json).collect::<Vec<_>>(),
  4253	        }),
  4254	        None => json!({
  4255	            "id": task_id_str,
  4256	            "metadata": Value::Object(Map::new()),
  4257	            "children": Value::Array(Vec::new()),
  4258	        }),
  4259	    };
  4260	
  4261	    let rhei_json = match plan {
  4262	        Some(rhei) => json!({
  4263	            "title": rhei.title,
  4264	            "path": plan_path.display().to_string(),
  4265	            "tasks": rhei.tasks.iter().map(task_summary_json).collect::<Vec<_>>(),
  4266	        }),
  4267	        None => json!({
  4268	            "title": Value::Null,
  4269	            "path": plan_path.display().to_string(),
  4270	            "tasks": Value::Array(Vec::new()),
  4271	        }),
  4272	    };
  4273	
  4274	    json!({
  4275	        "rhei": rhei_json,
  4276	        "task": task_json,
  4277	        "transition": {
  4278	            "from": from_state,
  4279	            "to": to_state,
  4280	            "triggeredBy": triggered_by,
  4281	            "timestamp": current_iso8601(),
  4282	        },
  4283	        "transitionData": transition_data,
  4284	        "environment": {
  4285	            "platform": "cli",
  4286	            "version": env!("CARGO_PKG_VERSION"),
  4287	            "workingDirectory": working_dir.display().to_string(),
  4288	        },
  4289	    })
  4290	}
