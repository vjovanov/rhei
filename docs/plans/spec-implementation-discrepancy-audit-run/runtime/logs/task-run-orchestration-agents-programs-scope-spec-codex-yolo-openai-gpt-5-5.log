  4841	#[allow(clippy::too_many_arguments)]
  4842	fn ensure_state_inputs_exist(
  4843	    workspace_root: &Path,
  4844	    task_id: &str,
  4845	    state_name: &str,
  4846	    state_def: &rhei_validator::StateDef,
  4847	    visit_count: Option<u64>,
