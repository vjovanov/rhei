  4655	/// Evaluate a condition expression for `{if <condition>}` blocks.
  4656	///
  4657	/// Supported forms: `input.<name>.exists`, `mcp.<name>.available`,
  4658	/// `skill.<id>.available`.
  4659	fn evaluate_if_condition(condition: &str, context: &RuntimeTemplateContext<'_>) -> bool {
  4660	    if let Some(name) = condition.strip_prefix("input.").and_then(|s| s.strip_suffix(".exists")) {
  4661	        let visit_count = Some(render_visit_count(
  4662	            context.metadata,
  4663	            &context.task.id,
  4664	            context.state_name,
  4665	            context.current_state_raw,
  4666	            context.machine,
  4667	        ));
  4668	        if let Some(state_def) = context.machine.states.get(context.state_name) {
  4669	            if let Some(artifact) = state_def.inputs.iter().find(|a| a.name == name) {
  4670	                let (_, path) = resolve_artifact_path(
  4671	                    context.workspace_root,
  4672	                    artifact,
  4673	                    &context.task.id.to_string(),
  4674	                    context.state_name,
  4675	                    visit_count,
  4676	                    context.target,
  4677	                    context.model,
  4678	                    context.agent,
  4679	                    context.agent_mode,
  4680	                );
  4681	                return path.exists();
  4682	            }
  4683	        }
  4684	        return false;
  4685	    }
  4686	
  4687	    if let Some(name) = condition.strip_prefix("mcp.").and_then(|s| s.strip_suffix(".available")) {
  4688	        return context.tooling.map_or(false, |t| t.mcp_available(name));
  4689	    }
  4690	
  4691	    if let Some(id) = condition.strip_prefix("skill.").and_then(|s| s.strip_suffix(".available")) {
  4692	        return context.tooling.map_or(false, |t| t.skill_available(id));
  4693	    }
  4694	
  4695	    false
  4696	}
  4697	
  4698	/// Parse the body of an `{if}` block (text after the opening `{if ...}\n`).
  4699	///
  4700	/// Returns `(true_branch, optional_false_branch, text_after_endif)`.
  4701	/// Tag lines (`{else}`, `{endif}`) are consumed and excluded from all slices.
  4702	fn parse_if_block(body: &str) -> (&str, Option<&str>, &str) {
  4703	    if let Some(else_pos) = body.find("{else}") {
  4704	        let true_branch = &body[..else_pos];
  4705	        let after_else_tag = else_pos + "{else}".len();
  4706	        let false_start = if body[after_else_tag..].starts_with('\n') {
  4707	            after_else_tag + 1
  4708	        } else {
  4709	            after_else_tag
  4710	        };
  4711	        if let Some(endif_rel) = body[false_start..].find("{endif}") {
  4712	            let false_branch = &body[false_start..false_start + endif_rel];
  4713	            let after_endif_tag = false_start + endif_rel + "{endif}".len();
  4714	            let after_endif = if body[after_endif_tag..].starts_with('\n') {
  4715	                &body[after_endif_tag + 1..]
  4716	            } else {
  4717	                &body[after_endif_tag..]
  4718	            };
  4719	            return (true_branch, Some(false_branch), after_endif);
  4720	        }
  4721	        // Malformed: {else} but no {endif} — treat whole body as true branch
  4722	        return (body, None, "");
  4723	    }
  4724	
  4725	    if let Some(endif_pos) = body.find("{endif}") {
  4726	        let true_branch = &body[..endif_pos];
  4727	        let after_endif_tag = endif_pos + "{endif}".len();
  4728	        let after_endif = if body[after_endif_tag..].starts_with('\n') {
  4729	            &body[after_endif_tag + 1..]
  4730	        } else {
  4731	            &body[after_endif_tag..]
  4732	        };
  4733	        return (true_branch, None, after_endif);
  4734	    }
  4735	
  4736	    // Malformed: no {endif} — treat whole body as true branch
  4737	    (body, None, "")
  4738	}
  4739	
  4740	/// Collapse runs of three or more consecutive newlines to exactly two.
  4741	///
  4742	/// Two newlines (`\n\n`) represent a single blank line in prose. When a
  4743	/// conditional block is removed, adjacent blank lines from the surrounding text
  4744	/// and the removed block merge into a run of 3+; this collapses them back to
  4745	/// one blank line so the output stays clean.
  4746	fn collapse_extra_blank_lines(text: &str) -> String {
  4747	    let mut result = String::with_capacity(text.len());
  4748	    let mut newline_run = 0usize;
  4749	    for ch in text.chars() {
  4750	        if ch == '\n' {
  4751	            newline_run += 1;
  4752	            if newline_run <= 2 {
  4753	                result.push(ch);
  4754	            }
  4755	        } else {
  4756	            newline_run = 0;
  4757	            result.push(ch);
  4758	        }
  4759	    }
  4760	    result
  4761	}
  4762	
  4763	/// Pre-pass over `text` that resolves `{if condition}…{else}…{endif}` blocks
  4764	/// before variable substitution runs.
  4765	///
  4766	/// Supported conditions (v1): `input.<name>.exists`
  4767	/// Nesting is not supported in v1.
  4768	fn process_conditional_blocks(text: &str, context: &RuntimeTemplateContext<'_>) -> String {
  4769	    let mut result = String::with_capacity(text.len());
  4770	    let mut remaining = text;
  4771	
  4772	    while let Some(if_start) = remaining.find("{if ") {
  4773	        let after_open = if_start + "{if ".len();
  4774	        let Some(close_brace) = remaining[after_open..].find('}') else {
  4775	            // Malformed opening tag — pass through the '{' and move on
  4776	            result.push_str(&remaining[..if_start + 1]);
  4777	            remaining = &remaining[if_start + 1..];
  4778	            continue;
  4779	        };
  4780	        let condition = &remaining[after_open..after_open + close_brace];
  4781	        let tag_end = after_open + close_brace + 1; // position after '}'
  4782	
  4783	        // Consume the newline that follows the opening tag line
  4784	        let body_start = if remaining[tag_end..].starts_with('\n') { tag_end + 1 } else { tag_end };
  4785	
  4786	        // Emit everything before the opening tag unchanged
  4787	        result.push_str(&remaining[..if_start]);
  4788	
  4789	        let (true_branch, false_branch, after_endif) = parse_if_block(&remaining[body_start..]);
  4790	
  4791	        if evaluate_if_condition(condition, context) {
  4792	            result.push_str(true_branch);
  4793	        } else if let Some(fb) = false_branch {
  4794	            result.push_str(fb);
  4795	        }
  4796	        // else: block removed entirely
  4797	
  4798	        remaining = after_endif;
  4799	    }
  4800	
  4801	    result.push_str(remaining);
  4802	    collapse_extra_blank_lines(&result)
  4803	}
  4804	
  4805	fn resolve_runtime_template_text(text: &str, context: &RuntimeTemplateContext<'_>) -> String {
  4806	    let preprocessed = process_conditional_blocks(text, context);
  4807	    let text = preprocessed.as_str();
  4808	    let mut rendered = String::with_capacity(text.len());
  4809	    let mut idx = 0usize;
  4810	
  4811	    while idx < text.len() {
  4812	        if !text[idx..].starts_with('{') {
  4813	            let ch = text[idx..].chars().next().expect("substring should have a char");
  4814	            rendered.push(ch);
  4815	            idx += ch.len_utf8();
  4816	            continue;
  4817	        }
  4818	
  4819	        let mut end = idx + 1;
  4820	        while end < text.len() && !text[end..].starts_with('}') {
  4821	            end += 1;
  4822	        }
  4823	        if end >= text.len() {
  4824	            rendered.push('{');
  4825	            idx += 1;
  4826	            continue;
  4827	        }
  4828	
  4829	        let token = &text[idx + 1..end];
  4830	        if let Some(value) = resolve_runtime_template_variable(token, context) {
  4831	            rendered.push_str(&value);
  4832	        } else {
  4833	            rendered.push_str(&text[idx..=end]);
  4834	        }
  4835	        idx = end + 1;
  4836	    }
  4837	
  4838	    rendered
  4839	}
