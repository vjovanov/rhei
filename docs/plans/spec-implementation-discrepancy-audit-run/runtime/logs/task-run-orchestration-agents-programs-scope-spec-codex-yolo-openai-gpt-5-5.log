  3866	                miette!("condition operand '{}' is not available in task metadata", other)
  3867	            })?;
  3868	            Ok(value as i64)
  3869	        }
  3870	    }
  3871	}
  3872	
  3873	fn evaluate_transition_condition(
  3874	    condition: &str,
  3875	    metadata: Option<&Metadata>,
  3876	    task_id: &TaskId,
  3877	    current_state: &str,
  3878	    current_state_raw: &str,
  3879	    machine: &rhei_validator::StateMachine,
  3880	) -> MietteResult<bool> {
  3881	    let parts = condition.split_whitespace().collect::<Vec<_>>();
  3882	    if parts.len() != 3 {
  3883	        return Err(miette!(
  3884	            "unsupported transition condition '{}'; expected '<lhs> <op> <rhs>'",
  3885	            condition
  3886	        ));
  3887	    }
  3888	
  3889	    let lhs = resolve_condition_operand(
  3890	        parts[0],
  3891	        metadata,
  3892	        task_id,
  3893	        current_state,
  3894	        current_state_raw,
  3895	        machine,
  3896	    )?;
  3897	    let rhs = resolve_condition_operand(
  3898	        parts[2],
  3899	        metadata,
  3900	        task_id,
  3901	        current_state,
  3902	        current_state_raw,
  3903	        machine,
  3904	    )?;
  3905	
  3906	    let outcome = match parts[1] {
  3907	        "<" => lhs < rhs,
  3908	        "<=" => lhs <= rhs,
  3909	        ">" => lhs > rhs,
  3910	        ">=" => lhs >= rhs,
  3911	        "==" => lhs == rhs,
  3912	        "!=" => lhs != rhs,
  3913	        op => {
  3914	            return Err(miette!(
  3915	                "unsupported operator '{}' in transition condition '{}'",
  3916	                op,
  3917	                condition
  3918	            ))
  3919	        }
  3920	    };
  3921	
  3922	    Ok(outcome)
  3923	}
  3924	
  3925	fn loop_reentry_allowed(
  3926	    machine: &rhei_validator::StateMachine,
  3927	    metadata: Option<&Metadata>,
  3928	    task_id: &TaskId,
  3929	    current_state: &str,
  3930	    current_state_raw: &str,
  3931	    to_state: &str,
  3932	) -> bool {
  3933	    let Some(limit) = state_visit_limit(machine, to_state) else {
  3934	        return true;
  3935	    };
  3936	
  3937	    let mut current = task_visit_count(metadata, task_id, to_state);
  3938	    if current_state == to_state {
  3939	        current = current.max(raw_state_visit_count(current_state_raw, machine, to_state));
  3940	    }
  3941	    current < limit
  3942	}
  3943	
  3944	/// Explain why a specific declared transition is not applicable right now,
  3945	/// in user-facing prose. Returns a short phrase (e.g. "condition `visitCount
  3946	/// >= visits` evaluated to false" or "visit budget for state 'review' is
  3947	/// exhausted"). Does NOT re-check applicability — callers are expected to
  3948	/// invoke this only when `transition_rule_is_applicable` returned false.
  3949	fn describe_blocked_transition(
  3950	    rule: &rhei_core::ast::TransitionRule,
  3951	    machine: &rhei_validator::StateMachine,
  3952	    metadata: Option<&Metadata>,
  3953	    task_id: &TaskId,
  3954	    current_state: &str,
  3955	    current_state_raw: &str,
  3956	) -> String {
  3957	    if !loop_reentry_allowed(
  3958	        machine,
  3959	        metadata,
  3960	        task_id,
  3961	        current_state,
  3962	        current_state_raw,
  3963	        &rule.to.0,
  3964	    ) {
  3965	        return format!("visit budget for state '{}' is exhausted", current_state);
  3966	    }
  3967	    if let Some(condition) = rule.condition.as_deref() {
  3968	        return format!("condition `{}` evaluated to false", condition);
  3969	    }
  3970	    "transition is not currently applicable".to_string()
  3971	}
  3972	
  3973	/// Return the list of `to` states reachable from `from` whose applicability
  3974	/// check currently passes. Used to build actionable error messages when a
  3975	/// specific transition is blocked.
  3976	fn applicable_alternatives(
  3977	    machine: &rhei_validator::StateMachine,
  3978	    metadata: Option<&Metadata>,
  3979	    task_id: &TaskId,
  3980	    from: &str,
  3981	    current_state_raw: &str,
  3982	) -> Vec<String> {
  3983	    let mut out = Vec::new();
  3984	    for rule in machine.transitions() {
  3985	        if rule.from.0 != from && rule.from.0 != "*" {
  3986	            continue;
  3987	        }
  3988	        match transition_rule_is_applicable(
  3989	            rule,
  3990	            machine,
  3991	            metadata,
  3992	            task_id,
  3993	            from,
  3994	            current_state_raw,
  3995	        ) {
  3996	            Ok(true) => {
  3997	                if !out.contains(&rule.to.0) {
  3998	                    out.push(rule.to.0.clone());
  3999	                }
  4000	            }
  4001	            _ => continue,
  4002	        }
  4003	    }
  4004	    out
  4005	}
  4006	
  4007	fn transition_rule_is_applicable(
  4008	    rule: &rhei_core::ast::TransitionRule,
  4009	    machine: &rhei_validator::StateMachine,
  4010	    metadata: Option<&Metadata>,
  4011	    task_id: &TaskId,
  4012	    current_state: &str,
  4013	    current_state_raw: &str,
  4014	) -> MietteResult<bool> {
  4015	    if !loop_reentry_allowed(
  4016	        machine,
  4017	        metadata,
  4018	        task_id,
  4019	        current_state,
  4020	        current_state_raw,
  4021	        &rule.to.0,
  4022	    ) {
  4023	        return Ok(false);
  4024	    }
  4025	
  4026	    if let Some(condition) = rule.condition.as_deref() {
  4027	        return evaluate_transition_condition(
  4028	            condition,
  4029	            metadata,
  4030	            task_id,
  4031	            current_state,
  4032	            current_state_raw,
  4033	            machine,
  4034	        );
  4035	    }
  4036	
  4037	    Ok(true)
  4038	}
