    90	
    91	## 2. Dependency Validation
    92	
    93	Check that all prior tasks are completed before allowing a transition.
    94	
    95	### TypeScript
    96	
    97	```typescript
    98	rhei.onLeave('pending', 'in-progress', async (ctx: TransitionContext): Promise<TransitionResult> => {
    99	  const { task, rhei } = ctx;
   100	
   101	  for (const depId of task.metadata.dependsOn) {
   102	    const depTask = rhei.tasks.find(t => t.id === depId);
   103	
   104	    if (!depTask) {
   105	      return { success: false, error: `Dependency ${depId} not found` };
   106	    }
   107	
   108	    if (depTask.metadata.state !== 'completed') {
   109	      return {
   110	        success: false,
   111	        error: `Dependency "${depTask.title}" is ${depTask.metadata.state}, not completed`
   112	      };
   113	    }
   114	  }
   115	
   116	  return { success: true };
   117	});
   118	```
   119	
   120	### Python
   121	
   122	```python
   123	@rhei.on_leave("pending", "in-progress")
   124	def check_dependencies(ctx: TransitionContext) -> TransitionResult:
   125	    """Ensure all dependencies are completed."""
   126	    task = ctx.task
   127	    rhei = ctx.rhei
   128	
   129	    for dep_id in task.metadata.depends_on:
   130	        dep_task = next((t for t in rhei.tasks if t.id == dep_id), None)
   131	
   132	        if dep_task is None:
   133	            return TransitionResult(
   134	                success=False,
   135	                error=f"Dependency {dep_id} not found"
   136	            )
   137	
   138	        if dep_task.metadata.state != "completed":
   139	            return TransitionResult(
   140	                success=False,
   141	                error=f'Dependency "{dep_task.title}" is {dep_task.metadata.state}, not completed'
   142	            )
   143	
   144	    return TransitionResult(success=True)
   145	```
   146	
   147	### Java
   148	
   149	```java
   150	public static TransitionResult checkDependencies(TransitionContext ctx) {
   151	    Task task = ctx.getTask();
   152	    Rhei rhei = ctx.getRhei();
   153	
   154	    for (Object depId : task.getMetadata().getDependsOn()) {
   155	        Task depTask = rhei.getTasks().stream()
   156	            .filter(t -> t.getId().equals(depId))
   157	            .findFirst()
   158	            .orElse(null);
   159	
   160	        if (depTask == null) {
   161	            return TransitionResult.failure("Dependency " + depId + " not found");
   162	        }
   163	
   164	        String depState = depTask.getMetadata().getState();
   165	        if (!"completed".equals(depState)) {
   166	            return TransitionResult.failure(
   167	                String.format("Dependency \"%s\" is %s, not completed",
   168	                    depTask.getTitle(), depState)
   169	            );
   170	        }
   171	    }
   172	
   173	    return TransitionResult.success();
   174	}
   175	```
   176	
   177	### Bash (CLI)
   178	
   179	```bash
   180	check_dependencies() {
   181	    local context
   182	    context=$(cat)
   183	
   184	    task_id=$(echo "$context" | jq -r '.task.id')
   185	    dependencies=$(echo "$context" | jq -r '.task.metadata.dependsOn[]' 2>/dev/null)
   186	
   187	    for dep_id in $dependencies; do
   188	        dep_state=$(echo "$context" | jq -r \
   189	            ".rhei.tasks[] | select(.id == \"$dep_id\" or .id == $dep_id) | .metadata.state")
   190	        dep_title=$(echo "$context" | jq -r \
   191	            ".rhei.tasks[] | select(.id == \"$dep_id\" or .id == $dep_id) | .title")
   192	
   193	        if [[ -z "$dep_state" ]]; then
   194	            echo "{\"success\": false, \"error\": \"Dependency $dep_id not found\"}"
   195	            return 0
   196	        fi
   197	
   198	        if [[ "$dep_state" != "completed" ]]; then
   199	            echo "{\"success\": false, \"error\": \"Dependency \\\"$dep_title\\\" is $dep_state, not completed\"}"
   200	            return 0
   201	        fi
   202	    done
   203	
   204	    echo '{"success": true}'
   205	}
   206	```
