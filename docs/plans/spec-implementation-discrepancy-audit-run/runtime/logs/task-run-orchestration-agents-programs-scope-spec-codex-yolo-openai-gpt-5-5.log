   584	check_metadata() {
   585	    local context
   586	    context=$(cat)
   587	
   588	    # Access custom metadata fields
   589	    priority=$(echo "$context" | jq -r '.task.metadata.priority // "normal"')
   590	    max_retries=$(echo "$context" | jq -r '.task.metadata.maxRetries // 3')
   591	    assignee=$(echo "$context" | jq -r '.task.metadata.assignee // empty')
   592	    estimated_duration=$(echo "$context" | jq -r '.task.metadata.estimatedDuration // "unknown"')
   593	    platform=$(echo "$context" | jq -r '.environment.platform')
   594	
   595	    echo "Processing $priority-priority task for $assignee" >&2
   596	    echo "Estimated duration: $estimated_duration" >&2
   597	
   598	    # Enforce priority-based rules
