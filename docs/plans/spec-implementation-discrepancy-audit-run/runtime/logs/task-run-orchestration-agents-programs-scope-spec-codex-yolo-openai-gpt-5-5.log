   210	## 3. Data Passing Between Callbacks
   211	
   212	Pass data from `on_leave` to `on_enter` via `transitionData`.
   213	
   214	### TypeScript
   215	
   216	```typescript
   217	// on_leave: collect data for the next phase
   218	rhei.onLeave('processing', 'review', async (ctx: TransitionContext): Promise<TransitionResult> => {
   219	  const results = await collectProcessingResults(ctx.task.id);
   220	
   221	  return {
   222	    success: true,
   223	    data: {
   224	      processedAt: ctx.transition.timestamp,
   225	      artifactCount: results.artifacts.length,
   226	      metrics: results.metrics
   227	    }
   228	  };
   229	});
   230	
   231	// on_enter: use data from on_leave
   232	rhei.onEnter('review', async (ctx: TransitionContext): Promise<TransitionResult> => {
   233	  // Access data passed from on_leave
   234	  const { processedAt, artifactCount, metrics } = ctx.transitionData;
   235	
   236	  console.log(`Reviewing ${artifactCount} artifacts processed at ${processedAt}`);
   237	  console.log(`Quality score: ${metrics.qualityScore}`);
   238	
   239	  // Notify reviewers with context
   240	  await notifyReviewers({
   241	    taskId: ctx.task.id,
   242	    taskTitle: ctx.task.title,
   243	    artifactCount,
   244	    metrics
   245	  });
   246	
   247	  return { success: true };
   248	});
   249	```
   250	
   251	### Python
   252	
   253	```python
   254	@rhei.on_leave("processing", "review")
   255	def package_results(ctx: TransitionContext) -> TransitionResult:
   256	    """Collect processing results for review phase."""
   257	    results = collect_processing_results(ctx.task.id)
   258	
   259	    return TransitionResult(
   260	        success=True,
   261	        data={
   262	            "processed_at": ctx.transition.timestamp,
   263	            "artifact_count": len(results.artifacts),
   264	            "metrics": results.metrics
   265	        }
   266	    )
   267	
   268	@rhei.on_enter("review")
   269	def setup_review(ctx: TransitionContext) -> TransitionResult:
   270	    """Use data from on_leave to set up review."""
   271	    processed_at = ctx.transition_data.get("processed_at")
   272	    artifact_count = ctx.transition_data.get("artifact_count")
   273	    metrics = ctx.transition_data.get("metrics", {})
   274	
   275	    print(f"Reviewing {artifact_count} artifacts processed at {processed_at}")
   276	    print(f"Quality score: {metrics.get('quality_score')}")
   277	
   278	    notify_reviewers(
   279	        task_id=ctx.task.id,
   280	        task_title=ctx.task.title,
   281	        artifact_count=artifact_count,
   282	        metrics=metrics
   283	    )
   284	
   285	    return TransitionResult(success=True)
   286	```
   287	
   288	### Java
   289	
   290	```java
   291	public static TransitionResult packageResults(TransitionContext ctx) {
   292	    ProcessingResults results = collectProcessingResults(ctx.getTask().getId());
   293	
   294	    Map<String, Object> data = new HashMap<>();
   295	    data.put("processedAt", ctx.getTransition().getTimestamp());
   296	    data.put("artifactCount", results.getArtifacts().size());
   297	    data.put("metrics", results.getMetrics());
   298	
   299	    return TransitionResult.success().withData(data);
   300	}
   301	
   302	public static TransitionResult setupReview(TransitionContext ctx) {
   303	    Map<String, Object> transitionData = ctx.getTransitionData();
   304	
   305	    String processedAt = (String) transitionData.get("processedAt");
   306	    Integer artifactCount = (Integer) transitionData.get("artifactCount");
   307	    Map<String, Object> metrics = (Map<String, Object>) transitionData.get("metrics");
   308	
   309	    System.out.printf("Reviewing %d artifacts processed at %s%n",
   310	        artifactCount, processedAt);
   311	    System.out.printf("Quality score: %s%n", metrics.get("qualityScore"));
   312	
   313	    notifyReviewers(ctx.getTask().getId(), ctx.getTask().getTitle(),
   314	        artifactCount, metrics);
   315	
   316	    return TransitionResult.success();
   317	}
   318	```
   319	
