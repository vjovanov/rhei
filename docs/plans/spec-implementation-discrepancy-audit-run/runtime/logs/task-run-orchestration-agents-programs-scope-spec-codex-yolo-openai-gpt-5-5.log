  4415	/// Merge `src` object keys into `dst` (last write wins). Non-object `src`
  4416	/// values are ignored. Used to accumulate `data` payloads across multiple
  4417	/// `on_leave` callbacks into a single `transitionData`.
  4418	fn merge_transition_data(dst: &mut serde_json::Value, src: &serde_json::Value) {
  4419	    use serde_json::Value;
  4420	    let (Value::Object(dst_map), Value::Object(src_map)) = (dst, src) else {
  4421	        return;
  4422	    };
  4423	    for (key, value) in src_map {
  4424	        dst_map.insert(key.clone(), value.clone());
  4425	    }
  4426	}
