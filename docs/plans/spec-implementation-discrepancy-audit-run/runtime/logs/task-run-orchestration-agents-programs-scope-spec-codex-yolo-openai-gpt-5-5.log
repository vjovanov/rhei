  5370	/// Extract the current state of a task from raw markdown content.
  5371	///
  5372	/// Tries full-plan parsing first, falls back to workspace task-file parsing.
  5373	fn find_task_current_state(
  5374	    raw: &str,
  5375	    file_path: &Path,
  5376	    target_id: &TaskId,
  5377	    task_id_str: &str,
  5378	) -> MietteResult<String> {
  5379	    // Try full plan parse.
  5380	    if let Ok(rhei) = rhei_core::parse(raw) {
  5381	        if let Some(task) = rhei.tasks.iter().find(|t| &t.id == target_id) {
  5382	            return Ok(task.state.as_str().to_string());
  5383	        }
  5384	    }
  5385	
  5386	    // Try workspace task-file parse.
  5387	    if let Ok(tasks) = rhei_core::parser::parse_workspace_tasks(raw) {
  5388	        if let Some(task) = tasks.iter().find(|t| &t.id == target_id) {
  5389	            return Ok(task.state.as_str().to_string());
  5390	        }
  5391	    }
  5392	
  5393	    Err(miette!("task '{}' not found in {}", task_id_str, file_path.display()))
  5394	}
