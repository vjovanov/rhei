  4186	fn resolve_callback_paths(
  4187	    state_machine_path: Option<&Path>,
  4188	    plan_path: &Path,
  4189	) -> MietteResult<CallbackPaths> {
  4190	    let plan_path = plan_path.canonicalize().map_err(|err| {
  4191	        file_io_report(plan_path, "failed to resolve plan path for callbacks", err)
  4192	    })?;
  4193	    let state_machine_path = state_machine_path
  4194	        .map(|path| {
  4195	            path.canonicalize().map_err(|err| {
  4196	                file_io_report(path, "failed to resolve state machine path for callbacks", err)
  4197	            })
  4198	        })
  4199	        .transpose()?;
  4200	    let base_dir = if let Some(path) = state_machine_path.as_deref() {
  4201	        path.parent().filter(|parent| !parent.as_os_str().is_empty()).unwrap_or(Path::new("."))
  4202	    } else if plan_path.is_dir() {
  4203	        plan_path.as_path()
  4204	    } else {
  4205	        plan_path.parent().filter(|parent| !parent.as_os_str().is_empty()).unwrap_or(Path::new("."))
  4206	    };
  4207	
  4208	    let working_dir = base_dir.canonicalize().map_err(|err| {
  4209	        file_io_report(base_dir, "failed to resolve callback working directory", err)
  4210	    })?;
  4211	
  4212	    Ok(CallbackPaths { plan_path, state_machine_path, working_dir })
  4213	}
