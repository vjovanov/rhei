  4101	fn ensure_mapping(parent: &mut YamlMapping, key: YamlValue) -> &mut YamlMapping {
  4102	    if !matches!(parent.get(&key), Some(YamlValue::Mapping(_))) {
  4103	        parent.insert(key.clone(), YamlValue::Mapping(YamlMapping::new()));
  4104	    }
  4105	
  4106	    match parent.get_mut(&key) {
  4107	        Some(YamlValue::Mapping(mapping)) => mapping,
  4108	        _ => unreachable!("mapping just initialized"),
  4109	    }
  4110	}
  4111	
  4112	fn ensure_current_state_visit_count(
  4113	    existing: Option<&Metadata>,
  4114	    task_id: &TaskId,
  4115	    current_state: &str,
  4116	    current_state_raw: &str,
  4117	    machine: &rhei_validator::StateMachine,
  4118	) -> Option<Metadata> {
  4119	    state_visit_limit(machine, current_state)?;
  4120	
  4121	    let current =
  4122	        current_state_visit_count(existing, task_id, current_state, current_state_raw, machine);
  4123	    if current == task_visit_count(existing, task_id, current_state) {
  4124	        return existing.cloned();
  4125	    }
  4126	
  4127	    let mut root = existing.cloned().unwrap_or_default();
  4128	    let metadata_section = ensure_mapping(&mut root, yaml_key("metadata"));
  4129	    let tasks = ensure_mapping(metadata_section, yaml_key("tasks"));
  4130	    let task_entry = ensure_mapping(tasks, task_id_yaml_key(task_id));
  4131	    let state_visits = ensure_mapping(task_entry, yaml_key("stateVisits"));
  4132	    state_visits.insert(yaml_key(current_state), yaml_u64(current));
  4133	    Some(root)
  4134	}
  4135	
  4136	fn update_metadata_for_transition(
  4137	    existing: Option<&Metadata>,
  4138	    task_id: &TaskId,
  4139	    to_state: &str,
  4140	    machine: &rhei_validator::StateMachine,
  4141	) -> Option<Metadata> {
  4142	    state_visit_limit(machine, to_state)?;
  4143	
  4144	    let mut root = existing.cloned().unwrap_or_default();
  4145	    let metadata_section = ensure_mapping(&mut root, yaml_key("metadata"));
  4146	    let tasks = ensure_mapping(metadata_section, yaml_key("tasks"));
  4147	    let task_entry = ensure_mapping(tasks, task_id_yaml_key(task_id));
  4148	    let state_visits = ensure_mapping(task_entry, yaml_key("stateVisits"));
  4149	    let state_key = yaml_key(to_state);
  4150	    let next =
  4151	        state_visits.get(&state_key).and_then(yaml_value_to_u64).map(|n| n.max(1) + 1).unwrap_or(1);
  4152	    state_visits.insert(state_key, yaml_u64(next));
  4153	    Some(root)
  4154	}
  4155	
  4156	fn clear_runtime_state_visits(existing: Option<&Metadata>) -> Option<Metadata> {
  4157	    let mut root = existing.cloned()?;
  4158	    let Some(YamlValue::Mapping(metadata_section)) = root.get_mut(yaml_key("metadata")) else {
  4159	        return Some(root);
  4160	    };
  4161	    let Some(YamlValue::Mapping(tasks)) = metadata_section.get_mut(yaml_key("tasks")) else {
  4162	        return Some(root);
  4163	    };
  4164	
  4165	    for value in tasks.values_mut() {
  4166	        if let YamlValue::Mapping(task_map) = value {
  4167	            task_map.remove(yaml_key("stateVisits"));
  4168	        }
  4169	    }
  4170	
  4171	    Some(root)
  4172	}
