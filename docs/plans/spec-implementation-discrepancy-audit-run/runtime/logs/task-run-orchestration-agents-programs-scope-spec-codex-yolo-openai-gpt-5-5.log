   363	
   364	## 4. State Redirection
   365	
   366	Dynamically redirect to a different state based on runtime conditions.
   367	
   368	### TypeScript
   369	
   370	```typescript
   371	rhei.onLeave('validation', 'approved', async (ctx: TransitionContext): Promise<TransitionResult> => {
   372	  const validationResult = await runValidation(ctx.task);
   373	
   374	  if (validationResult.hasBlockingErrors) {
   375	    // Redirect to rejected instead of approved
   376	    return {
   377	      success: true,
   378	      nextState: 'rejected',
   379	      data: { errors: validationResult.errors }
   380	    };
   381	  }
   382	
   383	  if (validationResult.hasWarnings) {
   384	    // Redirect to manual review
   385	    return {
   386	      success: true,
   387	      nextState: 'manual-review',
   388	      data: { warnings: validationResult.warnings }
   389	    };
   390	  }
   391	
   392	  // Proceed to approved as originally requested
   393	  return { success: true };
   394	});
   395	```
   396	
   397	### Python
   398	
   399	```python
   400	@rhei.on_leave("validation", "approved")
   401	def validate_and_route(ctx: TransitionContext) -> TransitionResult:
   402	    """Validate and potentially redirect to different states."""
   403	    validation_result = run_validation(ctx.task)
   404	
   405	    if validation_result.has_blocking_errors:
   406	        # Redirect to rejected instead of approved
   407	        return TransitionResult(
   408	            success=True,
   409	            next_state="rejected",
   410	            data={"errors": validation_result.errors}
   411	        )
   412	
   413	    if validation_result.has_warnings:
   414	        # Redirect to manual review
   415	        return TransitionResult(
   416	            success=True,
   417	            next_state="manual-review",
   418	            data={"warnings": validation_result.warnings}
   419	        )
   420	
   421	    # Proceed to approved as originally requested
   422	    return TransitionResult(success=True)
   423	```
   424	
   425	### Java
   426	
   427	```java
   428	public static TransitionResult validateAndRoute(TransitionContext ctx) {
   429	    ValidationResult validation = runValidation(ctx.getTask());
   430	
   431	    if (validation.hasBlockingErrors()) {
   432	        // Redirect to rejected instead of approved
   433	        return TransitionResult.builder()
   434	            .success(true)
   435	            .nextState("rejected")
   436	            .data("errors", validation.getErrors())
   437	            .build();
   438	    }
   439	
   440	    if (validation.hasWarnings()) {
   441	        // Redirect to manual review
   442	        return TransitionResult.builder()
   443	            .success(true)
   444	            .nextState("manual-review")
   445	            .data("warnings", validation.getWarnings())
   446	            .build();
   447	    }
   448	
   449	    // Proceed to approved as originally requested
   450	    return TransitionResult.success();
   451	}
   452	```
   453	
   454	### Bash (CLI)
   455	
   456	```bash
   457	validate_and_route() {
   458	    local context
   459	    context=$(cat)
   460	
   461	    task_id=$(echo "$context" | jq -r '.task.id')
   462	
   463	    # Simulate validation (in practice, run actual validation)
   464	    has_blocking_errors=false
   465	    has_warnings=true
   466	
   467	    if [[ "$has_blocking_errors" == "true" ]]; then
   468	        cat <<EOF
   469	{
   470	    "success": true,
   471	    "nextState": "rejected",
   472	    "data": {"errors": ["Critical validation failure"]}
   473	}
   474	EOF
   475	    elif [[ "$has_warnings" == "true" ]]; then
   476	        cat <<EOF
   477	{
   478	    "success": true,
   479	    "nextState": "manual-review",
   480	    "data": {"warnings": ["Non-critical issue detected"]}
   481	}
   482	EOF
   483	    else
   484	        echo '{"success": true}'
   485	    fi
   486	}
   487	```
