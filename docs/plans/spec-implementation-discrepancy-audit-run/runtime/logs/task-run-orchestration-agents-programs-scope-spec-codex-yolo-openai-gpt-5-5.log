   618	## 6. Environment-Aware Logic
   619	
   620	Adapt behavior based on the execution environment.
   621	
   622	### TypeScript
   623	
   624	```typescript
   625	rhei.onEnter('deploying', async (ctx: TransitionContext): Promise<TransitionResult> => {
   626	  const { environment, task, rhei } = ctx;
   627	
   628	  console.log(`Deploying from ${environment.platform} v${environment.version}`);
   629	  console.log(`Working directory: ${environment.workingDirectory}`);
   630	
   631	  // Platform-specific deployment logic
   632	  switch (environment.platform) {
   633	    case 'cli':
   634	      // CLI runs actual shell commands
   635	      await execShell(`deploy.sh --task ${task.id}`);
   636	      break;
   637	
   638	    case 'nodejs':
   639	      // Node.js uses programmatic deployment
   640	      await deployService.deploy(task.id, {
   641	        rheiPath: rhei.path,
   642	        dryRun: false
   643	      });
   644	      break;
   645	
   646	    case 'python':
   647	    case 'java':
   648	      // Other platforms delegate to CLI
   649	      await execShell(`rhei-cli deploy --task ${task.id} --input ${rhei.path}`);
   650	      break;
   651	  }
   652	
   653	  return {
   654	    success: true,
   655	    data: { deployedFrom: environment.platform }
   656	  };
   657	});
   658	```
