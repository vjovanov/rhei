 11788	    #[test]
 11789	    fn resolve_tooling_unions_defaults_with_state_overrides_by_id() {
 11790	        let machine = machine_with_tooling(
 11791	            r#"  pending:
 11792	    description: Work
 11793	    agent: claude-code
 11794	    mcp_servers:
 11795	      - id: linear
 11796	        optional: true
 11797	"#,
 11798	        );
 11799	        let mut registry = BTreeMap::new();
 11800	        registry.insert("linear".to_string(), McpServerProfile::default());
 11801	        registry.insert("postgres".to_string(), McpServerProfile::default());
 11802	        let settings = settings_with(
 11803	            Some(vec![
 11804	                StateMcpEntry::Id("postgres".to_string()),
 11805	                StateMcpEntry::Id("linear".to_string()),
 11806	            ]),
 11807	            registry,
 11808	        );
 11809	
 11810	        let tooling = resolve_tooling(&machine, "pending", &settings);
 11811	        // postgres from defaults stays first; linear from defaults is replaced
 11812	        // by the state-level entry that flips optional to true.
 11813	        let ids: Vec<&str> = tooling.mcp_servers.iter().map(|e| e.id.as_str()).collect();
 11814	        assert_eq!(ids, vec!["postgres", "linear"]);
 11815	        let linear = tooling.mcp_servers.iter().find(|e| e.id == "linear").unwrap();
 11816	        assert!(linear.optional, "state override should win");
 11817	        assert!(linear.definition.is_some(), "registry entry resolves");
 11818	    }
