    16	## 1. Basic Transition Approval
    17	
    18	The simplest callback pattern: approve or reject a transition based on a condition.
    19	
    20	### TypeScript
    21	
    22	```typescript
    23	import { Rhei, TransitionContext, TransitionResult } from 'rhei-napi';
    24	
    25	const rhei = new Rhei({ rheiPath: './workflow.rhei.md' });
    26	
    27	rhei.onLeave('draft', 'pending', async (ctx: TransitionContext): Promise<TransitionResult> => {
    28	  // Reject if task title is empty
    29	  if (!ctx.task.title.trim()) {
    30	    return { success: false, error: 'Task title cannot be empty' };
    31	  }
    32	  return { success: true };
    33	});
    34	```
    35	
    36	### Python
    37	
    38	```python
    39	from rhei import Rhei, TransitionContext, TransitionResult
    40	
    41	rhei = Rhei(rhei_path="./workflow.rhei.md")
    42	
    43	@rhei.on_leave("draft", "pending")
    44	def validate_title(ctx: TransitionContext) -> TransitionResult:
    45	    """Reject if task title is empty."""
    46	    if not ctx.task.title.strip():
    47	        return TransitionResult(success=False, error="Task title cannot be empty")
    48	    return TransitionResult(success=True)
    49	```
    50	
    51	### Java
    52	
    53	```java
    54	import io.rhei.Rhei;
    55	import io.rhei.TransitionContext;
    56	import io.rhei.TransitionResult;
    57	
    58	public class BasicCallbacks {
    59	    public static TransitionResult validateTitle(TransitionContext ctx) {
    60	        // Reject if task title is empty
    61	        if (ctx.getTask().getTitle().trim().isEmpty()) {
    62	            return TransitionResult.failure("Task title cannot be empty");
    63	        }
    64	        return TransitionResult.success();
    65	    }
    66	}
    67	```
    68	
    69	### Bash (CLI)
    70	
    71	```bash
    72	#!/usr/bin/env bash
    73	# handlers.sh
    74	
    75	validate_title() {
    76	    local context
    77	    context=$(cat)  # Read JSON from stdin
    78	
    79	    title=$(echo "$context" | jq -r '.task.title')
    80	
    81	    if [[ -z "${title// /}" ]]; then
    82	        echo '{"success": false, "error": "Task title cannot be empty"}'
    83	    else
    84	        echo '{"success": true}'
    85	    fi
    86	}
    87	```
