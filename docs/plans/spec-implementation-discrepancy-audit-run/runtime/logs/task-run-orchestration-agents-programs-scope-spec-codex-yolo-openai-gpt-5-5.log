    description: Not started
    initial: true
  in-progress:
    description: Working
  completed:
    description: Done
    final: true
transitions:
  - from: pending
    to: in-progress
    on_leave: 'cli:printf ''{"success": false, "error": "dep not met"}'''
  - from: in-progress
    to: completed
"#;
    let dir = unique_temp_dir("callback-spec-rejection");
    let plan = r#"# Rhei: Spec Rejection Test

## Tasks

### Task 1: Alpha
**State:** pending
