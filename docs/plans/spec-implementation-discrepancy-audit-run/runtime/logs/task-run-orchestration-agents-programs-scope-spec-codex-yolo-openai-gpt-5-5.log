 12044	    #[cfg(unix)]
 12045	    fn write_fake_agent(dir: &Path) -> PathBuf {
 12046	        use std::os::unix::fs::PermissionsExt;
 12047	
 12048	        let script = dir.join("fake-agent");
 12049	        fs::write(
 12050	            &script,
 12051	            r#"#!/usr/bin/env bash
 12052	set -euo pipefail
 12053	printf 'stdout:start\n'
 12054	printf 'stderr:warn\n' >&2
 12055	prev=''
 12056	read_stdin=0
 12057	for arg in "$@"; do
 12058	  if [ "$prev" = "-p" ]; then
 12059	    printf 'prompt:%s\n' "$arg"
 12060	  fi
 12061	  if [ "$arg" = "--" ]; then
 12062	    read_stdin=1
 12063	  fi
 12064	  prev="$arg"
 12065	done
 12066	if [ "$read_stdin" = "1" ]; then
 12067	  while IFS= read -r line || [ -n "$line" ]; do
 12068	    printf 'stdin:%s\n' "$line"
 12069	  done
 12070	fi

 succeeded in 497ms:
 12070	fi
 12071	printf 'partial'
 12072	"#,
 12073	        )
 12074	        .expect("write fake agent");
 12075	        let mut perms = fs::metadata(&script).expect("metadata").permissions();
 12076	        perms.set_mode(0o755);
 12077	        fs::set_permissions(&script, perms).expect("chmod");
 12078	        script
 12079	    }
