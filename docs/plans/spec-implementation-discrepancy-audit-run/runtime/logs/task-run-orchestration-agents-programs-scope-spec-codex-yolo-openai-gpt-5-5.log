   490	
   491	## 5. Accessing Custom Metadata
   492	
   493	Use arbitrary metadata fields stored in the plan file's YAML frontmatter.
   494	
   495	### TypeScript
   496	
   497	```typescript
   498	rhei.onLeave('queued', 'processing', async (ctx: TransitionContext): Promise<TransitionResult> => {
   499	  const { task } = ctx;
   500	
   501	  // Access custom metadata fields
   502	  const priority = task.metadata.priority ?? 'normal';
   503	  const maxRetries = task.metadata.maxRetries ?? 3;
   504	  const assignee = task.metadata.assignee;
   505	  const estimatedDuration = task.metadata.estimatedDuration;
   506	
   507	  console.log(`Processing ${priority}-priority task for ${assignee}`);
   508	  console.log(`Estimated duration: ${estimatedDuration}`);
   509	
   510	  // Enforce priority-based rules
   511	  if (priority === 'critical' && !assignee) {
   512	    return {
   513	      success: false,
   514	      error: 'Critical tasks must have an assignee'
   515	    };
   516	  }
   517	
   518	  return {
   519	    success: true,
   520	    data: { maxRetries, startedBy: ctx.environment.platform }
   521	  };
   522	});
   523	```
   524	
   525	### Python
   526	
   527	```python
   528	@rhei.on_leave("queued", "processing")
   529	def check_metadata(ctx: TransitionContext) -> TransitionResult:
   530	    """Access and validate custom metadata fields."""
   531	    task = ctx.task
   532	
   533	    # Access custom metadata fields
   534	    priority = task.metadata.get("priority", "normal")
   535	    max_retries = task.metadata.get("maxRetries", 3)
   536	    assignee = task.metadata.get("assignee")
   537	    estimated_duration = task.metadata.get("estimatedDuration")
   538	
   539	    print(f"Processing {priority}-priority task for {assignee}")
   540	    print(f"Estimated duration: {estimated_duration}")
   541	
   542	    # Enforce priority-based rules
   543	    if priority == "critical" and not assignee:
   544	        return TransitionResult(
   545	            success=False,
   546	            error="Critical tasks must have an assignee"
   547	        )
   548	
   549	    return TransitionResult(
   550	        success=True,
   551	        data={"maxRetries": max_retries, "startedBy": ctx.environment.platform}
   552	    )
   553	```
   554	
   555	### Java
   556	
   557	```java
   558	public static TransitionResult checkMetadata(TransitionContext ctx) {
   559	    TaskMetadata metadata = ctx.getTask().getMetadata();
   560	
   561	    // Access custom metadata fields
   562	    String priority = metadata.getString("priority", "normal");
   563	    int maxRetries = metadata.getInt("maxRetries", 3);
   564	    String assignee = metadata.getString("assignee");
   565	    String estimatedDuration = metadata.getString("estimatedDuration");
   566	
   567	    System.out.printf("Processing %s-priority task for %s%n", priority, assignee);
   568	    System.out.printf("Estimated duration: %s%n", estimatedDuration);
   569	
   570	    // Enforce priority-based rules
   571	    if ("critical".equals(priority) && assignee == null) {
   572	        return TransitionResult.failure("Critical tasks must have an assignee");
   573	    }
   574	
   575	    return TransitionResult.success()
   576	        .withData("maxRetries", maxRetries)
   577	        .withData("startedBy", ctx.getEnvironment().getPlatform());
   578	}
   579	```
   580	
   581	### Bash (CLI)
   582	
