  3873	fn evaluate_transition_condition(
  3874	    condition: &str,
  3875	    metadata: Option<&Metadata>,
  3876	    task_id: &TaskId,
  3877	    current_state: &str,
  3878	    current_state_raw: &str,
  3879	    machine: &rhei_validator::StateMachine,
  3880	) -> MietteResult<bool> {
  3881	    let parts = condition.split_whitespace().collect::<Vec<_>>();
  3882	    if parts.len() != 3 {
  3883	        return Err(miette!(
  3884	            "unsupported transition condition '{}'; expected '<lhs> <op> <rhs>'",
  3885	            condition
  3886	        ));
  3887	    }
  3888	
  3889	    let lhs = resolve_condition_operand(
  3890	        parts[0],
  3891	        metadata,
  3892	        task_id,
  3893	        current_state,
  3894	        current_state_raw,
  3895	        machine,
  3896	    )?;
  3897	    let rhs = resolve_condition_operand(
  3898	        parts[2],
  3899	        metadata,
  3900	        task_id,
  3901	        current_state,
  3902	        current_state_raw,
  3903	        machine,
  3904	    )?;
  3905	
  3906	    let outcome = match parts[1] {
  3907	        "<" => lhs < rhs,
  3908	        "<=" => lhs <= rhs,
  3909	        ">" => lhs > rhs,
  3910	        ">=" => lhs >= rhs,
  3911	        "==" => lhs == rhs,
  3912	        "!=" => lhs != rhs,
  3913	        op => {
  3914	            return Err(miette!(
  3915	                "unsupported operator '{}' in transition condition '{}'",
  3916	                op,
  3917	                condition
  3918	            ))
  3919	        }
  3920	    };
  3921	
  3922	    Ok(outcome)
  3923	}
