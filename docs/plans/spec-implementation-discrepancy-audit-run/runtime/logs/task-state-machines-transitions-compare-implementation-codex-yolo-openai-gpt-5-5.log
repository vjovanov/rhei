   106	/// Trait for executing transition callbacks.
   107	///
   108	/// Implementations resolve a [`CallbackRef`] identifier and invoke the
   109	/// corresponding callback, passing the [`CallbackContext`] as input.
   110	pub trait CallbackExecutor {
   111	    /// Execute a callback and return its result.
   112	    fn execute(
   113	        &self,
   114	        callback: &CallbackRef,
   115	        context: &CallbackContext<'_>,
   116	    ) -> Result<CallbackResult, CallbackError>;
   117	}
