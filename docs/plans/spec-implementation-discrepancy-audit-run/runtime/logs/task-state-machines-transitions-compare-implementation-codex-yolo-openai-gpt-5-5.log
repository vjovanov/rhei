     1	//! Callback execution interface for state transition rules.
     2	//!
     3	//! When a transition rule declares `on_leave` or `on_enter` callbacks, a
     4	//! [`CallbackExecutor`] is responsible for resolving and invoking them.
     5	//!
     6	//! The [`ShellCallbackExecutor`] implementation runs callbacks as shell
     7	//! commands, passing transition context via environment variables and
     8	//! JSON on stdin, and parsing a JSON `TransitionResult` on stdout per the
     9	//! transitions specification.
    10	
    11	use crate::ast::CallbackRef;
    12	use serde_json::Value as JsonValue;
    13	use std::io::Write;
    14	use std::path::Path;
    15	use std::process::{Command, Stdio};
    16	
    17	/// Context provided to a callback during a state transition.
    18	///
    19	/// `context_json`, when present, is serialized and piped to the callback
    20	/// process as its stdin payload — matching the cross-language
    21	/// `TransitionContext` shape documented in the transitions specification.
    22	/// Callers that do not have the full context (e.g., unit tests) may pass
    23	/// `None` to skip stdin delivery; callbacks then rely solely on environment
    24	/// variables.
    25	#[derive(Debug, Clone)]
    26	pub struct CallbackContext<'a> {
    27	    /// Identifier of the task being transitioned.
    28	    pub task_id: &'a str,
    29	    /// State the task is leaving.
    30	    pub from_state: &'a str,
    31	    /// State the task is entering.
    32	    pub to_state: &'a str,
    33	    /// Path to the plan file.
    34	    pub plan_path: &'a Path,
    35	    /// Working directory used to execute shell callbacks.
    36	    pub callback_cwd: &'a Path,
    37	    /// Current model identifier when a state declares `all_models` or `model`, or `None`.
    38	    pub model: Option<&'a str>,
    39	    /// Current agent identifier when a state declares `agent`, or `None`.
    40	    pub agent: Option<&'a str>,
    41	    /// Full `TransitionContext` payload to deliver on stdin, if available.
    42	    pub context_json: Option<&'a JsonValue>,
    43	}
    44	
    45	/// Outcome of a callback invocation.
    46	///
    47	/// Mirrors the cross-language `TransitionResult` shape: `success`, optional
    48	/// `error` message, optional `next_state` redirect, and optional `data`
    49	/// blob to forward as `transitionData` to downstream callbacks.
    50	#[derive(Debug, Clone)]
    51	pub struct CallbackResult {
    52	    /// Whether the callback approves the transition proceeding.
    53	    pub success: bool,
    54	    /// Error message explaining why the transition was rejected.
    55	    /// Populated when `success` is false, or when the callback crashed
    56	    /// (non-zero exit). `None` on success.
    57	    pub error: Option<String>,
    58	    /// Redirected target state, only valid when `success` is true.
    59	    /// `None` means "proceed to the originally requested target".
    60	    pub next_state: Option<String>,
    61	    /// Data emitted by the callback to flow into the next callback's
    62	    /// `transitionData` field.
    63	    pub data: Option<JsonValue>,
    64	    /// Stdout captured from the callback (if any).
    65	    pub stdout: String,
    66	    /// Stderr captured from the callback (if any).
    67	    pub stderr: String,
    68	}
    69	
    70	impl CallbackResult {
    71	    /// Implicit success — used when a callback emits no parseable payload.
    72	    fn implicit_success(stdout: String, stderr: String) -> Self {
    73	        Self { success: true, error: None, next_state: None, data: None, stdout, stderr }
    74	    }
    75	}
    76	
    77	/// Error returned when a callback cannot be executed.
    78	#[derive(Debug)]
    79	pub enum CallbackError {
    80	    /// The callback identifier has no recognized platform prefix.
    81	    UnknownPlatform(String),
    82	    /// The callback command could not be started.
    83	    SpawnFailed(String, std::io::Error),
    84	    /// The callback command was started but writing to its stdin failed.
    85	    StdinWriteFailed(String, std::io::Error),
    86	}
    87	
    88	impl std::fmt::Display for CallbackError {
    89	    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
    90	        match self {
    91	            CallbackError::UnknownPlatform(id) => {
    92	                write!(f, "unknown callback platform in '{id}' (expected prefix like 'cli:')")
    93	            }
    94	            CallbackError::SpawnFailed(cmd, err) => {
    95	                write!(f, "failed to execute callback '{cmd}': {err}")
    96	            }
    97	            CallbackError::StdinWriteFailed(cmd, err) => {
    98	                write!(f, "failed to write context to callback '{cmd}' stdin: {err}")
    99	            }
   100	        }
   101	    }
   102	}
   103	
   104	impl std::error::Error for CallbackError {}
