   235	/// Parse the stdout of a CLI callback as a `TransitionResult`.
   236	///
   237	/// Returns `None` when the payload is empty or not a recognizable
   238	/// `TransitionResult` JSON object, signalling to the caller that it
   239	/// should fall back to the implicit-success behavior.
   240	fn parse_callback_stdout(stdout: &str, stderr: String) -> Option<CallbackResult> {
   241	    let trimmed = stdout.trim();
   242	    if trimmed.is_empty() {
   243	        return None;
   244	    }
   245	    let value: JsonValue = serde_json::from_str(trimmed).ok()?;
   246	    let object = value.as_object()?;
   247	    let success = object.get("success")?.as_bool()?;
   248	
   249	    let error = object.get("error").and_then(|v| v.as_str()).map(str::to_string);
   250	    let next_state = object.get("nextState").and_then(|v| v.as_str()).map(str::to_string);
   251	    let data = object.get("data").cloned();
   252	
   253	    // Spec invariant: `success: false` with `nextState` is invalid and is
   254	    // downgraded to rejection. Never forward a redirect from a rejection.
   255	    let next_state = if success { next_state } else { None };
   256	    let error = if success {
   257	        error
   258	    } else {
   259	        error.or_else(|| Some("transition rejected by callback".to_string()))
   260	    };
   261	
   262	    Some(CallbackResult { success, error, next_state, data, stdout: stdout.to_string(), stderr })
   263	}
