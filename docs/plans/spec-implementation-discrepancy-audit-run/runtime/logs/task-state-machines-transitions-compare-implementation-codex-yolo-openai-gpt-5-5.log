  1749	}
  1750	
  1751	/// Load a [`StateMachine`] from `machine_path` and validate a parsed rhei.
  1752	pub fn validate_from_machine_file<P: AsRef<Path>>(
  1753	    rhei: &Rhei,
  1754	    machine_path: P,
  1755	) -> Result<ValidationReport, StateMachineLoadError> {
  1756	    let machine = StateMachine::from_yaml_file(machine_path)?;
