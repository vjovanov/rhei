  4040	fn render_frontmatter_yaml(metadata: &Metadata) -> MietteResult<String> {
  4041	    let mut rendered = serde_yaml::to_string(metadata)
  4042	        .map_err(|err| miette!("failed to serialize frontmatter: {err}"))?;
  4043	    if let Some(stripped) = rendered.strip_prefix("---\n") {
  4044	        rendered = stripped.to_string();
  4045	    }
  4046	    Ok(rendered.trim_end().to_string())
