  1760	// ---------------------------
  1761	// Validation helpers
  1762	// ---------------------------
  1763	
  1764	fn build_task_index(rhei: &Rhei) -> HashMap<TaskId, &Task> {
  1765	    fn visit<'a>(task: &'a Task, map: &mut HashMap<TaskId, &'a Task>) {
  1766	        map.insert(task.id.clone(), task);
  1767	        for child in &task.children {
  1768	            visit(child, map);
  1769	        }
  1770	    }
  1771	    let mut map = HashMap::new();
  1772	    for t in &rhei.tasks {
  1773	        visit(t, &mut map);
  1774	    }
  1775	    map
  1776	}
  1777	
  1778	/// Call `f` for every node in the tree, depth-first.
  1779	fn for_each_node<'a>(rhei: &'a Rhei, mut f: impl FnMut(&'a Task)) {
  1780	    fn recurse<'a>(task: &'a Task, f: &mut impl FnMut(&'a Task)) {
  1781	        f(task);
  1782	        for child in &task.children {
  1783	            recurse(child, f);
  1784	        }
  1785	    }
  1786	    for t in &rhei.tasks {
  1787	        recurse(t, &mut f);
  1788	    }
  1789	}
  1790	
  1791	fn validate_dependency_integrity(
  1792	    rhei: &Rhei,
  1793	    index: &HashMap<TaskId, &Task>,
  1794	    report: &mut ValidationReport,
  1795	) {
  1796	    fn recurse(
  1797	        task: &Task,
  1798	        ancestors: &mut Vec<TaskId>,
  1799	        index: &HashMap<TaskId, &Task>,
  1800	        report: &mut ValidationReport,
  1801	    ) {
  1802	        for dep in &task.prior {
  1803	            if !index.contains_key(dep) {
  1804	                report.errors.push(format!("Task {} depends on missing Task {}", task.id, dep));
  1805	            }
  1806	            if ancestors.iter().any(|ancestor| ancestor == dep) {
  1807	                report.errors.push(format!(
  1808	                    "Task {} cannot list ancestor Task {} as **Prior:**; parent/child structure already defines containment. Make the dependent work a top-level sibling if it must wait for Task {}.",
  1809	                    task.id, dep, dep
  1810	                ));
  1811	            }
  1812	        }
  1813	        ancestors.push(task.id.clone());
  1814	        for child in &task.children {
  1815	            recurse(child, ancestors, index, report);
  1816	        }
  1817	        ancestors.pop();
  1818	    }
  1819	
  1820	    let mut ancestors = Vec::new();
  1821	    for task in &rhei.tasks {
  1822	        recurse(task, &mut ancestors, index, report);
  1823	    }
  1824	}
  1825	
  1826	fn validate_state_consistency(rhei: &Rhei, machine: &StateMachine, report: &mut ValidationReport) {
  1827	    for_each_node(rhei, |task| {
  1828	        let task_id_str = task.id.to_string();
  1829	        let kind_label = title_case_kind(&task.kind);
  1830	        let subject = format!("{} {}", kind_label, task.id);
  1831	        validate_task_state_instance(&subject, &task.state, machine, report);
  1832	        validate_task_state_against_profile(
  1833	            &subject,
  1834	            &task.state,
  1835	            Some(task.kind.as_str()),
  1836	            Some(task_id_str.as_str()),
  1837	            machine,
  1838	            report,
  1839	        );
  1840	    });
  1841	}
  1842	
  1843	fn title_case_kind(kind: &str) -> String {
  1844	    let mut out = String::with_capacity(kind.len());
  1845	    let mut chars = kind.chars();
  1846	    if let Some(first) = chars.next() {
  1847	        for c in first.to_uppercase() {
  1848	            out.push(c);
  1849	        }
  1850	    }
  1851	    for c in chars {
  1852	        out.push(c);
  1853	    }
  1854	    out
  1855	}
  1856	
  1857	/// Enforce that the authored state (ignoring any `-<visit>` suffix) is a
  1858	/// member of the resolved profile's `allowed` set. No-op when the machine
  1859	/// declares no `profiles` / `node_policy`.
  1860	fn validate_task_state_against_profile(
  1861	    subject: &str,
  1862	    raw_state: &str,
  1863	    kind: Option<&str>,
  1864	    task_id: Option<&str>,
  1865	    machine: &StateMachine,
  1866	    report: &mut ValidationReport,
  1867	) {
  1868	    let Some(profile) = machine.profile_for(kind, task_id) else {
  1869	        return;
  1870	    };
  1871	
  1872	    let parsed = parse_task_state(raw_state, machine);
  1873	    if !machine.is_valid_state(&parsed.state) {
  1874	        // `validate_task_state_instance` already reported the invalid state.
  1875	        return;
  1876	    }
  1877	
  1878	    if !profile.allowed.iter().any(|s| s == &parsed.state) {
  1879	        let allowed = profile.allowed.join(", ");
  1880	        report.errors.push(format!(
  1881	            "{} has state '{}' which is not allowed by its resolved profile. Profile allows: [{}]",
  1882	            subject, parsed.state, allowed
  1883	        ));
  1884	    }
  1885	}
  1886	
  1887	fn validate_task_state_instance(
  1888	    subject: &str,
  1889	    raw_state: &str,
  1890	    machine: &StateMachine,
  1891	    report: &mut ValidationReport,
  1892	) {
  1893	    let parsed = parse_task_state(raw_state, machine);
  1894	    if !machine.is_valid_state(&parsed.state) {
  1895	        let allowed = machine.allowed_states().collect::<Vec<_>>().join(", ");
  1896	        report
  1897	            .errors
  1898	            .push(format!("{} has invalid state '{}'. Allowed: [{}]", subject, raw_state, allowed));
  1899	        return;
  1900	    }
