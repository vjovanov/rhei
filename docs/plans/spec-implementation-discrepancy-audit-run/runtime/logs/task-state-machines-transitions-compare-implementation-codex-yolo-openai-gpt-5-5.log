  6449	        YamlValue::Mapping(mapping) => {
  6450	            let command = mapping
  6451	                .get(yaml_key("command"))
  6452	                .ok_or_else(|| miette!("program object must include a 'command' field"))?;
  6453	            let command = match command {
  6454	                YamlValue::String(value) => ProgramCommand::Shell(value.clone()),
  6455	                YamlValue::Sequence(items) => ProgramCommand::Exec(
  6456	                    items
  6457	                        .iter()
  6458	                        .map(|item| {
  6459	                            item.as_str()
  6460	                                .map(str::to_string)
  6461	                                .ok_or_else(|| miette!("program.command entries must be strings"))
  6462	                        })
  6463	                        .collect::<MietteResult<Vec<_>>>()?,
  6464	                ),
  6465	                _ => return Err(miette!("program.command must be a string or string array")),
  6466	            };
  6467	
  6468	            let env = mapping
  6469	                .get(yaml_key("env"))
  6470	                .map(|value| match value {
  6471	                    YamlValue::Mapping(values) => values
  6472	                        .iter()
  6473	                        .map(|(key, value)| {
  6474	                            let key = key
  6475	                                .as_str()
  6476	                                .ok_or_else(|| miette!("program.env keys must be strings"))?;
  6477	                            let value = match value {
  6478	                                YamlValue::Null => String::new(),
  6479	                                YamlValue::Bool(value) => value.to_string(),
  6480	                                YamlValue::Number(value) => value.to_string(),
  6481	                                YamlValue::String(value) => value.clone(),
  6482	                                _ => {
  6483	                                    return Err(miette!(
  6484	                                        "program.env values must be strings, numbers, booleans, or null"
  6485	                                    ))
  6486	                                }
  6487	                            };
  6488	                            Ok((key.to_string(), value))
