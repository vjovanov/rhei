  3851	        "visitCount" | "visit_count" => Ok(current_state_visit_count(
  3852	            metadata,
  3853	            task_id,
  3854	            current_state,
  3855	            current_state_raw,
  3856	            machine,
  3857	        ) as i64),
  3858	        "visits" => {
