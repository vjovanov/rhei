   119	/// Executes `cli:`-prefixed callbacks as shell commands.
   120	///
   121	/// The command portion after `cli:` is run via `sh -c` from
   122	/// [`CallbackContext::callback_cwd`]. The runtime delivers two channels:
   123	///
   124	/// - **Environment variables** (always present):
   125	///   - `RHEI_TASK_ID` — the task identifier
   126	///   - `RHEI_FROM_STATE` — the state being left
   127	///   - `RHEI_TO_STATE` — the state being entered
   128	///   - `RHEI_PLAN_PATH` — path to the plan file
   129	///   - `RHEI_MODEL` — model identifier when the state declares one
   130	///   - `RHEI_AGENT` — agent identifier when the state declares one
   131	///
   132	/// - **Stdin JSON**: when `context.context_json` is `Some`, the full
   133	///   `TransitionContext` is serialized and written to the child's stdin.
   134	///
   135	/// The callback is expected to emit a `TransitionResult` JSON object on
   136	/// stdout (`{ success, error?, nextState?, data? }`). Exit-code semantics:
   137	///
   138	/// - **Zero** + parseable JSON → the parsed result is returned as-is,
   139	///   except that `success: false` combined with `nextState` is downgraded
   140	///   to rejection per the spec.
   141	/// - **Zero** + empty stdout → implicit success (compatible with callbacks
   142	///   that don't yet speak the TransitionResult protocol).
   143	/// - **Zero** + non-empty stdout that does not parse as JSON → implicit
   144	///   success; the raw stdout is preserved for logging but not interpreted.
   145	/// - **Non-zero** → rejection with an error synthesized from stderr. This
   146	///   matches the spec: "exit code non-zero = callback crashed".
   147	pub struct ShellCallbackExecutor;
   148	
   149	impl CallbackExecutor for ShellCallbackExecutor {
   150	    fn execute(
   151	        &self,
   152	        callback: &CallbackRef,
   153	        context: &CallbackContext<'_>,
   154	    ) -> Result<CallbackResult, CallbackError> {
   155	        let id = &callback.0;
   156	
   157	        let command =
   158	            id.strip_prefix("cli:").ok_or_else(|| CallbackError::UnknownPlatform(id.clone()))?;
   159	
   160	        let mut cmd = Command::new("sh");
   161	        cmd.arg("-c")
   162	            .arg(command)
   163	            .current_dir(context.callback_cwd)
   164	            .env("RHEI_TASK_ID", context.task_id)
   165	            .env("RHEI_FROM_STATE", context.from_state)
   166	            .env("RHEI_TO_STATE", context.to_state)
   167	            .env("RHEI_PLAN_PATH", context.plan_path.as_os_str())
   168	            .stdin(Stdio::piped())
   169	            .stdout(Stdio::piped())
   170	            .stderr(Stdio::piped());
   171	        if let Some(model) = context.model {
   172	            cmd.env("RHEI_MODEL", model);
   173	        }
   174	        if let Some(agent) = context.agent {
   175	            cmd.env("RHEI_AGENT", agent);
   176	        }
   177	
   178	        let mut child =
   179	            cmd.spawn().map_err(|e| CallbackError::SpawnFailed(command.to_string(), e))?;
