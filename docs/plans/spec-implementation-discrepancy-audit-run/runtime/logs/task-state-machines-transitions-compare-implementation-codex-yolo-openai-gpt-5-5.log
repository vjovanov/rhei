  1695	/// Validator configured with a loaded [`StateMachine`].
  1696	pub struct Validator {
  1697	    machine: StateMachine,
  1698	}
  1699	
  1700	impl Validator {
  1701	    /// Create a validator that will use `machine` for allowed-state checks.
  1702	    pub fn new(machine: StateMachine) -> Self {
  1703	        Self { machine }
  1704	    }
  1705	
  1706	    /// Validate a parsed rhei using the currently configured states.
  1707	    ///
  1708	    /// This does not check markdown link targets (no file-system context).
  1709	    /// Use [`validate_with_base`](Self::validate_with_base) to also verify links.
  1710	    pub fn validate(&self, rhei: &Rhei) -> ValidationReport {
  1711	        self.validate_with_base(rhei, None)
  1712	    }
  1713	
  1714	    /// Validate a parsed rhei, optionally resolving markdown links relative
  1715	    /// to `base_path` (the directory containing the plan file).
  1716	    pub fn validate_with_base(&self, rhei: &Rhei, base_path: Option<&Path>) -> ValidationReport {
  1717	        let mut report = ValidationReport::ok();
  1718	
  1719	        let index = build_task_index(rhei);
  1720	        validate_task_id_uniqueness(rhei, &mut report);
  1721	        validate_sibling_uniqueness(rhei, &mut report);
  1722	        validate_dependency_integrity(rhei, &index, &mut report);
  1723	        validate_state_consistency(rhei, &self.machine, &mut report);
  1724	        validate_terminal_tree_coherence(rhei, &self.machine, &mut report);
  1725	        validate_circular_dependencies(rhei, &index, &mut report);
  1726	        validate_assignee_nonempty(rhei, &mut report);
  1727	
  1728	        if let Some(base) = base_path {
  1729	            validate_markdown_links(rhei, base, &mut report);
  1730	        }
  1731	
  1732	        report
  1733	    }
  1734	}
  1735	
  1736	/// Validate a parsed rhei using an already-loaded [`StateMachine`].
  1737	pub fn validate_with_machine(rhei: &Rhei, machine: &StateMachine) -> ValidationReport {
  1738	    Validator::new(machine.clone()).validate(rhei)
  1739	}
  1740	
  1741	/// Validate a parsed rhei using an already-loaded [`StateMachine`], resolving
  1742	/// markdown links relative to `base_path`.
  1743	pub fn validate_with_machine_and_base(
  1744	    rhei: &Rhei,
  1745	    machine: &StateMachine,
  1746	    base_path: &Path,
  1747	) -> ValidationReport {
