  4136	fn update_metadata_for_transition(
  4137	    existing: Option<&Metadata>,
  4138	    task_id: &TaskId,
  4139	    to_state: &str,
  4140	    machine: &rhei_validator::StateMachine,
  4141	) -> Option<Metadata> {
  4142	    state_visit_limit(machine, to_state)?;
  4143	
  4144	    let mut root = existing.cloned().unwrap_or_default();
  4145	    let metadata_section = ensure_mapping(&mut root, yaml_key("metadata"));
  4146	    let tasks = ensure_mapping(metadata_section, yaml_key("tasks"));
  4147	    let task_entry = ensure_mapping(tasks, task_id_yaml_key(task_id));
  4148	    let state_visits = ensure_mapping(task_entry, yaml_key("stateVisits"));
  4149	    let state_key = yaml_key(to_state);
  4150	    let next =
  4151	        state_visits.get(&state_key).and_then(yaml_value_to_u64).map(|n| n.max(1) + 1).unwrap_or(1);
  4152	    state_visits.insert(state_key, yaml_u64(next));
  4153	    Some(root)
  4154	}
