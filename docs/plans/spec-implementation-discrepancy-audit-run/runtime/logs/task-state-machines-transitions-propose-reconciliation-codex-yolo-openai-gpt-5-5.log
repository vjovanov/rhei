# States Definition for Markdown Plan Compiler
# This file defines the valid states for tasks and the allowed transitions
# between them. The CLI can print this machine with `rhei states`.

name: rhei
version: 3.0

states:
  draft:
    description: Task requires analysis before execution — the agent studies the project and writes a concrete task description.
    instructions: |
      Pick up when all **Prior:** tasks are `completed`. Analyze the current
      state of the project and determine the most elegant way to accomplish
      the task. Based on that analysis, write a description of what should be
      done. Transition to `pending` once the description is finalized.

  pending:
    description: Task is ready for implementation. An **Assignee** on a pending task means work is actively in progress.
    instructions: |
      Pick up when all **Prior:** tasks are `completed`. Implement the task
      and any child task nodes, logging progress per child task. When
      implementation is complete and self-tested, either run `rhei complete`
      to finish directly or transition to `agent-review` when a separate
      review pass is required.

  agent-review:
    description: A separate reviewing agent inspects the result.
    instructions: |
      Review the implementation against the task description, any child task
      nodes, and repository conventions. On pass, transition to `human-review`
      (or `completed` if no human gate is required). On fail, transition to
      `agent-review-fix` with concrete findings.

  agent-review-fix:
    description: The implementing agent addresses reviewer findings.
    instructions: |
      Address the reviewer's findings only — no scope expansion. After
      applying fixes, transition back to `agent-review` for re-review.

  human-review:
    description: Work is paused pending human inspection.
    gating: true
    instructions: |
      Stop all agent work on this task. Wait for a human to approve, request
      changes, or edit the rhei. Do not transition out of this state
      autonomously.

  completed:
    description: Task finished successfully.
    instructions: |
      Treat as immutable. Do not re-open, re-run, or modify unless the user
      explicitly requests it.
    final: true

  cancelled:
    description: Task is no longer needed.
    instructions: |
      Skip entirely. Do not execute, review, or reference as a prerequisite
      for new work.
    final: true

# Explicit transition rules. Any transition not listed here is forbidden.
transitions:
  - from: draft
    to: pending
    description: Task analysis complete, description finalized and ready for implementation
  - from: draft
    to: cancelled
    description: Task abandoned before analysis
  - from: pending
    to: agent-review
    description: Implementation complete, ready for automated review
  - from: pending
    to: human-review
    description: Implementation complete, requires human inspection
  - from: pending
    to: completed
    description: Implementation complete, no review required
  - from: pending
    to: cancelled
    description: Task abandoned during implementation
  - from: agent-review
    to: agent-review-fix
    description: Review found issues, implementing agent must apply fixes
  - from: agent-review
    to: human-review
    description: Review passed but human gate required before completion
  - from: agent-review
    to: completed
    description: Review passed, task finished successfully
  - from: agent-review-fix
    to: agent-review
    description: Fixes applied, re-submit for review
  - from: agent-review-fix
    to: cancelled
    description: Task abandoned during fix phase
  - from: human-review
    to: pending
    description: Human requested rework, task returns to implementation
  - from: human-review
    to: completed
    description: Human approved the work
  - from: human-review
    to: cancelled
    description: Human decided to abandon the task

# Named, reusable state policies. Referenced from `node_policy` below.
profiles:
  default-rhei:
    # Built-in profile used by both the root and every task node in the
    # default configuration. Covers the full draft/review/completion flow.
    initial: draft
    allowed:
      - draft
      - pending
      - agent-review
      - agent-review-fix
      - human-review
      - completed
      - cancelled

# Maps each node to a profile. The root is always a `rhei`-kind node and is
# mapped through `root`. All other nodes resolve through `by_type` (if their
# kind is listed) or `default`.
node_policy:
  root: default-rhei
  default: default-rhei

