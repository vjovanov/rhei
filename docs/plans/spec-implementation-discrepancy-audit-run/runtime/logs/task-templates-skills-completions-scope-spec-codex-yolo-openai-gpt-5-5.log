### .agents/rhei/templates/changeset-review/template.yaml
name: changeset-review
version: 1.0.0
description: Review a code change (PR, branch, commit, or diff) — split into parts, multi-target review each, score findings, human-gate, then fan out fixes.

inputs:
  - name: change_ref
    description: The change to review. Any of — a PR URL or number, a branch name, a commit SHA (or range `base..head`), or a path to a .diff/.patch file. The coordinator resolves it to an actual set of files before splitting.
    type: string

  - name: review_targets
    description: Execution targets that independently review each part of the change (one parallel pass per target)
    type: array
    items:
      type: string
    default:
      - claude-code[yolo]:anthropic:claude-opus-4-7
      - codex[yolo]:openai:gpt-5.4

  - name: review_focus
    description: Optional focus areas each reviewer must address as its own subsection (e.g., performance, security, concurrency). Empty means a general review.
    type: array
    items:
      type: string
    default: []

  - name: aggregator_target
    description: Execution target that deduplicates per-part findings and produces the scored issue list
    type: string
    default: claude-code[yolo]:anthropic:claude-opus-4-7

  - name: fix_target
    description: Execution target that implements each human-approved fix
    type: string
    default: claude-code[yolo]:anthropic:claude-opus-4-7

  - name: fix_prepare
    description: Optional pre-fix workspace isolation. One of — none (apply in-tree), branch (create a new branch), worktree (create a git worktree), fork (fork the repo before working).
    type: string
    default: none
    validate: "^(none|branch|worktree|fork)$"

  - name: fix_commit
    description: Optional post-fix commit behavior. One of — none (leave uncommitted), commit (local commit), push (commit and push to remote), pr (commit, push, open PR).
    type: string
    default: none
    validate: "^(none|commit|push|pr)$"

### .agents/rhei/templates/hourly-human-intervention/template.yaml
name: hourly-human-intervention
version: 1.1.0
description: Hourly sweep for human-intervention GitHub issues and PRs, with routed Forge/GraalVM fix loops.

inputs:
  - name: repo
    description: GitHub repository to inspect for human-intervention work.
    type: string
    default: oracle/graalvm-reachability-metadata

  - name: label
    description: GitHub label that marks work requiring manual follow-up.
    type: string
    default: human-intervention

  - name: forge_checkout
    description: Workspace-relative path to the graalvm-reachability-metadata checkout used for Forge and metadata fixes.
    type: path
    default: master

  - name: graalvm_checkout
    description: Workspace-relative path to the GraalVM coordination directory containing ce/ and ee/.
    type: path
    default: graalvm

  - name: graalvm_ce_checkout
    description: Workspace-relative path to the GraalVM CE git checkout.
    type: path
    default: graalvm/ce

  - name: graalvm_ee_checkout
    description: Workspace-relative path to the GraalVM EE git checkout.
    type: path
    default: graalvm/ee

  - name: analysis_target
    description: Execution target for fetching, classification, deep analysis, and routing.
    type: string
    default: codex[yolo]:openai:gpt-5.5

  - name: forge_fix_target
    description: Execution target for Forge and reachability-metadata fixes.
    type: string
    default: codex[yolo]:openai:gpt-5.5

  - name: graalvm_fix_target
    description: Execution target for GraalVM fixes.
    type: string
    default: codex[yolo]:openai:gpt-5.5

  - name: review_target
    description: Execution target for automated review passes.
    type: string
    default: codex[yolo]:openai:gpt-5.5

  - name: github_reviewers
    description: GitHub reviewers to request when creating or updating PRs. Empty means use repository defaults.
    type: array
    items:
      type: string
    default: []

### .agents/rhei/templates/multi-model-analysis/template.yaml
name: multi-model-analysis
version: 1.0.0
description: Run one analytical task through multiple target-specific passes in one state, then have Claude write the final synthesis.

inputs:
  - name: plan_title
    description: Title of the instantiated Rhei plan
    type: string
    required: true

  - name: task_title
    description: Title of the shared analysis task
    type: string
    required: true

  - name: task_description
    description: Full task instructions given to each analysis model pass
    type: string
    required: true

  - name: analysis_output_dir
    description: Directory that stores per-model analysis notes
    type: string
    default: runtime/analyses

  - name: agents
    description: Agent targets used for the analysis fanout
    type: array
    items:
      type: object
      properties:
        id:
          type: string
          validate: "[a-z][a-z0-9-]*"
        label:
          type: string
        selector:
          type: string
    default:
      - id: claude
        label: Claude analysis note
        selector: claude-code[yolo]:anthropic:claude-opus-4-7
      - id: gemini
        label: Gemini analysis note
        selector: gemini[yolo]:google:gemini-3.1-pro-preview
      - id: codex
        label: Codex analysis note
        selector: codex[yolo]:openai:gpt-5-codex

  - name: summary_agent
    description: Agent target that synthesizes the final document
    type: string
    default: claude-code[yolo]:anthropic:claude-opus-4-7

  - name: final_document_path
    description: Path where Claude writes the synthesized final document
    type: string
