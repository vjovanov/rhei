  9759	/// Rewrite a task's markdown after completion: remove `**Assignee:**` and,
  9760	/// when `insert_link` is true, append a `> **Result:** [link_text](link_path)`
  9761	/// line to the task body.
  9762	///
  9763	/// Operates on raw text lines so the parser does not need to know about
  9764	/// assignee or result fields.
  9765	fn rewrite_task_completion(
  9766	    task_file: &Path,
  9767	    task_id: &str,
  9768	    link_text: &str,
  9769	    link_path: &str,
  9770	    insert_link: bool,
  9771	) -> MietteResult<()> {
  9772	    let raw = fs::read_to_string(task_file)
  9773	        .map_err(|err| file_io_report(task_file, "failed to read plan file", err))?;
  9774	
  9775	    let lines: Vec<&str> = raw.lines().collect();
  9776	    let mut result_lines: Vec<String> = Vec::with_capacity(lines.len() + 2);
  9777	    let task_prefix = format!("### Task {}:", task_id);
  9778	
  9779	    let mut in_target_task = false;
  9780	    let mut link_inserted = !insert_link; // skip insertion when not requested
  9781	    let result_line = format!("> **Result:** [{}]({})", link_text, link_path);
  9782	
  9783	    // Any H4..=H6 heading marks a child/descendant node under the current
  9784	    // root task, regardless of node kind. Insert the result link just before
  9785	    // the first descendant heading we encounter while still inside the target.
  9786	    let descendant_heading_re = regex::Regex::new(r#"^#{4,6}\s+"#).expect("regex");
  9787	
  9788	    for line in &lines {
  9789	        let is_new_task = line.starts_with("### Task ") && !line.starts_with(&task_prefix);
  9790	        let is_descendant = descendant_heading_re.is_match(line);
  9791	
  9792	        if in_target_task && !link_inserted && (is_new_task || is_descendant) {
  9793	            result_lines.push(String::new());
  9794	            result_lines.push(result_line.clone());
  9795	            link_inserted = true;
  9796	        }
  9797	
  9798	        if line.starts_with("### Task ") {
  9799	            in_target_task = line.starts_with(&task_prefix);
  9800	        }
  9801	
  9802	        // Strip the assignee line from the target task.
  9803	        if in_target_task && line.starts_with("**Assignee:**") {
  9804	            continue;
  9805	        }
  9806	
  9807	        result_lines.push(line.to_string());
  9808	    }
  9809	
  9810	    // If the target task is the last element in the file, append here.
  9811	    if in_target_task && !link_inserted {
  9812	        result_lines.push(String::new());
  9813	        result_lines.push(result_line);
  9814	    }
