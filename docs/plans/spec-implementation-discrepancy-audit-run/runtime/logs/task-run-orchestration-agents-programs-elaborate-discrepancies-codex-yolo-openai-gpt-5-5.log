  5523	/// Rhei settings loaded from `~/.config/rhei/settings.json` or `.rhei/settings.json`.
  5524	#[derive(Debug, Default, Deserialize)]
  5525	struct RheiSettings {
  5526	    #[serde(default)]
  5527	    agent: Option<AgentConfig>,
  5528	    #[serde(default)]
  5529	    agent_mode: Option<String>,
  5530	    #[serde(default)]
  5531	    model: Option<String>,
  5532	    #[serde(default)]
  5533	    agent_timeout: Option<String>,
  5534	    #[serde(default)]
  5535	    program_timeout: Option<String>,
  5536	    /// Spec-aligned nested defaults. Only `mcp_servers` and `skills` are read here
  5537	    /// today; `model` / `agent` remain readable at the top level for backward
  5538	    /// compatibility.
  5539	    #[serde(default)]
  5540	    defaults: SettingsDefaults,
  5541	    /// Registry of agent transport profiles keyed by agent id.
  5542	    #[serde(default)]
  5543	    agents: BTreeMap<String, CustomAgentProfile>,
  5544	    /// Registry of MCP server profiles keyed by server id.
  5545	    #[serde(default)]
  5546	    mcp_servers: BTreeMap<String, McpServerProfile>,
  5547	    /// Registry of skill profiles keyed by skill id.
  5548	    #[serde(default)]
  5549	    skills: BTreeMap<String, SkillProfile>,
  5550	}
  5551	
  5552	/// Nested `defaults` section in settings.
  5553	///
  5554	/// `mcp_servers` and `skills` use `Option<Vec<_>>` so the merge layer can
  5555	/// distinguish "unset" (inherit) from "empty" (explicitly clear inherited).
  5556	#[derive(Debug, Default, Deserialize, Clone)]
  5557	struct SettingsDefaults {
  5558	    /// Default agent mode applied when a state does not set `agent_mode`.
  5559	    /// `null` explicitly clears an inherited default.
  5560	    #[serde(default)]
  5561	    agent_mode: Option<String>,
  5562	    #[serde(default)]
  5563	    agent_timeout: Option<String>,
  5564	    #[serde(default)]
  5565	    mcp_servers: Option<Vec<StateMcpEntry>>,
  5566	    #[serde(default)]
  5567	    skills: Option<Vec<StateSkillEntry>>,
  5568	}
  5569	
  5570	/// Built-in agent registry.
  5571	///
  5572	/// Each entry is a ready-to-use `CustomAgentProfile` for one of the agents
  5573	/// that Rhei supports out of the box. The per-agent "autonomous" flag set
  5574	/// that was hard-coded as `default_args` is now exposed as a named `yolo`
  5575	/// mode so states and defaults can select it explicitly via `agent_mode`.
  5576	///
  5577	/// A user-written entry with the same id in global or project settings
  5578	/// replaces the built-in entry wholesale (see `load_merged_settings`).
  5579	fn built_in_agents() -> BTreeMap<String, CustomAgentProfile> {
  5580	    fn flags(items: &[&str]) -> Vec<String> {
  5581	        items.iter().map(|s| (*s).to_string()).collect()
  5582	    }
  5583	
  5584	    let modes_yolo_only = |yolo: Vec<String>| {
  5585	        let mut modes = BTreeMap::new();
  5586	        modes.insert("yolo".to_string(), yolo);
  5587	        modes
  5588	    };
  5589	
  5590	    let mut agents = BTreeMap::new();
  5591	
  5592	    agents.insert(
  5593	        "claude-code".to_string(),
  5594	        CustomAgentProfile {
  5595	            command: flags(&["claude"]),
  5596	            prompt_flag: Some("-p".to_string()),
  5597	            model_flag: Some("--model".to_string()),
  5598	            stdin_prompt: false,
  5599	            mcp_config_flag: Some("--mcp-config".to_string()),
  5600	            skill_flag: Some("--skill".to_string()),
  5601	            modes: modes_yolo_only(flags(&["--permission-mode", "bypassPermissions"])),
  5602	            ..Default::default()
  5603	        },
  5604	    );
  5605	
  5606	    // codex: `codex exec` is non-interactive; the installed CLI accepts the
  5607	    // sandbox and repo flags below but no longer supports the older `-a`
  5608	    // approval shortcut.
  5609	    agents.insert(
  5610	        "codex".to_string(),
  5611	        CustomAgentProfile {
  5612	            command: flags(&["codex", "exec"]),
  5613	            prompt_flag: None,
  5614	            model_flag: Some("--model".to_string()),
  5615	            stdin_prompt: true,
  5616	            mcp_flag: Some("--mcp".to_string()),
  5617	            modes: modes_yolo_only(flags(&[
  5618	                "--sandbox",
  5619	                "danger-full-access",
  5620	                "--skip-git-repo-check",
  5621	            ])),
  5622	            ..Default::default()
  5623	        },
  5624	    );
  5625	
  5626	    // gemini: `--approval-mode yolo` is the autonomous posture
  5627	    // (`auto_edit` still prompts on shell tool calls).
  5628	    agents.insert(
  5629	        "gemini".to_string(),
  5630	        CustomAgentProfile {
  5631	            command: flags(&["gemini"]),
  5632	            prompt_flag: Some("--prompt".to_string()),
  5633	            model_flag: Some("--model".to_string()),
  5634	            stdin_prompt: false,
  5635	            modes: modes_yolo_only(flags(&["--approval-mode", "yolo"])),
  5636	            ..Default::default()
  5637	        },
  5638	    );
  5639	
  5640	    // kilocode: `kilo --auto "<prompt>"` is the documented CI invocation;
  5641	    // `--yolo` auto-approves tool permissions. `--auto` takes the prompt
  5642	    // as its argument, so it maps onto `prompt_flag`.
  5643	    agents.insert(
  5644	        "kilocode".to_string(),
  5645	        CustomAgentProfile {
  5646	            command: flags(&["kilo"]),
  5647	            prompt_flag: Some("--auto".to_string()),
  5648	            model_flag: Some("--model".to_string()),
  5649	            stdin_prompt: false,
  5650	            modes: modes_yolo_only(flags(&["--yolo"])),
  5651	            ..Default::default()
  5652	        },
  5653	    );
  5654	
  5655	    // cursor: the headless binary is `cursor-agent` (distinct from the
  5656	    // `cursor` IDE launcher). `-p`/`--print` is the non-interactive flag;
  5657	    // `--force` is the auto-approve posture.
  5658	    agents.insert(
  5659	        "cursor".to_string(),
  5660	        CustomAgentProfile {
  5661	            command: flags(&["cursor-agent"]),
  5662	            prompt_flag: Some("--print".to_string()),
  5663	            model_flag: Some("--model".to_string()),
  5664	            stdin_prompt: false,
  5665	            modes: modes_yolo_only(flags(&["--force"])),
  5666	            ..Default::default()
  5667	        },
  5668	    );
  5669	
  5670	    // pi (openclaw / badlogic pi-coding-agent). Headless mode exits
  5671	    // deterministically after one turn. pi has no permission layer — modes
  5672	    // are intentionally empty; isolation is the caller's responsibility
  5673	    // (e.g. sandbox/container). See docs/specs/rhei-agents.spec.md §Known
  5674	    // Agent Profiles.
  5675	    agents.insert(
  5676	        "pi".to_string(),
  5677	        CustomAgentProfile {
  5678	            command: flags(&["pi"]),
  5679	            prompt_flag: Some("-p".to_string()),
  5680	            model_flag: Some("--model".to_string()),
  5681	            stdin_prompt: false,
  5682	            skill_flag: Some("--skill".to_string()),
  5683	            ..Default::default()
  5684	        },
  5685	    );
  5686	
  5687	    agents
  5688	}
  5689	
  5690	/// Load settings from a JSON file, returning defaults if the file doesn't exist.
  5691	fn load_settings(path: &Path) -> RheiSettings {
  5692	    match fs::read_to_string(path) {
  5693	        Ok(contents) => serde_json::from_str(&contents).unwrap_or_default(),
  5694	        Err(_) => RheiSettings::default(),
  5695	    }
  5696	}
  5697	
  5698	/// Load merged settings: built-ins, then global, then project-level overrides.
  5699	fn load_merged_settings(plan_root: &Path) -> RheiSettings {
  5700	    let global = home_dir()
  5701	        .map(|h| h.join(".config/rhei/settings.json"))
  5702	        .map(|p| load_settings(&p))
  5703	        .unwrap_or_default();
  5704	
  5705	    let project = load_settings(&plan_root.join(".rhei/settings.json"));
  5706	
  5707	    // Agent registry: built-ins seed the map; global then project entries
  5708	    // replace an id wholesale when present.
  5709	    let mut agents = built_in_agents();
  5710	    for (id, profile) in global.agents {
  5711	        agents.insert(id, profile);
  5712	    }
  5713	    for (id, profile) in project.agents {
  5714	        agents.insert(id, profile);
  5715	    }
  5716	
  5717	    // Registries merge by id: start with global, override by project.
  5718	    let mut mcp_servers = global.mcp_servers.clone();
  5719	    for (id, profile) in project.mcp_servers {
  5720	        mcp_servers.insert(id, profile);
  5721	    }
  5722	    let mut skills = global.skills.clone();
  5723	    for (id, profile) in project.skills {
  5724	        skills.insert(id, profile);
  5725	    }
  5726	
  5727	    // `defaults.mcp_servers` / `defaults.skills`: project replaces global
  5728	    // wholesale when present (including an explicit empty list).
  5729	    let defaults = SettingsDefaults {
  5730	        agent_mode: project.defaults.agent_mode.or(global.defaults.agent_mode),
  5731	        agent_timeout: project.defaults.agent_timeout.or(global.defaults.agent_timeout),
  5732	        mcp_servers: project.defaults.mcp_servers.or(global.defaults.mcp_servers),
  5733	        skills: project.defaults.skills.or(global.defaults.skills),
  5734	    };
  5735	
  5736	    RheiSettings {
  5737	        agent: project.agent.or(global.agent),
  5738	        agent_mode: project.agent_mode.or(global.agent_mode),
  5739	        model: project.model.or(global.model),
  5740	        agent_timeout: project.agent_timeout.or(global.agent_timeout),
  5741	        program_timeout: project.program_timeout.or(global.program_timeout),
  5742	        defaults,
  5743	        agents,
  5744	        mcp_servers,
  5745	        skills,
  5746	    }
  5747	}
  5748	
  5749	fn validate_machine_settings_references(
  5750	    machine: &rhei_validator::StateMachine,
  5751	    settings: &RheiSettings,
  5752	) -> Vec<String> {
  5753	    let mut errors = Vec::new();
  5754	
  5755	    for (state_name, state) in &machine.states {
  5756	        if let Some(agent) = state.agent.as_ref() {
  5757	            let Some(profile) = settings.agents.get(agent.id()) else {
  5758	                errors.push(format!(
  6110	    settings: &RheiSettings,
  6111	    opts: &RunOptions,
  6112	    model_override: Option<String>,
  6113	) -> MietteResult<Option<ResolvedAgent>> {
  6114	    // Agent id resolution: CLI > state > settings.
  6115	    let agent = if let Some(ovr) = opts.agent_override() {
  6116	        Some(AgentConfig::from(ovr))
  6117	    } else if let Some(a) = state_def.and_then(|d| d.agent.clone()) {
  6118	        Some(a)
  6119	    } else {
  6120	        settings.agent.clone()
  6121	    };
  6122	
  6123	    let Some(agent) = agent else {
  6124	        return Ok(None);
  6125	    };
  6126	
  6127	    let profile = settings.agents.get(agent.id()).cloned().ok_or_else(|| {
  6128	        miette!(
  6129	            "agent '{}' is not defined. Add an entry to agents.<id> in \
  6130	             .rhei/settings.json or ~/.config/rhei/settings.json, or \
  6131	             reference one of the built-in ids ({}).",
  6132	            agent.id(),
  6133	            built_in_agents().keys().map(|s| s.as_str()).collect::<Vec<_>>().join(", ")
  6134	        )
  6135	    })?;
  6136	
  6137	    let model = if let Some(ovr) = model_override {
  6138	        Some(ovr)
  6139	    } else if let Some(ovr) = opts.model_override() {
  6140	        Some(ovr.to_string())
  6141	    } else if let Some(m) = state_def.and_then(|d| d.model.clone()) {
  6142	        Some(m)
  6143	    } else {
  6144	        settings.model.clone()
  6145	    };
  6146	
  6147	    let mode = if let Some(ovr) = opts.agent_mode_override() {
  6148	        Some(ovr.to_string())
  6149	    } else if let Some(m) = state_def.and_then(|d| d.agent_mode.clone()) {
  6150	        Some(m)
  6151	    } else if let Some(m) = settings.defaults.agent_mode.clone() {
  6152	        Some(m)
  6153	    } else if let Some(m) = settings.agent_mode.clone() {
  6154	        Some(m)
  6155	    } else {
  6156	        profile.modes.keys().next().cloned()
  6157	    };
  6158	
  6159	    if let Some(name) = &mode {
  6160	        if !profile.modes.contains_key(name) && !profile.modes.is_empty() {
  6161	            return Err(miette!(
  6162	                "agent '{}' has no mode '{}'. Available modes: {}.",
  6163	                agent.id(),
  6164	                name,
  6165	                profile.modes.keys().map(|s| s.as_str()).collect::<Vec<_>>().join(", ")
  6166	            ));
  6167	        }
  6168	    }
  6169	
  6170	    let timeout_secs = state_def
  6171	        .and_then(|d| d.agent_timeout.as_deref())
  6172	        .and_then(rhei_validator::parse_duration_secs)
  6173	        .or_else(|| profile.timeout.as_deref().and_then(rhei_validator::parse_duration_secs))
  6174	        .or_else(|| settings.agent_timeout.as_deref().and_then(rhei_validator::parse_duration_secs))
  6175	        .or_else(|| {
  6176	            settings.defaults.agent_timeout.as_deref().and_then(rhei_validator::parse_duration_secs)
  6177	        });
  6178	
  6179	    Ok(Some(ResolvedAgent { agent, profile, mode, target: None, model, timeout_secs }))
  6180	}
