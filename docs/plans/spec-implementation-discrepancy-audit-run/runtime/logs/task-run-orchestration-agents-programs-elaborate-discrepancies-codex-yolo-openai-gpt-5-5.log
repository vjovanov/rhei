  4483	        relative = relative.replace("{visit_count}", &visit_count.to_string());
  4484	    }
  4485	    if let Some(target) = target {
  4486	        relative = relative.replace("{target}", &target.selector());
  4487	        relative = relative.replace("{target.slug}", &target.slug());
  4488	        if let Some(provider) = target.provider.as_deref() {
  4489	            relative = relative.replace("{model.provider}", provider);
  4490	        }
  4491	    }
  4492	    if let Some(model) = model {
  4493	        relative = relative.replace("{model}", model);
  4494	        relative = relative.replace("{model.name}", model);
  4495	    }
  4496	    if let Some(agent) = agent {
  4497	        relative = relative.replace("{agent}", agent);
  4498	    }
  4499	    if let Some(agent_mode) = agent_mode {
  4500	        relative = relative.replace("{agent.mode}", agent_mode);
  4501	    }
  4502	    relative
  4503	}
