  5307	    }
  5308	
  5309	    // Execute on_enter callback after the state change (not model-looped).
  5310	    let triggered_by = if redirect_next_state.is_some() { "callback" } else { "user" };
  5311	    let on_enter_context_json = build_transition_context_json(
  5312	        plan_for_context.as_ref(),
  5313	        &callback_paths.plan_path,
  5314	        task_id_str,
  5315	        from,
  5316	        to,
  5317	        triggered_by,
  5318	        &transition_data,
  5319	        &callback_paths.working_dir,
  5320	    );
  5520	    }
  5521	}
