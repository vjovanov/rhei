  3838	fn resolve_condition_operand(
  3839	    token: &str,
  3840	    metadata: Option<&Metadata>,
  3841	    task_id: &TaskId,
  3842	    current_state: &str,
  3843	    current_state_raw: &str,
  3844	    machine: &rhei_validator::StateMachine,
  3845	) -> MietteResult<i64> {
  3846	    if let Ok(value) = token.parse::<i64>() {
  3847	        return Ok(value);
  3848	    }
  3849	
  3850	    match token {
  3851	        "visitCount" | "visit_count" => Ok(current_state_visit_count(
  3852	            metadata,
  3853	            task_id,
  3854	            current_state,
  3855	            current_state_raw,
  4480	) -> String {
  4481	    let mut relative = artifact.path.replace("{task_id}", task_id).replace("{state}", state_name);
