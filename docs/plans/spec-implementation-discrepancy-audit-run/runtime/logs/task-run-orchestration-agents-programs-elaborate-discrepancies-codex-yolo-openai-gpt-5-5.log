  6414	#[allow(clippy::too_many_arguments)]
  6415	fn task_has_pending_agent_invocations(
  6416	    workspace_root: &Path,
  6417	    task: &rhei_core::ast::Task,
  6418	    state_name: &str,
  6419	    current_state_raw: &str,
  6420	    machine: &rhei_validator::StateMachine,
  6421	    metadata: Option<&Metadata>,
  6422	    state_def: &rhei_validator::StateDef,
  6423	    settings: &RheiSettings,
  6424	) -> MietteResult<bool> {
  6425	    let invocations =
  6426	        resolve_agent_invocations(machine, state_name, settings, &default_run_options())?;
  6427	    Ok(invocations.iter().any(|resolved| {
  6428	        !state_outputs_exist_for_resolved_invocation(
  6429	            workspace_root,
  6430	            task,
  6431	            state_name,
  6432	            current_state_raw,
  6433	            machine,
  6434	            metadata,
  6435	            state_def,
  6436	            resolved,
  6437	        )
  6438	    }))
  6570	    }
  6571	
  6572	    let plan_path_str = render_context.plan_path.display().to_string();
  6573	    let state_machine_label = render_context
  6574	        .state_machine_path
  6575	        .map(|path| path.display().to_string())
  6576	        .unwrap_or_else(|| "the built-in default".to_string());
  6577	    let task_id = render_context.task.id.to_string();
  6578	
  6579	    let mut prompt = format!(
  6580	        "# Task {task_id}: {}\n\n## State: {}\n",
  6581	        render_context.task.title, render_context.state_name
  6582	    );
  6583	    if let Some(p) = personality {
  6584	        prompt.push_str(&format!("\n{p}\n"));
  6585	    }
  6586	    prompt.push_str(&format!("\n## Instructions\n\n{instructions}\n"));
  6587	    if !render_context.task.content.trim().is_empty() {
  6588	        prompt.push_str(&format!("\n## Task Content\n\n{}\n", render_context.task.content.trim()));
  6589	    }
  6590	    if !render_context.task.children.is_empty() {
  6591	        prompt.push_str("\n## Child Tasks\n\n");
  6592	        for child in &render_context.task.children {
  6593	            prompt.push_str(&format!(
  6594	                "- {} {}: {} [{}]\n",
  6595	                title_case_kind(&child.kind),
  6596	                child.id,
  6597	                child.title,
  6598	                child.state
  6599	            ));
  6600	        }
  6601	    }
  6602	    prompt.push_str(&format!(
  6603	        "\n## Rhei Commands\n\n\
  6604	         You are working in a rhei-managed plan at `{plan_path_str}`.\n\
  6605	         The active state machine is `{state_machine_label}`.\n\
  6606	         The `rhei run` process that spawned you is responsible for advancing the task after this invocation completes.\n\
  6607	         Do not call `rhei transition` or `rhei complete`, and do not modify `**State:**` lines directly, unless you are launching a nested execution that manages its own state.\n\n\
  6608	         Available transitions from `{}`:\n{transitions_list}",
  6609	        render_context.state_name
  6610	    ));
  6611	    prompt
  6612	}
  6613	
  6614	/// Build a `Command` for the resolved agent.
  6615	///
  6616	/// Flag order:
  6617	/// `<command...> <mode flags...> <prompt_flag> <prompt>? <model_flag> <model>?`
  6618	/// `-- ` is appended after the model flag when `stdin_prompt` is `true`, to
  6619	/// match `codex exec -- `-style invocations that expect stdin.
  6620	#[allow(clippy::too_many_arguments)]
  6621	fn build_agent_command(
  6622	    resolved: &ResolvedAgent,
  6623	    prompt: &str,
  6624	    working_dir: &Path,
  6625	    plan_path: &Path,
  6626	    state_machine_path: Option<&Path>,
  6627	    task_id: &str,
  6628	    state_name: &str,
  6629	    tooling: &ResolvedTooling,
  6630	) -> std::process::Command {
  6631	    let profile = &resolved.profile;
  6632	    let id = resolved.agent.id();
  6633	
  6634	    let (program, base_args) =
  6635	        profile.command.split_first().expect("registry profile has non-empty command");
  6636	
  6637	    let mut cmd = std::process::Command::new(program);
  6638	    cmd.current_dir(working_dir);
  6639	    for arg in base_args {
  6640	        cmd.arg(arg);
  6641	    }
  6642	
  6643	    if let Some(mode) = resolved.mode.as_deref() {
  6644	        if let Some(flags) = profile.modes.get(mode) {
  6645	            for arg in flags {
  6646	                cmd.arg(arg);
  6647	            }
  6648	        }
  6649	    }
  6650	
  6651	    if profile.stdin_prompt {
  6652	        cmd.stdin(std::process::Stdio::piped());
  6653	    } else if let Some(flag) = &profile.prompt_flag {
  6654	        cmd.arg(flag).arg(prompt);
  6655	    }
  6656	
  6657	    if let (Some(flag), Some(model)) = (&profile.model_flag, &resolved.model) {
  6658	        cmd.arg(flag).arg(model);
  6659	    }
  6660	
  6661	    if profile.stdin_prompt {
  6662	        cmd.arg("--");
  6663	    }
  6664	
  6665	    cmd.env("RHEI_PLAN_PATH", plan_path)
  6666	        .env("RHEI_TASK_ID", task_id)
  6667	        .env("RHEI_STATE", state_name)
