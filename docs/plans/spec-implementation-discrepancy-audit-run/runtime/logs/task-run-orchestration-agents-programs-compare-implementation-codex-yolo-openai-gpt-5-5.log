  6689	/// Format the `mcp_servers:` / `skills:` line in the agent log header.
  6690	///
  6691	/// Returns `None` when the slice is empty (no line is written). An entry
  6692	/// suffixed with `?` is `optional: true` and failed its availability check —
  6693	/// it was dropped before spawn but appears here for diagnostics.
  6694	fn format_tooling_log_line<T, F>(entries: &[T], project: F) -> Option<String>
  6695	where
  6696	    F: Fn(&T) -> (&str, bool, bool),
  6697	{
  6698	    if entries.is_empty() {
  6699	        return None;
  6700	    }
  6701	    let rendered: Vec<String> = entries
  6702	        .iter()
  6703	        .map(|entry| {
  6704	            let (id, optional, available) = project(entry);
  6705	            if optional && !available {
  6706	                format!("{id}?")
  6707	            } else {
  6708	                id.to_string()
  6709	            }
  6710	        })
  6711	        .collect();
  6712	    Some(rendered.join(","))
  6713	}
