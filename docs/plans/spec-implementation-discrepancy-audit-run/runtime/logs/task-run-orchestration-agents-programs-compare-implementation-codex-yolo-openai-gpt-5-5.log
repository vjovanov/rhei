  4049	fn rewrite_frontmatter(raw: &str, metadata: &Metadata) -> MietteResult<String> {
  4050	    let lines = raw.lines().collect::<Vec<_>>();
  4051	    let header_index = lines
  4052	        .iter()
  4053	        .position(|line| line.trim_start().starts_with("# Rhei:"))
  4054	        .ok_or_else(|| miette!("could not find '# Rhei:' header when rewriting frontmatter"))?;
  4055	
  4056	    let mut idx = header_index + 1;
  4057	    while idx < lines.len() && lines[idx].trim().is_empty() {
  4058	        idx += 1;
  4059	    }
  4060	    if idx < lines.len() && lines[idx].trim_start().starts_with("**States:**") {
  4061	        idx += 1;
  4062	    }
  4063	    while idx < lines.len() && lines[idx].trim().is_empty() {
  4064	        idx += 1;
  4065	    }
  4066	
  4067	    let start = idx;
  4068	    let mut end = idx;
  4069	    if start < lines.len() && lines[start].trim() == "---" {
  4070	        end += 1;
  4071	        while end < lines.len() && lines[end].trim() != "---" {
  4072	            end += 1;
  4073	        }
  4074	        if end == lines.len() {
  4075	            return Err(miette!("unterminated YAML frontmatter in plan source"));
  4076	        }
  4077	        end += 1;
  4078	        while end < lines.len() && lines[end].trim().is_empty() {
  4079	            end += 1;
  4080	        }
  4081	    }
  4082	
  4083	    let mut result = Vec::with_capacity(lines.len() + 8);
  4084	    result.extend(lines[..start].iter().map(|line| (*line).to_string()));
  4085	    result.push("---".to_string());
  4086	    let rendered_yaml = render_frontmatter_yaml(metadata)?;
  4087	    if !rendered_yaml.is_empty() {
  4088	        result.extend(rendered_yaml.lines().map(|line| line.to_string()));
  4089	    }
  4090	    result.push("---".to_string());
  4091	    result.push(String::new());
  4092	    result.extend(lines[end..].iter().map(|line| (*line).to_string()));
  4093	
  4094	    let mut output = result.join("\n");
  4095	    if raw.ends_with('\n') || !output.is_empty() {
  4096	        output.push('\n');
  4097	    }
  4098	    Ok(output)
  4099	}
