  6182	/// Resolve the agent/model/mode/timeout for a task's current state.
  6183	fn resolve_agent_invocations(
  6184	    machine: &rhei_validator::StateMachine,
  6185	    state_name: &str,
  6186	    settings: &RheiSettings,
  6187	    opts: &RunOptions,
  6188	) -> MietteResult<Vec<ResolvedAgent>> {
  6189	    if opts.no_agent() {
  6190	        return Ok(Vec::new());
  6191	    }
  6192	
  6193	    let state_def = machine.states.get(state_name);
  6194	    if let Some(state_def) = state_def {
  6195	        if !state_def.all_targets.is_empty() {
  6196	            let mut resolved = Vec::with_capacity(state_def.all_targets.len());
  6197	            for selector in &state_def.all_targets {
  6198	                resolved.push(resolve_target_agent(selector, Some(state_def), settings)?);
  6199	            }
  6200	            return Ok(resolved);
  6201	        }
  6202	        if let Some(selector) = state_def.target.as_deref() {
  6203	            return Ok(vec![resolve_target_agent(selector, Some(state_def), settings)?]);
  6204	        }
  6205	        if !state_def.all_models.is_empty() {
  6206	            let mut resolved = Vec::with_capacity(state_def.all_models.len());
  6207	            for model in &state_def.all_models {
  6208	                if let Some(agent) = resolve_legacy_agent_with_model(
  6209	                    Some(state_def),
  6210	                    settings,
  6211	                    opts,
  6212	                    Some(model.clone()),
  6213	                )? {
  6214	                    resolved.push(agent);
  6215	                }
  6216	            }
  6217	            return Ok(resolved);
  6218	        }
  6219	    }
  6220	
  6221	    Ok(resolve_legacy_agent_with_model(state_def, settings, opts, None)?.into_iter().collect())
  6222	}
