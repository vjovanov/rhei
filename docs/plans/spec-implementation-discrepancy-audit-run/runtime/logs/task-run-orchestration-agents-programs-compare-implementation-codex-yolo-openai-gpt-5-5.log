  4380	/// Minimal civil-calendar conversion from seconds-since-Unix-epoch to UTC
  4381	/// Y-M-D h:m:s components. Uses the Howard Hinnant algorithm. Good through
  4382	/// the full 64-bit range; we don't need leap seconds or time zones for a
  4383	/// transition timestamp.
  4384	fn unix_to_utc_components(secs: u64) -> (i32, u32, u32, u32, u32, u32) {
  4385	    let days = (secs / 86_400) as i64;
  4386	    let time_of_day = (secs % 86_400) as u32;
  4387	    let hour = time_of_day / 3600;
  4388	    let minute = (time_of_day % 3600) / 60;
  4389	    let second = time_of_day % 60;
  4390	
  4391	    // days since 1970-01-01 → civil date.
  4392	    let z = days + 719_468;
  4393	    let era = if z >= 0 { z / 146_097 } else { (z - 146_096) / 146_097 };
  4394	    let doe = (z - era * 146_097) as u64; // [0, 146096]
  4395	    let yoe = (doe - doe / 1_460 + doe / 36_524 - doe / 146_096) / 365; // [0, 399]
  4396	    let y = yoe as i64 + era * 400;
  4397	    let doy = doe - (365 * yoe + yoe / 4 - yoe / 100); // [0, 365]
  4398	    let mp = (5 * doy + 2) / 153; // [0, 11]
  4399	    let d = doy - (153 * mp + 2) / 5 + 1; // [1, 31]
  4400	    let m = if mp < 10 { mp + 3 } else { mp - 9 }; // [1, 12]
  4401	    let y = y + if m <= 2 { 1 } else { 0 };
  4402	    (y as i32, m as u32, d as u32, hour, minute, second)
  4403	}
