     1	# CI Watch and Heal — state machine
     2	# ──────────────────────────────────
     3	#
     4	# A single task walks two nested loops:
     5	#
     6	#   INNER (time-triggered poll, capped by poll.max_attempts):
     7	#     ci-watch ──exit 75──► ci-watch           (CI still running; wait interval)
     8	#     ci-watch ──exit  0──► heal-done          (CI green)
     9	#     ci-watch ──exit  1──► analyze-and-fix    (CI red; hand off to agent)
    10	#     ci-watch ──exhausted►  poll-gave-up      (pollAttempts >= pollMaxAttempts)
    11	#
    12	#   OUTER (visit-counted fix loop):
    13	#     analyze-and-fix ──visitCount < visits──► push-fix
    14	#     analyze-and-fix ──visitCount >= visits─► fix-exhausted
    15	#     push-fix        ──exit  0──────────────► ci-watch    (re-enter inner loop)
    16	#
    17	# The `poll:` block makes `ci-watch` time-triggered: a self-loop transition
    18	# means "retry after poll.interval"; rhei run releases the --parallel slot
    19	# during the wait and re-claims the task once poll.interval has elapsed.
    20	# See docs/specs/rhei-states.spec.md#polling-states.
    21	
    22	name: ci-watch-and-heal
    23	version: 1.0
    24	
    25	states:
    26	  ci-watch:
    27	    description: Poll GitHub CI for the current branch.
    28	    personality: |
    29	      You do not run here — a deterministic program does. Its exit code
    30	      picks the transition: 0 = all checks green, 1 = at least one failed,
    31	      75 = still running (retry after poll.interval).
    32	    program:
    33	      command: ".rhei/gh-ci-status.sh"
    34	      env:
    35	        BRANCH: "{task.metadata.branch}"
    36	        REPORT_PATH: "{output.ci-report.path}"
    37	    program_timeout: 1m
    38	    poll:
    39	      interval: 2m
    40	      max_attempts: 30
    41	    outputs:
    42	      - name: ci-report
    43	        path: "runtime/ci-report/{task.id}.json"
    44	
    45	  analyze-and-fix:
    46	    description: Read the CI report, apply the smallest fix that addresses the first failing job.
    47	    agent: claude-code
    48	    agent_timeout: 30m
    49	    # Outer loop budget: how many fix cycles we are willing to spend before
    50	    # escalating to a human. Distinct from poll.max_attempts above, which
    51	    # bounds attempts inside one ci-watch visit.
    52	    visits: 5
    53	    instructions: |
    54	      The CI report at {input.ci-report.path} lists failing jobs on branch
    55	      {task.metadata.branch}. Diagnose the first failing job, make the
    56	      smallest change that fixes it, run the relevant tests locally if
    57	      possible, and write a short summary of what you changed to
    58	      {output.fix-summary.path}. Do not commit or push — the next state
    59	      handles that deterministically. Exit 0 on success.
    60	    inputs:
    61	      - name: ci-report
    62	        path: "runtime/ci-report/{task.id}.json"
    63	    outputs:
    64	      - name: fix-summary
    65	        path: "runtime/fix-summary/{task.id}.{visit}.md"
    66	
    67	  push-fix:
    68	    description: Commit the fix and push to the branch under observation.
    69	    program:
    70	      command: ".rhei/commit-and-push.sh"
    71	      env:
    72	        BRANCH: "{task.metadata.branch}"
    73	        SUMMARY_PATH: "runtime/fix-summary/{task.id}.{visit}.md"
    74	    program_timeout: 5m
    75	
    76	  heal-done:
    77	    description: CI is green; the branch is healed.
    78	    final: true
    79	
    80	  poll-gave-up:
    81	    description: CI never returned a verdict within the poll budget.
    82	    final: true
    83	
    84	  fix-exhausted:
    85	    description: Fix-loop budget exhausted; human review required.
    86	    final: true
    87	
    88	transitions:
    89	  # ── Inner poll loop (ci-watch) ────────────────────────────────────────
    90	  - from: ci-watch
    91	    to: ci-watch
    92	    exit_code: 75
    93	    description: CI still running — retry after poll.interval.
    94	
    95	  - from: ci-watch
    96	    to: heal-done
    97	    exit_code: 0
    98	    description: All checks green.
    99	
   100	  - from: ci-watch
   101	    to: analyze-and-fix
   102	    exit_code: 1
   103	    description: One or more jobs failed — hand off to the agent.
   104	
   105	  - from: ci-watch
   106	    to: poll-gave-up
   107	    condition: pollAttempts >= pollMaxAttempts
   108	    description: Exhausted the poll budget without a verdict.
   109	
   110	  # ── Outer fix loop (analyze-and-fix → push-fix → ci-watch) ────────────
   111	  - from: analyze-and-fix
   112	    to: push-fix
   113	    condition: visitCount < visits
   114	    description: Fix written; push it so CI re-runs.
   115	
   116	  - from: analyze-and-fix
   117	    to: fix-exhausted
   118	    condition: visitCount >= visits
   119	    description: Too many fix cycles — escalate.
   120	
   121	  - from: push-fix
   122	    to: ci-watch
   123	    exit_code: 0
   124	    description: Fix pushed; re-enter the poll loop (ci-watch counters reset).
   125	
   126	profiles:
   127	  default:
   128	    initial: ci-watch
   129	    allowed: [ci-watch, analyze-and-fix, push-fix, heal-done, poll-gave-up, fix-exhausted]
   130	
   131	node_policy:
   132	  root: default
   133	  default: default

