  1322	fn validate_state_skill_entries(
  1323	    state_name: &str,
  1324	    state: &StateDef,
  1325	) -> Result<(), StateMachineLoadError> {
  1326	    let Some(entries) = state.skills.as_deref() else {
  1327	        return Ok(());
  1328	    };
  1329	
  1330	    if !entries.is_empty() {
  1331	        if state.gating {
  1332	            return Err(StateMachineLoadError::Invalid(format!(
  1333	                "state '{state_name}' is gating and cannot declare 'skills' (gating states are human-only)"
  1334	            )));
  1335	        }
  1336	        if state.program.is_some() {
  1337	            return Err(StateMachineLoadError::Invalid(format!(
  1338	                "state '{state_name}' declares 'program' and cannot declare 'skills' (programs execute deterministically)"
  1339	            )));
  1340	        }
  1341	        if state.terminal {
  1342	            return Err(StateMachineLoadError::Invalid(format!(
  1343	                "state '{state_name}' is final and cannot declare 'skills' (terminal states have no work)"
  1344	            )));
  1345	        }
  1346	    }
  1347	
  1348	    let mut seen = HashSet::new();
  1349	    for entry in entries {
  1350	        let id = entry.id();
  1351	        if id.trim().is_empty() {
  1352	            return Err(StateMachineLoadError::Invalid(format!(
  1353	                "state '{state_name}' has a skills entry with an empty id"
  1354	            )));
  1355	        }
  1356	        if !seen.insert(id.to_string()) {
  1357	            return Err(StateMachineLoadError::Invalid(format!(
  1358	                "state '{state_name}' has a duplicate skills id '{id}'"
  1359	            )));
  1360	        }
  1361	        if let StateSkillEntry::Object(obj) = entry {
  1362	            if let Some(path) = &obj.path {
  1363	                if path.trim().is_empty() {
  1364	                    return Err(StateMachineLoadError::Invalid(format!(
  1365	                        "state '{state_name}' skills entry '{id}' has an empty 'path'"
  1366	                    )));
  1367	                }
  1368	            }
  1369	        }
  1370	    }
  1371	    Ok(())
  1372	}
