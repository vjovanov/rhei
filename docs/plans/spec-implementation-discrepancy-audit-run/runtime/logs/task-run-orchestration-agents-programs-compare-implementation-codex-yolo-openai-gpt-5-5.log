  5903	/// Compute the effective tooling set for a state given the merged settings.
  5904	fn resolve_tooling(
  5905	    machine: &rhei_validator::StateMachine,
  5906	    state_name: &str,
  5907	    settings: &RheiSettings,
  5908	) -> ResolvedTooling {
  5909	    let state_def = machine.states.get(state_name);
  5910	
  5911	    // MCP: start from defaults (if any), then override/extend with state-level.
  5912	    let mcp_entries = effective_mcp_entries(
  5913	        settings.defaults.mcp_servers.as_deref().unwrap_or(&[]),
  5914	        state_def.and_then(|d| d.mcp_servers.as_deref()),
  5915	    );
  5916	    let mcp_servers: Vec<ResolvedMcpEntry> = mcp_entries
  5917	        .into_iter()
  5918	        .map(|entry| resolve_mcp_entry(&entry, &settings.mcp_servers))
  5919	        .collect();
  5920	
  5921	    let skill_entries = effective_skill_entries(
  5922	        settings.defaults.skills.as_deref().unwrap_or(&[]),
  5923	        state_def.and_then(|d| d.skills.as_deref()),
  5924	    );
  5925	    let skills: Vec<ResolvedSkillEntry> = skill_entries
  5926	        .into_iter()
  5927	        .map(|entry| resolve_skill_entry(&entry, &settings.skills))
  5928	        .collect();
  5929	
  5930	    ResolvedTooling { mcp_servers, skills }
  5931	}
