  7084	    let input_visit_count = Some(render_visit_count(
  7085	        render_context.metadata,
  7086	        &render_context.task.id,
  7087	        render_context.state_name,
  7088	        render_context.current_state_raw,
  7089	        render_context.machine,
  7090	    ));
  7091	    if let Some(state_def) = render_context.machine.states.get(render_context.state_name) {
  7092	        for artifact in &state_def.inputs {
  7093	            let env_base = artifact.name.to_uppercase().replace(['-', ' '], "_");
  7094	            let (relative, path) = resolve_artifact_path(
  7095	                render_context.workspace_root,
