  5979	/// Resolve one entry against the registry. Inline definitions on the entry
  5980	/// take precedence over registry lookups.
  5981	fn resolve_mcp_entry(
  5982	    entry: &StateMcpEntry,
  5983	    registry: &BTreeMap<String, McpServerProfile>,
  5984	) -> ResolvedMcpEntry {
  5985	    let id = entry.id().to_string();
  5986	    let optional = entry.is_optional();
  5987	    let inline = match entry {
  5988	        StateMcpEntry::Object(obj) if obj.command.is_some() || obj.url.is_some() => {
  5989	            Some(inline_mcp_profile(obj))
  5990	        }
  5991	        _ => None,
  5992	    };
  5993	    let definition = inline.or_else(|| registry.get(&id).cloned());
  5994	    ResolvedMcpEntry { id, optional, definition }
  5995	}
  5996	
  5997	fn resolve_skill_entry(
  5998	    entry: &StateSkillEntry,
  5999	    registry: &BTreeMap<String, SkillProfile>,
  6000	) -> ResolvedSkillEntry {
  6001	    let id = entry.id().to_string();
  6002	    let optional = entry.is_optional();
  6003	    let inline = match entry {
  6004	        StateSkillEntry::Object(obj) if obj.path.is_some() => Some(SkillProfile {
  6005	            path: obj.path.clone().unwrap_or_default(),
  6006	            description: obj.description.clone(),
  6007	        }),
  6008	        _ => None,
  6009	    };
  6010	    let definition = inline.or_else(|| registry.get(&id).cloned());
  6011	    ResolvedSkillEntry { id, optional, definition }
  6012	}
