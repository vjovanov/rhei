  1385	            "transition from '{}' to '{}' declares '{field_name}: false' — omit the field instead",
  1386	            transition.from.0, transition.to.0
  1387	        ))),
  1388	        serde_yaml::Value::Sequence(items) => {
  1389	            if items.is_empty() {
  1390	                return Err(StateMachineLoadError::Invalid(format!(
  1391	                    "transition from '{}' to '{}' declares an empty '{field_name}' list",
  1392	                    transition.from.0, transition.to.0
  1393	                )));
  1394	            }
  1395	            let mut seen = HashSet::new();
  1396	            for item in items {
  1397	                let Some(id) = item.as_str() else {
  1398	                    return Err(StateMachineLoadError::Invalid(format!(
  1399	                        "transition from '{}' to '{}' '{field_name}' entries must be strings",
  1400	                        transition.from.0, transition.to.0
  1401	                    )));
  1402	                };
  1403	                if id.trim().is_empty() {
  1404	                    return Err(StateMachineLoadError::Invalid(format!(
  1405	                        "transition from '{}' to '{}' '{field_name}' contains an empty id",
  1406	                        transition.from.0, transition.to.0
  1407	                    )));
  1408	                }
  1409	                if !seen.insert(id.to_string()) {
  1410	                    return Err(StateMachineLoadError::Invalid(format!(
  1411	                        "transition from '{}' to '{}' '{field_name}' contains duplicate id '{id}'",
  1412	                        transition.from.0, transition.to.0
  1413	                    )));
  1414	                }
  1415	            }
  1416	            Ok(())
  1417	        }
  1418	        _ => Err(StateMachineLoadError::Invalid(format!(
  1419	            "transition from '{}' to '{}' '{field_name}' must be `true` or a list of ids",
  1420	            transition.from.0, transition.to.0
  1421	        ))),
  1422	    }
  1423	}
