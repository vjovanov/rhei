   181	        if let Some(ctx_json) = context.context_json {
   182	            let payload = serde_json::to_vec(ctx_json).unwrap_or_else(|_| b"{}".to_vec());
   183	            if let Some(mut stdin) = child.stdin.take() {
   184	                match stdin.write_all(&payload) {
   185	                    Ok(()) => {}
   186	                    // `BrokenPipe` means the callback closed its stdin
   187	                    // before we finished writing (e.g. `exit 1` / scripts
   188	                    // that don't consume stdin). That's not an executor
   189	                    // failure — the child still ran and its exit status /
   190	                    // stdout / stderr are the truth of the matter.
   191	                    Err(e) if e.kind() == std::io::ErrorKind::BrokenPipe => {}
   192	                    Err(e) => {
   193	                        return Err(CallbackError::StdinWriteFailed(command.to_string(), e));
   194	                    }
   195	                }
   196	                // Dropping stdin here closes the pipe so the callback sees EOF.
   197	            }
   198	        } else {
   199	            // No context payload — still close the callback's stdin so reads
   200	            // (e.g. `cat`) return immediately instead of blocking.
   201	            drop(child.stdin.take());
   202	        }
