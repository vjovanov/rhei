  5881	/// Normalize an id into the env-var segment used by `RHEI_*_<NAME>_AVAILABLE`.
  5882	fn env_id_segment(id: &str) -> String {
  5883	    id.chars()
  5884	        .map(|c| if c.is_ascii_alphanumeric() { c.to_ascii_uppercase() } else { '_' })
  5885	        .collect()
  5886	}
  5887	
  5888	fn slugify_target_value(value: &str) -> String {
  5889	    let mut slug = String::new();
  5890	    let mut last_was_dash = false;
  5891	    for ch in value.chars() {
  5892	        if ch.is_ascii_alphanumeric() {
  5893	            slug.push(ch.to_ascii_lowercase());
  5894	            last_was_dash = false;
  5895	        } else if !last_was_dash {
  5896	            slug.push('-');
  5897	            last_was_dash = true;
  5898	        }
  5899	    }
  5900	    slug.trim_matches('-').to_string()
  5901	}
