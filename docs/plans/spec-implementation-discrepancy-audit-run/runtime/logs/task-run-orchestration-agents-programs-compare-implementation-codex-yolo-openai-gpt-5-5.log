    17	/// Context provided to a callback during a state transition.
    18	///
    19	/// `context_json`, when present, is serialized and piped to the callback
    20	/// process as its stdin payload — matching the cross-language
    21	/// `TransitionContext` shape documented in the transitions specification.
    22	/// Callers that do not have the full context (e.g., unit tests) may pass
    23	/// `None` to skip stdin delivery; callbacks then rely solely on environment
    24	/// variables.
    25	#[derive(Debug, Clone)]
    26	pub struct CallbackContext<'a> {
    27	    /// Identifier of the task being transitioned.
    28	    pub task_id: &'a str,
    29	    /// State the task is leaving.
    30	    pub from_state: &'a str,
    31	    /// State the task is entering.
    32	    pub to_state: &'a str,
    33	    /// Path to the plan file.
    34	    pub plan_path: &'a Path,
    35	    /// Working directory used to execute shell callbacks.
    36	    pub callback_cwd: &'a Path,
    37	    /// Current model identifier when a state declares `all_models` or `model`, or `None`.
    38	    pub model: Option<&'a str>,
    39	    /// Current agent identifier when a state declares `agent`, or `None`.
    40	    pub agent: Option<&'a str>,
    41	    /// Full `TransitionContext` payload to deliver on stdin, if available.
    42	    pub context_json: Option<&'a JsonValue>,
    43	}
    44	
    45	/// Outcome of a callback invocation.
    46	///
    47	/// Mirrors the cross-language `TransitionResult` shape: `success`, optional
