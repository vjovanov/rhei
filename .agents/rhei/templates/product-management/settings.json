{
  "defaults": {
    "agent_timeout": "30m"
  },
  "agents": {
    "codex": {
      "command": [
        "codex",
        "exec"
      ],
      "model_flag": "--model",
      "stdin_prompt": true,
      "mcp_flag": "--mcp",
      "modes": {
        "yolo": [
          "--sandbox",
          "danger-full-access",
          "--skip-git-repo-check",
          "-a",
          "never"
        ],
        "medium": [
          "--sandbox",
          "danger-full-access",
          "--skip-git-repo-check",
          "-a",
          "never",
          "-c",
          "model_reasoning_effort=\"medium\""
        ],
        "high": [
          "--sandbox",
          "danger-full-access",
          "--skip-git-repo-check",
          "-a",
          "never",
          "-c",
          "model_reasoning_effort=\"high\""
        ],
        "xhigh": [
          "--sandbox",
          "danger-full-access",
          "--skip-git-repo-check",
          "-a",
          "never",
          "-c",
          "model_reasoning_effort=\"xhigh\""
        ]
      }
    }
  }
}
