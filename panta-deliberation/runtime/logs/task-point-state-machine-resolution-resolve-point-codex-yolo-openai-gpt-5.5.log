/usr/bin/bash -lc "sed -n '88,106p' ../docs/functional-spec/rhei-panta.spec.md && sed -n '84,96p' ../docs/architecture/rhei-panta.spec.md" in /home/vjovanov/f/rhei/panta-deliberation
